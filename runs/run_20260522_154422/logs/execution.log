{"timestamp": "2026-05-22 16:02:33,728", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task0: ```python\nimport pygame\nfrom dataclasses import dataclass\nfrom typing import List, Tuple, Dict\n\n# Game Constants\nGRID_WIDTH = 10\nGRID_HEIGHT = 20\nCELL_SIZE = 30\nSCREEN_WIDTH = GRID_WIDTH * CELL_SIZE + 200  # extra space for UI\nSCREEN_HEIGHT = GRID_HEIGHT * CELL_SIZE\nFPS = 30\n\n# Colors (R, G, B)\nWHITE   = (255, 255, 255)\nBLACK   = (  0,   0,   0)\nGRAY    = (128, 128, 128)\nRED     = (255,   0,   0)\nGREEN   = (  0, 255,   0)\nBLUE    = (  0,   0, 255)\nYELLOW  = (255, 255,   0)\nCYAN    = (  0, 255, 255)\nMAGENTA = (255,   0, 255)\nORANGE  = (255, 165,   0)\n\n# Gem Colors Pool\nGEM_COLORS: List[Tuple[int, int, int]] = [\n    RED, GREEN, BLUE, YELLOW, CYAN, MAGENTA, ORANGE\n]\n\n# Map each tetromino letter to a fixed color\nSHAPE_COLORS: Dict[str, Tuple[int, int, int]] = {\n    \"I\": CYAN,\n    \"J\": BLUE,\n    \"L\": ORANGE,\n    \"O\": YELLOW,\n    \"S\": GREEN,\n    \"T\": MAGENTA,\n    \"Z\": RED,\n}\n\n# Tetromino shapes as lists of rotation states.\n# Each rotation is a list of (row_offset, col_offset)\nTETROMINO_SHAPES: Dict[str, List[List[Tuple[int, int]]]] = {\n    \"I\": [\n        [(0, 0), (0, 1), (0, 2), (0, 3)],\n        [(0, 0), (1, 0), (2, 0), (3, 0)]\n    ],\n    \"J\": [\n        [(0, 0), (1, 0), (1, 1), (1, 2)],\n        [(0, 1), (0, 0), (1, 0), (2, 0)],\n        [(0, 0), (0, 1), (0, 2), (1, 2)],\n        [(2, 0), (2, 1), (1, 1), (0, 1)]\n    ],\n    \"L\": [\n        [(0, 2), (1, 0), (1, 1), (1, 2)],\n        [(0, 0), (0, 1), (1, 1), (2, 1)],\n        [(1, 0), (1, 1), (1, 2), (2, 0)],\n        [(0, 1), (1, 1), (2, 1), (2, 2)]\n    ],\n    \"O\": [\n        [(0, 0), (0, 1), (1, 0), (1, 1)]\n    ],\n    \"S\": [\n        [(0, 1), (0, 2), (1, 0), (1, 1)],\n        [(0, 0), (1, 0), (1, 1), (2, 1)]\n    ],\n    \"T\": [\n        [(0, 1), (1, 0), (1, 1), (1, 2)],\n        [(0, 0), (1, 0), (2, 0), (1, 1)],\n        [(1, 0), (1, 1), (1, 2), (2, 1)],\n        [(0, 1), (1, 1), (2, 1), (1, 2)]\n    ],\n    \"Z\": [\n        [(0, 0), (0, 1), (1, 1), (1, 2)],\n        [(0, 1), (1, 0), (1, 1), (2, 0)]\n    ],\n}\n\n# Grid Representation: None means empty, else stores a color tuple\nGRID: List[List[Tuple[int, int, int] or None]] = [\n    [None for _ in range(GRID_WIDTH)]\n    for _ in range(GRID_HEIGHT)\n]\n\n# Score Constants\nINITIAL_SCORE = 0\nTETRIS_CLEAR_SCORE       = 800\nMATCH_3_SCORE            = 100\nCHAIN_REACTION_MULTIPLIER = 1.5\n\n# Structured score tracker\nclass ScoreTracker:\n    def __init__(self):\n        self.current = INITIAL_SCORE\n\n    def add_tetris_clear(self):\n        self.current += TETRIS_CLEAR_SCORE\n\n    def add_match(self, num_matches: int, chain: int = 1):\n        self.current += int(MATCH_3_SCORE * num_matches * chain)\n\n# Dataclass for active tetromino\n@dataclass\nclass Tetromino:\n    shape_key: str                  # \"I\", \"J\", ...\n    rotation: int                   # index into TETROMINO_SHAPES[shape_key]\n    position: Tuple[int, int]       # (row, col) of the shape’s origin\n    color: Tuple[int, int, int]     # from SHAPE_COLORS\n\n    @property\n    def blocks(self) -> List[Tuple[int, int]]:\n        \"\"\"Return absolute grid positions of the 4 blocks.\"\"\"\n        offsets = TETROMINO_SHAPES[self.shape_key][self.rotation]\n        r0, c0 = self.position\n        return [(r0 + dr, c0 + dc) for dr, dc in offsets]\n\n# Current and Next pieces; will be set when game starts\nCURRENT_TETROMINO: Tetromino = None\nNEXT_TETROMINO: Tetromino = None\n\n# Instantiate score tracker\nscore_tracker = ScoreTracker()\n```"}
{"timestamp": "2026-05-22 16:02:33,728", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task1: ```python\nimport pygame\nimport random\nfrom typing import List, Tuple, Optional\nfrom dataclasses import dataclass\n\n# Import game constants and data structures from task0\nfrom task0 import (\n    GRID_WIDTH, GRID_HEIGHT, CELL_SIZE,\n    TETROMINO_SHAPES, SHAPE_COLORS,\n    GRID, Tetromino,\n    CURRENT_TETROMINO, NEXT_TETROMINO,\n    GEM_COLORS, ScoreTracker, score_tracker\n)\n\n# -----------------------------------------------------------------------------\n# Tetromino Spawning\n# -----------------------------------------------------------------------------\ndef new_tetromino() -> Tetromino:\n    \"\"\"Creates a new tetromino randomly from the available shapes.\"\"\"\n    shape_key = random.choice(list(TETROMINO_SHAPES.keys()))\n    return Tetromino(\n        shape_key=shape_key,\n        rotation=0,\n        position=(0, GRID_WIDTH // 2 - 2),  # start at top-center\n        color=SHAPE_COLORS[shape_key]\n    )\n\ndef spawn_tetromino() -> None:\n    \"\"\"Spawns a new tetromino, updating CURRENT_TETROMINO and NEXT_TETROMINO.\"\"\"\n    global CURRENT_TETROMINO, NEXT_TETROMINO\n    if NEXT_TETROMINO is None:\n        CURRENT_TETROMINO = new_tetromino()\n        NEXT_TETROMINO = new_tetromino()\n    else:\n        CURRENT_TETROMINO = NEXT_TETROMINO\n        NEXT_TETROMINO = new_tetromino()\n\n# -----------------------------------------------------------------------------\n# Movement and Rotation\n# -----------------------------------------------------------------------------\nGridType = List[List[Optional[Tuple[int, int, int]]]]\n\ndef valid_move(tetromino: Tetromino, grid: GridType, row_offset: int, col_offset: int) -> bool:\n    \"\"\"Checks if a move is valid given the grid and offsets.\"\"\"\n    for row, col in tetromino.blocks:\n        new_row = row + row_offset\n        new_col = col + col_offset\n\n        if (new_row < 0 or new_row >= GRID_HEIGHT or\n            new_col < 0 or new_col >= GRID_WIDTH or\n            (0 <= new_row < len(grid) and 0 <= new_col < len(grid[0]) and grid[new_row][new_col] is not None)):\n            return False\n    return True\n\ndef move_tetromino(tetromino: Tetromino, grid: GridType, row_offset: int, col_offset: int) -> bool:\n    \"\"\"Moves the tetromino if the move is valid. Returns True if moved, False otherwise.\"\"\"\n    if valid_move(tetromino, grid, row_offset, col_offset):\n        tetromino.position = (tetromino.position[0] + row_offset,\n                              tetromino.position[1] + col_offset)\n        return True\n    return False\n\ndef rotate_tetromino(tetromino: Tetromino, grid: GridType) -> bool:\n    \"\"\"Rotates the tetromino if the rotation is valid. Returns True if rotated, False otherwise.\"\"\"\n    original_rotation = tetromino.rotation\n    new_rotation = (original_rotation + 1) % len(TETROMINO_SHAPES[tetromino.shape_key])\n\n    # Create a temporary tetromino to test the rotation\n    temp_tetromino = Tetromino(\n        shape_key=tetromino.shape_key,\n        rotation=new_rotation,\n        position=tetromino.position,\n        color=tetromino.color\n    )\n\n    valid = True\n    for r, c in temp_tetromino.blocks:\n        if not (0 <= r < GRID_HEIGHT and 0 <= c < GRID_WIDTH):\n            valid = False\n            break\n        if grid[r][c] is not None:\n            valid = False\n            break\n\n    if valid:\n        tetromino.rotation = new_rotation\n        return True\n\n    # Try kicking (moving the tetromino slightly to see if it fits)\n    kick_offsets = [(0, 0), (0, -1), (0, 1), (-1, 0), (1, 0)]  # Basic kick offsets; more complex kicks exist in real Tetris\n\n    for row_offset, col_offset in kick_offsets:\n        temp_tetromino.position = (tetromino.position[0] + row_offset, tetromino.position[1] + col_offset)\n\n        valid = True\n        for r, c in temp_tetromino.blocks:\n            if not (0 <= r < GRID_HEIGHT and 0 <= c < GRID_WIDTH and grid[r][c] is None):\n                valid = False\n                break\n        if valid:\n            tetromino.rotation = new_rotation\n            tetromino.position = (tetromino.position[0] + row_offset, tetromino.position[1] + col_offset)\n            return True\n        temp_tetromino.position = tetromino.position  # Reset position for next kick attempt\n\n    return False\n\n# -----------------------------------------------------------------------------\n# Locking and Clearing\n# -----------------------------------------------------------------------------\ndef lock_tetromino(tetromino: Tetromino, grid: GridType) -> None:\n    \"\"\"Locks the tetromino into the grid, converting its blocks into colored gems.\"\"\"\n    for row, col in tetromino.blocks:\n        if 0 <= row < GRID_HEIGHT and 0 <= col < GRID_WIDTH:\n            grid[row][col] = tetromino.color\n\ndef check_tetris_clear(grid: GridType) -> List[int]:\n    \"\"\"Checks for and returns a list of indices of lines that are full (Tetris clear).\"\"\"\n    lines_to_clear = []\n    for i, row in enumerate(grid):\n        if all(cell is not None for cell in row):\n            lines_to_clear.append(i)\n    return lines_to_clear\n\ndef clear_lines(grid: GridType, lines: List[int]) -> None:\n    \"\"\"Clears the specified lines in the grid and shifts the above lines down.\"\"\"\n    for line_index in sorted(lines, reverse=True):\n        del grid[line_index]\n        grid.insert(0, [None] * GRID_WIDTH)\n    score_tracker.add_tetris_clear()\n\n# -----------------------------------------------------------------------------\n# Match 3 Logic\n# -----------------------------------------------------------------------------\ndef check_match_3(grid: GridType) -> List[Tuple[int, int]]:\n    \"\"\"Checks for horizontal and vertical match-3 gem formations and returns a list of their coordinates.\"\"\"\n    matches = []\n\n    # Horizontal matches\n    for row in range(GRID_HEIGHT):\n        for col in range(GRID_WIDTH - 2):\n            if (grid[row][col] is not None and\n                grid[row][col] == grid[row][col+1] == grid[row][col+2]):\n                matches.extend([(row, col), (row, col+1), (row, col+2)])\n\n    # Vertical matches\n    for col in range(GRID_WIDTH):\n        for row in range(GRID_HEIGHT - 2):\n            if (grid[row][col] is not None and\n                grid[row][col] == grid[row+1][col] == grid[row+2][col]):\n                matches.extend([(row, col), (row+1, col), (row+2, col)])\n\n    # Remove duplicate coordinates\n    unique_matches = []\n    for match in matches:\n        if match not in unique_matches:\n            unique_matches.append(match)\n\n    return unique_matches\n\ndef clear_matches(grid: GridType, matches: List[Tuple[int, int]]) -> None:\n    \"\"\"Clears the gems at the specified coordinates in the grid.\"\"\"\n    score_tracker.add_match(len(matches))\n    for row, col in matches:\n        grid[row][col] = None\n\ndef drop_floating_gems(grid: GridType) -> None:\n    \"\"\"Simulates gems falling down to fill empty spaces below them.\"\"\"\n    for col in range(GRID_WIDTH):\n        empty_pos = -1\n        for row in range(GRID_HEIGHT - 1, -1, -1):\n            if grid[row][col] is None:\n                empty_pos = row\n            elif empty_pos != -1:\n                grid[empty_pos][col] = grid[row][col]\n                grid[row][col] = None\n                empty_pos -= 1\n\n# -----------------------------------------------------------------------------\n# Grid Resolution\n# -----------------------------------------------------------------------------\ndef resolve_grid(grid: GridType) -> None:\n    \"\"\"Resolves the grid by clearing lines and matches, and dropping gems.\"\"\"\n    lines_to_clear = check_tetris_clear(grid)\n    clear_lines(grid, lines_to_clear)\n\n    matches_to_clear = check_match_3(grid)\n    clear_matches(grid, matches_to_clear)\n\n    drop_floating_gems(grid)\n\nif __name__ == '__main__':\n    # Example Usage (for testing purposes)\n    # Initialize Pygame (required for font rendering, even if display is created later)\n    pygame.init()\n\n    # Initialize the grid\n    grid: GridType = [[None for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]\n\n    # Initial spawn\n    spawn_tetromino()\n    current_tetromino = CURRENT_TETROMINO\n\n    # Example movement and locking\n    if current_tetromino is not None:\n        move_tetromino(current_tetromino, grid, 1, 0)  # Move down\n        move_tetromino(current_tetromino, grid, 1, 0)  # Move down\n        rotate_tetromino(current_tetromino, grid)  # Rotate\n        lock_tetromino(current_tetromino, grid)  # Lock\n\n        # Resolve the grid\n        resolve_grid(grid)\n\n        # Print grid for demonstration\n        for row in grid:\n            print(row)\n\n    pygame.quit()\n```"}
{"timestamp": "2026-05-22 16:02:33,728", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task2: ```python\nimport pygame\nfrom dataclasses import dataclass\nfrom typing import List, Tuple, Dict\nimport random\n\n# Game Constants\nGRID_WIDTH = 10\nGRID_HEIGHT = 20\nCELL_SIZE = 30\nSCREEN_WIDTH = GRID_WIDTH * CELL_SIZE + 200  # extra space for UI\nSCREEN_HEIGHT = GRID_HEIGHT * CELL_SIZE\nFPS = 30\n\n# Colors (R, G, B)\nWHITE   = (255, 255, 255)\nBLACK   = (  0,   0,   0)\nGRAY    = (128, 128, 128)\nRED     = (255,   0,   0)\nGREEN   = (  0, 255,   0)\nBLUE    = (  0,   0, 255)\nYELLOW  = (255, 255,   0)\nCYAN    = (  0, 255, 255)\nMAGENTA = (255,   0, 255)\nORANGE  = (255, 165,   0)\n\n# Gem Colors Pool\nGEM_COLORS: List[Tuple[int, int, int]] = [\n    RED, GREEN, BLUE, YELLOW, CYAN, MAGENTA, ORANGE\n]\n\n# Map each tetromino letter to a fixed color\nSHAPE_COLORS: Dict[str, Tuple[int, int, int]] = {\n    \"I\": CYAN,\n    \"J\": BLUE,\n    \"L\": ORANGE,\n    \"O\": YELLOW,\n    \"S\": GREEN,\n    \"T\": MAGENTA,\n    \"Z\": RED,\n}\n\n# Tetromino shapes as lists of rotation states.\n# Each rotation is a list of (row_offset, col_offset)\nTETROMINO_SHAPES: Dict[str, List[List[Tuple[int, int]]]] = {\n    \"I\": [\n        [(0, 0), (0, 1), (0, 2), (0, 3)],\n        [(0, 0), (1, 0), (2, 0), (3, 0)]\n    ],\n    \"J\": [\n        [(0, 0), (1, 0), (1, 1), (1, 2)],\n        [(0, 1), (0, 0), (1, 0), (2, 0)],\n        [(0, 0), (0, 1), (0, 2), (1, 2)],\n        [(2, 0), (2, 1), (1, 1), (0, 1)]\n    ],\n    \"L\": [\n        [(0, 2), (1, 0), (1, 1), (1, 2)],\n        [(0, 0), (0, 1), (1, 1), (2, 1)],\n        [(1, 0), (1, 1), (1, 2), (2, 0)],\n        [(0, 1), (1, 1), (2, 1), (2, 2)]\n    ],\n    \"O\": [\n        [(0, 0), (0, 1), (1, 0), (1, 1)]\n    ],\n    \"S\": [\n        [(0, 1), (0, 2), (1, 0), (1, 1)],\n        [(0, 0), (1, 0), (1, 1), (2, 1)]\n    ],\n    \"T\": [\n        [(0, 1), (1, 0), (1, 1), (1, 2)],\n        [(0, 0), (1, 0), (2, 0), (1, 1)],\n        [(1, 0), (1, 1), (1, 2), (2, 1)],\n        [(0, 1), (1, 1), (2, 1), (1, 2)]\n    ],\n    \"Z\": [\n        [(0, 0), (0, 1), (1, 1), (1, 2)],\n        [(0, 1), (1, 0), (1, 1), (2, 0)]\n    ],\n}\n\n# Grid Representation: None means empty, else stores a color tuple\nGRID: List[List[Tuple[int, int, int] or None]] = [\n    [None for _ in range(GRID_WIDTH)]\n    for _ in range(GRID_HEIGHT)\n]\n\n# Score Constants\nINITIAL_SCORE = 0\nTETRIS_CLEAR_SCORE       = 800   # per line\nMATCH_3_SCORE            = 100   # per gem in match-3\nCHAIN_REACTION_MULTIPLIER = 1.5   # multiplier per cascade\n\n# Structured score tracker\nclass ScoreTracker:\n    def __init__(self):\n        self.current = INITIAL_SCORE\n\n    def add_tetris_clear(self, lines: int):\n        \"\"\"Award score for Tetris line clears.\"\"\"\n        self.current += TETRIS_CLEAR_SCORE * lines\n\n    def add_match(self, num_gems: int, chain: int = 1):\n        \"\"\"Award score for Bejeweled matches, using the chain multiplier.\"\"\"\n        bonus = MATCH_3_SCORE * num_gems * (CHAIN_REACTION_MULTIPLIER ** (chain - 1))\n        self.current += int(bonus)\n\n# Dataclass for active tetromino\n@dataclass\nclass Tetromino:\n    shape_key: str                  # \"I\", \"J\", ...\n    rotation: int                   # index into TETROMINO_SHAPES[shape_key]\n    position: Tuple[int, int]       # (row, col) of the shape’s origin\n    color: Tuple[int, int, int]     # from SHAPE_COLORS\n\n    @property\n    def blocks(self) -> List[Tuple[int, int]]:\n        \"\"\"Return absolute grid positions of the 4 blocks.\"\"\"\n        offsets = TETROMINO_SHAPES[self.shape_key][self.rotation]\n        r0, c0 = self.position\n        return [(r0 + dr, c0 + dc) for dr, dc in offsets]\n\n# Current and Next pieces; will be set when game starts\nCURRENT_TETROMINO: Tetromino = None\nNEXT_TETROMINO: Tetromino = None\n\n# Instantiate score tracker\nscore_tracker = ScoreTracker()\n\ndef clear_lines(grid: List[List[Tuple[int, int, int] or None]]) -> int:\n    \"\"\"Detect and clear full lines. Returns how many lines were cleared.\"\"\"\n    lines_cleared = 0\n    new_grid = [row for row in grid if not all(row)]\n    lines_cleared = GRID_HEIGHT - len(new_grid)\n    for _ in range(lines_cleared):\n        new_grid.insert(0, [None] * GRID_WIDTH)\n    for r in range(GRID_HEIGHT):\n        grid[r] = new_grid[r]\n    return lines_cleared\n\ndef find_matches(grid: List[List[Tuple[int, int, int] or None]]) -> List[Tuple[int, int]]:\n    \"\"\"Find all horizontal and vertical match-3+ clusters.\"\"\"\n    matches = set()\n    # Horizontal\n    for r in range(GRID_HEIGHT):\n        c = 0\n        while c < GRID_WIDTH - 2:\n            color = grid[r][c]\n            if color and grid[r][c+1] == color and grid[r][c+2] == color:\n                length = 3\n                while c+length < GRID_WIDTH and grid[r][c+length] == color:\n                    length += 1\n                for k in range(length):\n                    matches.add((r, c+k))\n                c += length\n            else:\n                c += 1\n    # Vertical\n    for c in range(GRID_WIDTH):\n        r = 0\n        while r < GRID_HEIGHT - 2:\n            color = grid[r][c]\n            if color and grid[r+1][c] == color and grid[r+2][c] == color:\n                length = 3\n                while r+length < GRID_HEIGHT and grid[r+length][c] == color:\n                    length += 1\n                for k in range(length):\n                    matches.add((r+k, c))\n                r += length\n            else:\n                r += 1\n    return list(matches)\n\ndef clear_matches(grid: List[List[Tuple[int, int, int] or None]],\n                  matches: List[Tuple[int, int]]):\n    \"\"\"Remove matched gems.\"\"\"\n    for r, c in matches:\n        grid[r][c] = None\n\ndef apply_gravity(grid: List[List[Tuple[int, int, int] or None]]):\n    \"\"\"Drop all gems down to fill empty spaces.\"\"\"\n    for c in range(GRID_WIDTH):\n        stack = [grid[r][c] for r in range(GRID_HEIGHT) if grid[r][c] is not None]\n        empties = GRID_HEIGHT - len(stack)\n        for r in range(GRID_HEIGHT):\n            if r < empties:\n                grid[r][c] = None\n            else:\n                grid[r][c] = stack[r - empties]\n\ndef handle_clearing(grid: List[List[Tuple[int, int, int] or None]],\n                    score_tracker: ScoreTracker) -> Tuple[int, int]:\n    \"\"\"\n    Clear Tetris lines and Bejeweled matches, apply chain reactions,\n    and update score. Returns (lines_cleared, total_matches_cleared).\n    \"\"\"\n    total_lines = 0\n    total_matches = 0\n    chain = 1\n\n    while True:\n        # 1) Tetris lines\n        lines = clear_lines(grid)\n        if lines:\n            score_tracker.add_tetris_clear(lines)\n            total_lines += lines\n\n        # 2) Bejeweled matches\n        matches = find_matches(grid)\n        if matches:\n            clear_matches(grid, matches)\n            score_tracker.add_match(len(matches), chain)\n            total_matches += len(matches)\n            chain += 1\n            apply_gravity(grid)\n        else:\n            break\n\n    return total_lines, total_matches\n```"}
{"timestamp": "2026-05-22 16:02:33,728", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task3: ```python\nimport pygame\nfrom dataclasses import dataclass\nfrom typing import List, Tuple, Dict\nimport random\n\n# Game Constants\nGRID_WIDTH = 10\nGRID_HEIGHT = 20\nCELL_SIZE = 30\nSCREEN_WIDTH = GRID_WIDTH * CELL_SIZE + 200  # extra space for UI\nSCREEN_HEIGHT = GRID_HEIGHT * CELL_SIZE\nFPS = 30\n\n# Colors (R, G, B)\nWHITE   = (255, 255, 255)\nBLACK   = (  0,   0,   0)\nGRAY    = (128, 128, 128)\nRED     = (255,   0,   0)\nGREEN   = (  0, 255,   0)\nBLUE    = (  0,   0, 255)\nYELLOW  = (255, 255,   0)\nCYAN    = (  0, 255, 255)\nMAGENTA = (255,   0, 255)\nORANGE  = (255, 165,   0)\n\n# Gem Colors Pool\nGEM_COLORS: List[Tuple[int, int, int]] = [\n    RED, GREEN, BLUE, YELLOW, CYAN, MAGENTA, ORANGE\n]\n\n# Map each tetromino letter to a fixed color\nSHAPE_COLORS: Dict[str, Tuple[int, int, int]] = {\n    \"I\": CYAN,\n    \"J\": BLUE,\n    \"L\": ORANGE,\n    \"O\": YELLOW,\n    \"S\": GREEN,\n    \"T\": MAGENTA,\n    \"Z\": RED,\n}\n\n# Tetromino shapes as lists of rotation states.\n# Each rotation is a list of (row_offset, col_offset)\nTETROMINO_SHAPES: Dict[str, List[List[Tuple[int, int]]]] = {\n    \"I\": [\n        [(0, 0), (0, 1), (0, 2), (0, 3)],\n        [(0, 0), (1, 0), (2, 0), (3, 0)]\n    ],\n    \"J\": [\n        [(0, 0), (1, 0), (1, 1), (1, 2)],\n        [(0, 1), (0, 0), (1, 0), (2, 0)],\n        [(0, 0), (0, 1), (0, 2), (1, 2)],\n        [(2, 0), (2, 1), (1, 1), (0, 1)]\n    ],\n    \"L\": [\n        [(0, 2), (1, 0), (1, 1), (1, 2)],\n        [(0, 0), (0, 1), (1, 1), (2, 1)],\n        [(1, 0), (1, 1), (1, 2), (2, 0)],\n        [(0, 1), (1, 1), (2, 1), (2, 2)]\n    ],\n    \"O\": [\n        [(0, 0), (0, 1), (1, 0), (1, 1)]\n    ],\n    \"S\": [\n        [(0, 1), (0, 2), (1, 0), (1, 1)],\n        [(0, 0), (1, 0), (1, 1), (2, 1)]\n    ],\n    \"T\": [\n        [(0, 1), (1, 0), (1, 1), (1, 2)],\n        [(0, 0), (1, 0), (2, 0), (1, 1)],\n        [(1, 0), (1, 1), (1, 2), (2, 1)],\n        [(0, 1), (1, 1), (2, 1), (1, 2)]\n    ],\n    \"Z\": [\n        [(0, 0), (0, 1), (1, 1), (1, 2)],\n        [(0, 1), (1, 0), (1, 1), (2, 0)]\n    ],\n}\n\n# Grid Representation: None means empty, else stores a color tuple\nGRID: List[List[Tuple[int, int, int] or None]] = [\n    [None for _ in range(GRID_WIDTH)]\n    for _ in range(GRID_HEIGHT)\n]\n\n# Score Constants\nINITIAL_SCORE = 0\nTETRIS_CLEAR_SCORE       = 800\nMATCH_3_SCORE            = 100\nCHAIN_REACTION_MULTIPLIER = 1.5\n\n# Structured score tracker\nclass ScoreTracker:\n    def __init__(self):\n        self.current = INITIAL_SCORE\n\n    def add_tetris_clear(self):\n        self.current += TETRIS_CLEAR_SCORE\n\n    def add_match(self, num_matches: int, chain: int = 1):\n        self.current += int(MATCH_3_SCORE * num_matches * chain)\n\n# Dataclass for active tetromino\n@dataclass\nclass Tetromino:\n    shape_key: str                  # \"I\", \"J\", ...\n    rotation: int                   # index into TETROMINO_SHAPES[shape_key]\n    position: Tuple[int, int]       # (row, col) of the shape’s origin\n    color: Tuple[int, int, int]     # from SHAPE_COLORS\n\n    @property\n    def blocks(self) -> List[Tuple[int, int]]:\n        \"\"\"Return absolute grid positions of the 4 blocks.\"\"\"\n        offsets = TETROMINO_SHAPES[self.shape_key][self.rotation]\n        r0, c0 = self.position\n        return [(r0 + dr, c0 + dc) for dr, dc in offsets]\n\n# Current and Next pieces; will be set when game starts\nCURRENT_TETROMINO: Tetromino = None\nNEXT_TETROMINO: Tetromino = None\n\n# Instantiate score tracker\nscore_tracker = ScoreTracker()\n\npygame.init()\nscreen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\npygame.display.set_caption(\"Tetris Bejeweled\")\nfont = pygame.font.Font(None, 30)\n\ndef draw_grid(screen, grid):\n    \"\"\"Draws the game grid on the screen.\"\"\"\n    for row_index, row in enumerate(grid):\n        for col_index, cell in enumerate(row):\n            x = col_index * CELL_SIZE\n            y = row_index * CELL_SIZE\n            rect = pygame.Rect(x, y, CELL_SIZE, CELL_SIZE)\n            if cell is None:\n                pygame.draw.rect(screen, GRAY, rect, 1)  # Draw grid lines\n            else:\n                pygame.draw.rect(screen, cell, rect)  # Draw filled cell\n\ndef draw_tetromino(screen, tetromino: Tetromino):\n    \"\"\"Draws the active tetromino on the screen.\"\"\"\n    for row, col in tetromino.blocks:\n        x = col * CELL_SIZE\n        y = row * CELL_SIZE\n        rect = pygame.Rect(x, y, CELL_SIZE, CELL_SIZE)\n        pygame.draw.rect(screen, tetromino.color, rect)\n\ndef draw_next_tetromino(screen, tetromino: Tetromino):\n    \"\"\"Draws the next tetromino preview.\"\"\"\n    x_offset = GRID_WIDTH * CELL_SIZE + 20\n    y_offset = 50\n\n    # Scale down the preview\n    scale = 0.7\n    scaled_cell_size = int(CELL_SIZE * scale)\n\n    for row_offset, col_offset in TETROMINO_SHAPES[tetromino.shape_key][tetromino.rotation]:\n        x = x_offset + col_offset * scaled_cell_size\n        y = y_offset + row_offset * scaled_cell_size\n        rect = pygame.Rect(x, y, scaled_cell_size, scaled_cell_size)\n        pygame.draw.rect(screen, tetromino.color, rect)\n\ndef draw_score(screen, score: int):\n    \"\"\"Draws the current score on the screen.\"\"\"\n    text_surface = font.render(f\"Score: {score}\", True, WHITE)\n    screen.blit(text_surface, (GRID_WIDTH * CELL_SIZE + 20, 200))\n\ndef render(screen, grid, current_tetromino, next_tetromino, score):\n    \"\"\"Main rendering function.\"\"\"\n    screen.fill(BLACK)\n    draw_grid(screen, grid)\n    if current_tetromino:\n        draw_tetromino(screen, current_tetromino)\n    if next_tetromino:\n        draw_next_tetromino(screen, next_tetromino)\n    draw_score(screen, score)\n    pygame.display.flip()\n```"}
