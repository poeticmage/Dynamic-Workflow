set\n\n        if (new_row < 0 or new_row >= GRID_HEIGHT or\n            new_col < 0 or new_col >= GRID_WIDTH or\n            (0 <= new_row < len(grid) and 0 <= new_col < len(grid[0]) and grid[new_row][new_col] is not None)):\n            return False\n    return True\n\ndef move_tetromino(tetromino: Tetromino, grid: GridType, row_offset: int, col_offset: int) -> bool:\n    \"\"\"Moves the tetromino if the move is valid. Returns True if moved, False otherwise.\"\"\"\n    if valid_move(tetromino, grid, row_offset, col_offset):\n        tetromino.position = (tetromino.position[0] + row_offset,\n                              tetromino.position[1] + col_offset)\n        return True\n    return False\n\ndef rotate_tetromino(tetromino: Tetromino, grid: GridType) -> bool:\n    \"\"\"Rotates the tetromino if the rotation is valid. Returns True if rotated, False otherwise.\"\"\"\n    original_rotation = tetromino.rotation\n    new_rotation = (original_rotation + 1) % len(TETROMINO_SHAPES[tetromino.shape_key])\n\n    # Create a temporary tetromino to test the rotation\n    temp_tetromino = Tetromino(\n        shape_key=tetromino.shape_key,\n        rotation=new_rotation,\n        position=tetromino.position,\n        color=tetromino.color\n    )\n\n    valid = True\n    for r, c in temp_tetromino.blocks:\n        if not (0 <= r < GRID_HEIGHT and 0 <= c < GRID_WIDTH):\n            valid = False\n            break\n        if grid[r][c] is not None:\n            valid = False\n            break\n\n    if valid:\n        tetromino.rotation = new_rotation\n        return True\n\n    # Try kicking (moving the tetromino slightly to see if it fits)\n    kick_offsets = [(0, 0), (0, -1), (0, 1), (-1, 0), (1, 0)]  # Basic kick offsets; more complex kicks exist in real Tetris\n\n    for row_offset, col_offset in kick_offsets:\n        temp_tetromino.position = (tetromino.position[0] + row_offset, tetromino.position[1] + col_offset)\n\n        valid = True\n        for r, c in temp_tetromino.blocks:\n            if not (0 <= r < GRID_HEIGHT and 0 <= c < GRID_WIDTH and grid[r][c] is None):\n                valid = False\n                break\n        if valid:\n            tetromino.rotation = new_rotation\n            tetromino.position = (tetromino.position[0] + row_offset, tetromino.position[1] + col_offset)\n            return True\n        temp_tetromino.position = tetromino.position  # Reset position for next kick attempt\n\n    return False\n\n# -----------------------------------------------------------------------------\n# Locking and Clearing\n# -----------------------------------------------------------------------------\ndef lock_tetromino(tetromino: Tetromino, grid: GridType) -> None:\n    \"\"\"Locks the tetromino into the grid, converting its blocks into colored gems.\"\"\"\n    for row, col in tetromino.blocks:\n        if 0 <= row < GRID_HEIGHT and 0 <= col < GRID_WIDTH:\n            grid[row][col] = tetromino.color\n\ndef check_tetris_clear(grid: GridType) -> List[int]:\n    \"\"\"Checks for and returns a list of indices of lines that are full (Tetris clear).\"\"\"\n    lines_to_clear = []\n    for i, row in enumerate(grid):\n        if all(cell is not None for cell in row):\n            lines_to_clear.append(i)\n    return lines_to_clear\n\ndef clear_lines(grid: GridType, lines: List[int]) -> None:\n    \"\"\"Clears the specified lines in the grid and shifts the above lines down.\"\"\"\n    for line_index in sorted(lines, reverse=True):\n        del grid[line_index]\n        grid.insert(0, [None] * GRID_WIDTH)\n    score_tracker.add_tetris_clear()\n\n# -----------------------------------------------------------------------------\n# Match 3 Logic\n# -----------------------------------------------------------------------------\ndef check_match_3(grid: GridType) -> List[Tuple[int, int]]:\n    \"\"\"Checks for horizontal and vertical match-3 gem formations and returns a list of their coordinates.\"\"\"\n    matches = []\n\n    # Horizontal matches\n    for row in range(GRID_HEIGHT):\n        for col in range(GRID_WIDTH - 2):\n            if (grid[row][col] is not None and\n                grid[row][col] == grid[row][col+1] == grid[row][col+2]):\n                matches.extend([(row, col), (row, col+1), (row, col+2)])\n\n    # Vertical matches\n    for col in range(GRID_WIDTH):\n        for row in range(GRID_HEIGHT - 2):\n            if (grid[row][col] is not None and\n                grid[row][col] == grid[row+1][col] == grid[row+2][col]):\n                matches.extend([(row, col), (row+1, col), (row+2, col)])\n\n    # Remove duplicate coordinates\n    unique_matches = []\n    for match in matches:\n        if match not in unique_matches:\n            unique_matches.append(match)\n\n    return unique_matches\n\ndef clear_matches(grid: GridType, matches: List[Tuple[int, int]]) -> None:\n    \"\"\"Clears the gems at the specified coordinates in the grid.\"\"\"\n    score_tracker.add_match(len(matches))\n    for row, col in matches:\n        grid[row][col] = None\n\ndef drop_floating_gems(grid: GridType) -> None:\n    \"\"\"Simulates gems falling down to fill empty spaces below them.\"\"\"\n    for col in range(GRID_WIDTH):\n        empty_pos = -1\n        for row in range(GRID_HEIGHT - 1, -1, -1):\n            if grid[row][col] is None:\n                empty_pos = row\n            elif empty_pos != -1:\n                grid[empty_pos][col] = grid[row][col]\n                grid[row][col] = None\n                empty_pos -= 1\n\n# -----------------------------------------------------------------------------\n# Grid Resolution\n# -----------------------------------------------------------------------------\ndef resolve_grid(grid: GridType) -> None:\n    \"\"\"Resolves the grid by clearing lines and matches, and dropping gems.\"\"\"\n    lines_to_clear = check_tetris_clear(grid)\n    clear_lines(grid, lines_to_clear)\n\n    matches_to_clear = check_match_3(grid)\n    clear_matches(grid, matches_to_clear)\n\n    drop_floating_gems(grid)\n\n# -----------------------------------------------------------------------------\n# Input Handling\n# -----------------------------------------------------------------------------\ndef handle_input(event: pygame.event.Event, current_tetromino: Tetromino, grid: GridType) -> None:\n    \"\"\"Handles keyboard input events for controlling the tetromino.\"\"\"\n    if event.type == pygame.KEYDOWN:\n        if event.key == pygame.K_LEFT:\n            move_tetromino(current_tetromino, grid, 0, -1)\n        elif event.key == pygame.K_RIGHT:\n            move_tetromino(current_tetromino, grid, 0, 1)\n        elif event.key == pygame.K_DOWN:\n            move_tetromino(current_tetromino, grid, 1, 0)\n        elif event.key == pygame.K_UP:  # Rotate\n            rotate_tetromino(current_tetromino, grid)\n\nif __name__ == '__main__':\n    # Example Usage (for testing purposes)\n    # Initialize Pygame (required for font rendering, even if display is created later)\n    pygame.init()\n\n    # Initialize the grid\n    grid: GridType = [[None for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]\n\n    # Initial spawn\n    spawn_tetromino()\n    current_tetromino = CURRENT_TETROMINO\n\n    # Game loop\n    running = True\n    while running:\n        for event in pygame.event.get():\n            if event.type == pygame.QUIT:\n                running = False\n            if current_tetromino is not None:\n                handle_input(event, current_tetromino, grid)\n\n        # Example movement and locking (remove in actual game loop, handled by input)\n        if current_tetromino is not None:\n            move_tetromino(current_tetromino, grid, 1, 0)  # Move down\n            #lock_tetromino(current_tetromino, grid)  # Lock\n\n            # Resolve the grid\n            resolve_grid(grid)\n\n            # Print grid for demonstration\n            for row in grid:\n                print(row)\n            \n            spawn_tetromino()\n            current_tetromino = CURRENT_TETROMINO\n\n        pygame.time.delay(1000) # slow down the loop\n\n    pygame.quit()\n```"}
{"timestamp": "2026-05-22 16:02:33,728", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task5: ```python\nimport pygame\nimport random\nfrom typing import List, Tuple, Optional\nfrom dataclasses import dataclass\n\n# Import game constants and data structures from task2 and task3 and task4\nfrom task2 import (\n    GRID_WIDTH, GRID_HEIGHT, CELL_SIZE,\n    TETROMINO_SHAPES, SHAPE_COLORS,\n    GEM_COLORS, ScoreTracker,\n    SCREEN_WIDTH, SCREEN_HEIGHT, FPS\n)\nfrom task3 import (\n    draw_grid, draw_tetromino, draw_next_tetromino,\n    draw_score, render, font\n)\nfrom task4 import handle_input  # only input handler needed\n\n# -----------------------------------------------------------------------------\n# Data Structures\n# -----------------------------------------------------------------------------\nGridType = List[List[Optional[Tuple[int, int, int]]]]\n\n@dataclass\nclass Tetromino:\n    shape_key: str\n    rotation: int\n    position: Tuple[int, int]\n    color: Tuple[int, int, int]\n\n    @property\n    def blocks(self) -> List[Tuple[int, int]]:\n        offsets = TETROMINO_SHAPES[self.shape_key][self.rotation]\n        r0, c0 = self.position\n        return [(r0 + dr, c0 + dc) for dr, dc in offsets]\n\n# -----------------------------------------------------------------------------\n# Game State\n# -----------------------------------------------------------------------------\nGRID: GridType = [[None for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]\nCURRENT_TETROMINO: Optional[Tetromino] = None\nNEXT_TETROMINO: Optional[Tetromino] = None\nscore_tracker = ScoreTracker()\n\n# -----------------------------------------------------------------------------\n# Tetromino Spawning\n# -----------------------------------------------------------------------------\ndef new_tetromino() -> Tetromino:\n    shape_key = random.choice(list(TETROMINO_SHAPES.keys()))\n    return Tetromino(\n        shape_key=shape_key,\n        rotation=0,\n        position=(0, GRID_WIDTH // 2 - 2),\n        color=SHAPE_COLORS[shape_key]\n    )\n\ndef spawn_tetromino() -> bool:\n    global CURRENT_TETROMINO, NEXT_TETROMINO\n\n    if NEXT_TETROMINO is None:\n        CURRENT_TETROMINO = new_tetromino()\n        NEXT_TETROMINO = new_tetromino()\n    else:\n        CURRENT_TETROMINO = NEXT_TETROMINO\n        NEXT_TETROMINO = new_tetromino()\n\n    if not valid_move(CURRENT_TETROMINO, GRID, 0, 0):\n        return False  # Game over\n    return True\n\n# -----------------------------------------------------------------------------\n# Movement and Rotation\n# -----------------------------------------------------------------------------\ndef valid_move(tetromino: Tetromino, grid: GridType, row_offset: int, col_offset: int) -> bool:\n    for row, col in tetromino.blocks:\n        r, c = row + row_offset, col + col_offset\n        if r < 0 or r >= GRID_HEIGHT or c < 0 or c >= GRID_WIDTH:\n            return False\n        if 0 <= r < GRID_HEIGHT and 0 <= c < GRID_WIDTH and grid[r][c] is not None:\n            return False\n    return True\n\ndef move_tetromino_internal(t: Tetromino, grid: GridType, dr: int, dc: int) -> bool:\n    if valid_move(t, grid, dr, dc):\n        t.position = (t.position[0] + dr, t.position[1] + dc)\n        return True\n    return False\n\ndef rotate_tetromino_internal(t: Tetromino, grid: GridType) -> bool:\n    orig_rot = t.rotation\n    new_rot = (orig_rot + 1) % len(TETROMINO_SHAPES[t.shape_key])\n    temp = Tetromino(t.shape_key, new_rot, t.position, t.color)\n\n    # try kicks\n    for kick in [(0,0),(0,-1),(0,1),(-1,0),(1,0)]:\n        temp.position = (t.position[0]+kick[0], t.position[1]+kick[1])\n        if valid_move(temp, grid, 0, 0):\n            t.rotation = new_rot\n            t.position = temp.position\n            return True\n    return False\n\n# -----------------------------------------------------------------------------\n# Locking and Clearing\n# -----------------------------------------------------------------------------\ndef lock_tetromino(t: Tetromino, grid: GridType) -> None:\n    for r, c in t.blocks:\n        if 0 <= r < GRID_HEIGHT and 0 <= c < GRID_WIDTH:\n            grid[r][c] = t.color\n\ndef check_tetris_clear(grid: GridType) -> List[int]:\n    return [i for i, row in enumerate(grid) if all(cell is not None for cell in row)]\n\ndef clear_lines(grid: GridType, lines: List[int]) -> None:\n    for idx in sorted(lines, reverse=True):\n        del grid[idx]\n        grid.insert(0, [None] * GRID_WIDTH)\n    score_tracker.add_tetris_clear(len(lines))\n\n# -----------------------------------------------------------------------------\n# Match-3 Logic\n# -----------------------------------------------------------------------------\ndef check_match_3(grid: GridType) -> List[Tuple[int,int]]:\n    matches = []\n    # horizontal\n    for r in range(GRID_HEIGHT):\n        for c in range(GRID_WIDTH - 2):\n            if grid[r][c] and grid[r][c] == grid[r][c+1] == grid[r][c+2]:\n                matches += [(r,c),(r,c+1),(r,c+2)]\n    # vertical\n    for c in range(GRID_WIDTH):\n        for r in range(GRID_HEIGHT - 2):\n            if grid[r][c] and grid[r][c] == grid[r+1][c] == grid[r+2][c]:\n                matches += [(r,c),(r+1,c),(r+2,c)]\n    # unique\n    return list(dict.fromkeys(matches))\n\ndef clear_matches(grid: GridType, matches: List[Tuple[int,int]]) -> None:\n    for r, c in matches:\n        grid[r][c] = None\n    score_tracker.add_match(len(matches))\n\ndef drop_floating_gems(grid: GridType) -> None:\n    for c in range(GRID_WIDTH):\n        stack = [grid[r][c] for r in range(GRID_HEIGHT) if grid[r][c] is not None]\n        for r in range(GRID_HEIGHT):\n            grid[r][c] = stack[r - (GRID_HEIGHT - len(stack))] if r >= GRID_HEIGHT - len(stack) else None\n\n# -----------------------------------------------------------------------------\n# Chain-Reaction Resolution\n# -----------------------------------------------------------------------------\ndef resolve_grid(grid: GridType) -> None:\n    any_clear = True\n    while any_clear:\n        any_clear = False\n        lines = check_tetris_clear(grid)\n        if lines:\n            clear_lines(grid, lines)\n            any_clear = True\n\n        matches = check_match_3(grid)\n        if matches:\n            clear_matches(grid, matches)\n            any_clear = True\n\n        if any_clear:\n            drop_floating_gems(grid)\n\n# -----------------------------------------------------------------------------\n# Main Game Loop\n# -----------------------------------------------------------------------------\ndef main():\n    global CURRENT_TETROMINO, NEXT_TETROMINO, GRID, score_tracker\n\n    pygame.init()\n    screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\n    pygame.display.set_caption(\"Tetris-Bejeweled\")\n    clock = pygame.time.Clock()\n\n    fall_speed = 1  # cells per second\n    fall_interval = 1000 / fall_speed\n    last_fall = pygame.time.get_ticks()\n\n    game_over = not spawn_tetromino()\n    running = True\n\n    while running:\n        now = pygame.time.get_ticks()\n        # 1. Input\n        for event in pygame.event.get():\n            if event.type == pygame.QUIT:\n                running = False\n            elif CURRENT_TETROMINO:\n                handle_input(event, CURRENT_TETROMINO, GRID)\n\n        # 2. Gravity & Lock\n        if not game_over and (now - last_fall) >= fall_interval:\n            if CURRENT_TETROMINO:\n                if not move_tetromino_internal(CURRENT_TETROMINO, GRID, 1, 0):\n                    lock_tetromino(CURRENT_TETROMINO, GRID)\n                    resolve_grid(GRID)\n                    if not spawn_tetromino():\n                        game_over = True\n            last_fall = now\n\n        # 3. Rendering\n        render(screen, GRID, CURRENT_TETROMINO, NEXT_TETROMINO, score_tracker.current)\n\n        pygame.display.flip()\n        clock.tick(FPS)\n\n    pygame.quit()\n\nif __name__ == \"__main__\":\n    main()\n```"}
