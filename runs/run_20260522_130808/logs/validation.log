ck_lines(self):\\n        \\\"\\\"\\\"Check for and clear full lines.\\\"\\\"\\\"\\n        lines_cleared = 0\\n        for row_index in range(self.height):\\n            if all(self.cells[row_index]):  # Check if all cells in row are not None\\n                self.clear_line(row_index)\\n                lines_cleared += 1\\n        return lines_cleared\\n\\n    def find_matches(self):\\n        \\\"\\\"\\\"Find and mark match-3 or more gems.\\\"\\\"\\\"\\n        for row in range(self.height):\\n            for col in range(self.width):\\n                if self.cells[row][col] is not None:\\n                    self.find_horizontal_matches(row, col)\\n                    self.find_vertical_matches(row, col)\\n\\n    def find_horizontal_matches(self, row, col):\\n        \\\"\\\"\\\"Check for horizontal matches starting at (row, col).\\\"\\\"\\\"\\n        count = 1\\n        initial_color = self.cells[row][col].color\\n        for i in range(col + 1, self.width):\\n            if self.cells[row][i] is not None and self.cells[row][i].color == initial_color:\\n                count += 1\\n            else:\\n                break\\n        if count >= 3:\\n            for i in range(col, col + count):\\n                self.cells[row][i].matched = True\\n\\n    def find_vertical_matches(self, row, col):\\n        \\\"\\\"\\\"Check for vertical matches starting at (row, col).\\\"\\\"\\\"\\n        count = 1\\n        initial_color = self.cells[row][col].color\\n        for i in range(row + 1, self.height):\\n            if self.cells[i][col] is not None and self.cells[i][col].color == initial_color:\\n                count += 1\\n            else:\\n                break\\n        if count >= 3:\\n            for i in range(row, row + count):\\n                self.cells[i][col].matched = True\\n\\n    def clear_matches(self):\\n        \\\"\\\"\\\"Clear matched gems and return the number of cleared gems.\\\"\\\"\\\"\\n        cleared_count = 0\\n        for row in range(self.height):\\n            for col in range(self.width):\\n                if self.cells[row][col] is not None and self.cells[row][col].matched:\\n                    self.cells[row][col] = None\\n                    cleared_count += 1\\n        return cleared_count\\n\\n    def drop_gems(self):\\n        \\\"\\\"\\\"Move gems down to fill empty spaces.\\\"\\\"\\\"\\n        for col in range(self.width):\\n            empty_space = None\\n            for row in range(self.height - 1, -1, -1):\\n                if self.cells[row][col] is None and empty_space is None:\\n                    empty_space = row\\n                elif self.cells[row][col] is not None and empty_space is not None:\\n                    self.cells[empty_space][col] = self.cells[row][col]\\n                    self.cells[row][col] = None\\n                    empty_space -= 1\\n\\nclass Tetromino:\\n    def __init__(self, shapes, color):\\n        \\\"\\\"\\\"\\n        shapes: list of 2D lists (rotation states)\\n        color: tuple RGB\\n        \\\"\\\"\\\"\\n        self.shapes = shapes\\n        self.color = color\\n        self.rotation_index = 0\\n        self.x = GRID_WIDTH // 2 - len(self.shape[0]) // 2\\n        self.y = 0\\n\\n\\n    @property\\n    def shape(self):\\n        return self.shapes[self.rotation_index]\\n\\n    def rotate(self, direction=1):\\n        \\\"\\\"\\\"Rotate clockwise (direction=1) or counterclockwise (direction=-1).\\\"\\\"\\\"\\n        n = len(self.shapes)\\n        self.rotation_index = (self.rotation_index + direction) % n\\n\\n    def move(self, dx, grid):\\n        \\\"\\\"\\\"Move the tetromino horizontally if possible.\\\"\\\"\\\"\\n        new_x = self.x + dx\\n        if grid.is_valid_move(self.shape, new_x, self.y):\\n            self.x = new_x\\n            return True\\n        return False\\n\\n    def move_down(self, grid):\\n        \\\"\\\"\\\"Move the tetromino down if possible.  Return True if moved, False if hit the bottom.\\\"\\