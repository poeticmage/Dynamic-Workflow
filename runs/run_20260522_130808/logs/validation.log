_random_tetromino()\\n                    current.set_position(GRID_WIDTH // 2 - len(current.shape[0]) // 2, 0)\\n                    # Basic game over check\\n                    if not grid.is_valid_move(current.shape, current.x, current.y):\\n                        print(\\\"Game Over!\\\")\\n                        running = False\\n\\n\\n        screen.fill((0,0,0))\\n        # Draw gems\\n        for row in range(GRID_HEIGHT):\\n            for col in range(GRID_WIDTH):\\n                gem = grid.get_cell(col, row)\\n                if gem:\\n                    pygame.draw.rect(screen, gem.color,\\n                                     (col*BLOCK_SIZE, row*BLOCK_SIZE,\\n                                      BLOCK_SIZE, BLOCK_SIZE))\\n        # Draw current tetromino\\n        for r, row in enumerate(current.shape):\\n            for c, cell in enumerate(row):\\n                if cell:\\n                    px, py = (current.x+c)*BLOCK_SIZE, (current.y+r)*BLOCK_SIZE\\n                    pygame.draw.rect(screen, current.color,\\n                                     (px, py, BLOCK_SIZE, BLOCK_SIZE))\\n        # Display score\\n        font = pygame.font.Font(None, 30)\\n        score_text = font.render(f\\\"Score: {score}\\\", True, (255, 255, 255))\\n        screen.blit(score_text, (10, 10))\\n\\n\\n        pygame.display.flip()\\n\\n    pygame.quit()\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task4:\\n  Objective: Develop scoring system: calculate base points and bonus points from line clears and match-3 chains.\\nTask task6:\\n  Objective: Assemble the main game loop: handle keyboard input, manage tetromino spawning with a random bag system and maintain the next-piece queue, invoke movement, locking, clearing, scoring, detect game-over conditions, and trigger GUI rendering each frame.\\n\\n---\\n# **Current Task Requirements**\\nImplement clearing mechanics: detect and clear full lines (Tetris) and match-3 gem patterns with chain reactions.