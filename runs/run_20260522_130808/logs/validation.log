, (O_SHAPES, \\\"O\\\"), (T_SHAPES, \\\"T\\\"),\\n        (S_SHAPES, \\\"S\\\"), (Z_SHAPES, \\\"Z\\\"), (J_SHAPES, \\\"J\\\"), (L_SHAPES, \\\"L\\\")\\n    ]\\n    shapes, _ = random.choice(tetromino_classes)\\n    color = random.choice(COLORS)\\n    return Tetromino(shapes, color)\\n\\n# Example usage (not part of core data structure definition)\\nif __name__ == '__main__':\\n    pygame.init()\\n    screen = pygame.display.set_mode((GRID_WIDTH * BLOCK_SIZE,\\n                                      GRID_HEIGHT * BLOCK_SIZE))\\n    pygame.display.set_caption(\\\"Tetris + Bejeweled Core Demo\\\")\\n\\n    grid = Grid(GRID_WIDTH, GRID_HEIGHT)\\n    current = create_random_tetromino()\\n    #initial position is now handled inside Tetromino class\\n    running = True\\n    clock = pygame.time.Clock()\\n    fall_speed = 1  # Blocks per second\\n    fall_event = pygame.USEREVENT + 1\\n    pygame.time.set_timer(fall_event, int(1000 / fall_speed))\\n    score = 0\\n\\n\\n    while running:\\n        clock.tick(30)  # Limit frame rate to 30 FPS\\n        for event in pygame.event.get():\\n            if event.type == pygame.QUIT:\\n                running = False\\n            elif event.type == pygame.KEYDOWN:\\n                if event.key == pygame.K_LEFT:\\n                    current.move(-1, grid)\\n                elif event.key == pygame.K_RIGHT:\\n                    current.move(1, grid)\\n                elif event.key == pygame.K_DOWN:\\n                    while current.move_down(grid):\\n                        pass # Move all the way down\\n                elif event.key == pygame.K_UP:\\n                    original_rotation = current.rotation_index\\n                    current.rotate(1)\\n                    if not grid.is_valid_move(current.shape, current.x, current.y):\\n                        current.rotation_index = original_rotation  # Revert rotation\\n            elif event.type == fall_event:\\n                if not current.move_down(grid):\\n                    # Lock the tetromino\\n                    grid.place_shape(current.shape, current.color, current.x, current.y)\\n                    # Check for cleared lines\\n                    lines_cleared = grid.check_lines()\\n                    if lines_cleared > 0:\\n                        score += 100 * (lines_cleared ** 2) # Example scoring\\n                    # Find and clear match-3's\\n                    gems_cleared = 0\\n                    chain_reaction = True\\n                    while chain_reaction:\\n                        grid.find_matches()\\n                        cleared = grid.clear_matches()\\n                        if cleared > 0:\\n                            gems_cleared += cleared\\n                            grid.drop_gems()\\n                        else:\\n                            chain_reaction = False\\n\\n                    score += gems_cleared * 50  # Example scoring for gems\\n                    # Create a new tetromino\\n                    current = create_random_tetromino()\\n                    current.set_position(GRID_WIDTH // 2 - len(current.shape[0]) // 2, 0)\\n                    # Basic game over check\\n                    if not grid.is_valid_move(current.shape, current.x, current.y):\\n                        print(\\\"Game Over!\\\")\\n                        running = False\\n\\n\\n        screen.fill((0,0,0))\\n        # Draw gems\\n        for row in range(GRID_HEIGHT):\\n            for col in range(GRID_WIDTH):\\n                gem = grid.get_cell(col, row)\\n                if gem:\\n                    pygame.draw.rect(screen, gem.color,\\n                                     (col*BLOCK_SIZE, row*BLOCK_SIZE,\\n                                      BLOCK_SIZE, BLOCK_SIZE))\\n        # Draw current tetromino\\n        for r, row in enumerate(current.shape):\\n            for c, cell in enumerate(row):\\n                if cell:\\n                    px, py = (current.x+c)*BLOCK_SIZE, (current.y+r)*BLOCK_SIZE\\n                    pygame.draw.rect(screen, current.color,\\n                                     (px, py, BLOCK_SIZE, BLOCK_SIZE))\\n        # Display score\\n        font = pygame.font.Font(None, 30)\\n        score_text = font.render(f\\\"Score: {score}\\\", True, (255, 255, 255))\\n        screen.blit(score_text, (10, 10))\\n\\n\\n        pygame.display.flip()\\n\\n    pygame.quit()\\n```\",\n  \"timestamp\": \"2026-05-22T13:10:23.388915\"\n}"}
