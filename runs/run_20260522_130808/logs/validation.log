game.display.set_mode((GRID_WIDTH * BLOCK_SIZE,\\n                                      GRID_HEIGHT * BLOCK_SIZE))\\n    pygame.display.set_caption(\\\"Tetris + Bejeweled Core Demo\\\")\\n\\n    grid = Grid(GRID_WIDTH, GRID_HEIGHT)\\n    current = create_random_tetromino()\\n    x, y = GRID_WIDTH // 2 - len(current.shape[0]) // 2, 0\\n\\n    running = True\\n    clock = pygame.time.Clock()\\n    while running:\\n        clock.tick(10)\\n        for evt in pygame.event.get():\\n            if evt.type == pygame.QUIT:\\n                running = False\\n            elif evt.type == pygame.KEYDOWN:\\n                if evt.key == pygame.K_LEFT and grid.is_valid_move(current.shape, x-1, y):\\n                    x -= 1\\n                elif evt.key == pygame.K_RIGHT and grid.is_valid_move(current.shape, x+1, y):\\n                    x += 1\\n                elif evt.key == pygame.K_DOWN and grid.is_valid_move(current.shape, x, y+1):\\n                    y += 1\\n                elif evt.key == pygame.K_UP:\\n                    current.rotate(1)\\n                    if not grid.is_valid_move(current.shape, x, y):\\n                        current.rotate(-1)\\n\\n        # Gravity\\n        if grid.is_valid_move(current.shape, x, y+1):\\n            y += 1\\n        else:\\n            grid.place_shape(current.shape, current.color, x, y)\\n            # next piece\\n            current = create_random_tetromino()\\n            x, y = GRID_WIDTH // 2 - len(current.shape[0]) // 2, 0\\n\\n        screen.fill((0,0,0))\\n        # Draw gems\\n        for row in range(GRID_HEIGHT):\\n            for col in range(GRID_WIDTH):\\n                gem = grid.get_cell(col, row)\\n                if gem:\\n                    pygame.draw.rect(screen, gem.color,\\n                                     (col*BLOCK_SIZE, row*BLOCK_SIZE,\\n                                      BLOCK_SIZE, BLOCK_SIZE))\\n        # Draw current tetromino\\n        for r, row in enumerate(current.shape):\