               if not grid.is_valid_move(current.shape, current.x, current.y):\\n                        current.rotation_index = orig\\n            elif event.type == fall_event:\\n                if not current.move_down(grid):\\n                    # Lock shape\\n                    grid.place_shape(current.shape, current.color, current.x, current.y)\\n                    # Clear lines\\n                    lines = grid.check_lines()\\n                    line_clear_score = 100 * (lines ** 2)\\n                    score += line_clear_score\\n                    # Chain-reaction match-3\\n                    total_gems = 0\\n                    chain_multiplier = 1\\n                    while True:\\n                        matches = grid.find_matches()\\n                        if matches == 0:\\n                            break\\n                        cleared = grid.clear_matches()\\n                        total_gems += cleared\\n                        grid.drop_gems()\\n                        match_score = cleared * 50 * chain_multiplier\\n                        score += match_score\\n                        chain_multiplier += 0.2\\n                    # New tetromino\\n                    current = create_random_tetromino()\\n                    current.set_position(GRID_WIDTH//2 - len(current.shape[0])//2, 0)\\n                    if not grid.is_valid_move(current.shape, current.x, current.y):\\n                        print(\\\"Game Over!\\\")\\n                        running = False\\n\\n        # Drawing\\n        screen.fill((0,0,0))\\n        for r in range(GRID_HEIGHT):\\n            for c in range(GRID_WIDTH):\\n                gem = grid.get_cell(c, r)\\n                if gem:\\n                    pygame.draw.rect(screen, gem.color,\\n                                     (c*BLOCK_SIZE, r*BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE))\\n        for r, row in enumerate(current.shape):\\n            for c, cell in enumerate(row):\\n                if ce