ore = 0\\n\\n    clock = pygame.time.Clock()\\n    fall_event = pygame.USEREVENT + 1\\n    fall_speed = 1  # Blocks per second\\n    pygame.time.set_timer(fall_event, int(1000 / fall_speed))\\n\\n    running = True\\n    while running:\\n        clock.tick(30)\\n        for event in pygame.event.get():\\n            if event.type == pygame.QUIT:\\n                running = False\\n            elif event.type == pygame.KEYDOWN:\\n                if event.key == pygame.K_LEFT:\\n                    current.move(-1, grid)\\n                elif event.key == pygame.K_RIGHT:\\n                    current.move(1, grid)\\n                elif event.key == pygame.K_DOWN:\\n                    while current.move_down(grid):\\n                        pass\\n                elif event.key == pygame.K_UP:\\n                    orig = current.rotation_index\\n                    current.rotate(1)\\n                    if not grid.is_valid_move(current.shape, current.x, current.y):\\n                        current.rotation_index = orig\\n            elif event.type == fall_event:\\n                if not current.move_down(grid):\\n                    # Lock shape\\n                    grid.place_shape(current.shape, current.color, current.x, current.y)\\n                    # Clear lines\\n                    lines = grid.check_lines()\\n                    if lines:\\n                        score += 100 * (lines ** 2)\\n                    # Chain-reaction match-3\\n                    total_gems = 0\\n                    while True:\\n                        matches = grid.find_matches()\\n                        if matches == 0:\\n                            break\\n                        cleared = grid.clear_matches()\\n                        total_gems += cleared\\n                        grid.drop_gems()\\n                    if total_gems:\\n                        score += total_gems * 50\\n                    # New tetromino\\n                    current = create_ran