n  Objective: Implement clearing mechanics: detect and clear full lines (Tetris) and match-3 gem patterns with chain reactions.\\n  Result: ```python\\nimport pygame\\nimport random\\n\\n# Constants\\nGRID_WIDTH = 10\\nGRID_HEIGHT = 20\\nBLOCK_SIZE = 30\\nCOLORS = [\\n    (255, 0, 0),    # Red\\n    (0, 255, 0),    # Green\\n    (0, 0, 255),    # Blue\\n    (255, 255, 0),  # Yellow\\n    (255, 0, 255),  # Magenta\\n    (0, 255, 255)   # Cyan\\n]\\n\\nclass Gem:\\n    def __init__(self, color):\\n        self.color = color\\n        self.matched = False\\n\\nclass Grid:\\n    def __init__(self, width, height):\\n        self.width = width\\n        self.height = height\\n        # Each cell holds either None or a Gem instance\\n        self.cells = [[None for _ in range(width)] for _ in range(height)]\\n\\n    def is_valid_move(self, shape_matrix, offset_x, offset_y):\\n        for r, row in enumerate(shape_matrix):\\n            for c, cell in enumerate(row):\\n                if cell:\\n                    x = offset_x + c\\n                    y = offset_y + r\\n                    if x < 0 or x >= self.width or y < 0 or y >= self.height:\\n                        return False\\n                    if self.cells[y][x] is not None:\\n                        return False\\n        return True\\n\\n    def place_shape(self, shape_matrix, color, offset_x, offset_y):\\n        \\\"\\\"\\\"Lock a tetromino into the grid by creating Gem instances.\\\"\\\"\\\"\\n        for r, row in enumerate(shape_matrix):\\n            for c, cell in enumerate(row):\\n                if cell:\\n                    x = offset_x + c\\n                    y = offset_y + r\\n                    self.cells[y][x] = Gem(color)\\n\\n    def get_cell(self, x, y):\\n        return self.cells[y][x]\\n\\n    def clear_line(self, row_index):\\n        \\\"\\\"\\\"Remove a full line and push everything above down.\\\"\\\"\\\"\\n        del self.cells[row_index]\\n        self.cells.insert(0, [None for _ in range(self.width)])\\n\\n    def check_lines(self):\\n        \\\"\\\"\\\"Check for and clear full lines (bottom-up).\\\"\\\"\\\"\\n        lines_cleared = 0\\n        for row_index in reversed(range(self.height)):\\n            if all(self.cells[row_index]):\\n                self.clear_line(row_index)\\n                lines_cleared += 1\\n        return lines_cleared\\n\\n    def find_matches(self):\\n        \\\"\\\"\\\"Find and mark match-3 or more gems, return total matches marked.\\\"\\\"\\\"\\n        # Reset previous matched flags\\n        for row in self.cells:\\n            for gem in row:\\n                if gem:\\n                    gem.matched = False\\n\\n        total_matches = 0\\n        # Horizontal matches\\n        for r in range(self.height):\\n            c = 0\\n            while c < self.width:\\n                if self.cells[r][c] is None:\\n                    c += 1\\n                    continue\\n                color = self.cells[r][c].color\\n                run_len = 1\\n                for k in range(c+1, self.width):\\n                    if self.cells[r][k] and self.cells[r][k].color == color:\\n                        run_len += 1\\n                    else:\\n                        break\\n                if run_len >= 3:\\n                    for k in range(c, c+run_len):\\n                        self.cells[r][k].matched = True\\n                    total_matches += run_len\\n                c += run_len\\n\\n        # Vertical matches\\n        for c in range(self.width):\\n            r = 0\\n            while r < self.height:\\n                if self.cells[r][c] is None:\\n                    r += 1\\n                    continue\\n                color = self.cells[r][c].color\\n                run_len = 1\\n                for k in range(r+1, self.height):\\n                    if self.cells[k][c] and self.cells[k][c].color == color:\\n                        run_len += 1\\n                    else:\\n       