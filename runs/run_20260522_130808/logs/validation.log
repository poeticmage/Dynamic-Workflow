pe, x, y+1):\\n            y += 1\\n        else:\\n            grid.place_shape(current.shape, current.color, x, y)\\n            # next piece\\n            current = create_random_tetromino()\\n            x, y = GRID_WIDTH // 2 - len(current.shape[0]) // 2, 0\\n\\n        screen.fill((0,0,0))\\n        # Draw gems\\n        for row in range(GRID_HEIGHT):\\n            for col in range(GRID_WIDTH):\\n                gem = grid.get_cell(col, row)\\n                if gem:\\n                    pygame.draw.rect(screen, gem.color,\\n                                     (col*BLOCK_SIZE, row*BLOCK_SIZE,\\n                                      BLOCK_SIZE, BLOCK_SIZE))\\n        # Draw current tetromino\\n        for r, row in enumerate(current.shape):\\n            for c, cell in enumerate(row):\\n                if cell:\\n                    px, py = (x+c)*BLOCK_SIZE, (y+r)*BLOCK_SIZE\\n                    pygame.draw.rect(screen, current.color,\\n                                     (px, py, BLOCK_SIZE, BLOCK_SIZE))\\n\\n        pygame.display.flip()\\n\\n    pygame.quit()\\n```\\nTask task4:\\n  Objective: Develop scoring system: calculate base points and bonus points from line clears and match-3 chains.\\n  Result: ```python\\nimport pygame\\nimport random\\n\\n# Constants\\nGRID_WIDTH = 10\\nGRID_HEIGHT = 20\\nBLOCK_SIZE = 30\\nCOLORS = [\\n    (255, 0, 0),    # Red\\n    (0, 255, 0),    # Green\\n    (0, 0, 255),    # Blue\\n    (255, 255, 0),  # Yellow\\n    (255, 0, 255),  # Magenta\\n    (0, 255, 255)   # Cyan\\n]\\n\\nclass Gem:\\n    def __init__(self, color):\\n        self.color = color\\n        self.matched = False\\n\\nclass Grid:\\n    def __init__(self, width, height):\\n        self.width = width\\n        self.height = height\\n        # Each cell holds either None or a Gem instance\\n        self.cells = [[None for _ in range(width)] for _ in range(height)]\\n\\n    def is_valid_move(self, shape_matrix, offset_x, offset_y):\\n        for r, row in 