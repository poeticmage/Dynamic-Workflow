ion\\\": \\\"Record Candidate Responses\\\",\\n      \\\"details\\\": \\\"Document the candidate's answers and performance during the technical interview, saving the responses for future reference.\\\"\\n    },\\n    {\\n      \\\"step\\\": 12,\\n      \\\"action\\\": \\\"Calculate Overall Score\\\",\\n      \\\"details\\\": \\\"Calculate the overall score for the candidate based on the weighted scores for each category. Consider any qualitative observations or notes made during the interview.\\\"\\n    },\\n    {\\n      \\\"step\\\": 13,\\n      \\\"action\\\": \\\"Rank Candidate\\\",\\n      \\\"details\\\": \\\"Rank the candidate relative to other candidates based on their overall score and performance. Consider their strengths and weaknesses and their potential fit for the role.\\\"\\n    },\\n    {\\n      \\\"step\\\": 14,\\n      \\\"action\\\": \\\"Generate Final Evaluation Report\\\",\\n      \\\"details\\\": \\\"Compile the scored results and observations into a final evaluation report. Include the candidate's overall score, individual category scores, strengths and weaknesses, and a recommendation for next steps (e.g., move to next round, reject).\\\"\\n    },\\n    {\\n      \\\"step\\\": 15,\\n      \\\"action\\\": \\\"Send Emails As and When Needed\\\",\\n      \\\"details\\\": \\\"Send emails for scheduling interviews, providing feedback, or updating stakeholders on the hiring process\\\"\\n    }\\n  ]\\n}\\n```\",\n  \"timestamp\": \"2026-05-27T17:27:22.202497\"\n}"}
