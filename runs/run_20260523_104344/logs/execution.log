{"timestamp": "2026-05-23 10:47:44,328", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task0: ```python\nimport pygame\nimport random\n\n# Define colors\nCOLORS = {\n    \"red\": (255, 0, 0),\n    \"green\": (0, 255, 0),\n    \"blue\": (0, 0, 255),\n    \"yellow\": (255, 255, 0),\n    \"cyan\": (0, 255, 255),\n    \"magenta\": (255, 0, 255),\n    \"orange\": (255, 165, 0),\n    \"gray\": (128, 128, 128)\n}\n\nCOLOR_LIST = list(COLORS.keys())\n\n\n# Define Tetromino shapes and colors\nTETROMINOS = {\n    \"I\": {\"shape\": [[1, 1, 1, 1]], \"color\": \"cyan\"},\n    \"J\": {\"shape\": [[1, 0, 0], [1, 1, 1]], \"color\": \"blue\"},\n    \"L\": {\"shape\": [[0, 0, 1], [1, 1, 1]], \"color\": \"orange\"},\n    \"O\": {\"shape\": [[1, 1], [1, 1]], \"color\": \"yellow\"},\n    \"S\": {\"shape\": [[0, 1, 1], [1, 1, 0]], \"color\": \"green\"},\n    \"T\": {\"shape\": [[0, 1, 0], [1, 1, 1]], \"color\": \"magenta\"},\n    \"Z\": {\"shape\": [[1, 1, 0], [0, 1, 1]], \"color\": \"red\"}\n}\n\nclass Tetromino:\n    def __init__(self, x, y, shape, color):\n        self.x = x\n        self.y = y\n        self.shape = shape\n        self.color = color\n\n    def rotate(self):\n        # Rotate the shape 90 degrees clockwise\n        rotated_shape = list(zip(*self.shape[::-1]))\n        self.shape = [list(row) for row in rotated_shape]\n\n\n# Game grid dimensions\nGRID_WIDTH = 10\nGRID_HEIGHT = 20\n\n# Initialize the game grid with None values\ndef create_grid(width, height):\n    return [[None for _ in range(width)] for _ in range(height)]\n\n# Example of initializing the grid\ngrid = create_grid(GRID_WIDTH, GRID_HEIGHT)\n```"}
{"timestamp": "2026-05-23 10:47:44,328", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task1: ```python\nimport pygame\nimport random\n\n# Define colors\nCOLORS = {\n    \"red\": (255, 0, 0),\n    \"green\": (0, 255, 0),\n    \"blue\": (0, 0, 255),\n    \"yellow\": (255, 255, 0),\n    \"cyan\": (0, 255, 255),\n    \"magenta\": (255, 0, 255),\n    \"orange\": (255, 165, 0),\n    \"gray\": (128, 128, 128)\n}\n\n# Tetromino definitions\nTETROMINOS = {\n    \"I\": {\"shape\": [[1,1,1,1]],             \"color\": \"cyan\"},\n    \"J\": {\"shape\": [[1,0,0],[1,1,1]],       \"color\": \"blue\"},\n    \"L\": {\"shape\": [[0,0,1],[1,1,1]],       \"color\": \"orange\"},\n    \"O\": {\"shape\": [[1,1],[1,1]],           \"color\": \"yellow\"},\n    \"S\": {\"shape\": [[0,1,1],[1,1,0]],       \"color\": \"green\"},\n    \"T\": {\"shape\": [[0,1,0],[1,1,1]],       \"color\": \"magenta\"},\n    \"Z\": {\"shape\": [[1,1,0],[0,1,1]],       \"color\": \"red\"}\n}\n\nGRID_WIDTH  = 10\nGRID_HEIGHT = 20\n\nclass Gem:\n    \"\"\"A single colored gem in the grid.\"\"\"\n    def __init__(self, color_name):\n        self.color_name = color_name\n        self.rgb = COLORS[color_name]\n\nclass Tetromino:\n    def __init__(self, shape, color_name, x=3, y=0):\n        self.shape = [row[:] for row in shape]\n        self.color = color_name\n        self.x = x\n        self.y = y\n\n    def _rotate_shape(self):\n        return [list(row) for row in zip(*self.shape[::-1])]\n\n    def rotate(self, grid):\n        \"\"\"Attempt to rotate; revert if invalid.\"\"\"\n        old_shape = self.shape\n        self.shape = self._rotate_shape()\n        if not is_valid_position(self, grid):\n            self.shape = old_shape\n\n    def move(self, dx, grid):\n        \"\"\"Attempt horizontal move; revert if invalid.\"\"\"\n        old_x = self.x\n        self.x += dx\n        if not is_valid_position(self, grid):\n            self.x = old_x\n\n    def soft_drop(self, grid):\n        \"\"\"Move down one; return False if it would collide.\"\"\"\n        old_y = self.y\n        self.y += 1\n        if not is_valid_position(self, grid):\n            self.y = old_y\n            return False\n        return True\n\n    def hard_drop(self, grid):\n        \"\"\"Drop until collision; lock in place at the end.\"\"\"\n        while self.soft_drop(grid):\n            pass\n        return False  # indicates it landed\n\ndef create_grid(width, height):\n    \"\"\"Initialize empty grid of specified size.\"\"\"\n    return [[None for _ in range(width)] for _ in range(height)]\n\ndef is_valid_position(tetromino, grid):\n    \"\"\"Check if tetromino is within bounds and not colliding.\"\"\"\n    for dy, row in enumerate(tetromino.shape):\n        for dx, cell in enumerate(row):\n            if cell:\n                x = tetromino.x + dx\n                y = tetromino.y + dy\n                if x < 0 or x >= GRID_WIDTH or y < 0 or y >= GRID_HEIGHT:\n                    return False\n                if grid[y][x] is not None:\n                    return False\n    return True\n\ndef lock_tetromino(tetromino, grid):\n    \"\"\"Convert all occupied cells of the tetromino into Gems in the grid.\"\"\"\n    for dy, row in enumerate(tetromino.shape):\n        for dx, cell in enumerate(row):\n            if cell:\n                x = tetromino.x + dx\n                y = tetromino.y + dy\n                if 0 <= x < GRID_WIDTH and 0 <= y < GRID_HEIGHT:\n                    grid[y][x] = Gem(tetromino.color)\n\nclass TetrominoManager:\n    \"\"\"Manages active tetromino, spawning, and locking.\"\"\"\n    def __init__(self, grid):\n        self.grid = grid\n        self.current = self._spawn_new()\n\n    def _spawn_new(self):\n        key = random.choice(list(TETROMINOS.keys()))\n        data = TETROMINOS[key]\n        # center initial x so shape appears roughly in middle\n        start_x = (GRID_WIDTH - len(data[\"shape\"][0])) // 2\n        return Tetromino(data[\"shape\"], data[\"color\"], x=start_x, y=0)\n\n    def update(self, command=None):\n        \"\"\"\n        command: one of 'left','right','rotate','soft_drop','hard_drop'\n        Returns True if piece locked (and a new spawn occurred).\n        \"\"\"\n        if command == 'left':\n            self.current.move(-1, self.grid)\n        elif command == 'right':\n            self.current.move(1, self.grid)\n        elif command == 'rotate':\n            self.current.rotate(self.grid)\n        elif command == 'soft_drop':\n            landed = not self.current.soft_drop(self.grid)\n            if landed:\n                lock_tetromino(self.current, self.grid)\n                self.current = self._spawn_new()\n                return True\n        elif command == 'hard_drop':\n            self.current.hard_drop(self.grid)\n            lock_tetromino(self.current, self.grid)\n            self.current = self._spawn_new()\n            return True\n        else:\n            # gravity tick\n            landed = not self.current.soft_drop(self.grid)\n            if landed:\n                lock_tetromino(self.current, self.grid)\n                self.current = self._spawn_new()\n                return True\n        return False\n```"}
{"timestamp": "2026-05-23 10:47:44,329", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task2: ```python\nimport pygame\nimport random\n\n# Define colors\nCOLORS = {\n    \"red\": (255, 0, 0),\n    \"green\": (0, 255, 0),\n    \"blue\": (0, 0, 255),\n    \"yellow\": (255, 255, 0),\n    \"cyan\": (0, 255, 255),\n    \"magenta\": (255, 0, 255),\n    \"orange\": (255, 165, 0),\n    \"gray\": (128, 128, 128)\n}\n\n# Tetromino definitions\nTETROMINOS = {\n    \"I\": {\"shape\": [[1,1,1,1]],             \"color\": \"cyan\"},\n    \"J\": {\"shape\": [[1,0,0],[1,1,1]],       \"color\": \"blue\"},\n    \"L\": {\"shape\": [[0,0,1],[1,1,1]],       \"color\": \"orange\"},\n    \"O\": {\"shape\": [[1,1],[1,1]],           \"color\": \"yellow\"},\n    \"S\": {\"shape\": [[0,1,1],[1,1,0]],       \"color\": \"green\"},\n    \"T\": {\"shape\": [[0,1,0],[1,1,1]],       \"color\": \"magenta\"},\n    \"Z\": {\"shape\": [[1,1,0],[0,1,1]],       \"color\": \"red\"}\n}\n\nGRID_WIDTH  = 10\nGRID_HEIGHT = 20\n\nclass Gem:\n    \"\"\"A single colored gem in the grid.\"\"\"\n    def __init__(self, color_name):\n        self.color_name = color_name\n        self.rgb = COLORS[color_name]\n\nclass Tetromino:\n    def __init__(self, shape, color_name, x=3, y=0):\n        self.shape = [row[:] for row in shape]\n        self.color = color_name\n        self.x = x\n        self.y = y\n\n    def _rotate_shape(self):\n        return [list(row) for row in zip(*self.shape[::-1])]\n\n    def rotate(self, grid):\n        \"\"\"Attempt to rotate; revert if invalid.\"\"\"\n        old_shape = self.shape\n        self.shape = self._rotate_shape()\n        if not is_valid_position(self, grid):\n            self.shape = old_shape\n\n    def move(self, dx, grid):\n        \"\"\"Attempt horizontal move; revert if invalid.\"\"\"\n        old_x = self.x\n        self.x += dx\n        if not is_valid_position(self, grid):\n            self.x = old_x\n\n    def soft_drop(self, grid):\n        \"\"\"Move down one; return False if it would collide.\"\"\"\n        old_y = self.y\n        self.y += 1\n        if not is_valid_position(self, grid):\n            self.y = old_y\n            return False\n        return True\n\n    def hard_drop(self, grid):\n        \"\"\"Drop until collision; lock in place at the end.\"\"\"\n        while self.soft_drop(grid):\n            pass\n        return False  # indicates it landed\n\ndef create_grid(width, height):\n    \"\"\"Initialize empty grid of specified size.\"\"\"\n    return [[None for _ in range(width)] for _ in range(height)]\n\ndef is_valid_position(tetromino, grid):\n    \"\"\"Check if tetromino is within bounds and not colliding.\"\"\"\n    for dy, row in enumerate(tetromino.shape):\n        for dx, cell in enumerate(row):\n            if cell:\n                x = tetromino.x + dx\n                y = tetromino.y + dy\n                if x < 0 or x >= GRID_WIDTH or y < 0 or y >= GRID_HEIGHT:\n                    return False\n                if grid[y][x] is not None:\n                    return False\n    return True\n\ndef lock_tetromino(tetromino, grid):\n    \"\"\"Convert all occupied cells of the tetromino into Gems in the grid.\"\"\"\n    for dy, row in enumerate(tetromino.shape):\n        for dx, cell in enumerate(row):\n            if cell:\n                x = tetromino.x + dx\n                y = tetromino.y + dy\n                if 0 <= x < GRID_WIDTH and 0 <= y < GRID_HEIGHT:\n                    grid[y][x] = Gem(tetromino.color)\n\nclass TetrominoManager:\n    \"\"\"Manages active tetromino, spawning, and locking.\"\"\"\n    def __init__(self, grid):\n        self.grid = grid\n        self.current = self._spawn_new()\n\n    def _spawn_new(self):\n        key = random.choice(list(TETROMINOS.keys()))\n        data = TETROMINOS[key]\n        # center initial x so shape appears roughly in middle\n        start_x = (GRID_WIDTH - len(data[\"shape\"][0])) // 2\n        return Tetromino(data[\"shape\"], data[\"color\"], x=start_x, y=0)\n\n    def update(self, command=None):\n        \"\"\"\n        command: one of 'left','right','rotate','soft_drop','hard_drop'\n        Returns True if piece locked (and a new spawn occurred).\n        \"\"\"\n        if command == 'left':\n            self.current.move(-1, self.grid)\n        elif command == 'right':\n            self.current.move(1, self.grid)\n        elif command == 'rotate':\n            self.current.rotate(self.grid)\n        elif command == 'soft_drop':\n            landed = not self.current.soft_drop(self.grid)\n            if landed:\n                lock_tetromino(self.current, self.grid)\n                self.current = self._spawn_new()\n                return True\n        elif command == 'hard_drop':\n            self.current.hard_drop(self.grid)\n            lock_tetromino(self.current, self.grid)\n            self.current = self._spawn_new()\n            return True\n        else:\n            # gravity tick\n            landed = not self.current.soft_drop(self.grid)\n            if landed:\n                lock_tetromino(self.current, self.grid)\n                self.current = self._spawn_new()\n                return True\n        return False\n\ndef check_line_clears(grid):\n    \"\"\"Check for and clear full horizontal lines.\"\"\"\n    lines_to_clear = []\n    for i, row in enumerate(grid):\n        if all(row):  # all cells are gems\n            lines_to_clear.append(i)\n\n    for row_index in lines_to_clear:\n        del grid[row_index]\n        grid.insert(0, [None] * GRID_WIDTH)  # Add empty row at top\n    return len(lines_to_clear)  # Return number of lines cleared\n\ndef check_match_3(grid):\n    \"\"\"Check for and clear Bejeweled-style match-3.\"\"\"\n    matches = []\n\n    # Horizontal matches\n    for y in range(GRID_HEIGHT):\n        for x in range(GRID_WIDTH - 2):\n            if (grid[y][x] is not None and\n                grid[y][x] == grid[y][x+1] and\n                grid[y][x] == grid[y][x+2]):\n                matches.append(((x, y), (x+1, y), (x+2, y)))\n\n    # Vertical matches\n    for x in range(GRID_WIDTH):\n        for y in range(GRID_HEIGHT - 2):\n            if (grid[y][x] is not None and\n                grid[y][x] == grid[y+1][x] and\n                grid[y][x] == grid[y+2][x]):\n                matches.append(((x, y), (x, y+1), (x, y+2)))\n\n    # Remove duplicates and clear matches\n    cleared_positions = set()\n    for match in matches:\n        for x, y in match:\n            cleared_positions.add((x, y))\n\n    # Convert to list for easier manipulation\n    cleared_positions = list(cleared_positions)\n\n    # Clear the matched gems from the grid\n    for x, y in cleared_positions:\n        grid[y][x] = None\n\n    # Apply gravity to move gems down\n    for x in range(GRID_WIDTH):\n        # Move empty spaces to the top\n        empty_count = 0\n        for y in range(GRID_HEIGHT):\n            if grid[y][x] is None:\n                empty_count += 1\n            elif empty_count > 0:\n                grid[y - empty_count][x] = grid[y][x]\n                grid[y][x] = None\n\n    return len(cleared_positions)\n\ndef calculate_score(lines_cleared, gems_cleared, chain_reaction_level):\n    \"\"\"Calculate score based on lines cleared and gems cleared.\"\"\"\n    line_clear_score = lines_cleared * (100 * lines_cleared)  # Tetris scoring\n    gem_clear_score  = gems_cleared * 50  # Bejeweled scoring\n    chain_bonus      = chain_reaction_level * 25 # Bonus for chain reactions\n\n    return line_clear_score + gem_clear_score + chain_bonus\n```"}
