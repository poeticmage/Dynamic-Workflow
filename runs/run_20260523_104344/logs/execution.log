x\n\n    def soft_drop(self, grid):\n        \"\"\"Move down one; return False if it would collide.\"\"\"\n        old_y = self.y\n        self.y += 1\n        if not is_valid_position(self, grid):\n            self.y = old_y\n            return False\n        return True\n\n    def hard_drop(self, grid):\n        \"\"\"Drop until collision; lock in place at the end.\"\"\"\n        while self.soft_drop(grid):\n            pass\n        return False  # indicates it landed\n\ndef create_grid(width, height):\n    \"\"\"Initialize empty grid of specified size.\"\"\"\n    return [[None for _ in range(width)] for _ in range(height)]\n\ndef is_valid_position(tetromino, grid):\n    \"\"\"Check if tetromino is within bounds and not colliding.\"\"\"\n    for dy, row in enumerate(tetromino.shape):\n        for dx, cell in enumerate(row):\n            if cell:\n                x = tetromino.x + dx\n                y = tetromino.y + dy\n                if x < 0 or x >= GRID_WIDTH or y < 0 or y >= GRID_HEIGHT:\n                    return False\n                if grid[y][x] is not None:\n                    return False\n    return True\n\ndef lock_tetromino(tetromino, grid):\n    \"\"\"Convert all occupied cells of the tetromino into Gems in the grid.\"\"\"\n    for dy, row in enumerate(tetromino.shape):\n        for dx, cell in enumerate(row):\n            if cell:\n                x = tetromino.x + dx\n                y = tetromino.y + dy\n                if 0 <= x < GRID_WIDTH and 0 <= y < GRID_HEIGHT:\n                    grid[y][x] = Gem(tetromino.color)\n\nclass TetrominoManager:\n    \"\"\"Manages active tetromino, spawning, and locking.\"\"\"\n    def __init__(self, grid):\n        self.grid = grid\n        self.current = self._spawn_new()\n\n    def _spawn_new(self):\n        key = random.choice(list(TETROMINOS.keys()))\n        data = TETROMINOS[key]\n        # center initial x so shape appears roughly in middle\n        start_x = (GRID_WIDTH - len(data[\"shape\"][0])) // 2\n        return Tetromino(data[\"shape\"], data[\"color\"], x=start_x, y=0)\n\n    def update(self, command=None):\n        \"\"\"\n        command: one of 'left','right','rotate','soft_drop','hard_drop'\n        Returns True if piece locked (and a new spawn occurred).\n        \"\"\"\n        if command == 'left':\n            self.current.move(-1, self.grid)\n        elif command == 'right':\n            self.current.move(1, self.grid)\n        elif command == 'rotate':\n            self.current.rotate(self.grid)\n        elif command == 'soft_drop':\n            landed = not self.current.soft_drop(self.grid)\n            if landed:\n                lock_tetromino(self.current, self.grid)\n                self.current = self._spawn_new()\n                return True\n        elif command == 'hard_drop':\n            self.current.hard_drop(self.grid)\n            lock_tetromino(self.current, self.grid)\n            self.current = self._spawn_new()\n            return True\n        else:\n            # gravity tick\n            landed = not self.current.soft_drop(self.grid)\n            if landed:\n                lock_tetromino(self.current, self.grid)\n                self.current = self._spawn_new()\n                return True\n        return False\n\ndef handle_input(event, tetromino_manager):\n    \"\"\"Handles keyboard input for controlling the tetromino.\"\"\"\n    if event.type == pygame.KEYDOWN:\n        if event.key == pygame.K_LEFT:\n            tetromino_manager.update('left')\n        elif event.key == pygame.K_RIGHT:\n            tetromino_manager.update('right')\n        elif event.key == pygame.K_UP:\n            tetromino_manager.update('rotate')\n        elif event.key == pygame.K_DOWN:\n            tetromino_manager.update('soft_drop')\n        elif event.key == pygame.K_SPACE:\n            tetromino_manager.update('hard_drop')\n```"}
{"timestamp": "2026-05-23 10:47:44,329", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task4: ```python\nimport pygame\nimport random\nimport time\n\n# Define colors\nCOLORS = {\n    \"red\": (255, 0, 0),\n    \"green\": (0, 255, 0),\n    \"blue\": (0, 0, 255),\n    \"yellow\": (255, 255, 0),\n    \"cyan\": (0, 255, 255),\n    \"magenta\": (255, 0, 255),\n    \"orange\": (255, 165, 0),\n    \"gray\": (128, 128, 128),\n    \"white\": (255, 255, 255),\n    \"black\": (0, 0, 0),\n}\n\n# Define Tetromino shapes and colors\nTETROMINOS = {\n    \"I\": {\"shape\": [[1, 1, 1, 1]], \"color\": \"cyan\"},\n    \"J\": {\"shape\": [[1, 0, 0], [1, 1, 1]], \"color\": \"blue\"},\n    \"L\": {\"shape\": [[0, 0, 1], [1, 1, 1]], \"color\": \"orange\"},\n    \"O\": {\"shape\": [[1, 1], [1, 1]], \"color\": \"yellow\"},\n    \"S\": {\"shape\": [[0, 1, 1], [1, 1, 0]], \"color\": \"green\"},\n    \"T\": {\"shape\": [[0, 1, 0], [1, 1, 1]], \"color\": \"magenta\"},\n    \"Z\": {\"shape\": [[1, 1, 0], [0, 1, 1]], \"color\": \"red\"}\n}\n\n# Game grid dimensions\nGRID_WIDTH = 10\nGRID_HEIGHT = 20\nCELL_SIZE = 30\nSCREEN_WIDTH = GRID_WIDTH * CELL_SIZE + 200\nSCREEN_HEIGHT = GRID_HEIGHT * CELL_SIZE\n\nclass Gem:\n    \"\"\"A single colored gem in the grid.\"\"\"\n    def __init__(self, color_name):\n        self.color_name = color_name\n        self.rgb = COLORS[color_name]\n\nclass Tetromino:\n    def __init__(self, shape, color_name, x=3, y=0):\n        self.shape = [row[:] for row in shape]\n        self.color = color_name\n        self.x = x\n        self.y = y\n\n    def _rotate_shape(self):\n        return [list(row) for row in zip(*self.shape[::-1])]\n\n    def rotate(self, grid):\n        old_shape = self.shape\n        self.shape = self._rotate_shape()\n        if not is_valid_position(self, grid):\n            self.shape = old_shape\n\n    def move(self, dx, grid):\n        old_x = self.x\n        self.x += dx\n        if not is_valid_position(self, grid):\n            self.x = old_x\n\n    def soft_drop(self, grid):\n        old_y = self.y\n        self.y += 1\n        if not is_valid_position(self, grid):\n            self.y = old_y\n            return False\n        return True\n\n    def hard_drop(self, grid):\n        while self.soft_drop(grid):\n            pass\n\ndef create_grid(width, height):\n    return [[None for _ in range(width)] for _ in range(height)]\n\ndef is_valid_position(tetromino, grid):\n    for dy, row in enumerate(tetromino.shape):\n        for dx, cell in enumerate(row):\n            if cell:\n                x = tetromino.x + dx\n                y = tetromino.y + dy\n                if x < 0 or x >= GRID_WIDTH or y < 0 or y >= GRID_HEIGHT:\n                    return False\n                if grid[y][x] is not None:\n                    return False\n    return True\n\ndef lock_tetromino(tetromino, grid):\n    for dy, row in enumerate(tetromino.shape):\n        for dx, cell in enumerate(row):\n            if cell:\n                x = tetromino.x + dx\n                y = tetromino.y + dy\n                if 0 <= x < GRID_WIDTH and 0 <= y < GRID_HEIGHT:\n                    grid[y][x] = Gem(tetromino.color)\n\nclass TetrominoManager:\n    def __init__(self, grid):\n        self.grid = grid\n        self.current = self._spawn_new()\n        self.next = self._spawn_new()\n\n    def _spawn_new(self):\n        key = random.choice(list(TETROMINOS.keys()))\n        data = TETROMINOS[key]\n        start_x = (GRID_WIDTH - len(data[\"shape\"][0])) // 2\n        return Tetromino(data[\"shape\"], data[\"color\"], x=start_x, y=0)\n\n    def update(self, command=None):\n        if command == 'left':\n            self.current.move(-1, self.grid)\n        elif command == 'right':\n            self.current.move(1, self.grid)\n        elif command == 'rotate':\n            self.current.rotate(self.grid)\n        elif command == 'soft_drop':\n            landed = not self.current.soft_drop(self.grid)\n            if landed:\n                lock_tetromino(self.current, self.grid)\n                self.current = self.next\n                self.next = self._spawn_new()\n                return True\n        elif command == 'hard_drop':\n            self.current.hard_drop(self.grid)\n            lock_tetromino(self.current, self.grid)\n            self.current = self.next\n            self.next = self._spawn_new()\n            return True\n        else:\n            # gravity tick\n            landed = not self.current.soft_drop(self.grid)\n            if landed:\n                lock_tetromino(self.current, self.grid)\n                self.current = self.next\n                self.next = self._spawn_new()\n                return True\n        return False\n\ndef check_line_clears(grid):\n    lines_to_clear = [i for i, row in enumerate(grid) if all(row)]\n    for row_index in reversed(lines_to_clear):\n        del grid[row_index]\n        grid.insert(0, [None] * GRID_WIDTH)\n    return len(lines_to_clear)\n\ndef check_match_3(grid):\n    matches = set()\n    # Horizontal\n    for y in range(GRID_HEIGHT):\n        for x in range(GRID_WIDTH - 2):\n            g = grid[y][x]\n            if g and grid[y][x+1] and grid[y][x+2] and \\\n               g.color_name == grid[y][x+1].color_name == grid[y][x+2].color_name:\n                matches.update({(x,y),(x+1,y),(x+2,y)})\n    # Vertical\n    for x in range(GRID_WIDTH):\n        for y in range(GRID_HEIGHT - 2):\n            g = grid[y][x]\n            if g and grid[y+1][x] and grid[y+2][x] and \\\n               g.color_name == grid[y+1][x].color_name == grid[y+2][x].color_name:\n                matches.update({(x,y),(x,y+1),(x,y+2)})\n    # Clear matches\n    for (x,y) in matches:\n        grid[y][x] = None\n    # Gravity drop\n    for x in range(GRID_WIDTH):\n        column = [grid[y][x] for y in range(GRID_HEIGHT) if grid[y][x] is not None]\n        empties = [None] * (GRID_HEIGHT - len(column))\n        for y in range(GRID_HEIGHT):\n            grid[y][x] = empties[y] if y < len(empties) else column[y - len(empties)]\n    return len(matches)\n\ndef calculate_score(lines_cleared, gems_cleared, chain_level):\n    line_score = lines_cleared * 100 * lines_cleared\n    gem_score = gems_cleared * 50\n    chain_bonus = chain_level * 25\n    return line_score + gem_score + chain_bonus\n\ndef draw_grid(screen, grid):\n    for y in range(GRID_HEIGHT):\n        for x in range(GRID_WIDTH):\n            gem = grid[y][x]\n            color = gem.rgb if gem else COLORS[\"black\"]\n            rect = (x*CELL_SIZE, y*CELL_SIZE, CELL_SIZE, CELL_SIZE)\n            pygame.draw.rect(screen, color, rect)\n            pygame.draw.rect(screen, COLORS[\"gray\"], rect, 1)\n\ndef draw_tetromino(screen, tetro):\n    for dy, row in enumerate(tetro.shape):\n        for dx, cell in enumerate(row):\n            if cell:\n                x = tetro.x + dx\n                y = tetro.y + dy\n                rect = (x*CELL_SIZE, y*CELL_SIZE, CELL_SIZE, CELL_SIZE)\n                pygame.draw.rect(screen, COLORS[tetro.color], rect)\n                pygame.draw.rect(screen, COLORS[\"gray\"], rect, 1)\n\ndef draw_next_tetromino(screen, tetro, px, py):\n    for dy, row in enumerate(tetro.shape):\n        for dx, cell in enumerate(row):\n            if cell:\n                rect = (px + dx*CELL_SIZE, py + dy*CELL_SIZE, CELL_SIZE, CELL_SIZE)\n                pygame.draw.rect(screen, COLORS[tetro.color], rect)\n                pygame.draw.rect(screen, COLORS[\"gray\"], rect, 1)\n\ndef draw_score(screen, score):\n    font = pygame.font.Font(None, 36)\n    text = font.render(f\"Score: {score}\", True, COLORS[\"white\"])\n    screen.blit(text, (GRID_WIDTH*CELL_SIZE + 20, 20))\n\ndef main():\n    pygame.init()\n    screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\n    pygame.display.set_caption(\"Tetris-Bejeweled Fusion\")\n    clock = pygame.time.Clock()\n\n    grid = create_grid(GRID_WIDTH, GRID_HEIGHT)\n    manager = TetrominoManager(grid)\n    score = 0\n    fall_speed = 0.5    # blocks per second\n    last_fall = time.time()\n    game_over = False\n\n    # Key repeat settings\n    pygame.key.set_repeat(250, 50)  # delay, interval\n\n    while True:\n        screen.fill(COLORS[\"black\"])\n        for event in pygame.event.get():\n            if event.type == pygame.QUIT:\n                pygame.quit()\n                return\n            if event.type == pygame.KEYDOWN and not game_over:\n                if event.key == pygame.K_LEFT:\n                    manager.update('left')\n                elif event.key == pygame.K_RIGHT:\n                    manager.update('right')\n                elif event.key == pygame.K_UP:\n                    manager.update('rotate')\n                elif event.key == pygame.K_DOWN:\n                    manager.update('soft_drop')\n                elif event.key == pygame.K_SPACE:\n                    manager.update('hard_drop')\n\n        if not game_over and time.time() - last_fall > 1/fall_speed:\n            landed = manager.update()\n            if landed:\n                # Tetris line clears\n                lines = check_line_clears(grid)\n                # Bejeweled chain reactions\n                chain = 0\n                total_gems = 0\n                while True:\n                    gems = check_match_3(grid)\n                    if gems == 0:\n                        break\n                    chain += 1\n                    total_gems += gems\n                score += calculate_score(lines, total_gems, chain)\n            last_fall = time.time()\n            # Check game over\n            if any(grid[0]):\n                game_over = True\n\n        # Draw everything\n        draw_grid(screen, grid)\n        draw_tetromino(screen, manager.current)\n        draw_score(screen, score)\n\n        # Next piece preview\n        font = pygame.font.Font(None, 24)\n        txt = font.render(\"Next Piece:\", True, COLORS[\"white\"])\n        screen.blit(txt, (GRID_WIDTH*CELL_SIZE + 20, 80))\n        preview_x = GRID_WIDTH*CELL_SIZE + 20\n        preview_y = 110\n        draw_next_tetromino(screen, manager.next, preview_x, preview_y)\n\n        if game_over:\n            font = pygame.font.Font(None, 48)\n            over = font.render(\"Game Over!\", True, COLORS[\"white\"])\n            rect = over.get_rect(center=(SCREEN_WIDTH//2, SCREEN_HEIGHT//2))\n            screen.blit(over, rect)\n\n        pygame.display.flip()\n        clock.tick(60)\n\nif __name__ == \"__main__\":\n    main()\n```"}
{"timestamp": "2026-05-23 10:47:44,329", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task5: ```python\nimport pygame\nimport random\n\n# Constants\nGRID_WIDTH = 10\nGRID_HEIGHT = 20\nCELL_SIZE = 30\nSCREEN_WIDTH = GRID_WIDTH * CELL_SIZE + 200  # Increased width for preview\nSCREEN_HEIGHT = GRID_HEIGHT * CELL_SIZE\nWHITE = (255, 255, 255)\nBLACK = (0, 0, 0)\nGRAY = (128, 128, 128)\nGEM_COLORS = [(255, 0, 0), (0, 255, 0), (0, 0, 255), (255, 255, 0), (255, 0, 255), (0, 255, 255)]  # Example colors\n\nTETROMINO_TYPES = [\n    [[1, 1, 1, 1]],  # I\n    [[1, 1, 1], [0, 0, 1]],  # J\n    [[1, 1, 1], [1, 0, 0]],  # L\n    [[1, 1], [1, 1]],  # O\n    [[0, 1, 1], [1, 1, 0]],  # S\n    [[1, 1, 0], [0, 1, 1]],  # Z\n    [[0, 1, 0], [1, 1, 1]]   # T\n]\n\nclass GameState:\n    def __init__(self):\n        self.grid = [[None for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]\n        self.current_piece = self.new_piece()\n        self.next_piece = self.new_piece()  # Store the next piece\n        self.score = 0\n        self.game_over = False\n\n    def new_piece(self):\n        tetromino_type = random.choice(TETROMINO_TYPES)\n        color = random.choice(GEM_COLORS)\n        return Tetromino(tetromino_type, color, GRID_WIDTH // 2 - len(tetromino_type[0]) // 2, 0)\n\n    def update(self):\n        if not self.game_over:\n            if self.can_move_down():\n                self.current_piece.y += 1\n            else:\n                self.lock_piece()\n                self.process_matches()\n                if not self.game_over:\n                    self.current_piece = self.next_piece  # Use the next piece\n                    self.next_piece = self.new_piece()      # Generate a new next piece\n                else:\n                    print(\"Game Over!\")\n\n    def can_move_down(self):\n        for row in range(len(self.current_piece.shape)):\n            for col in range(len(self.current_piece.shape[row])):\n                if self.current_piece.shape[row][col]:\n                    x = self.current_piece.x + col\n                    y = self.current_piece.y + row\n                    if y == GRID_HEIGHT - 1 or (y + 1 < GRID_HEIGHT and self.grid[y + 1][x] is not None):\n                        return False\n        return True\n\n    def lock_piece(self):\n        for row in range(len(self.current_piece.shape)):\n            for col in range(len(self.current_piece.shape[row])):\n                if self.current_piece.shape[row][col]:\n                    x = self.current_piece.x + col\n                    y = self.current_piece.y + row\n                    if y < 0:\n                        self.game_over = True\n                        return\n                    self.grid[y][x] = self.current_piece.color\n        self.clear_lines()\n\n    def clear_lines(self):\n        lines_to_clear = []\n        for y in range(GRID_HEIGHT):\n            if all(self.grid[y][x] is not None for x in range(GRID_WIDTH)):\n                lines_to_clear.append(y)\n\n        for line in lines_to_clear:\n            del self.grid[line]\n            self.grid.insert(0, [None for _ in range(GRID_WIDTH)])\n            self.score += 100  # Add score for clearing lines\n\n\n    def process_matches(self):\n        # Placeholder for Bejeweled-style match processing\n        #  Implement the logic to detect and clear 3+ gem matches.\n        pass\n\n    def move_left(self):\n        if self.can_move_sideways(-1):\n            self.current_piece.x -= 1\n\n    def move_right(self):\n        if self.can_move_sideways(1):\n            self.current_piece.x += 1\n            \n    def can_move_sideways(self, direction):\n        for row in range(len(self.current_piece.shape)):\n            for col in range(len(self.current_piece.shape[row])):\n                if self.current_piece.shape[row][col]:\n                    x = self.current_piece.x + col + direction\n                    y = self.current_piece.y + row\n                    if x < 0 or x >= GRID_WIDTH or (self.grid[y][x] is not None):\n                        return False\n        return True\n\n    def rotate(self):\n        rotated_shape = list(zip(*self.current_piece.shape[::-1]))\n        \n        # Check for collisions after rotation\n        for row in range(len(rotated_shape)):\n            for col in range(len(rotated_shape[row])):\n                if rotated_shape[row][col]:\n                    x = self.current_piece.x + col\n                    y = self.current_piece.y + row\n                    if x < 0 or x >= GRID_WIDTH or y >= GRID_HEIGHT or self.grid[y][x] is not None:\n                        return  # Cannot rotate\n\n        self.current_piece.shape = rotated_shape\n\nclass Tetromino:\n    def __init__(self, shape, color, x, y):\n        self.shape = shape\n        self.color = color\n        self.x = x\n        self.y = y\n```"}
{"timestamp": "2026-05-23 10:47:44,330", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task6: ```python\nimport pygame\nimport random\nimport time\n\n# Define colors\nCOLORS = {\n    \"red\": (255, 0, 0),\n    \"green\": (0, 255, 0),\n    \"blue\": (0, 0, 255),\n    \"yellow\": (255, 255, 0),\n    \"cyan\": (0, 255, 255),\n    \"magenta\": (255, 0, 255),\n    \"orange\": (255, 165, 0),\n    \"gray\": (128, 128, 128),\n    \"white\": (255, 255, 255),\n    \"black\": (0, 0, 0),\n}\n\n# Define Tetromino shapes and colors\nTETROMINOS = {\n    \"I\": {\"shape\": [[1, 1, 1, 1]],             \"color\": \"cyan\"},\n    \"J\": {\"shape\": [[1, 0, 0], [1, 1, 1]],     \"color\": \"blue\"},\n    \"L\": {\"shape\": [[0, 0, 1], [1, 1, 1]],     \"color\": \"orange\"},\n    \"O\": {\"shape\": [[1, 1], [1, 1]],           \"color\": \"yellow\"},\n    \"S\": {\"shape\": [[0, 1, 1], [1, 1, 0]],     \"color\": \"green\"},\n    \"T\": {\"shape\": [[0, 1, 0], [1, 1, 1]],     \"color\": \"magenta\"},\n    \"Z\": {\"shape\": [[1, 1, 0], [0, 1, 1]],     \"color\": \"red\"},\n}\n\nGRID_WIDTH = 10\nGRID_HEIGHT = 20\nCELL_SIZE = 30\nSCREEN_WIDTH = GRID_WIDTH * CELL_SIZE + 200\nSCREEN_HEIGHT = GRID_HEIGHT * CELL_SIZE\n\nclass Gem:\n    def __init__(self, color_name):\n        self.color_name = color_name\n        self.rgb = COLORS[color_name]\n\nclass Tetromino:\n    def __init__(self, shape, color_name, x=3, y=0):\n        self.shape = [row[:] for row in shape]\n        self.color = color_name\n        self.x = x\n        self.y = y\n\n    def _rotate_shape(self):\n        return [list(row) for row in zip(*self.shape[::-1])]\n\n    def rotate(self, grid):\n        old = self.shape\n        self.shape = self._rotate_shape()\n        if not is_valid_position(self, grid):\n            self.shape = old\n\n    def move(self, dx, grid):\n        self.x += dx\n        if not is_valid_position(self, grid):\n            self.x -= dx\n\n    def soft_drop(self, grid):\n        self.y += 1\n        if not is_valid_position(self, grid):\n            self.y -= 1\n            return False\n        return True\n\n    def hard_drop(self, grid):\n        while self.soft_drop(grid):\n            pass\n\ndef create_grid(width, height):\n    return [[None for _ in range(width)] for _ in range(height)]\n\ndef is_valid_position(tetromino, grid):\n    for dy, row in enumerate(tetromino.shape):\n        for dx, cell in enumerate(row):\n            if cell:\n                x, y = tetromino.x + dx, tetromino.y + dy\n                if x < 0 or x >= GRID_WIDTH or y < 0 or y >= GRID_HEIGHT:\n                    return False\n                if grid[y][x] is not None:\n                    return False\n    return True\n\ndef lock_tetromino(tetromino, grid):\n    for dy, row in enumerate(tetromino.shape):\n        for dx, cell in enumerate(row):\n            if cell:\n                x, y = tetromino.x + dx, tetromino.y + dy\n                if 0 <= x < GRID_WIDTH and 0 <= y < GRID_HEIGHT:\n                    grid[y][x] = Gem(tetromino.color)\n\nclass TetrominoManager:\n    def __init__(self, grid):\n        self.grid = grid\n        self.current = self._spawn_new()\n        self.next = self._spawn_new()\n\n    def _spawn_new(self):\n        key = random.choice(list(TETROMINOS.keys()))\n        data = TETROMINOS[key]\n        start_x = (GRID_WIDTH - len(data[\"shape\"][0])) // 2\n        return Tetromino(data[\"shape\"], data[\"color\"], x=start_x, y=0)\n\n    def update(self, command=None):\n        landed = False\n        if command == 'left':\n            self.current.move(-1, self.grid)\n        elif command == 'right':\n            self.current.move(1, self.grid)\n        elif command == 'rotate':\n            self.current.rotate(self.grid)\n        elif command == 'soft_drop':\n            if not self.current.soft_drop(self.grid):\n                landed = True\n        elif command == 'hard_drop':\n            self.current.hard_drop(self.grid)\n            landed = True\n        else:\n            # gravity tick\n            if not self.current.soft_drop(self.grid):\n                landed = True\n\n        if landed:\n            lock_tetromino(self.current, self.grid)\n            self.current = self.next\n            self.next = self._spawn_new()\n        return landed\n\ndef check_line_clears(grid):\n    to_clear = [i for i, row in enumerate(grid) if all(row)]\n    for i in reversed(to_clear):\n        del grid[i]\n        grid.insert(0, [None] * GRID_WIDTH)\n    return len(to_clear)\n\ndef check_match_3(grid):\n    matches = set()\n    # horizontal\n    for y in range(GRID_HEIGHT):\n        for x in range(GRID_WIDTH - 2):\n            g = grid[y][x]\n            if g and grid[y][x+1] and grid[y][x+2] and \\\n               g.color_name == grid[y][x+1].color_name == grid[y][x+2].color_name:\n                matches |= {(x,y), (x+1,y), (x+2,y)}\n    # vertical\n    for x in range(GRID_WIDTH):\n        for y in range(GRID_HEIGHT - 2):\n            g = grid[y][x]\n            if g and grid[y+1][x] and grid[y+2][x] and \\\n               g.color_name == grid[y+1][x].color_name == grid[y+2][x].color_name:\n                matches |= {(x,y), (x,y+1), (x,y+2)}\n    for (x,y) in matches:\n        grid[y][x] = None\n    # gravity\n    for col in range(GRID_WIDTH):\n        column = [grid[r][col] for r in range(GRID_HEIGHT) if grid[r][col]]\n        empties = [None] * (GRID_HEIGHT - len(column))\n        for r in range(GRID_HEIGHT):\n            grid[r][col] = empties[r] if r < len(empties) else column[r - len(empties)]\n    return len(matches)\n\ndef calculate_score(lines_cleared, gems_cleared, chain_level):\n    return lines_cleared * 100 * lines_cleared + gems_cleared * 50 + chain_level * 25\n\ndef draw_grid(screen, grid):\n    for y in range(GRID_HEIGHT):\n        for x in range(GRID_WIDTH):\n            gem = grid[y][x]\n            color = gem.rgb if gem else COLORS[\"black\"]\n            rect = pygame.Rect(x*CELL_SIZE, y*CELL_SIZE, CELL_SIZE, CELL_SIZE)\n            pygame.draw.rect(screen, color, rect)\n            pygame.draw.rect(screen, COLORS[\"gray\"], rect, 1)\n\ndef draw_tetromino(screen, tetro):\n    for dy, row in enumerate(tetro.shape):\n        for dx, cell in enumerate(row):\n            if cell:\n                x = tetro.x + dx\n                y = tetro.y + dy\n                rect = pygame.Rect(x*CELL_SIZE, y*CELL_SIZE, CELL_SIZE, CELL_SIZE)\n                pygame.draw.rect(screen, COLORS[tetro.color], rect)\n                pygame.draw.rect(screen, COLORS[\"gray\"], rect, 1)\n\ndef draw_next(screen, tetro, px, py):\n    for dy, row in enumerate(tetro.shape):\n        for dx, cell in enumerate(row):\n            if cell:\n                rect = pygame.Rect(px + dx*CELL_SIZE, py + dy*CELL_SIZE, CELL_SIZE, CELL_SIZE)\n                pygame.draw.rect(screen, COLORS[tetro.color], rect)\n                pygame.draw.rect(screen, COLORS[\"gray\"], rect, 1)\n\ndef draw_score(screen, score):\n    font = pygame.font.Font(None, 36)\n    text = font.render(f\"Score: {score}\", True, COLORS[\"white\"])\n    screen.blit(text, (GRID_WIDTH*CELL_SIZE + 20, 20))\n\ndef handle_landing(grid, score):\n    # Tetris clears\n    lines = check_line_clears(grid)\n    # Bejeweled chains\n    chain = 0\n    total_gems = 0\n    while True:\n        gems = check_match_3(grid)\n        if gems == 0:\n            break\n        chain += 1\n        total_gems += gems\n    score += calculate_score(lines, total_gems, chain)\n    return score\n\ndef main():\n    pygame.init()\n    screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\n    pygame.display.set_caption(\"Tetris-Bejeweled Fusion\")\n    clock = pygame.time.Clock()\n\n    grid = create_grid(GRID_WIDTH, GRID_HEIGHT)\n    manager = TetrominoManager(grid)\n    score = 0\n    fall_speed = 0.5    # blocks per second\n    last_fall = time.time()\n    game_over = False\n\n    pygame.key.set_repeat(250, 50)\n\n    while True:\n        screen.fill(COLORS[\"black\"])\n        for event in pygame.event.get():\n            if event.type == pygame.QUIT:\n                pygame.quit()\n                return\n\n            if event.type == pygame.KEYDOWN and not game_over:\n                cmd = None\n                if event.key == pygame.K_LEFT:\n                    cmd = 'left'\n                elif event.key == pygame.K_RIGHT:\n                    cmd = 'right'\n                elif event.key == pygame.K_UP:\n                    cmd = 'rotate'\n                elif event.key == pygame.K_DOWN:\n                    cmd = 'soft_drop'\n                elif event.key == pygame.K_SPACE:\n                    cmd = 'hard_drop'\n\n                if cmd:\n                    landed = manager.update(cmd)\n                    if landed:\n                        score = handle_landing(grid, score)\n                        last_fall = time.time()\n                        if any(grid[0]):\n                            game_over = True\n\n        # automatic gravity\n        if not game_over and time.time() - last_fall > 1 / fall_speed:\n            landed = manager.update()\n            if landed:\n                score = handle_landing(grid, score)\n                last_fall = time.time()\n                if any(grid[0]):\n                    game_over = True\n\n        # draw\n        draw_grid(screen, grid)\n        draw_tetromino(screen, manager.current)\n        draw_score(screen, score)\n\n        # next preview\n        font = pygame.font.Font(None, 24)\n        screen.blit(font.render(\"Next:\", True, COLORS[\"white\"]),\n                    (GRID_WIDTH*CELL_SIZE + 20, 80))\n        draw_next(screen, manager.next,\n                  GRID_WIDTH*CELL_SIZE + 20, 110)\n\n        if game_over:\n            font = pygame.font.Font(None, 48)\n            over = font.render(\"Game Over!\", True, COLORS[\"white\"])\n            screen.blit(over, over.get_rect(center=(SCREEN_WIDTH//2, SCREEN_HEIGHT//2)))\n\n        pygame.display.flip()\n        clock.tick(60)\n\nif __name__ == \"__main__\":\n    main()\n```"}
