 move_left(self):\\n        if self.can_move_sideways(-1):\\n            self.current_piece.x -= 1\\n\\n    def move_right(self):\\n        if self.can_move_sideways(1):\\n            self.current_piece.x += 1\\n            \\n    def can_move_sideways(self, direction):\\n        for row in range(len(self.current_piece.shape)):\\n            for col in range(len(self.current_piece.shape[row])):\\n                if self.current_piece.shape[row][col]:\\n                    x = self.current_piece.x + col + direction\\n                    y = self.current_piece.y + row\\n                    if x < 0 or x >= GRID_WIDTH or (self.grid[y][x] is not None):\\n                        return False\\n        return True\\n\\n    def rotate(self):\\n        rotated_shape = list(zip(*self.current_piece.shape[::-1]))\\n        \\n        # Check for collisions after rotation\\n        for row in range(len(rotated_shape)):\\n            for col in range(len(rotated_shape[row])):\\n                if rotated_shape[row][col]:\\n                    x = self.current_piece.x + col\\n                    y = self.current_piece.y + row\\n                    if x < 0 or x >= GRID_WIDTH or y >= GRID_HEIGHT or self.grid[y][x] is not None:\\n                        return  # Cannot rotate\\n\\n        self.current_piece.shape = rotated_shape\\n\\nclass Tetromino:\\n    def __init__(self, shape, color, x, y):\\n        self.shape = shape\\n        self.color = color\\n        self.x = x\\n        self.y = y\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task6:\\n  Objective: Assemble main game loop: orchestrate piece spawning, controls input, physics updates, gem conversion, match processing, scoring, and GUI updates\\n\\n---\\n# **Current Task Requirements**\\nBuild Pygame-based GUI: render game grid as colored gems, animate falling pieces, clears, display score and next-piece preview\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport pygame\\nimport random\\nimport time\\n\\n# Define colors\\nCOLORS = {\\n    \\\"red\\\": (255, 0, 0),\\n    \\\"green\\\": (0, 255, 0),\\n    \\\"blue\\\": (0, 0, 255),\\n    \\\"yellow\\\": (255, 255, 0),\\n    \\\"cyan\\\": (0, 255, 255),\\n    \\\"magenta\\\": (255, 0, 255),\\n    \\\"orange\\\": (255, 165, 0),\\n    \\\"gray\\\": (128, 128, 128)\\n}\\n\\nCOLOR_LIST = list(COLORS.keys())\\n\\n# Define Tetromino shapes and colors\\nTETROMINOS = {\\n    \\\"I\\\": {\\\"shape\\\": [[1, 1, 1, 1]], \\\"color\\\": \\\"cyan\\\"},\\n    \\\"J\\\": {\\\"shape\\\": [[1, 0, 0], [1, 1, 1]], \\\"color\\\": \\\"blue\\\"},\\n    \\\"L\\\": {\\\"shape\\\": [[0, 0, 1], [1, 1, 1]], \\\"color\\\": \\\"orange\\\"},\\n    \\\"O\\\": {\\\"shape\\\": [[1, 1], [1, 1]], \\\"color\\\": \\\"yellow\\\"},\\n    \\\"S\\\": {\\\"shape\\\": [[0, 1, 1], [1, 1, 0]], \\\"color\\\": \\\"green\\\"},\\n    \\\"T\\\": {\\\"shape\\\": [[0, 1, 0], [1, 1, 1]], \\\"color\\\": \\\"magenta\\\"},\\n    \\\"Z\\\": {\\\"shape\\\": [[1, 1, 0], [0, 1, 1]], \\\"color\\\": \\\"red\\\"}\\n}\\n\\n# Game grid dimensions\\nGRID_WIDTH = 10\\nGRID_HEIGHT = 20\\nCELL_SIZE = 30\\nSCREEN_WIDTH = GRID_WIDTH * CELL_SIZE + 200\\nSCREEN_HEIGHT = GRID_HEIGHT * CELL_SIZE\\nPREVIEW_WIDTH = 6\\nPREVIEW_HEIGHT = 4\\n\\nclass Gem:\\n    \\\"\\\"\\\"A single colored gem in the grid.\\\"\\\"\\\"\\n\\n    def __init__(self, color_name):\\n        self.color_name = color_name\\n        self.rgb = COLORS[color_name]\\n\\n\\nclass Tetromino:\\n    def __init__(self, shape, color_name, x=3, y=0):\\n        self.shape = [row[:] for row in shape]\\n        self.color = color_name\\n        self.x = x\\n        self.y = y\\n\\n    def _rotate_shape(self):\\n        return [list(row) for row in zip(*self.shape[::-1])]\\n\\n    def rotate(self, grid):\\n        \\\"\\\"\\\"Attempt to rotate; revert if invalid.\\\"\\\"\\\"\\n        old_shape = self.shape\\n        self.shape = self._rotate_shape()\\n        if not is_valid_position(self, grid):\\n            self.shape = old_shape\\n\\n    def move(self, dx, grid):\\n        \\\"\\\"\\\"Attempt horizontal move; revert if invalid.\\\"\\\"\\\"\\n        old_x = self.x\\n        self.x += dx\\n        if not is_valid_position(self, grid):\\n            self.x = old_x\\n\\n    def soft_drop(self, grid):\\n        \\\"\\\"\\\"Move down one; return False if it would collide.\\\"\\\"\\\"\\n        old_y = self.y\\n        self.y += 1\\n        if not is_valid_position(self, grid):\\n            self.y = old_y\\n            return False\\n        return True\\n\\n    def hard_drop(self, grid):\\n        \\\"\\\"\\\"Drop until collision; lock in place at the end.\\\"\\\"\\\"\\n        while self.soft_drop(grid):\\n            pass\\n        return False  # indicates it landed\\n\\n\\ndef create_grid(width, height):\\n    \\\"\\\"\\\"Initialize empty grid of specified size.\\\"\\\"\\\"\\n    return [[None for _ in range(width)] for _ in range(height)]\\n\\n\\ndef is_valid_position(tetromino, grid):\\n    \\\"\\\"\\\"Check if tetromino is within bounds and not colliding.\\\"\\\"\\\"\\n    for dy, row in enumerate(tetromino.shape):\\n        for dx, cell in enumerate(row):\\n            if cell:\\n                x = tetromino.x + dx\\n                y = tetromino.y + dy\\n                if x < 0 or x >= GRID_WIDTH or y < 0 or y >= GRID_HEIGHT:\\n                    return False\\n                if grid[y][x] is not None:\\n                    return False\\n    return True\\n\\n\\ndef lock_tetromino(tetromino, grid):\\n    \\\"\\\"\\\"Convert all occupied cells of the tetromino into Gems in the grid.\\\"\\\"\\\"\\n    for dy, row in enumerate(tetromino.shape):\\n        for dx, cell in enumerate(row):\\n            if cell:\\n                x = tetromino.x + dx\\n                y = tetromino.y + dy\\n                if 0 <= x < GRID_WIDTH and 0 <= y < GRID_HEIGHT:\\n                    grid[y][x] = Gem(tetromino.color)\\n\\n\\nclass TetrominoManager:\\n    \\\"\\\"\\\"Manages active tetromino, spawning, and locking.\\\"\\\"\\\"\\n\\n    def __init__(self, grid):\\n        self.grid = grid\\n        self.current = self._spawn_new()\\n        self.next = self._spawn_new()\\n\\n    def _spawn_new(self):\\n        key = random.choice(list(TETROMINOS.keys()))\\n        data = TETROMINOS[key]\\n        # center initial x so shape appears roughly in middle\\n        start_x = (GRID_WIDTH - len(data[\\\"shape\\\"][0])) // 2\\n        return Tetromino(data[\\\"shape\\\"], data[\\\"color\\\"], x=start_x, y=0)\\n\\n    def update(self, command=None):\\n        \\\"\\\"\\\"\\n        command: one of 'left','right','rotate','soft_drop','hard_drop'\\n        Returns True if piece locked (and a new spawn occurred).\\n        \\\"\\\"\\\"\\n        if command == 'left':\\n            self.current.move(-1, self.grid)\\n        elif command == 'right':\\n            self.current.move(1, self.grid)\\n        elif command == 'rotate':\\n            self.current.rotate(self.grid)\\n        elif command == 'soft_drop':\\n            landed = not self.current.soft_drop(self.grid)\\n            if landed:\\n                lock_tetromino(self.current, self.grid)\\n                self.current = self.next\\n                self.next = self._spawn_new()\\n                return True\\n        elif command == 'hard_drop':\\n            self.current.hard_drop(self.grid)\\n            lock_tetromino(self.current, self.grid)\\n            self.current = self.next\\n            self.next = self._spawn_new()\\n            return True\\n        else:\\n            # gravity tick\\n            landed = not self.current.soft_drop(self.grid)\\n            if landed:\\n                lock_tetromino(self.current, self.grid)\\n                self.current = self.next\\n                self.next = self._spawn_new()\\n                return True\\n        return False\\n\\n\\ndef check_line_clears(grid):\\n    \\\"\\\"\\\"Check for and clear full horizontal lines.\\\"\\\"\\\"\\n    lines_to_clear = []\\n    for i, row in enumerate(grid):\\n        if all(row):  # all cells are gems\\n            lines_to_clear.append(i)\\n\\n    for row_index in lines_to_clear:\\n        del grid[row_index]\\n        grid.insert(0, [None] * GRID_WIDTH)  # Add empty row at top\\n    return len(lines_to_clear)  # Return number of lines cleared\\n\\n\\ndef check_match_3(grid):\\n    \\\"\\\"\\\"Check for and clear Bejeweled-style match-3.\\\"\\\"\\\"\\n    matches = []\\n\\n    # Horizontal matches\\n    for y in range(GRID_HEIGHT):\\n        for x in range(GRID_WIDTH - 2):\\n            if (grid[y][x] is not None and\\n                    grid[y][x] == grid[y][x + 1] and\\n                    grid[y][x] == grid[y][x + 2]):\\n                matches.append(((x, y), (x + 1, y), (x + 2, y)))\\n\\n    # Vertical matches\\n    for x in range(GRID_WIDTH):\\n        for y in range(GRID_HEIGHT - 2):\\n            if (grid[y][x] is not None and\\n                    grid[y][x] == grid[y + 1][x] and\\n                    grid[y][x] == grid[y + 2][x]):\\n                matches.append(((x, y), (x, y + 1), (x, y + 2)))\\n\\n    # Remove duplicates and clear matches\\n    cleared_positions = set()\\n    for match in matches:\\n        for x, y in match:\\n            cleared_positions.add((x, y))\\n\\n    # Convert to list for easier manipulation\\n    cleared_positions = list(cleared_positions)\\n\\n    # Clear the matched gems from the grid\\n    for x, y in cleared_positions:\\n        grid[y][x] = None\\n\\n    # Apply gravity to move gems down\\n    for x in range(GRID_WIDTH):\\n        # Move empty spaces to the top\\n        empty_count = 0\\n        for y in range(GRID_HEIGHT):\\n            if grid[y][x] is None:\\n                empty_count += 1\\n            elif empty_count > 0:\\n                grid[y - empty_count][x] = grid[y][x]\\n                grid[y][x] = None\\n\\n    return len(cleared_positions)\\n\\n\\ndef calculate_score(lines_cleared, gems_cleared, chain_reaction_level):\\n    \\\"\\\"\\\"Calculate score based on lines cleared and gems cleared.\\\"\\\"\\\"\\n    line_clear_score = lines_cleared * (100 * lines_cleared)  # Tetris scoring\\n    gem_clear_score = gems_cleared * 50  # Bejeweled scoring\\n    chain_bonus = chain_reaction_level * 25  # Bonus for chain reactions\\n\\n    return line_clear_score + gem_clear_score + chain_bonus\\n\\n\\ndef draw_grid(screen, grid):\\n    \\\"\\\"\\\"Draw the game grid.\\\"\\\"\\\"\\n    for y in range(GRID_HEIGHT):\\n        for x in range(GRID_WIDTH):\\n            gem = grid[y][x]\\n            if gem:\\n                color = gem.rgb\\n                pygame.draw.rect(screen, color, (x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE))\\n                pygame.draw.rect(screen, COLORS[\\\"gray\\\"],\\n                                 (x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE), 1)  # Grid lines\\n            else:\\n                pygame.draw.rect(screen, COLORS[\\\"gray\\\"],\\n                                 (x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE), 1)  # Empty grid\\n\\n\\ndef draw_tetromino(screen, tetromino):\\n    \\\"\\\"\\\"Draw the falling tetromino.\\\"\\\"\\\"\\n    for dy, row in enumerate(tetromino.shape):\\n        for dx, cell in enumerate(row):\\n            if cell:\\n                x = tetromino.x + dx\\n                y = tetromino.y + dy\\n                color = COLORS[tetromino.color]\\n                pygame.draw.rect(screen, color, (x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE))\\n                pygame.draw.rect(screen, COLORS[\\\"gray\\\"],\\n                                 (x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE), 1)  # Grid lines\\n\\n\\ndef draw_next_tetromino(screen, tetromino, x_offset, y_offset):\\n    \\\"\\\"\\\"Draw the next tetromino preview.\\\"\\\"\\\"\\n    for dy, row in enumerate(tetromino.shape):\\n        for dx, cell in enumerate(row):\\n            if cell:\\n                x = x_offset + dx\\n                y = y_offset + dy\\n                color = COLORS[tetromino.color]\\n                pygame.draw.rect(screen, color, (x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE))\\n                pygame.draw.rect(screen, COLORS[\\\"gray\\\"],\\n                                 (x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE), 1)  # Grid lines\\n\\n\\ndef draw_score(screen, score):\\n    \\\"\\\"\\\"Draw the score on the screen.\\\"\\\"\\\"\\n    font = pygame.font.Font(None, 36)\\n    text = font.render(f\\\"Score: {score}\\\", True, COLORS[\\\"white\\\"])\\n    screen.blit(text, (GRID_WIDTH * CELL_SIZE + 20, 20))\\n\\n\\ndef main():\\n    pygame.init()\\n    screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\\n    pygame.display.set_caption(\\\"Tetris Bejeweled\\\")\\n\\n    grid = create_grid(GRID_WIDTH, GRID_HEIGHT)\\n    tetromino_manager = TetrominoManager(grid)\\n    score = 0\\n    fall_speed = 0.5  # Blocks per second\\n    last_fall_time = pygame.time.time()\\n    game_over = False\\n\\n    # Define colors\\n    WHITE = (255, 255, 255)\\n    BLACK = (0, 0, 0)\\n\\n    running = True\\n    while running:\\n        screen.fill(BLACK)\\n\\n        # Event handling\\n        for event in pygame.event.get():\\n            if event.type == pygame.QUIT:\\n                running = False\\n            if event.type == pygame.KEYDOWN:\\n                if event.key == pygame.K_LEFT:\\n                    tetromino_manager.update('left')\\n                if event.key == pygame.K_RIGHT:\\n                    tetromino_manager.update('right')\\n                if event.key == pygame.K_UP:\\n                    tetromino_manager.update('rotate')\\n                if event.key == pygame.K_DOWN:\\n                    tetromino_manager.update('soft_drop')\\n                if event.key == pygame.K_SPACE:\\n                    tetromino_manager.update('hard_drop')\\n\\n        # Game logic\\