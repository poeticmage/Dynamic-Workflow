, y, shape, color):\\n        self.x = x\\n        self.y = y\\n        self.shape = shape\\n        self.color = color\\n\\n    def rotate(self):\\n        # Rotate the shape 90 degrees clockwise\\n        rotated_shape = list(zip(*self.shape[::-1]))\\n        self.shape = [list(row) for row in rotated_shape]\\n\\n    def move(self, dx):\\n        self.x += dx\\n\\n    def move_down(self):\\n        self.y += 1\\n\\n\\n# Game grid dimensions\\nGRID_WIDTH = 10\\nGRID_HEIGHT = 20\\n\\n# Initialize the game grid with None values\\ndef create_grid(width, height):\\n    return [[None for _ in range(width)] for _ in range(height)]\\n\\n# Example of initializing the grid\\ngrid = create_grid(GRID_WIDTH, GRID_HEIGHT)\\n\\n\\ndef is_valid_move(tetromino, grid):\\n    for row_index, row in enumerate(tetromino.shape):\\n        for col_index, cell in enumerate(row):\\n            if cell:\\n                x = tetromino.x + col_index\\n                y = tetromino.y + row_index\\n\\n                if x < 0 or x >= GRID_WIDTH or y >= GRID_HEIGHT:\\n                    return False\\n\\n                if y >= 0 and grid[y][x] is not None:\\n                    return False\\n    return True\\n\\n\\ndef lock_tetromino(tetromino, grid):\\n    for row_index, row in enumerate(tetromino.shape):\\n        for col_index, cell in enumerate(row):\\n            if cell:\\n                x = tetromino.x + col_index\\n                y = tetromino.y + row_index\\n                if 0 <= y < GRID_HEIGHT and 0 <= x < GRID_WIDTH:\\n                    grid[y][x] = tetromino.color\\n```\",\n  \"timestamp\": \"2026-05-23T10:44:11.426201\"\n}"}
