class Tetromino:\\n    def __init__(self, shape, color, x, y):\\n        self.shape = shape\\n        self.color = color\\n        self.x = x\\n        self.y = y\\n\\ndef draw_grid(screen, grid):\\n    for y in range(GRID_HEIGHT):\\n        for x in range(GRID_WIDTH):\\n            if grid[y][x] is not None:\\n                pygame.draw.rect(screen, grid[y][x], (x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE))\\n            else:\\n                pygame.draw.rect(screen, GRAY, (x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE), 1)\\n\\ndef draw_piece(screen, piece):\\n    for row in range(len(piece.shape)):\\n        for col in range(len(piece.shape[row])):\\n            if piece.shape[row][col]:\\n                x = piece.x + col\\n                y = piece.y + row\\n                pygame.draw.rect(screen, piece.color, (x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE))\\n\\ndef draw_next_piece(screen, piece):\\n    \\\"\\\"\\\"Draw the next piece preview.\\\"\\\"\\\"\\n    font = pygame.font.Font(None, 30)\\n    text = font.render(\\\"Next Piece:\\\", True, WHITE)\\n    screen.blit(text, (GRID_WIDTH * CELL_SIZE + 10, 10))\\n\\n    # Offset to position the preview nicely\\n    offset_x = GRID_WIDTH * CELL_SIZE + 10\\n    offset_y = 40\\n\\n    for row in range(len(piece.shape)):\\n        for col in range(len(piece.shape[row])):\\n            if piece.shape[row][col]:\\n                x = col\\n                y = row\\n                pygame.draw.rect(screen, piece.color,\\n                                 (offset_x + x * CELL_SIZE, offset_y + y * CELL_SIZE, CELL_SIZE, CELL_SIZE))\\n\\ndef draw_score(screen, score):\\n    \\\"\\\"\\\"Draw the current score.\\\"\\\"\\\"\\n    font = pygame.font.Font(None, 36)\\n    text = font.render(f\\\"Score: {score}\\\", True, WHITE)\\n    screen.blit(text, (GRID_WIDTH * CELL_SIZE + 10, SCREEN_HEIGHT - 50))\\n\\ndef main():\\n    pygame.init()\\n    screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\\n    pygame.display.set_caption(\\\"Tetris Bejeweled\\\")\\n\\n    game_state = GameState()\\n    clock = pygame.time.Clock()\\n    fall_speed = 1  # Cells per second\\n    last_fall_time = pygame.time.get_ticks()\\n\\n    running = True\\n    while running:\\n        screen.fill(BLACK)\\n        current_time = pygame.time.get_ticks()\\n\\n        for event in pygame.event.get():\\n            if event.type == pygame.QUIT:\\n                running = False\\n            if event.type == pygame.KEYDOWN:\\n                if event.key == pygame.K_LEFT:\\n                    game_state.move_left()\\n                if event.key == pygame.K_RIGHT:\\n                    game_state.move_right()\\n                if event.key == pygame.K_UP:\\n                    game_state.rotate()\\n                if event.key == pygame.K_DOWN:\\n                    game_state.update()\\n\\n        if current_time - last_fall_time > 1000 / fall_speed:\\n            game_state.update()\\n            last_fall_time = current_time\\n        \\n        draw_grid(screen, game_state.grid)\\n        draw_piece(screen, game_state.current_piece)\\n        draw_next_piece(screen, game_state.next_piece)\\n        draw_score(screen, game_state.score)\\n        \\n        pygame.display.flip()\\n        clock.tick(60)\\n\\n    pygame.quit()\\n\\nif __name__ == \\\"__main__\\\":\\n    main()\\n```\",\n  \"timestamp\": \"2026-05-23T10:45:17.680219\"\n}"}
