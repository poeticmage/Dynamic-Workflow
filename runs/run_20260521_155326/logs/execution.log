{"timestamp": "2026-05-21 15:55:42,692", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task0: ```python\n# Core data structures for Tetris-Bejeweled hybrid\n\n# Grid dimensions\nGRID_WIDTH = 10\nGRID_HEIGHT = 20\n\n# Game grid representation: each cell is None or an (R, G, B) color tuple\nclass GameGrid:\n    def __init__(self, width=GRID_WIDTH, height=GRID_HEIGHT):\n        self.width = width\n        self.height = height\n        self.cells = [[None for _ in range(width)] for _ in range(height)]\n\n    def is_empty(self, x, y):\n        return 0 <= x < self.width and 0 <= y < self.height and self.cells[y][x] is None\n\n    def set_cell(self, x, y, color):\n        if 0 <= x < self.width and 0 <= y < self.height:\n            self.cells[y][x] = color\n\n    def clear_cell(self, x, y):\n        if 0 <= x < self.width and 0 <= y < self.height:\n            self.cells[y][x] = None\n\n# Tetromino base shapes defined in a 4×4 local coordinate system\n# Each shape is a list of (x, y) block offsets\nTETROMINO_SHAPES = {\n    'I': [(0,1), (1,1), (2,1), (3,1)],\n    'O': [(1,0), (2,0), (1,1), (2,1)],\n    'T': [(1,0), (0,1), (1,1), (2,1)],\n    'S': [(1,1), (2,1), (0,2), (1,2)],\n    'Z': [(0,1), (1,1), (1,2), (2,2)],\n    'J': [(0,0), (0,1), (1,1), (2,1)],\n    'L': [(2,0), (0,1), (1,1), (2,1)],\n}\n\n# Gem colors (RGB) mapped to each tetromino type\nGEM_COLORS = {\n    'I': (0, 255, 255),\n    'O': (255, 255, 0),\n    'T': (128, 0, 128),\n    'S': (0, 255, 0),\n    'Z': (255, 0, 0),\n    'J': (0, 0, 255),\n    'L': (255, 165, 0),\n}\n\n# Example usage:\n#   grid = GameGrid()\n#   shape = TETROMINO_SHAPES['T']\n#   color = GEM_COLORS['T']\n#   for dx, dy in shape:\n#       grid.set_cell(x0 + dx, y0 + dy, color)\n```"}
{"timestamp": "2026-05-21 15:55:42,692", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task1: import random\n\n# Assumes GameGrid, TETROMINO_SHAPES, GEM_COLORS, GRID_WIDTH are defined upstream\n\nclass Tetromino:\n    def __init__(self, shape_type):\n        self.shape_type = shape_type\n        self.rotation = 0\n        self.color = GEM_COLORS[shape_type]\n        self.blocks = TETROMINO_SHAPES[shape_type]\n        self.x = (GRID_WIDTH // 2) - 2\n        self.y = 0\n\n    def get_cells(self, x_offset=0, y_offset=0, blocks=None):\n        cells = []\n        for bx, by in blocks or self.blocks:\n            cells.append((self.x + bx + x_offset, self.y + by + y_offset))\n        return cells\n\n    def can_move(self, grid, dx, dy):\n        for x, y in self.get_cells(dx, dy):\n            if not (0 <= x < grid.width and 0 <= y < grid.height):\n                return False\n            if grid.cells[y][x] is not None:\n                return False\n        return True\n\n    def move(self, grid, dx, dy):\n        if self.can_move(grid, dx, dy):\n            self.x += dx\n            self.y += dy\n            return True\n        return False\n\n    def rotate(self, grid):\n        new_blocks = []\n        for bx, by in self.blocks:\n            rx = by\n            ry = 3 - bx\n            new_blocks.append((rx, ry))\n        for x, y in self.get_cells(0, 0, new_blocks):\n            if not (0 <= x < grid.width and 0 <= y < grid.height):\n                return False\n            if grid.cells[y][x] is not None:\n                return False\n        self.blocks = new_blocks\n        self.rotation = (self.rotation + 90) % 360\n        return True\n\n    def drop_one(self, grid):\n        if not self.move(grid, 0, 1):\n            self.lock(grid)\n            return False\n        return True\n\n    def lock(self, grid):\n        for x, y in self.get_cells():\n            grid.set_cell(x, y, self.color)\n\ndef spawn_tetromino():\n    return Tetromino(random.choice(list(TETROMINO_SHAPES.keys())))"}
{"timestamp": "2026-05-21 15:55:42,692", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task2: import random\n\n# Grid dimensions\nGRID_WIDTH = 10\nGRID_HEIGHT = 20\n\n# Define tetromino shapes as lists of (x, y) offsets\nTETROMINO_SHAPES = {\n    'I': [(0,0), (1,0), (2,0), (3,0)],\n    'O': [(0,0), (1,0), (0,1), (1,1)],\n    'T': [(1,0), (0,1), (1,1), (2,1)],\n    'S': [(1,0), (2,0), (0,1), (1,1)],\n    'Z': [(0,0), (1,0), (1,1), (2,1)],\n    'J': [(0,0), (0,1), (1,1), (2,1)],\n    'L': [(2,0), (0,1), (1,1), (2,1)],\n}\n\n# Map each shape to a gem color\nGEM_COLORS = {\n    'I': 'cyan',\n    'O': 'yellow',\n    'T': 'purple',\n    'S': 'green',\n    'Z': 'red',\n    'J': 'blue',\n    'L': 'orange',\n}\n\nclass Gem:\n    def __init__(self, color):\n        self.color = color\n        self.marked_for_clear = False\n\n    def __repr__(self):\n        return f\"Gem({self.color[0].upper()})\"\n\nclass GameGrid:\n    def __init__(self, width=GRID_WIDTH, height=GRID_HEIGHT):\n        self.width = width\n        self.height = height\n        self.cells = [[None for _ in range(width)] for _ in range(height)]\n\n    def in_bounds(self, x, y):\n        return 0 <= x < self.width and 0 <= y < self.height\n\n    def set_cell(self, x, y, value):\n        if not self.in_bounds(x, y):\n            raise IndexError(f\"Position out of bounds: ({x},{y})\")\n        self.cells[y][x] = value\n\n    def get_cell(self, x, y):\n        if not self.in_bounds(x, y):\n            raise IndexError(f\"Position out of bounds: ({x},{y})\")\n        return self.cells[y][x]\n\n    def __repr__(self):\n        rows = []\n        for row in self.cells:\n            rows.append(' '.join(str(cell) if cell else '.' for cell in row))\n        return '\\n'.join(rows)\n\nclass Tetromino:\n    def __init__(self, shape_type):\n        self.shape_type = shape_type\n        self.blocks = TETROMINO_SHAPES[shape_type]\n        self.color = GEM_COLORS[shape_type]\n        self.x = (GRID_WIDTH // 2) - 2\n        self.y = 0\n        self.rotation = 0  # degrees\n\n    def get_cells(self, x_offset=0, y_offset=0, blocks=None):\n        cells = []\n        for bx, by in blocks or self.blocks:\n            cells.append((self.x + bx + x_offset, self.y + by + y_offset))\n        return cells\n\n    def can_move(self, grid, dx, dy):\n        for x, y in self.get_cells(dx, dy):\n            if not grid.in_bounds(x, y) or grid.cells[y][x] is not None:\n                return False\n        return True\n\n    def move(self, grid, dx, dy):\n        if self.can_move(grid, dx, dy):\n            self.x += dx\n            self.y += dy\n            return True\n        return False\n\n    def rotate(self, grid):\n        new_blocks = []\n        for bx, by in self.blocks:\n            rx = by\n            ry = 3 - bx\n            new_blocks.append((rx, ry))\n        for x, y in self.get_cells(0, 0, new_blocks):\n            if not grid.in_bounds(x, y) or grid.cells[y][x] is not None:\n                return False\n        self.blocks = new_blocks\n        self.rotation = (self.rotation + 90) % 360\n        return True\n\n    def drop_one(self, grid):\n        if not self.move(grid, 0, 1):\n            self.lock(grid)\n            return False\n        return True\n\n    def lock(self, grid):\n        \"\"\"\n        Place a Gem instance in each occupied cell when locking.\n        \"\"\"\n        for x, y in self.get_cells():\n            if not grid.in_bounds(x, y):\n                raise ValueError(f\"Cannot lock out of bounds at ({x},{y})\")\n            gem = Gem(self.color)\n            grid.set_cell(x, y, gem)\n\ndef spawn_tetromino():\n    shape = random.choice(list(TETROMINO_SHAPES.keys()))\n    return Tetromino(shape)\n\n# Example usage\nif __name__ == \"__main__\":\n    grid = GameGrid()\n    tet = spawn_tetromino()\n    # Move tetromino down until it locks\n    while tet.drop_one(grid):\n        pass\n    print(grid)   "}
{"timestamp": "2026-05-21 15:55:42,692", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task3: import random\n\n# Scoring constants\nLINE_CLEAR_SCORES = {1: 100, 2: 300, 3: 500, 4: 800}\nGEM_CLEAR_SCORE = 50\n\nclass Gem:\n    def __init__(self, color):\n        self.color = color\n        self.marked_for_clear = False\n\n    def __repr__(self):\n        return f\"Gem({self.color[0].upper()})\"\n\nclass GameGrid:\n    def __init__(self, width=10, height=20):\n        self.width = width\n        self.height = height\n        self.cells = [[None for _ in range(width)] for _ in range(height)]\n\n    def in_bounds(self, x, y):\n        return 0 <= x < self.width and 0 <= y < self.height\n\n    def set_cell(self, x, y, value):\n        if not self.in_bounds(x, y):\n            raise IndexError(f\"Position out of bounds: ({x},{y})\")\n        self.cells[y][x] = value\n\n    def get_cell(self, x, y):\n        if not self.in_bounds(x, y):\n            raise IndexError(f\"Position out of bounds: ({x},{y})\")\n        return self.cells[y][x]\n\n    def __repr__(self):\n        rows = []\n        for row in self.cells:\n            rows.append(' '.join(str(cell) if cell else '.' for cell in row))\n        return '\\n'.join(rows)\n\n    def clear_completed_lines(self):\n        full_rows = [y for y in range(self.height)\n                     if all(self.cells[y][x] is not None for x in range(self.width))]\n        for y in full_rows:\n            for yy in range(y, 0, -1):\n                self.cells[yy] = list(self.cells[yy-1])\n            self.cells[0] = [None] * self.width\n        return len(full_rows)\n\n    def find_match3(self):\n        to_clear = set()\n        # Horizontal runs\n        for y in range(self.height):\n            x = 0\n            while x < self.width:\n                cell = self.cells[y][x]\n                if cell:\n                    color = cell.color\n                    run = [(x, y)]\n                    x2 = x + 1\n                    while x2 < self.width and self.cells[y][x2] and self.cells[y][x2].color == color:\n                        run.append((x2, y))\n                        x2 += 1\n                    if len(run) >= 3:\n                        to_clear.update(run)\n                    x = x2\n                else:\n                    x += 1\n        # Vertical runs\n        for x in range(self.width):\n            y = 0\n            while y < self.height:\n                cell = self.cells[y][x]\n                if cell:\n                    color = cell.color\n                    run = [(x, y)]\n                    y2 = y + 1\n                    while y2 < self.height and self.cells[y2][x] and self.cells[y2][x].color == color:\n                        run.append((x, y2))\n                        y2 += 1\n                    if len(run) >= 3:\n                        to_clear.update(run)\n                    y = y2\n                else:\n                    y += 1\n        return to_clear\n\n    def apply_gravity(self):\n        for x in range(self.width):\n            stack = [self.cells[y][x] for y in range(self.height) if self.cells[y][x] is not None]\n            for y in range(self.height - 1, -1, -1):\n                self.cells[y][x] = stack.pop() if stack else None\n\n    def clear_positions(self, positions):\n        for x, y in positions:\n            self.cells[y][x] = None\n        self.apply_gravity()\n        return len(positions)\n\n    def process_clears(self):\n        total_score = 0\n        chain = 0\n        while True:\n            cleared = False\n            # Tetris line clears\n            num_lines = self.clear_completed_lines()\n            if num_lines > 0:\n                chain += 1\n                cleared = True\n                score_per = LINE_CLEAR_SCORES.get(num_lines, num_lines * 200)\n                total_score += score_per * chain\n            # Bejeweled match-3 clears\n            matches = self.find_match3()\n            if matches:\n                chain += 1\n                cleared = True\n                num_gems = self.clear_positions(matches)\n                total_score += GEM_CLEAR_SCORE * num_gems * chain\n            if not cleared:\n                break\n        return total_score\n\n# Example usage\nif __name__ == \"__main__\":\n    grid = GameGrid()\n    # Manually fill a line for testing\n    for x in range(grid.width):\n        grid.set_cell(x, grid.height - 1, Gem('red'))\n    # Fill a small match-3\n    grid.set_cell(0, grid.height - 2, Gem('blue'))\n    grid.set_cell(1, grid.height - 2, Gem('blue'))\n    grid.set_cell(2, grid.height - 2, Gem('blue'))\n    print(\"Before clears:\\n\", grid, sep='')\n    score = grid.process_clears()\n    print(\"\\nAfter clears:\\n\", grid, sep='')\n    print(\"\\nScore gained:\", score)"}
{"timestamp": "2026-05-21 15:55:42,692", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task4: ```python\nimport pygame\nimport sys\nimport random\nfrom task0 import GameGrid, TETROMINO_SHAPES, GEM_COLORS, GRID_WIDTH, GRID_HEIGHT\n\n# Pygame setup constants\nCELL_SIZE = 30\nGRID_ORIGIN = (20, 20)\nPREVIEW_ORIGIN = (GRID_ORIGIN[0] + GRID_WIDTH * CELL_SIZE + 40, GRID_ORIGIN[1])\nPREVIEW_SIZE = 4\nSCREEN_WIDTH = GRID_ORIGIN[0] + GRID_WIDTH * CELL_SIZE + 200\nSCREEN_HEIGHT = GRID_ORIGIN[1] + GRID_HEIGHT * CELL_SIZE + 40\nFPS = 60\nFALL_EVENT = pygame.USEREVENT + 1\nFALL_INTERVAL = 500  # milliseconds\n\n# Scoring\nLINE_SCORES = {1: 100, 2: 300, 3: 500, 4: 800}\nMATCH_SCORE_PER_GEM = 50\n\nclass Tetromino:\n    def __init__(self, kind):\n        self.kind = kind\n        self.shape = TETROMINO_SHAPES[kind]\n        self.color = GEM_COLORS[kind]\n        self.rotation = 0\n        self.x = GRID_WIDTH // 2 - 2\n        self.y = 0\n\n    def blocks(self):\n        out = []\n        for dx, dy in self.shape:\n            x, y = dx, dy\n            for _ in range(self.rotation):\n                x, y = y, 3 - x\n            out.append((self.x + x, self.y + y))\n        return out\n\n    def move(self, dx, dy, grid):\n        if all(0 <= x + dx < grid.width and 0 <= y + dy < grid.height and\n               grid.cells[y + dy][x + dx] is None for x, y in self.blocks()):\n            self.x += dx\n            self.y += dy\n            return True\n        return False\n\n    def rotate_cw(self, grid):\n        old_rot = self.rotation\n        self.rotation = (self.rotation + 1) % 4\n        if not all(0 <= x < grid.width and 0 <= y < grid.height and grid.cells[y][x] is None\n                   for x, y in self.blocks()):\n            self.rotation = old_rot\n\nclass Game:\n    def __init__(self):\n        pygame.init()\n        self.screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\n        pygame.display.set_caption(\"Tetris-Bejeweled Hybrid\")\n        self.clock = pygame.time.Clock()\n        self.font = pygame.font.SysFont(None, 36)\n        self.grid = GameGrid()\n        self.score = 0\n        self.current = self.next_tetromino()\n        self.next = self.next_tetromino()\n        pygame.time.set_timer(FALL_EVENT, FALL_INTERVAL)\n        self.game_over = False\n\n    def next_tetromino(self):\n        return Tetromino(random.choice(list(TETROMINO_SHAPES.keys())))\n\n    def lock_piece(self):\n        for x, y in self.current.blocks():\n            self.grid.set_cell(x, y, self.current.color)\n        self.clear_lines()\n        self.clear_matches()\n        self.current = self.next\n        self.next = self.next_tetromino()\n        if any(not self.grid.is_empty(x, y) for x, y in self.current.blocks()):\n            self.game_over = True\n\n    def clear_lines(self):\n        full_rows = [y for y in range(self.grid.height)\n                     if all(self.grid.cells[y][x] is not None for x in range(self.grid.width))]\n        for y in full_rows:\n            for x in range(self.grid.width):\n                self.grid.clear_cell(x, y)\n        for y in reversed(full_rows):\n            for pull_y in range(y, 0, -1):\n                for x in range(self.grid.width):\n                    self.grid.cells[pull_y][x] = self.grid.cells[pull_y - 1][x]\n            for x in range(self.grid.width):\n                self.grid.clear_cell(x, 0)\n        if full_rows:\n            lines = len(full_rows)\n            self.score += LINE_SCORES.get(lines, lines * 200)\n\n    def clear_matches(self):\n        chain = 0\n        while True:\n            to_clear = set()\n            # horizontal\n            for y in range(self.grid.height):\n                run = []\n                last_color = None\n                for x in range(self.grid.width):\n                    c = self.grid.cells[y][x]\n                    if c and c == last_color:\n                        run.append((x, y))\n                    else:\n                        if len(run) >= 3:\n                            to_clear.update(run)\n                        run = [(x, y)] if c else []\n                        last_color = c\n                if len(run) >= 3:\n                    to_clear.update(run)\n            # vertical\n            for x in range(self.grid.width):\n                run = []\n                last_color = None\n                for y in range(self.grid.height):\n                    c = self.grid.cells[y][x]\n                    if c and c == last_color:\n                        run.append((x, y))\n                    else:\n                        if len(run) >= 3:\n                            to_clear.update(run)\n                        run = [(x, y)] if c else []\n                        last_color = c\n                if len(run) >= 3:\n                    to_clear.update(run)\n            if not to_clear:\n                break\n            for x, y in to_clear:\n                self.grid.clear_cell(x, y)\n            self.gravity()\n            chain += 1\n            self.score += len(to_clear) * MATCH_SCORE_PER_GEM * chain\n\n    def gravity(self):\n        for x in range(self.grid.width):\n            stack = [self.grid.cells[y][x] for y in range(self.grid.height) if self.grid.cells[y][x]]\n            for y in range(self.grid.height - 1, -1, -1):\n                self.grid.cells[y][x] = stack.pop() if stack else None\n\n    def handle_input(self, event):\n        if event.type == pygame.KEYDOWN and not self.game_over:\n            if event.key == pygame.K_LEFT:\n                self.current.move(-1, 0, self.grid)\n            elif event.key == pygame.K_RIGHT:\n                self.current.move(1, 0, self.grid)\n            elif event.key == pygame.K_DOWN:\n                moved = self.current.move(0, 1, self.grid)\n                if moved:\n                    self.score += 1\n            elif event.key == pygame.K_UP:\n                self.current.rotate_cw(self.grid)\n        if event.type == FALL_EVENT and not self.game_over:\n            if not self.current.move(0, 1, self.grid):\n                self.lock_piece()\n\n    def draw_grid(self):\n        for y in range(self.grid.height):\n            for x in range(self.grid.width):\n                cell = self.grid.cells[y][x]\n                rect = pygame.Rect(\n                    GRID_ORIGIN[0] + x * CELL_SIZE,\n                    GRID_ORIGIN[1] + y * CELL_SIZE,\n                    CELL_SIZE, CELL_SIZE\n                )\n                pygame.draw.rect(self.screen, (50, 50, 50), rect, 1)\n                if cell:\n                    pygame.draw.rect(self.screen, cell, rect.inflate(-2, -2))\n\n    def draw_current(self):\n        for x, y in self.current.blocks():\n            rect = pygame.Rect(\n                GRID_ORIGIN[0] + x * CELL_SIZE,\n                GRID_ORIGIN[1] + y * CELL_SIZE,\n                CELL_SIZE, CELL_SIZE\n            )\n            pygame.draw.rect(self.screen, self.current.color, rect.inflate(-2, -2))\n\n    def draw_preview(self):\n        label = self.font.render(\"Next:\", True, (255, 255, 255))\n        self.screen.blit(label, (PREVIEW_ORIGIN[0], PREVIEW_ORIGIN[1] - 30))\n        for dx, dy in self.next.shape:\n            x = PREVIEW_ORIGIN[0] + dx * CELL_SIZE\n            y = PREVIEW_ORIGIN[1] + dy * CELL_SIZE\n            rect = pygame.Rect(x, y, CELL_SIZE, CELL_SIZE)\n            pygame.draw.rect(self.screen, (100, 100, 100), rect, 1)\n            pygame.draw.rect(self.screen, self.next.color, rect.inflate(-2, -2))\n\n    def draw_score(self):\n        txt = self.font.render(f\"Score: {self.score}\", True, (255, 255, 255))\n        self.screen.blit(txt, (PREVIEW_ORIGIN[0], PREVIEW_ORIGIN[1] + PREVIEW_SIZE * CELL_SIZE + 20))\n\n    def draw_game_over(self):\n        msg = self.font.render(\"GAME OVER\", True, (200, 0, 0))\n        rect = msg.get_rect(center=(SCREEN_WIDTH // 2, SCREEN_HEIGHT // 2))\n        self.screen.blit(msg, rect)\n\n    def run(self):\n        while True:\n            for event in pygame.event.get():\n                if event.type == pygame.QUIT:\n                    pygame.quit()\n                    sys.exit()\n                self.handle_input(event)\n            self.screen.fill((0, 0, 0))\n            self.draw_grid()\n            self.draw_current()\n            self.draw_preview()\n            self.draw_score()\n            if self.game_over:\n                self.draw_game_over()\n            pygame.display.flip()\n            self.clock.tick(FPS)\n\nif __name__ == \"__main__\":\n    Game().run()\n```"}
{"timestamp": "2026-05-21 15:55:42,692", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task5: ```python\nimport pygame\nimport sys\nimport random\nfrom task3 import GameGrid, Gem\nfrom task0 import TETROMINO_SHAPES, GEM_COLORS, GRID_WIDTH, GRID_HEIGHT\n\n# Pygame setup\nCELL_SIZE    = 30\nGRID_ORIGIN  = (20, 20)\nPREVIEW_ORIGIN = (GRID_ORIGIN[0] + GRID_WIDTH * CELL_SIZE + 40, GRID_ORIGIN[1])\nSCREEN_WIDTH  = GRID_ORIGIN[0] + GRID_WIDTH * CELL_SIZE + 200\nSCREEN_HEIGHT = GRID_ORIGIN[1] + GRID_HEIGHT * CELL_SIZE + 40\nFPS           = 60\nFALL_EVENT    = pygame.USEREVENT + 1\nFALL_INTERVAL = 500  # milliseconds\n\nclass Tetromino:\n    def __init__(self, kind):\n        self.kind     = kind\n        self.shape    = TETROMINO_SHAPES[kind]\n        self.color    = GEM_COLORS[kind]\n        self.rotation = 0\n        self.x        = GRID_WIDTH // 2 - 2\n        self.y        = 0\n\n    def blocks(self):\n        cells = []\n        for dx, dy in self.shape:\n            x, y = dx, dy\n            for _ in range(self.rotation):\n                x, y = y, 3 - x\n            cells.append((self.x + x, self.y + y))\n        return cells\n\n    def move(self, dx, dy, grid):\n        new_positions = [(x + dx, y + dy) for x, y in self.blocks()]\n        if all(0 <= x < grid.width and 0 <= y < grid.height and grid.get_cell(x, y) is None\n               for x, y in new_positions):\n            self.x += dx\n            self.y += dy\n            return True\n        return False\n\n    def rotate_cw(self, grid):\n        old_rot = self.rotation\n        self.rotation = (self.rotation + 1) % 4\n        if any(not (0 <= x < grid.width and 0 <= y < grid.height and grid.get_cell(x, y) is None)\n               for x, y in self.blocks()):\n            self.rotation = old_rot\n\nclass Game:\n    def __init__(self):\n        pygame.init()\n        self.screen    = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\n        pygame.display.set_caption(\"Tetris-Bejeweled Hybrid\")\n        self.clock     = pygame.time.Clock()\n        self.font      = pygame.font.SysFont(None, 36)\n        self.grid      = GameGrid(width=GRID_WIDTH, height=GRID_HEIGHT)\n        self.score     = 0\n        self.current   = self._next_tetromino()\n        self.next_piece= self._next_tetromino()\n        self.game_over = False\n        pygame.time.set_timer(FALL_EVENT, FALL_INTERVAL)\n\n    def _next_tetromino(self):\n        kind = random.choice(list(TETROMINO_SHAPES.keys()))\n        return Tetromino(kind)\n\n    def lock_piece(self):\n        for x, y in self.current.blocks():\n            self.grid.set_cell(x, y, Gem(self.current.color))\n        self.score += self.grid.process_clears()\n        self.current = self.next_piece\n        self.next_piece = self._next_tetromino()\n        if any(self.grid.get_cell(x, y) is not None for x, y in self.current.blocks()):\n            self.game_over = True\n\n    def handle_input(self, event):\n        if event.type == pygame.KEYDOWN and not self.game_over:\n            if event.key == pygame.K_LEFT:\n                self.current.move(-1, 0, self.grid)\n            elif event.key == pygame.K_RIGHT:\n                self.current.move(1, 0, self.grid)\n            elif event.key == pygame.K_DOWN:\n                if self.current.move(0, 1, self.grid):\n                    self.score += 1\n            elif event.key == pygame.K_UP:\n                self.current.rotate_cw(self.grid)\n        if event.type == FALL_EVENT and not self.game_over:\n            if not self.current.move(0, 1, self.grid):\n                self.lock_piece()\n\n    def draw_grid(self):\n        for y in range(self.grid.height):\n            for x in range(self.grid.width):\n                rect = pygame.Rect(\n                    GRID_ORIGIN[0] + x * CELL_SIZE,\n                    GRID_ORIGIN[1] + y * CELL_SIZE,\n                    CELL_SIZE, CELL_SIZE\n                )\n                pygame.draw.rect(self.screen, (50, 50, 50), rect, 1)\n                cell = self.grid.get_cell(x, y)\n                if cell:\n                    pygame.draw.rect(self.screen, cell.color,\n                                     rect.inflate(-2, -2))\n\n    def draw_current(self):\n        for x, y in self.current.blocks():\n            rect = pygame.Rect(\n                GRID_ORIGIN[0] + x * CELL_SIZE,\n                GRID_ORIGIN[1] + y * CELL_SIZE,\n                CELL_SIZE, CELL_SIZE\n            )\n            pygame.draw.rect(self.screen, self.current.color,\n                             rect.inflate(-2, -2))\n\n    def draw_preview(self):\n        label = self.font.render(\"Next:\", True, (255, 255, 255))\n        self.screen.blit(label, (PREVIEW_ORIGIN[0], PREVIEW_ORIGIN[1] - 30))\n        for dx, dy in self.next_piece.shape:\n            px = PREVIEW_ORIGIN[0] + dx * CELL_SIZE\n            py = PREVIEW_ORIGIN[1] + dy * CELL_SIZE\n            rect = pygame.Rect(px, py, CELL_SIZE, CELL_SIZE)\n            pygame.draw.rect(self.screen, (100, 100, 100), rect, 1)\n            pygame.draw.rect(self.screen, self.next_piece.color, rect.inflate(-2, -2))\n\n    def draw_score(self):\n        txt = self.font.render(f\"Score: {self.score}\", True, (255, 255, 255))\n        self.screen.blit(txt, (PREVIEW_ORIGIN[0], PREVIEW_ORIGIN[1] + 4 * CELL_SIZE + 20))\n\n    def draw_game_over(self):\n        msg  = self.font.render(\"GAME OVER\", True, (200, 0, 0))\n        rect = msg.get_rect(center=(SCREEN_WIDTH // 2, SCREEN_HEIGHT // 2))\n        self.screen.blit(msg, rect)\n\n    def run(self):\n        while True:\n            for event in pygame.event.get():\n                if event.type == pygame.QUIT:\n                    pygame.quit()\n                    sys.exit()\n                self.handle_input(event)\n\n            self.screen.fill((0, 0, 0))\n            self.draw_grid()\n            self.draw_current()\n            self.draw_preview()\n            self.draw_score()\n            if self.game_over:\n                self.draw_game_over()\n\n            pygame.display.flip()\n            self.clock.tick(FPS)\n\nif __name__ == \"__main__\":\n    Game().run()\n```"}
