\n    - Technical assessment\\n    - Behavioral assessment\\n    - Strengths and weaknesses\\n    - Final recommendation and scoring breakdown\\n\\nFinal output: Evaluation report of candidate in .txt\\n\\n---\\n# **Context from Upstream Tasks**\\nNo completed previous tasks context available.\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task5:\\n  Objective: Implement a report generator that compiles resume-job match, interview summary, technical & behavioral assessments, strengths/weaknesses, and final recommendations into a .txt file.\\n\\n---\\n# **Current Task Requirements**\\nImplement an evaluation engine that scores candidate answers on relevance, depth, confidence, and technical accuracy across categories.\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nclass EvaluationEngine:\\n    \\\"\\\"\\\"\\n    A class to evaluate candidate answers based on relevance, depth,\\n    confidence, and technical accuracy across different categories.\\n    \\\"\\\"\\\"\\n\\n    def __init__(self, weight_relevance=0.25, weight_depth=0.25,\\n                 weight_confidence=0.25, weight_accuracy=0.25):\\n        \\\"\\\"\\\"\\n        Initializes the EvaluationEngine with weights for each evaluation criterion.\\n\\n        Args:\\n            weight_relevance (float): Weight for relevance score.\\n            weight_depth (float): Weight for depth score.\\n            weight_confidence (float): Weight for confidence score.\\n            weight_accuracy (float): Weight for technical accuracy score.\\n        \\\"\\\"\\\"\\n        self.weight_relevance = weight_relevance\\n        self.weight_depth = weight_depth\\n        self.weight_confidence = weight_confidence\\n        self.weight_accuracy = weight_accuracy\\n\\n    def evaluate_answer(self, answer, expected_answer, technical_domain,\\n                        relevance_rubric, depth_rubric, confidence_rubric, accuracy_rubric):\\n        \\\"\\\"\\\"\\n        Evaluates a candidate's answer based on predefined rubrics.\\n\\n        Args:\\n            answer (str): The candidate's answer.\\n            expected_answer (str): The ideal or expected answer.\\n            technical_domain (str): The technical area the question pertains to.\\n            relevance_rubric (dict): A dictionary mapping relevance levels (e.g., \\\"High\\\", \\\"Medium\\\", \\\"Low\\\") to scores (0-10).\\n            depth_rubric (dict): A dictionary mapping depth levels to scores (0-10).\\n            confidence_rubric (dict): A dictionary mapping confidence levels to scores (0-10).\\n            accuracy_rubric (dict): A dictionary mapping accuracy levels to scores (0-10).\\n\\n        Returns:\\n            dict: A dictionary containing scores for relevance, depth, confidence,\\n                  technical accuracy, and an overall score. The keys will be 'relevance_score',\\n                  'depth_score', 'confidence_score', 'accuracy_score', and 'overall_score'.\\n        \\\"\\\"\\\"\\n\\n        relevance_level = self._assess_relevance(answer, expected_answer)\\n        depth_level = self._assess_depth(answer, expected_answer)\\n        confidence_level = self._assess_confidence(answer)\\n        accuracy_level = self._assess_accuracy(answer, expected_answer, technical_domain)\\n\\n        relevance_score = relevance_rubric.get(relevance_level, 0)\\n        depth_score = depth_rubric.get(depth_level, 0)\\n        confidence_score = confidence_rubric.get(confidence_level, 0)\\n        accuracy_score = accuracy_rubric.get(accuracy_level, 0)\\n\\n        overall_score = (\\n            self.weight_relevance * relevance_score +\\n            self.weight_depth * depth_score +\\n            self.weight_confidence * confidence_score +\\n            self.weight_accuracy * accuracy_score\\n        )\\n\\n        return {\\n            'relevance_score': relevance_score,\\n            'depth_score': depth_score,\\n            'confidence_score': confidence_score,\\n            'accuracy_score': accuracy_score,\\n            'overall_score': overall_score\\n        }\\n\\n    def _assess_relevance(self, answer, expected_answer):\\n        \\\"\\\"\\\"\\n        Assesses the relevance of the answer to the expected answer.\\n        This is a placeholder and needs to be implemented with NLP techniques.\\n\\n        Args:\\n            answer (str): The candidate's answer.\\n            expected_answer (str): The ideal answer.\\n\\n        Returns:\\n            str: Relevance level (e.g., \\\"High\\\", \\\"Medium\\\", \\\"Low\\\").\\n        \\\"\\\"\\\"\\n        # Placeholder implementation; replace with NLP-based relevance detection\\n        if answer and expected_answer:\\n            return \\\"Medium\\\"\\n        else:\\n            return \\\"Low\\\"\\n\\n    def _assess_depth(self, answer, expected_answer):\\n        \\\"\\\"\\\"\\n        Assesses the depth of the answer compared to the expected answer.\\n        This is a placeholder and needs to be implemented with NLP techniques.\\n\\n        Args:\\n            answer (str): The candidate's answer.\\n            expected_answer (str): The ideal answer.\\n\\n        Returns:\\n            str: Depth level (e.g., \\\"High\\\", \\\"Medium\\\", \\\"Low\\\").\\n        \\\"\\\"\\\"\\n        # Placeholder implementation; replace with NLP-based depth analysis\\n        if len(answer) > 50:\\n            return \\\"Medium\\\"\\n        else:\\n            return \\\"Low\\\"\\n\\n    def _assess_confidence(self, answer):\\n        \\\"\\\"\\\"\\n        Assesses the confidence level conveyed in the answer.\\n        This is a placeholder and needs to be implemented with NLP techniques (sentiment analysis).\\n\\n        Args:\\n            answer (str): The candidate's answer.\\n\\n        Returns:\\n            str: Confidence level (e.g., \\\"High\\\", \\\"Medium\\\", \\\"Low\\\").\\n        \\\"\\\"\\\"\\n        # Placeholder implementation; replace with sentiment analysis\\n        if \\\"I think\\\" not in answer:\\n            return \\\"Medium\\\"\\n        else:\\n            return \\\"Low\\\"\\n\\n    def _assess_accuracy(self, answer, expected_answer, technical_domain):\\n        \\\"\\\"\\\"\\n        Assesses the technical accuracy of the answer.\\n        This is a placeholder and needs to be implemented with domain-specific knowledge.\\n\\n        Args:\\n            answer (str): The candidate's answer.\\n            expected_answer (str): The ideal answer.\\n            technical_domain (str): The technical domain of the question.\\n\\n        Returns:\\n            str: Accuracy level (e.g., \\\"High\\\", \\\"Medium\\\", \\\"Low\\\").\\n        \\\"\\\"\\\"\\n        # Placeholder implementation; needs domain-specific implementation\\n        if technical_domain == \\\"Python\\\":\\n           if \\\"def\\\" in answer:\\n                return \\\"Medium\\\"\\n           else:\\n                return \\\"Low\\\"\\n        else:\\n            return \\\"Low\\\"\\n\\n\\nif __name__ == '__main__':\\n    # Example Usage:\\n    engine = EvaluationEngine()\\n\\n    # Define rubrics\\n    relevance_rubric = {\\\"High\\\": 10, \\\"Medium\\\": 7, \\\"Low\\\": 3}\\n    depth_rubric = {\\\"High\\\": 10, \\\"Medium\\\": 7, \\\"Low\\\": 3}\\n    confidence_rubric = {\\\"High\\\": 10, \\\"Medium\\\": 7, \\\"Low\\\": 3}\\n    accuracy_rubric = {\\\"High\\\": 10, \\\"Medium\\\": 7, \\\"Low\\\": 3}\\n\\n    # Example question and answer\\n    candidate_answer = \\\"It's a way to define functions in Python.\\\"\\n    expected_answer = \\\"The 'def' keyword is used to define functions in Python.\\\"\\n    technical_domain = \\\"Python\\\"\\n\\n    # Evaluate the answer\\n    scores = engine.evaluate_answer(\\n        candidate_answer, expected_answer, technical_domain,\\n        relevance_rubric, depth_rubric, confidence_rubric, accuracy_rubric\\n    )\\n\\n    print(scores)\\n```\",\n  \"timestamp\": \"2026-05-26T16:20:47.677528\"\n}"}
{"timestamp": "2026-05-26 16:20:49,299", "level": "INFO", "logger": "flow.validation", "module": "logging_config", "function": "log_gpt_conversation", "line": 403, "message": "{\n  \"event_type\": \"gpt_conversation\",\n  \"task_id\": \"task_2\",\n  \"conversation_type\": \"task_execution\",\n  \"iteration\": 1,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"\\n# Role:\\nHelp me produce a precise and detailed solution for the given task. Follow these instructions exactly:\\n\\n# Objective & Steps:\\n1. Ensure Completeness:\\n   - Avoid placeholders or incomplete text.\\n   - Your output must meet all requirements of the task.\\n   - Include all necessary details so that the output is self-contained and can be directly used as input for downstream tasks.\\n\\n2. Maintain Precision and Clarity:\\n   - Your output will be used as input for subsequent tasks; therefore, it must be comprehensive and precise.\\n   - **Output the answer only without any jusifications**\\n\\n3. Avoid Repetition:\\n   - Do not repeat verbatim any content from previous tasks.\\n   - Ensure your output is original and adds value to the workflow.\\n\\n\\n\\n# Audience:\\nYour output will be used as a solution for the given task, it will be used in the later validation and intergration process.\\n\\n\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"# **The Overall Goal**\\nPerform interview and candidate evaluation for a candidate.\\n- Analyze job descriptions and candidate resumes\\n- Conduct  interviews with technical and behavioral questions\\n- Ask follow-up questions based on candidate responses\\n- Evaluate candidate answers for relevance, depth, confidence, and technical accuracy\\n- Score candidates across multiple evaluation categories\\n- Generate recruiter communication emails such as interview invitations and follow-ups\\n- Produce a final candidate evaluation report containing:\\n    - Resume-job match analysis\\n    - Interview summary\\n    - Technical assessment\\n    - Behavioral assessment\\n    - Strengths and weaknesses\\n    - Final recommendation and scoring breakdown\\n\\nFinal output: Evaluation report of candidate in .txt\\n\\n---\\n# **Context from Upstream Tasks**\\nNo completed previous tasks context available.\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task2:\\n  Objective: Build a follow-up question generation component that dynamically creates questions based on candidate responses.\\n\\n---\\n# **Current Task Requirements**\\nDevelop an interview question generator for technical and behavioral topics based on the role requirements.\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport json\\nimport random\\n\\nclass InterviewQuestionGenerator:\\n    def __init__(self, job_description_path):\\n        \\\"\\\"\\\"\\n        Initializes the InterviewQuestionGenerator with a job description.\\n\\n        Args:\\n            job_description_path (str): Path to the JSON file containing the job description.\\n        \\\"\\\"\\\"\\n        self.job_description_path = job_description_path\\n        self.job_description = self._load_job_description()\\n        self.technical_keywords = self._extract_keywords(\\\"technical_skills\\\")\\n        self.soft_skills = self._extract_keywords(\\\"soft_skills\\\")\\n\\n    def _load_job_description(self):\\n        \\\"\\\"\\\"\\n        Loads the job description from the specified JSON file.\\n\\n        Returns:\\n            dict: A dictionary containing the job description.\\n        \\\"\\\"\\\"\\n        try:\\n            with open(self.job_description_path, 'r') as f:\\n                job_description = json.load(f)\\n            return job_description\\n        except FileNotFoundError:\\n            print(f\\\"Error: Job description file not found at {self.job_description_path}\\\")\\n            return {}\\n        except json.JSONDecodeError:\\n            print(f\\\"Error: Invalid JSON format in {self.job_description_path}\\\")\\n            return {}\\n\\n    def _extract_keywords(self, key):\\n        \\\"\\\"\\\"\\n        Extracts keywords (technical skills or soft skills) from the job description.\\n\\n        Args:\\n            key (str): The key in the job description dictionary corresponding to the skills (e.g., \\\"technical_skills\\\", \\\"soft_skills\\\").\\n\\n        Returns:\\n            list: A list of keywords. Returns an empty list if the key is not found or the value is not a list.\\n        \\\"\\\"\\\"\\n        if key in self.job_description and isinstance(self.job_description[key], list):\\n            return self.job_description[key]\\n        else:\\n            return []\\n\\n    def generate_technical_questions(self, num_questions=3):\\n        \\\"\\\"\\\"\\n        Generates technical interview questions based on the job description and technical keywords.\\n\\n        Args:\\n            num_questions (int): The number of technical questions to generate.  Defaults to 3.\\n\\n        Returns:\\n            list: A list of technical interview questions.\\n        \\\"\\\"\\\"\\n        questions = []\\n        if not self.technical_keywords:\\n            return [\\\"No technical skills specified in job description. Cannot generate questions.\\\"]\\n\\n        # Sample questions for each technical keyword.\\n        keyword_questions = {\\n            keyword: [\\n                f\\\"Explain your experience with {keyword}.\\\",\\n                f\\\"Describe a project where you used {keyword}.\\\",\\n                f\\\"What are the advantages and disadvantages of using {keyword}?\\\",\\n                f\\\"How do you troubleshoot issues related to {keyword}?\\\",\\n                f\\\"What are the best practices for using {keyword}?\\\"\\n            ]\\n            for keyword in self.technical_keywords\\n        }\\n\\n        # Select N number of questions.\\n        selected_keywords = random.sample(self.technical_keywords, min(num_questions, len(self.technical_keywords)))\\n        for keyword in selected_keywords:\\n            questions.append(random.choice(keyword_questions[keyword]))\\n        return questions\\n\\n    def generate_behavioral_questions(self, num_questions=3):\\n        \\\"\\\"\\\"\\n        Generates behavioral interview questions based on the job description and soft skills.\\n\\n        Args:\\n            num_questions (int): The number of behavioral questions to generate. Defaults to 3.\\n\\n        Returns:\\n            list: A list of behavioral interview questions.\\n        \\\"\\\"\\\"\\n        questions = []\\n        if not self.soft_skills:\\n            return [\\\"No soft skills specified in job description. Cannot generate questions.\\\"]\\n\\n        # Sample questions for each soft skill.\\n        soft_skill_questions = {\\n            skill: [\\n                f\\\"Tell me about a time you demonstrated {skill}.\\\",\\n                f\\\"Describe a situation where {skill} was crucial to your success.\\\",\\n                f\\\"How do you handle situations where you need to improve your {skill}?\\\",\\n                f\\\"Give an example of when you had to use {skill} under pressure.\\\",\\n                f\\\"How do you ensure you are effectively using {skill} in your daily work?\\\"\\n            ]\\n            for skill in self.soft_skills\\n        }\\n\\n        # Select N number of questions.\\n        selected_skills = random.sample(self.soft_skills, min(num_questions, len(self.soft_skills)))\\n        for skill in selected_skills:\\n            questions.append(random.choice(soft_skill_questions[skill]))\\n        return questions\\n\\n    def generate_follow_up_question(self, last_question, candidate_answer):\\n      \\\"\\\"\\\"\\n      Generates a follow-up question based on the previous question and the candidate's answer.\\n\\n      Args:\\n          last_question (str): The question previously asked.\\n          candidate_answer (str): The candidate's response to the previous question.\\n\\n      Returns:\\n          str: A follow-up question. Returns None if a follow-up cannot be generated.\\n      \\\"\\\"\\\"\\n      if not last_question or not candidate_answer:\\n          return None\\n\\n      # Simple example: Look for keywords in the answer and ask for more detail.\\n      answer_keywords = candidate_answer.lower().split()\\n      if self.technical_keywords:\\n          relevant_keywords = [keyword for keyword in self.technical_keywords if keyword.lower() in answer_keywords]\\n\\n          if relevant_keywords:\\n              keyword = random.choice(relevant_keywords)\\n              return f\\\"You mentioned {keyword}. Could you elaborate on your experience using it in more complex scenarios?\\\"\\n      if self.soft_skills:\\n          relevant_skills = [skill for skill in self.soft_skills if skill.lower() in answer_keywords]\\n          if relevant_skills:\\n              skill = random.choice(relevant_skills)\\n              return f\\\"You mentioned {skill}. Can you provide another example where you effectively used {skill}?\\\"\\n      return \\\"That's interesting. Can you tell me more about that?\\\"\\nif __name__ == '__main__':\\n    # Example Usage\\n    job_description = {\\n        \\\"title\\\": \\\"Software Engineer\\\",\\n        \\\"technical_skills\\\": [\\\"Python\\\", \\\"Django\\\", \\\"REST API\\\", \\\"SQL\\\"],\\n        \\\"soft_skills\\\": [\\\"Communication\\\", \\\"Teamwork\\\", \\\"Problem-solving\\\"]\\n    }\\n    with open(\\\"job_description.json\\\", \\\"w\\\") as f:\\n        json.dump(job_description, f)\\n\\n    generator = InterviewQuestionGenerator(\\\"job_description.json\\\")\\n\\n    technical_questions = generator.generate_technical_questions(2)\\n    print(\\\"Technical Questions:\\\", technical_questions)\\n\\n    behavioral_questions = generator.generate_behavioral_questions(2)\\n    print(\\\"Behavioral Questions:\\\", behavioral_questions)\\n\\n    # Example Follow-up Question\\n    last_question = \\\"Tell me about a time you demonstrated teamwork.\\\"\\n    candidate_answer = \\\"I worked on a project where communication was key. We used Slack and regular meetings.\\\"\\n    follow_up = generator.generate_follow_up_question(last_question, candidate_answer)\\n    print(\\\"Follow-up Question:\\\", follow_up)\\n```\",\n  \"timestamp\": \"2026-05-26T16:20:49.299726\"\n}"}
