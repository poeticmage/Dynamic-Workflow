echnical_questions(self, job_description):\\n        \\\"\\\"\\\"\\n        Generates technical interview questions based on the job description.\\n\\n        Args:\\n            job_description (str): The job description for the role.\\n\\n        Returns:\\n            list: A list of technical interview questions.\\n        \\\"\\\"\\\"\\n        technical_questions = []\\n\\n        # Extract technical skills from job description\\n        skills = self.extract_skills(job_description)\\n\\n        # Generate questions based on the extracted skills\\n        for skill in skills:\\n            technical_questions.append(f\\\"Explain your experience with {skill}.\\\")\\n            technical_questions.append(f\\\"Describe a project where you used {skill}.\\\")\\n            technical_questions.append(f\\\"What are the advantages and disadvantages of using {skill}?\\\")\\n            technical_questions.append(f\\\"How do you troubleshoot issues related to {skill}?\\\")\\n\\n        # Add some general technical questions\\n        technical_questions.append(\\\"Describe your experience with software development methodologies (e.g., Agile, Waterfall).\\\")\\n        technical_questions.append(\\\"Explain the difference between a stack and a queue.\\\")\\n        technical_questions.append(\\\"What is the purpose of version control systems like Git?\\\")\\n        technical_questions.append(\\\"How do you approach debugging a complex software issue?\\\")\\n        technical_questions.append(\\\"Explain the concept of object-oriented programming.\\\")\\n\\n        return technical_questions\\n\\n    def generate_behavioral_questions(self):\\n        \\\"\\\"\\\"\\n        Generates behavioral interview questions based on the role requirements.\\n\\n        Returns:\\n            list: A list of behavioral interview questions.\\n        \\\"\\\"\\\"\\n        behavioral_questions = []\\n\\n        # Generate questions based on common behavioral competencies\\n        behavioral_questions.append(\\\"Tell me about a time you had to work under pressure. How did you handle it?\\\")\\n        behavioral_questions.append(\\\"Describe a situation where you had to deal with a difficult colleague. How did you resolve the conflict?\\\")\\n        behavioral_questions.append(\\\"Give an example of a time you failed. What did you learn from it?\\\")\\n        behavioral_questions.append(\\\"Tell me about a time you had to make a quick decision with limited information.\\\")\\n        behavioral_questions.append(\\\"Describe a situation where you had to lead a team to achieve a common goal.\\\")\\n        behavioral_questions.append(\\\"How do you handle receiving negative feedback?\\\")\\n        behavioral_questions.append(\\\"Tell me about a time you went above and beyond what was expected of you.\\\")\\n        behavioral_questions.append(\\\"Describe your approach to problem-solving.\\\")\\n        behavioral_questions.append(\\\"How do you stay motivated and productive when facing challenging tasks?\\\")\\n        behavioral_questions.append(\\\"Explain how you prioritize tasks when faced with multiple deadlines.\\\")\\n        behavioral_questions.append(\\\"Describe a time when you had to adapt to a significant change in the workplace.\\\")\\n\\n        return behavioral_questions\\n\\n    def extract_skills(self, job_description):\\n        \\\"\\\"\\\"\\n        Extracts technical skills from the job description.\\n\\n        Args:\\n            job_description (str): The job description.\\n\\n        Returns:\\n            list: A list of extracted skills.\\n        \\\"\\\"\\\"\\n        # This is a placeholder.  A more sophisticated implementation would use NLP techniques.\\n        # For now, let's just return some hardcoded skills based on common keywords.\\n        skills = []\\n        job_description = job_description.lower()\\n        if \\\"python\\\" in job_description:\\n            skills.append(\\\"Python\\\")\\n        if \\\"java\\\" in job_description:\\n            skills.append(\\\"Java\\\")\\n        if \\\"c++\\\" in job_description:\\n            skills.append(\\\"C++\\\")\\n        if \\\"javascript\\\" in job_description:\\n            skills.append(\\\"JavaScript\\\")\\n        if \\\"sql\\\" in job_description:\\n            skills.append(\\\"SQL\\\")\\n        if \\\"aws\\\" in job_description:\\n            skills.append(\\\"AWS\\\")\\n        if \\\"azure\\\" in job_description:\\n            skills.append(\\\"Azure\\\")\\n        if \\\"docker\\\" in job_description:\\n            skills.append(\\\"Docker\\\")\\n        if \\\"kubernetes\\\" in job_description:\\n            skills.append(\\\"Kubernetes\\\")\\n        if \\\"machine learning\\\" in job_description:\\n            skills.append(\\\"Machine Learning\\\")\\n        if \\\"data science\\\" in job_description:\\n            skills.append(\\\"Data Science\\\")\\n        return skills\\n\\nif __name__ == '__main__':\\n    # Example Usage\\n    role_requirements = \\\"Software Engineer with experience in Python and AWS.\\\"\\n    job_description = \\\"\\\"\\\"\\n    We are looking for a Software Engineer to join our team.\\n    The ideal candidate should have experience with Python, AWS, and SQL.\\n    Experience with Docker and Kubernetes is a plus.\\n    \\\"\\\"\\\"\\n\\n    question_generator = InterviewQuestionGenerator(role_requirements)\\n\\n    technical_questions = question_generator.generate_technical_questions(job_description)\\n    print(\\\"Technical Questions:\\\")\\n    for question in technical_questions:\\n        print(f\\\"- {question}\\\")\\n\\n    behavioral_questions = question_generator.generate_behavioral_questions()\\n    print(\\\"\\\\nBehavioral Questions:\\\")\\n    for question in behavioral_questions:\\n        print(f\\\"- {question}\\\")\\n```\"\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": \"---\\n## FEEDBACK to VERSION 0\\nhere are some feedbacks:\\n- The `generate_behavioral_questions` method doesn’t leverage `role_requirements`, so behavioral questions aren’t tailored to the specific role.\\n- It would be useful to extract both technical skills and behavioral competencies from `role_requirements` and generate questions based on each.\\n- Add an `extract_competencies` method and update `generate_behavioral_questions` to use it.\\n- Provide a `generate_all_questions` wrapper to return both technical and behavioral questions in one call.\\n- Allow customization of the number of generic questions if needed.\\n\\nhere are the changes:\\n```python\\nclass InterviewQuestionGenerator:\\n    def __init__(self, role_requirements):\\n        \\\"\\\"\\\"\\n        Initializes the InterviewQuestionGenerator with the role requirements.\\n\\n        Args:\\n            role_requirements (str): A description of the role requirements.\\n        \\\"\\\"\\\"\\n        self.role_requirements = role_requirements.lower()\\n        self.skills = self.extract_skills(self.role_requirements)\\n        self.competencies = self.extract_competencies(self.role_requirements)\\n\\n    def extract_skills(self, text):\\n        \\\"\\\"\\\"\\n        Extracts technical skills from a text.\\n\\n        Args:\\n            text (str): The text to analyze.\\n\\n        Returns:\\n            list: A list of extracted technical skills.\\n        \\\"\\\"\\\"\\n        keywords = {\\n            \\\"python\\\": \\\"Python\\\",\\n            \\\"java\\\": \\\"Java\\\",\\n            \\\"c++\\\": \\\"C++\\\",\\n            \\\"javascript\\\": \\\"JavaScript\\\",\\n            \\\"sql\\\": \\\"SQL\\\",\\n            \\\"aws\\\": \\\"AWS\\\",\\n            \\\"azure\\\": \\\"Azure\\\",\\n            \\\"docker\\\": \\\"Docker\\\",\\n            \\\"kubernetes\\\": \\\"Kubernetes\\\",\\n            \\\"machine learning\\\": \\\"Machine Learning\\\",\\n            \\\"data science\\\": \\\"Data Science\\\",\\n        }\\n        return [name for key, name in keywords.items() if key in text]\\n\\n    def extract_competencies(self, text):\\n        \\\"\\\"\\\"\\n        Extracts behavioral competencies from a text.\\n\\n        Args:\\n            text (str): The text to analyze.\\n\\n        Returns:\\n            list: A list of extracted behavioral competencies.\\n        \\\"\\\"\\\"\\n        keywords = {\\n            \\\"lead\\\": \\\"leadership\\\",\\n            \\\"team\\\": \\\"teamwork\\\",\\n            \\\"solve\\\": \\\"problem solving\\\",\\n            \\\"adapt\\\": \\\"adaptability\\\",\\n            \\\"communic\\\": \\\"communication\\\",\\n            \\\"decis\\\": \\\"decision making\\\",\\n            \\\"innov\\\": \\\"innovation\\\",\\n            \\\"press\\\": \\\"working under pressure\\\",\\n            \\\"feedback\\\": \\\"receptiveness to feedback\\\",\\n            \\\"deadline\\\": \\\"time management\\\",\\n        }\\n        found = set()\\n        for key, comp in keywords.items():\\n            if key in text:\\n                found.add(comp)\\n        return list(found)\\n\\n    def generate_technical_questions(self, job_description):\\n        \\\"\\\"\\\"\\n        Generates technical interview questions based on the job description.\\n\\n        Args:\\n            job_description (str): The job description for the role.\\n\\n        Returns:\\n            list: A list of technical interview questions.\\n        \\\"\\\"\\\"\\n        tech_questions = []\\n        jd = job_description.lower()\\n        skills = self.extract_skills(jd)\\n\\n        # Questions per skill\\n        for skill in skills:\\n            tech_questions.extend([\\n                f\\\"Explain your experience with {skill}.\\\",\\n                f\\\"Describe a project where you used {skill}.\\\",\\n                f\\\"What are the advantages and disadvantages of using {skill}?\\\",\\n                f\\\"How do you troubleshoot issues related to {skill}?\\\"\\n            ])\\n\\n        # Some generic technical questions\\n        generic_tech = [\\n            \\\"Describe your experience with software development methodologies (e.g., Agile, Waterfall).\\\",\\n            \\\"Explain the difference between a stack and a queue.\\\",\\n            \\\"What is the purpose of version control systems like Git?\\\",\\n            \\\"How do you approach debugging a complex software issue?\\\",\\n            \\\"Explain the concept of object-oriented programming.\\\"\\n        ]\\n        tech_questions.extend(generic_tech)\\n        return tech_questions\\n\\n    def generate_behavioral_questions(self):\\n        \\\"\\\"\\\"\\n        Generates behavioral interview questions based on extracted competencies.\\n\\n        Returns:\\n            list: A list of behavioral interview questions.\\n        \\\"\\\"\\\"\\n        beh_questions = []\\n\\n        # Tailored questions per competency\\n        for comp in self.competencies:\\n            if comp == \\\"leadership\\\":\\n                beh_questions.append(\\\"Give an example of a time you had to lead a team to achieve a goal.\\\")\\n            elif comp == \\\"teamwork\\\":\\n                beh_questions.append(\\\"Describe a situation where you collaborated effectively with colleagues.\\\")\\n            elif comp == \\\"problem solving\\\":\\n                beh_questions.append(\\\"Tell me about a challenging problem you solved and your approach.\\\")\\n            elif comp == \\\"adaptability\\\":\\n                beh_questions.append(\\\"Describe a time you had to adapt to significant change at work.\\\")\\n            elif comp == \\\"communication\\\":\\n                beh_questions.append(\\\"Provide an example of how you have communicated complex ideas to non-technical stakeholders.\\\")\\n            elif comp == \\\"decision making\\\":\\n                beh_questions.append(\\\"Tell me about a difficult decision you made with incomplete information.\\\")\\n            elif comp == \\\"innovation\\\":\\n                beh_questions.append(\\\"Describe a time you introduced an innovative solution to a problem.\\\")\\n            elif comp == \\\"working under pressure\\\":\\n                beh_questions.append(\\\"Tell me about a time you had to work under tight deadlines. How did you manage?\\\")\\n            elif comp == \\\"receptiveness to feedback\\\":\\n                beh_questions.append(\\\"How do you handle and incorporate constructive feedback?\\\")\\n            elif comp == \\\"time management\\\":\\n                beh_questions.append(\\\"Explain how you prioritize tasks when faced with multiple deadlines.\\\")\\n\\n        # Fallback generic behavioral questions if none found\\n        if not beh_questions:\\n            beh_questions = [\\n                \\\"Tell me about a time you failed. What did you learn from it?\\\",\\n                \\\"Describe a situation where you had to deal with a difficult colleague. How did you resolve the conflict?\\\",\\n                \\\"Tell me about a time you went above and beyond what was expected of you.\\\",\\n                \\\"Describe your approach to problem-solving.\\\",\\n                \\\"How do you stay motivated and productive when facing challenging tasks?\\\"\\n            ]\\n        return beh_questions\\n\\n    def generate_all_questions(self, job_description):\\n        \\\"\\\"\\\"\\n        Generates both technical and behavioral questions.\\n\\n        Args:\\n            job_description (str): The job description for the role.\\n\\n        Returns:\\n            dict: A dictionary with 'technical' and 'behavioral' question lists.\\n        \\\"\\\"\\\"\\n        return {\\n            \\\"technical\\\": self.generate_technical_questions(job_description),\\n            \\\"behavioral\\\": self.generate_behavioral_questions()\\n        }\\n\\nif __name__ == '__main__':\\n    # Example Usage\\n    role_requirements = \\\"\\\"\\\"\\n    We need a Senior Software Engineer with Python, AWS, leadership experience,\\n    strong communication skills, and time management ability.\\n    \\\"\\\"\\\"\\n    job_description = \\\"\\\"\\\"\\n    Join our team as a Senior Software Engineer. You will work with Python, AWS, Docker,\\n    and Kubernetes. Experience with JavaScript and SQL is a plus.\\n    \\\"\\\"\\\"\\n\\n    qgen = InterviewQuestionGenerator(role_requirements)\\n    questions = qgen.generate_all_questions(job_description)\\n\\n    print(\\\"Technical Questions:\\\")\\n    for q in questions[\\\"technical\\\"]:\\n        print(f\\\"- {q}\\\")\\n\\n    print(\\\"\\\\nBehavioral Questions:\\\")\\n    for q in questions[\\\"behavioral\\\"]:\\n        print(f\\\"- {q}\\\")\\n```\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"# **The Overall Goal**\\nPerform interview and candidate evaluation for a candidate.\\n- Analyze job descriptions and candidate resumes\\n- Conduct  interviews with technical and behavioral questions\\n- Ask follow-up questions based on candidate responses\\n- Evaluate candidate answers for relevance, depth, confidence, and technical accuracy\\n- Score candidates across multiple evaluation categories\\n- Generate recruiter communication emails such as interview invitations and follow-ups\\n- Produce a final candidate evaluation report containing:\\n    - Resume-job match analysis\\n    - Interview summary\\n    - Technical assessment\\n    - Behavioral assessment\\n    - Strengths and weaknesses\\n    - Final recommendation and scoring breakdown\\n\\nFinal output: Evaluation report of candidate in .txt\\n\\n---\\n# **Context from Upstream Tasks**\\nTask task4:\\n  Objective: Develop a recruiter email generator for sending interview invitations and follow-up messages.\\n  Result: ```python\\nimport smtplib\\nfrom email.mime.text import MIMEText\\nfrom datetime import datetime, timedelta\\n\\nclass EmailGenerator:\\n    def __init__(self, smtp_server, smtp_port, sender_email, sender_password):\\n        self.smtp_server = smtp_server\\n        self.smtp_port = smtp_port\\n        self.sender_email = sender_email\\n        self.sender_password = sender_password\\n\\n    def create_invitation_email(self, recipient_email, candidate_name, role_name, interview_date, interview_time, interviewer_name, interview_details):\\n        \\\"\\\"\\\"Generates an interview invitation email.\\\"\\\"\\\"\\n        subject = f\\\"Interview Invitation for {role_name} at [Company Name]\\\"\\n        body = f\\\"\\\"\\\"Dear {candidate_name},\\n\\nWe are pleased to invite you to an interview for the {role_name} position at [Company Name].\\n\\nDate: {interview_date}\\nTime: {interview_time}\\nInterviewer: {interviewer_name}\\nDetails: {interview_details}\\n\\nPlease confirm your availability by replying to this email.\\n\\nWe look forward to speaking with you.\\n\\nSincerely,\\n[Your Name]\\n[Your Title]\\n[Company Name]\\n\\\"\\\"\\\"\\n        return self.create_email(recipient_email, subject, body)\\n\\n    def create_followup_email(self, recipient_email, candidate_name, interviewer_name, role_name):\\n        \\\"\\\"\\\"Generates a follow-up email after the interview.\\\"\\\"\\\"\\n        subject = f\\\"Following Up on Your Interview for {role_name} at [Company Name]\\\"\\n        body = f\\\"\\\"\\\"Dear {candidate_name},\\n\\nThank you for taking the time to interview for the {role_name} position at [Company Name] with {interviewer_name}.\\n\\nWe appreciate you sharing your experience and qualifications with us. We are currently reviewing all candidates and will be in touch soon regarding the next steps.\\n\\nSincerely,\\n[Your Name]\\n[Your Title]\\n[Company Name]\\n\\\"\\\"\\\"\\n        return self.create_email(recipient_email, subject, body)\\n\\n    def create_rejection_email(self, recipient_email, candidate_name, role_name):\\n        \\\"\\\"\\\"Generates a rejection email.\\\"\\\"\\\"\\n        subject = f\\\"Update on Your Application for {role_name} at [Company Name]\\\"\\n        body = f\\\"\\\"\\\"Dear {candidate_name},\\n\\nThank you for your interest in the {role_name} position at [Company Name]. We appreciate you taking the time to apply.\\n\\nWe have carefully reviewed your application and have decided to move forward with other candidates whose qualifications and experience are a closer match for the requirements of this role.\\n\\nWe wish you the best in your job search.\\n\\nSincerely,\\n[Your Name]\\n[Your Title]\\n[Company Name]\\n\\\"\\\"\\\"\\n        return self.create_email(recipient_email, subject, body)\\n\\n    def create_offer_email(self, recipient_email, candidate_name, role_name, salary, start_date):\\n      \\\"\\\"\\\"Generates an offer email.\\\"\\\"\\\"\\n      subject = f\\\"Job Offer: {role_name} at [Company Name]\\\"\\n      body = f\\\"\\\"\\\"Dear {candidate_name},\\n\\nWe are delighted to offer you the position of {role_name} at [Company Name]!\\n\\nWe were very impressed with your qualifications and experience during the interview process.\\n\\nHere are the details of the offer:\\n\\n* Role: {role_name}\\n* Salary: {salary}\\n* Start Date: {start_date}\\n\\nA formal offer letter with more details will follow shortly. Please let us know if you have any questions.\\n\\nWe are excited about the possibility of you joining our team!\\n\\nSincerely,\\n[Your Name]\\n[Your Title]\\n[Company Name]\\n\\\"\\\"\\\"\\n      return self.create_email(recipient_email, subject, body)\\n\\n    def create_email(self, recipient_email, subject, body):\\n        \\\"\\\"\\\"Creates and returns a MIMEText email object.\\\"\\\"\\\"\\n        msg = MIMEText(body)\\n        msg['Subject'] = subject\\n        msg['From'] = self.sender_email\\n        msg['To'] = recipient_email\\n        return msg\\n\\n    def send_email(self, recipient_email, subject, body):\\n        \\\"\\\"\\\"Sends an email.\\\"\\\"\\\"\\n        msg = self.create_email(recipient_email, subject, body)\\n        try:\\n            with smtplib.SMTP(self.smtp_server, self.smtp_port) as server:\\n                server.starttls()\\n                server.login(self.sender_email, self.sender_password)\\n                server.sendmail(self.sender_email, recipient_email, msg.as_string())\\n            print(f\\\"Email sent to {recipient_email}\\\")\\n        except Exception as e:\\n            print(f\\\"Error sending email: {e}\\\")\\n\\n\\nif __name__ == '__main__':\\n    # Example Usage\\n    smtp_server = 'smtp.gmail.com'  # Replace with your SMTP server\\n    smtp_port = 587  # Replace with your SMTP port\\n    sender_email = 'your_email@gmail.com'  # Replace with your email\\n    sender_password = 'your_password'  # Replace with your password (or app password)\\n\\n    email_generator = EmailGenerator(smtp_server, smtp_port, sender_email, sender_password)\\n\\n    # Example: Sending an interview invitation\\n    recipient_email = 'candidate@example.com'\\n    candidate_name = 'Jane Smith'\\n    role_name = 'Software Engineer'\\n    interview_date = datetime.now() + timedelta(days=2)\\n    interview_date_str = interview_date.strftime(\\\"%Y-%m-%d\\\")\\n    interview_time = \\\"10:00 AM\\\"\\n    interviewer_name = 'John Doe'\\n    interview_details = \\\"Please join the Zoom meeting: [Zoom Link]\\\"\\n\\n    email_generator.send_email(recipient_email,\\n                               f\\\"Interview Invitation for {role_name} at [Company Name]\\\",\\n                               email_generator.create_invitation_email(recipient_email, candidate_name, role_name, interview_date_str, interview_time, interviewer_name, interview_details).get_payload()) #Fixed: Correctly pass recipient email, subject, and body\\n\\n    # Example: Sending a follow-up email\\n    email_generator.send_email(recipient_email,\\n                               f\\\"Following Up on Your Interview for {role_name} at [Company Name]\\\",\\n                               email_generator.create_followup_email(recipient_email, candidate_name, interviewer_name, role_name).get_payload())\\n    \\n    # Example: Sending a rejection email\\n    email_generator.send_email(recipient_email,\\n                               f\\\"Update on Your Application for {role_name} at [Company Name]\\\",\\n                               email_generator.create_rejection_email(recipient_email, candidate_name, role_name).get_payload())\\n\\n    # Example: Sending an offer email\\n    email_generator.send_email(recipient_email,\\n                               f\\\"Job Offer: {role_name} at [Company Name]\\\",\\n                               email_generator.create_offer_email(recipient_email, candidate_name, role_name, \\\"$120,000\\\", \\\"2024-08-01\\\").get_payload())\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task2:\\n  Objective: Build a follow-up question generation component that dynamically creates questions based on candidate responses.\\n\\n---\\n# **Current Task Requirements**\\nDevelop an interview question generator for technical and behavioral topics based on the role requirements.\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nclass InterviewQuestionGenerator:\\n    def __init__(self, role_requirements):\\n        \\\"\\\"\\\"\\n        Initializes the InterviewQuestionGenerator with the role requirements.\\n\\n        Args:\\n            role_requirements (str): A description of the role requirements.\\n        \\\"\\\"\\\"\\n        self.role_requirements = role_requirements.lower()\\n        self.skills = self.extract_skills(self.role_requirements)\\n        self.competencies = self.extract_competencies(self.role_requirements)\\n\\n    def extract_skills(self, text):\\n        \\\"\\\"\\\"\\n        Extracts technical skills from a text.\\n\\n        Args:\\n            text (str): The text to analyze.\\n\\n        Returns:\\n            list: A list of extracted technical skills.\\n        \\\"\\\"\\\"\\n        keywords = {\\n            \\\"python\\\": \\\"Python\\\",\\n            \\\"java\\\": \\\"Java\\\",\\n            \\\"c++\\\": \\\"C++\\\",\\n            \\\"javascript\\\": \\\"JavaScript\\\",\\n            \\\"sql\\\": \\\"SQL\\\",\\n            \\\"aws\\\": \\\"AWS\\\",\\n            \\\"azure\\\": \\\"Azure\\\",\\n            \\\"docker\\\": \\\"Docker\\\",\\n            \\\"kubernetes\\\": \\\"Kubernetes\\\",\\n            \\\"machine learning\\\": \\\"Machine Learning\\\",\\n            \\\"data science\\\": \\\"Data Science\\\",\\n            \\\"react\\\": \\\"React\\\",\\n            \\\"angular\\\": \\\"Angular\\\",\\n            \\\"node.js\\\": \\\"Node.js\\\",\\n            \\\"typescript\\\": \\\"TypeScript\\\",\\n            \\\"git\\\": \\\"Git\\\",\\n            \\\"linux\\\": \\\"Linux\\\",\\n            \\\"testing\\\": \\\"Testing\\\",\\n            \\\"cloud computing\\\": \\\"Cloud Computing\\\",\\n            \\\"microservices\\\": \\\"Microservices\\\",\\n            \\\"api\\\": \\\"API\\\",\\n            \\\"database\\\": \\\"Database\\\",\\n        }\\n        return [name for key, name in keywords.items() if key in text]\\n\\n    def extract_competencies(self, text):\\n        \\\"\\\"\\\"\\n        Extracts behavioral competencies from a text.\\n\\n        Args:\\n            text (str): The text to analyze.\\n\\n        Returns:\\n            list: A list of extracted behavioral competencies.\\n        \\\"\\\"\\\"\\n        keywords = {\\n            \\\"lead\\\": \\\"leadership\\\",\\n            \\\"team\\\": \\\"teamwork\\\",\\n            \\\"solve\\\": \\\"problem solving\\\",\\n            \\\"adapt\\\": \\\"adaptability\\\",\\n            \\\"communic\\\": \\\"communication\\\",\\n            \\\"decis\\\": \\\"decision making\\\",\\n            \\\"innov\\\": \\\"innovation\\\",\\n            \\\"press\\\": \\\"working under pressure\\\",\\n            \\\"feedback\\\": \\\"receptiveness to feedback\\\",\\n            \\\"deadline\\\": \\\"time management\\\",\\n            \\\"customer\\\": \\\"customer service\\\",\\n            \\\"analyt\\\": \\\"analytical skills\\\",\\n            \\\"creat\\\": \\\"creativity\\\",\\n            \\\"negotiat\\\": \\\"negotiation\\\",\\n            \\\"conflict\\\": \\\"conflict resolution\\\",\\n            \\\"organize\\\": \\\"organizational skills\\\"\\n        }\\n        found = set()\\n        for key, comp in keywords.items():\\n            if key in text:\\n                found.add(comp)\\n        return list(found)\\n\\n    def generate_technical_questions(self, job_description, num_generic=5):\\n        \\\"\\\"\\\"\\n        Generates technical interview questions based on the job description.\\n\\n        Args:\\n            job_description (str): The job description for the role.\\n            num_generic (int, optional): The number of generic questions to include. Defaults to 5.\\n\\n        Returns:\\n            list: A list of technical interview questions.\\n        \\\"\\\"\\\"\\n        tech_questions = []\\n        jd = job_description.lower()\\n        skills = self.extract_skills(jd)\\n\\n        # Questions per skill\\n        for skill in skills:\\n            tech_questions.extend([\\n                f\\\"Explain your experience with {skill}.\\\",\\n                f\\\"Describe a project where you used {skill}.\\\",\\n                f\\\"What are the advantages and disadvantages of using {skill}?\\\",\\n                f\\\"How do you troubleshoot issues related to {skill}?\\\"\\n            ])\\n\\n        # Some generic technical questions\\n        generic_tech = [\\n            \\\"Describe your experience with software development methodologies (e.g., Agile, Waterfall).\\\",\\n            \\\"Explain the difference between a stack and a queue.\\\",\\n            \\\"What is the purpose of version control systems like Git?\\\",\\n            \\\"How do you approach debugging a complex software issue?\\\",\\n            \\\"Explain the concept of object-oriented programming.\\\",\\n            \\\"What are design patterns and why are they useful?\\\",\\n            \\\"Explain the difference between authentication and authorization.\\\",\\n            \\\"What is CI/CD and how have you used it in the past?\\\",\\n            \\\"Describe your experience with different testing methodologies.\\\",\\n             \\\"How do you ensure code quality?\\\"\\n        ]\\n        tech_questions.extend(generic_tech[:num_generic]) # Take only the specified number of generic questions\\n        return tech_questions\\n\\n    def generate_behavioral_questions(self, num_generic=5):\\n        \\\"\\\"\\\"\\n        Generates behavioral interview questions based on extracted competencies.\\n\\n        Args:\\n            num_generic (int, optional): The number of generic behavioral questions to include if no competencies are found. Defaults to 5.\\n\\n        Returns:\\n            list: A list of behavioral interview questions.\\n        \\\"\\\"\\\"\\n        beh_questions = []\\n\\n        # Tailored questions per competency\\n        for comp in self.competencies:\\n            if comp == \\\"leadership\\\":\\n                beh_questions.append(\\\"Give an example of a time you had to lead a team to achieve a goal.\\\")\\n                beh_questions.append(\\\"Describe a situation where you motivated a team to overcome a challenge.\\\")\\n            elif comp == \\\"teamwork\\\":\\n                beh_questions.append(\\\"Describe a situation where you collaborated effectively with colleagues.\\\")\\n                beh_questions.append(\\\"Tell me about a time you had a conflict within a team and how you resolved it.\\\")\\n            elif comp == \\\"problem solving\\\":\\n                beh_questions.append(\\\"Tell me about a challenging problem you solved and your approach.\\\")\\n                beh_questions.append(\\\"Describe a time when you had to think outside the box to solve a problem.\\\")\\n            elif comp == \\\"adaptability\\\":\\n                beh_questions.append(\\\"Describe a time you had to adapt to significant change at work.\\\")\\n                beh_questions.append(\\\"Tell me about a situation where you had to quickly learn a new technology or skill.\\\")\\n            elif comp == \\\"communication\\\":\\n                beh_questions.append(\\\"Provide an example of how you have communicated complex ideas to non-technical stakeholders.\\\")\\n                beh_questions.append(\\\"Describe a time when you had to deliver bad news. How did you approach it?\\\")\\n            elif comp == \\\"decision making\\\":\\n                beh_questions.append(\\\"Tell me about a difficult decision you made with incomplete information.\\\")\\n                beh_questions.append(\\\"Describe a situation where you had to make a decision under pressure.\\\")\\n            elif comp == \\\"innovation\\\":\\n                beh_questions.append(\\\"Describe a time you introduced an innovative solution to a problem.\\\")\\n                beh_questions.append(\\\"Tell me about a time you saw an opportunity for improvement and what you did.\\\")\\n            elif comp == \\\"working under pressure\\\":\\n                beh_questions.append(\\\"Tell me about a time you had to work under tight deadlines. How did you manage?\\\")\\n                beh_questions.append(\\\"Describe a situation where you had multiple competing priorities. How did you handle it?\\\")\\n            elif comp == \\\"receptiveness to feedback\\\":\\n                beh_questions.append(\\\"How do you handle and incorporate constructive feedback?\\\")\\n                beh_questions.append(\\\"Describe a time you received negative feedback and how you responded.\\\")\\n            elif comp == \\\"time management\\\":\\n                beh_questions.append(\\\"Explain how you prioritize tasks when faced with multiple deadlines.\\\")\\n                beh_questions.append(\\\"Describe your system for staying organized and managing your time effectively.\\\")\\n            elif comp == \\\"customer service\\\":\\n                beh_questions.append(\\\"Describe a time you went above and beyond for a customer.\\\")\\n                beh_questions.append(\\\"How do you handle a difficult or demanding customer?\\\")\\n            elif comp == \\\"analytical skills\\\":\\n                beh_questions.append(\\\"Describe a situation where you used data to make a decision.\\\")\\n                beh_questions.append(\\\"Tell me about a time you had to analyze a complex problem and develop a solution.\\\")\\n            elif comp == \\\"creativity\\\":\\n                beh_questions.append(\\\"Describe a time when you came up with a creative solution to a problem.\\\")\\n                beh_questions.append(\\\"Tell me about a project where you were able to express your creativity.\\\")\\n            elif comp == \\\"negotiation\\\":\\n                beh_questions.append(\\\"Describe a time when you successfully negotiated a deal or agreement.\\\")\\n                beh_questions.append(\\\"Tell me about a negotiation that didn't go as planned. What did you learn?\\\")\\n            elif comp == \\\"conflict resolution\\\":\\n                beh_questions.append(\\\"Describe a time when you successfully resolved a conflict between team members.\\\")\\n                beh_questions.append(\\\"How do you approach a situation where you have a disagreement with a colleague?\\\")\\n            elif comp == \\\"organizational skills\\\":\\n                beh_questions.append(\\\"Describe how you stay organized and manage your time effectively.\\\")\\n                beh_questions.append(\\\"Tell me about a time when your organizational skills helped you succeed on a project.\\\")\\n\\n\\n\\n        # Fallback generic behavioral questions if none found\\n        if not beh_questions:\\n            generic_behavioral = [\\n                \\\"Tell me about a time you failed. What did you learn from it?\\\",\\n                \\\"Describe a situation where you had to deal with a difficult colleague. How did you resolve the conflict?\\\",\\n                \\\"Tell me about a time you went above and beyond what was expected of you.\\\",\\n                \\\"Describe your approach to problem-solving.\\\",\\n                \\\"How do you stay motivated and productive when facing challenging tasks?\\\",\\n                \\\"Describe your proudest professional accomplishment.\\\",\\n                \\\"What are your strengths and weaknesses?\\\",\\n                \\\"Where do you see yourself in 5 years?\\\",\\n                \\\"Why are you interested in this role?\\\",\\n                \\\"Why are you leaving your current company?\\\"\\n            ]\\n            beh_questions.extend(generic_behavioral[:num_generic])\\n        return beh_questions\\n\\n    def generate_all_questions(self, job_description, num_generic_tech=5, num_generic_beh=5):\\n        \\\"\\\"\\\"\\n        Generates both technical and behavioral questions.\\n\\n        Args:\\n            job_description (str): The job description for the role.\\n            num_generic_tech (int, optional): The number of generic technical questions. Defaults to 5.\\n            num_generic_beh (int, optional): The number of generic behavioral questions. Defaults to 5.\\n\\n        Returns:\\n            dict: A dictionary with 'technical' and 'behavioral' question lists.\\n        \\\"\\\"\\\"\\n        return {\\n            \\\"technical\\\": self.generate_technical_questions(job_description, num_generic_tech),\\n            \\\"behavioral\\\": self.generate_behavioral_questions(num_generic_beh)\\n        }\\n\\nif __name__ == '__main__':\\n    # Example Usage\\n    role_requirements = \\\"\\\"\\\"\\n    We need a Senior Software Engineer with Python, AWS, leadership experience,\\n    strong communication skills, and time management ability. Experience with React and Microservices is a plus.\\n    \\\"\\\"\\\"\\n    job_description = \\\"\\\"\\\"\\n    Join our team as a Senior Software Engineer. You will work with Python, AWS, Docker,\\n    and Kubernetes. Experience with JavaScript and SQL is a plus. We utilize microservices architecture.\\n    \\\"\\\"\\\"\\n\\n    qgen = InterviewQuestionGenerator(role_requirements)\\n    questions = qgen.generate_all_questions(job_description, num_generic_tech=3, num_generic_beh=3)\\n\\n    print(\\\"Technical Questions:\\\")\\n    for q in questions[\\\"technical\\\"]:\\n        print(f\\\"- {q}\\\")\\n\\n    print(\\\"\\\\nBehavioral Questions:\\\")\\n    for q in questions[\\\"behavioral\\\"]:\\n        print(f\\\"- {q}\\\")\\n```\\n\",\n  \"timestamp\": \"2026-05-26T16:22:31.394108\"\n}"}
