\\"\\\"\\\"\\n        Initializes the EmailGenerator.\\n\\n        Args:\\n            sender_email (str): Sender's email address.\\n            sender_password (str): Sender's email password.\\n            company_name (str): Name of your company.\\n            sender_name (str): Your name as it should appear in the signature.\\n            sender_title (str): Your job title for the signature.\\n            smtp_server (str): SMTP server address. Defaults to 'smtp.gmail.com'.\\n            smtp_port (int): SMTP server port. Defaults to 587.\\n        \\\"\\\"\\\"\\n        self.sender_email = sender_email\\n        self.sender_password = sender_password\\n        self.company_name = company_name\\n        self.sender_name = sender_name\\n        self.sender_title = sender_title\\n        self.smtp_server = smtp_server\\n        self.smtp_port = smtp_port\\n\\n    def create_invitation_email(\\n        self,\\n        recipient_email: str,\\n        candidate_name: str,\\n        job_title: str,\\n        interview_date: str,\\n        interview_time: str,\\n        interviewer_name: str,\\n        interview_details: str\\n    ) -> str:\\n        \\\"\\\"\\\"\\n        Creates an interview invitation email.\\n\\n        Returns:\\n            str: Complete MIME-formatted email as a string.\\n        \\\"\\\"\\\"\\n        subject = f\\\"Interview Invitation: {job_title} at {self.company_name}\\\"\\n        body = f\\\"\\\"\\\"\\\\\\nDear {candidate_name},\\n\\nThank you for your interest in the {job_title} position at {self.company_name}.\\n\\nWe are pleased to invite you to an interview with {interviewer_name}.\\n\\nDate: {interview_date}\\nTime: {interview_time}\\nDetails: {interview_details}\\n\\nPlease confirm your availability by replying to this email.\\n\\nWe look forward to speaking with you.\\n\\nBest regards,\\n\\n{self.sender_name}\\n{self.sender_title}\\n{self.company_name}\\n\\\"\\\"\\\"\\n        return self._create_email(recipient_email, subject, body)\\n\\n    def create_followup_email(\\n        self,\\n        recipient_email: str,\\n        candidate_name: str,\\n        job_title: str,\\n        interview_date: str\\n    ) -> str:\\n        \\\"\\\"\\\"\\n        Creates a follow-up email after the interview.\\n\\n        Returns:\\n            str: Complete MIME-formatted email as a string.\\n        \\\"\\\"\\\"\\n        subject = f\\\"Following Up: Interview for {job_title} at {self.company_name}\\\"\\n        body = f\\\"\\\"\\\"\\\\\\nDear {candidate_name},\\n\\nI hope you’re doing well.\\n\\nI wanted to follow up on your interview for the {job_title} position on {interview_date}. We appreciate you taking the time and are currently reviewing all candidates. You will hear back from us soon with an update.\\n\\nThank you again for your interest in {self.company_name}.\\n\\nBest regards,\\n\\n{self.sender_name}\\n{self.sender_title}\\n{self.company_name}\\n\\\"\\\"\\\"\\n        return self._create_email(recipient_email, subject, body)\\n\\n    def create_rejection_email(\\n        self,\\n        recipient_email: str,\\n        candidate_name: str,\\n        job_title: str\\n    ) -> str:\\n        \\\"\\\"\\\"\\n        Creates a rejection email.\\n\\n        Returns:\\n            str: Complete MIME-formatted email as a string.\\n        \\\"\\\"\\\"\\n        subject = f\\\"Update on your application for {job_title} at {self.company_name}\\\"\\n        body = f\\\"\\\"\\\"\\\\\\nDear {candidate_name},\\n\\nThank you for your interest in the {job_title} position at {self.company_name} and for your time spent interviewing with us.\\n\\nAfter careful consideration, we have decided to move forward with other candidates whose qualifications better match our requirements at this time.\\n\\nWe truly appreciate your effort and wish you the best in your job search.\\n\\nSincerely,\\n\\n{self.sender_name}\\n{self.sender_title}\\n{self.company_name}\\n\\\"\\\"\\\"\\n        return self._create_email(recipient_email, subject, body)\\n\\n    def create_offer_email(\\n        self,\\n        recipient_email: str,\\n        candidate_name: str,\\n        job_title: str,\\n        salary: str,\\n        start_date: str\\n    ) -> str:\\n        \\\"\\\"\\\"\\n        Creates a job offer email.\\n\\n        Returns:\\n            str: Complete MIME-formatted email as a string.\\n        \\\"\\\"\\\"\\n        subject = f\\\"Job Offer: {job_title} at {self.company_name}\\\"\\n        body = f\\\"\\\"\\\"\\\\\\nDear {candidate_name},\\n\\nWe are delighted to offer you the position of {job_title} at {self.company_name}.\\n\\nYour starting salary will be {salary} per year, and your anticipated start date is {start_date}.\\n\\nPlease let us know if you have any questions. We look forward to welcoming you to our team!\\n\\nSincerely,\\n\\n{self.sender_name}\\n{self.sender_title}\\n{self.company_name}\\n\\\"\\\"\\\"\\n        return self._create_email(recipient_email, subject, body)\\n\\n    def _create_email(self, recipient_email: str, subject: str, body: str) -> str:\\n        \\\"\\\"\\\"\\n        Builds the MIMEText email.\\n\\n        Returns:\\n            str: Serialized email message.\\n        \\\"\\\"\\\"\\n        msg = MIMEText(body)\\n        msg['Subject'] = subject\\n        msg['From'] = self.sender_email\\n        msg['To'] = recipient_email\\n        return msg.as_string()\\n\\n    def send_email(self, recipient_email: str, message: str) -> bool:\\n        \\\"\\\"\\\"\\n        Sends an email via SMTP.\\n\\n        Returns:\\n            bool: True if successful, False otherwise.\\n        \\\"\\\"\\\"\\n        try:\\n            server = smtplib.SMTP(self.smtp_server, self.smtp_port)\\n            server.starttls()\\n            server.login(self.sender_email, self.sender_password)\\n            server.sendmail(self.sender_email, [recipient_email], message)\\n            server.quit()\\n            return True\\n        except Exception as e:\\n            print(f\\\"Error sending email: {e}\\\")\\n            return False\\n\\nif __name__ == '__main__':\\n    # Example usage\\n    sender = \\\"your_email@gmail.com\\\"\\n    password = \\\"your_password\\\"\\n    company = \\\"Acme Corp\\\"\\n    name = \\\"Alice Johnson\\\"\\n    title = \\\"Talent Acquisition Partner\\\"\\n\\n    email_gen = EmailGenerator(sender, password, company, name, title)\\n\\n    # Invitation\\n    invite_msg = email_gen.create_invitation_email(\\n        recipient_email=\\\"candidate@example.com\\\",\\n        candidate_name=\\\"John Doe\\\",\\n        job_title=\\\"Software Engineer\\\",\\n        interview_date=\\\"2024-07-01\\\",\\n        interview_time=\\\"10:00 AM\\\",\\n        interviewer_name=\\\"Bob Smith\\\",\\n        interview_details=\\\"Zoom Link: https://zoom.us/xyz\\\"\\n    )\\n    email_gen.send_email(\\\"candidate@example.com\\\", invite_msg)\\n    print(\\\"Invitation sent.\\\")\\n```\"}"}
