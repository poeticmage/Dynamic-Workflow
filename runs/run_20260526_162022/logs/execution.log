{"timestamp": "2026-05-26 16:22:33,725", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task0: ```python\nimport re\n\nclass ResumeJobAnalyzer:\n    def __init__(self, job_description, resume):\n        self.job_description = job_description\n        self.resume = resume\n        self.job_keywords = self.extract_keywords(job_description)\n        self.resume_keywords = self.extract_keywords(resume)\n\n    def extract_keywords(self, text):\n        # Convert to lowercase and remove special characters\n        text = text.lower()\n        text = re.sub(r'[^\\w\\s]', '', text)\n\n        # Split into words and remove common stop words\n        stop_words = set(['and', 'the', 'a', 'an', 'in', 'on', 'is', 'it', 'to', 'of', 'for', 'with', 'are', 'as', 'at', 'by', 'from'])  # Expand stop words as needed\n        words = [word for word in text.split() if word not in stop_words]\n        return words\n\n    def calculate_match_score(self):\n        \"\"\"Calculates a match score based on keyword overlap and experience.\"\"\"\n        job_set = set(self.job_keywords)\n        resume_set = set(self.resume_keywords)\n\n        # Keyword matching\n        keyword_match_count = len(job_set.intersection(resume_set))\n        keyword_match_percentage = (keyword_match_count / len(job_set)) * 100 if len(job_set) > 0 else 0\n        keyword_match_percentage = round(keyword_match_percentage, 2)\n      \n        # Experience matching (Placeholder - requires more sophisticated parsing)\n        experience_score = self.analyze_experience()  # Out of 100\n        \n        # Combined score - adjust weights as needed\n        overall_match_score = (0.7 * keyword_match_percentage + 0.3 * experience_score)\n        \n        return overall_match_score\n\n    def analyze_experience(self):\n        \"\"\"Analyzes the experience section for relevant keywords and duration. Returns score out of 100\"\"\"\n        experience_score = 0\n        \n        # Placeholder implementation - Enhance with NLP techniques for better accuracy\n        # Look for keywords related to years of experience, project types, roles mentioned in job description\n        \n        years_of_experience = self.extract_experience_years()\n        \n        if years_of_experience >= 5:\n            experience_score = 80\n        elif years_of_experience >= 3:\n            experience_score = 60\n        elif years_of_experience >= 1:\n            experience_score = 40\n        else:\n            experience_score = 20\n\n        return experience_score\n        \n    def extract_experience_years(self):\n        \"\"\"Extracts the number of years of experience from the resume.  Return 0 if nothing found.\"\"\"\n        years = 0\n        # Simple regex to find \"X years\" or \"X+ years\"\n        match = re.search(r'(\\d+)\\+?\\syears', self.resume.lower())\n        if match:\n            try:\n              years = int(match.group(1))\n            except:\n              years = 0\n        return years\n\n    def get_resume_summary(self):\n         \"\"\"Returns a summary of the resume analysis.\"\"\"\n         return f\"Keyword match percentage: {round(self.calculate_match_score(), 2)}%\"\n\n\n    def run_analysis(self):\n        \"\"\"Runs the analysis and returns the results.\"\"\"\n        match_score = self.calculate_match_score()\n        resume_summary = self.get_resume_summary()\n\n        return {\n            \"match_score\": match_score,\n            \"resume_summary\": resume_summary,\n            \"job_keywords\": self.job_keywords,\n            \"resume_keywords\": self.resume_keywords\n        }\n\nif __name__ == '__main__':\n    # Example Usage\n    job_description = \"\"\"\n    Software Engineer - Python\n    We are looking for a skilled software engineer with 5+ years of experience in Python development.\n    Experience with Django, REST APIs, and database design is required.\n    Must have experience with Agile development methodologies.\n    \"\"\"\n\n    resume = \"\"\"\n    John Doe\n    Software Engineer\n\n    Summary:\n    Experienced software engineer with 7 years of experience in Python.\n\n    Skills:\n    Python, Django, REST APIs, SQL, Agile\n\n    Experience:\n    Software Engineer at ABC Company (2016-Present)\n    - Developed and maintained REST APIs using Django\n    - Designed and implemented database schemas\n    \"\"\"\n\n    analyzer = ResumeJobAnalyzer(job_description, resume)\n    analysis_result = analyzer.run_analysis()\n\n    print(f\"Match Score: {analysis_result['match_score']:.2f}%\")\n    print(f\"Resume Summary: {analysis_result['resume_summary']}\")\n    print(f\"Job Keywords: {analysis_result['job_keywords']}\")\n    print(f\"Resume Keywords: {analysis_result['resume_keywords']}\")\n```"}
{"timestamp": "2026-05-26 16:22:33,726", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task1: ```python\nclass InterviewQuestionGenerator:\n    def __init__(self, role_requirements):\n        \"\"\"\n        Initializes the InterviewQuestionGenerator with the role requirements.\n\n        Args:\n            role_requirements (str): A description of the role requirements.\n        \"\"\"\n        self.role_requirements = role_requirements.lower()\n        self.skills = self.extract_skills(self.role_requirements)\n        self.competencies = self.extract_competencies(self.role_requirements)\n\n    def extract_skills(self, text):\n        \"\"\"\n        Extracts technical skills from a text.\n\n        Args:\n            text (str): The text to analyze.\n\n        Returns:\n            list: A list of extracted technical skills.\n        \"\"\"\n        keywords = {\n            \"python\": \"Python\",\n            \"java\": \"Java\",\n            \"c++\": \"C++\",\n            \"javascript\": \"JavaScript\",\n            \"sql\": \"SQL\",\n            \"aws\": \"AWS\",\n            \"azure\": \"Azure\",\n            \"docker\": \"Docker\",\n            \"kubernetes\": \"Kubernetes\",\n            \"machine learning\": \"Machine Learning\",\n            \"data science\": \"Data Science\",\n            \"react\": \"React\",\n            \"angular\": \"Angular\",\n            \"node.js\": \"Node.js\",\n            \"typescript\": \"TypeScript\",\n            \"git\": \"Git\",\n            \"linux\": \"Linux\",\n            \"testing\": \"Testing\",\n            \"cloud computing\": \"Cloud Computing\",\n            \"microservices\": \"Microservices\",\n            \"api\": \"API\",\n            \"database\": \"Database\",\n        }\n        return [name for key, name in keywords.items() if key in text]\n\n    def extract_competencies(self, text):\n        \"\"\"\n        Extracts behavioral competencies from a text.\n\n        Args:\n            text (str): The text to analyze.\n\n        Returns:\n            list: A list of extracted behavioral competencies.\n        \"\"\"\n        keywords = {\n            \"lead\": \"leadership\",\n            \"team\": \"teamwork\",\n            \"solve\": \"problem solving\",\n            \"adapt\": \"adaptability\",\n            \"communic\": \"communication\",\n            \"decis\": \"decision making\",\n            \"innov\": \"innovation\",\n            \"press\": \"working under pressure\",\n            \"feedback\": \"receptiveness to feedback\",\n            \"deadline\": \"time management\",\n            \"customer\": \"customer service\",\n            \"analyt\": \"analytical skills\",\n            \"creat\": \"creativity\",\n            \"negotiat\": \"negotiation\",\n            \"conflict\": \"conflict resolution\",\n            \"organize\": \"organizational skills\"\n        }\n        found = set()\n        for key, comp in keywords.items():\n            if key in text:\n                found.add(comp)\n        return list(found)\n\n    def generate_technical_questions(self, job_description, num_generic=5):\n        \"\"\"\n        Generates technical interview questions based on the job description.\n\n        Args:\n            job_description (str): The job description for the role.\n            num_generic (int, optional): The number of generic questions to include. Defaults to 5.\n\n        Returns:\n            list: A list of technical interview questions.\n        \"\"\"\n        tech_questions = []\n        jd = job_description.lower()\n        skills = self.extract_skills(jd)\n\n        # Questions per skill\n        for skill in skills:\n            tech_questions.extend([\n                f\"Explain your experience with {skill}.\",\n                f\"Describe a project where you used {skill}.\",\n                f\"What are the advantages and disadvantages of using {skill}?\",\n                f\"How do you troubleshoot issues related to {skill}?\"\n            ])\n\n        # Some generic technical questions\n        generic_tech = [\n            \"Describe your experience with software development methodologies (e.g., Agile, Waterfall).\",\n            \"Explain the difference between a stack and a queue.\",\n            \"What is the purpose of version control systems like Git?\",\n            \"How do you approach debugging a complex software issue?\",\n            \"Explain the concept of object-oriented programming.\",\n            \"What are design patterns and why are they useful?\",\n            \"Explain the difference between authentication and authorization.\",\n            \"What is CI/CD and how have you used it in the past?\",\n            \"Describe your experience with different testing methodologies.\",\n             \"How do you ensure code quality?\"\n        ]\n        tech_questions.extend(generic_tech[:num_generic]) # Take only the specified number of generic questions\n        return tech_questions\n\n    def generate_behavioral_questions(self, num_generic=5):\n        \"\"\"\n        Generates behavioral interview questions based on extracted competencies.\n\n        Args:\n            num_generic (int, optional): The number of generic behavioral questions to include if no competencies are found. Defaults to 5.\n\n        Returns:\n            list: A list of behavioral interview questions.\n        \"\"\"\n        beh_questions = []\n\n        # Tailored questions per competency\n        for comp in self.competencies:\n            if comp == \"leadership\":\n                beh_questions.append(\"Give an example of a time you had to lead a team to achieve a goal.\")\n                beh_questions.append(\"Describe a situation where you motivated a team to overcome a challenge.\")\n            elif comp == \"teamwork\":\n                beh_questions.append(\"Describe a situation where you collaborated effectively with colleagues.\")\n                beh_questions.append(\"Tell me about a time you had a conflict within a team and how you resolved it.\")\n            elif comp == \"problem solving\":\n                beh_questions.append(\"Tell me about a challenging problem you solved and your approach.\")\n                beh_questions.append(\"Describe a time when you had to think outside the box to solve a problem.\")\n            elif comp == \"adaptability\":\n                beh_questions.append(\"Describe a time you had to adapt to significant change at work.\")\n                beh_questions.append(\"Tell me about a situation where you had to quickly learn a new technology or skill.\")\n            elif comp == \"communication\":\n                beh_questions.append(\"Provide an example of how you have communicated complex ideas to non-technical stakeholders.\")\n                beh_questions.append(\"Describe a time when you had to deliver bad news. How did you approach it?\")\n            elif comp == \"decision making\":\n                beh_questions.append(\"Tell me about a difficult decision you made with incomplete information.\")\n                beh_questions.append(\"Describe a situation where you had to make a decision under pressure.\")\n            elif comp == \"innovation\":\n                beh_questions.append(\"Describe a time you introduced an innovative solution to a problem.\")\n                beh_questions.append(\"Tell me about a time you saw an opportunity for improvement and what you did.\")\n            elif comp == \"working under pressure\":\n                beh_questions.append(\"Tell me about a time you had to work under tight deadlines. How did you manage?\")\n                beh_questions.append(\"Describe a situation where you had multiple competing priorities. How did you handle it?\")\n            elif comp == \"receptiveness to feedback\":\n                beh_questions.append(\"How do you handle and incorporate constructive feedback?\")\n                beh_questions.append(\"Describe a time you received negative feedback and how you responded.\")\n            elif comp == \"time management\":\n                beh_questions.append(\"Explain how you prioritize tasks when faced with multiple deadlines.\")\n                beh_questions.append(\"Describe your system for staying organized and managing your time effectively.\")\n            elif comp == \"customer service\":\n                beh_questions.append(\"Describe a time you went above and beyond for a customer.\")\n                beh_questions.append(\"How do you handle a difficult or demanding customer?\")\n            elif comp == \"analytical skills\":\n                beh_questions.append(\"Describe a situation where you used data to make a decision.\")\n                beh_questions.append(\"Tell me about a time you had to analyze a complex problem and develop a solution.\")\n            elif comp == \"creativity\":\n                beh_questions.append(\"Describe a time when you came up with a creative solution to a problem.\")\n                beh_questions.append(\"Tell me about a project where you were able to express your creativity.\")\n            elif comp == \"negotiation\":\n                beh_questions.append(\"Describe a time when you successfully negotiated a deal or agreement.\")\n                beh_questions.append(\"Tell me about a negotiation that didn't go as planned. What did you learn?\")\n            elif comp == \"conflict resolution\":\n                beh_questions.append(\"Describe a time when you successfully resolved a conflict between team members.\")\n                beh_questions.append(\"How do you approach a situation where you have a disagreement with a colleague?\")\n            elif comp == \"organizational skills\":\n                beh_questions.append(\"Describe how you stay organized and manage your time effectively.\")\n                beh_questions.append(\"Tell me about a time when your organizational skills helped you succeed on a project.\")\n\n\n\n        # Fallback generic behavioral questions if none found\n        if not beh_questions:\n            generic_behavioral = [\n                \"Tell me about a time you failed. What did you learn from it?\",\n                \"Describe a situation where you had to deal with a difficult colleague. How did you resolve the conflict?\",\n                \"Tell me about a time you went above and beyond what was expected of you.\",\n                \"Describe your approach to problem-solving.\",\n                \"How do you stay motivated and productive when facing challenging tasks?\",\n                \"Describe your proudest professional accomplishment.\",\n                \"What are your strengths and weaknesses?\",\n                \"Where do you see yourself in 5 years?\",\n                \"Why are you interested in this role?\",\n                \"Why are you leaving your current company?\"\n            ]\n            beh_questions.extend(generic_behavioral[:num_generic])\n        return beh_questions\n\n    def generate_all_questions(self, job_description, num_generic_tech=5, num_generic_beh=5):\n        \"\"\"\n        Generates both technical and behavioral questions.\n\n        Args:\n            job_description (str): The job description for the role.\n            num_generic_tech (int, optional): The number of generic technical questions. Defaults to 5.\n            num_generic_beh (int, optional): The number of generic behavioral questions. Defaults to 5.\n\n        Returns:\n            dict: A dictionary with 'technical' and 'behavioral' question lists.\n        \"\"\"\n        return {\n            \"technical\": self.generate_technical_questions(job_description, num_generic_tech),\n            \"behavioral\": self.generate_behavioral_questions(num_generic_beh)\n        }\n\nif __name__ == '__main__':\n    # Example Usage\n    role_requirements = \"\"\"\n    We need a Senior Software Engineer with Python, AWS, leadership experience,\n    strong communication skills, and time management ability. Experience with React and Microservices is a plus.\n    \"\"\"\n    job_description = \"\"\"\n    Join our team as a Senior Software Engineer. You will work with Python, AWS, Docker,\n    and Kubernetes. Experience with JavaScript and SQL is a plus. We utilize microservices architecture.\n    \"\"\"\n\n    qgen = InterviewQuestionGenerator(role_requirements)\n    questions = qgen.generate_all_questions(job_description, num_generic_tech=3, num_generic_beh=3)\n\n    print(\"Technical Questions:\")\n    for q in questions[\"technical\"]:\n        print(f\"- {q}\")\n\n    print(\"\\nBehavioral Questions:\")\n    for q in questions[\"behavioral\"]:\n        print(f\"- {q}\")\n```\n"}
{"timestamp": "2026-05-26 16:22:33,726", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task2: ```python\nimport re\n\ndef generate_follow_up_questions(candidate_response, job_description, previous_questions=None):\n    \"\"\"\n    Generates follow-up questions based on a candidate's response, considering the job description and previous questions asked.\n\n    Args:\n        candidate_response (str): The candidate's response to the previous question.\n        job_description (str): The job description for the role.\n        previous_questions (list, optional): A list of previously asked questions. Defaults to None.\n\n    Returns:\n        list: A list of follow-up questions.\n    \"\"\"\n\n    follow_up_questions = []\n\n    # 1. Analyze the candidate's response for keywords and areas of interest/expertise\n    keywords = extract_keywords(candidate_response)\n\n    # 2. Identify areas where the candidate was vague or lacked depth\n    areas_for_clarification = identify_areas_for_clarification(candidate_response)\n\n    # 3. Check for alignment with the job description's requirements\n    missing_skills = identify_missing_skills(keywords, job_description)\n\n    # 4. Generate follow-up questions based on the above analysis\n    if keywords:\n        follow_up_questions.extend([\n            f\"Could you elaborate on your experience with {keyword}?\",\n            f\"How have you used {keyword} in a professional setting?\",\n        for keyword in keywords])\n\n    if areas_for_clarification:\n        follow_up_questions.extend([\n            f\"Could you provide more details about {area}?\",\n            f\"What were the specific challenges you faced when dealing with {area}?\",\n        for area in areas_for_clarification])\n\n    if missing_skills:\n        follow_up_questions.extend([\n            f\"How familiar are you with {skill}?\",\n            f\"Have you had any exposure to {skill} in your previous roles or personal projects?\",\n        for skill in missing_skills])\n\n    # 5. Avoid redundant questions (if previous questions are provided)\n    if previous_questions:\n        follow_up_questions = [q for q in follow_up_questions if q not in previous_questions]\n\n    return follow_up_questions\n\ndef extract_keywords(text):\n    \"\"\"\n    Extracts keywords from a given text.\n    This is a placeholder and can be improved with NLP techniques.\n\n    Args:\n        text (str): The text to extract keywords from.\n\n    Returns:\n        list: A list of keywords.\n    \"\"\"\n    # Simple keyword extraction based on word frequency and excluding common stop words\n    stop_words = set([\"the\", \"a\", \"an\", \"in\", \"on\", \"is\", \"it\", \"to\", \"of\", \"and\", \"for\", \"with\", \"I\", \"my\", \"me\"])\n    words = re.findall(r'\\b\\w+\\b', text.lower())\n    word_counts = {}\n    for word in words:\n        if word not in stop_words:\n            word_counts[word] = word_counts.get(word, 0) + 1\n\n    # Return the 3 most frequent words as keywords\n    sorted_words = sorted(word_counts.items(), key=lambda item: item[1], reverse=True)\n    return [word for word, count in sorted_words[:3]]\n\ndef identify_areas_for_clarification(text):\n    \"\"\"\n    Identifies areas in the text that require further clarification.\n    This is a placeholder and can be improved with NLP techniques.\n\n    Args:\n        text (str): The text to analyze.\n\n    Returns:\n        list: A list of areas for clarification.\n    \"\"\"\n    # Simple identification based on phrases like \"I think\", \"maybe\", \"it depends\"\n    clarification_areas = []\n    if \"I think\" in text.lower():\n        clarification_areas.append(\"the reasoning behind their thinking\")\n    if \"maybe\" in text.lower():\n        clarification_areas.append(\"the possibility under consideration\")\n    if \"it depends\" in text.lower():\n        clarification_areas.append(\"the conditions that influence the outcome\")\n\n    return clarification_areas\n\ndef identify_missing_skills(keywords, job_description):\n    \"\"\"\n    Identifies skills mentioned in the job description that are not present in the keywords.\n    This is a placeholder and can be improved with more sophisticated matching.\n\n    Args:\n        keywords (list): A list of keywords extracted from the candidate's response.\n        job_description (str): The job description.\n\n    Returns:\n        list: A list of missing skills.\n    \"\"\"\n    # Simple matching of keywords to job description requirements\n    job_description_keywords = extract_keywords(job_description)\n    missing_skills = [skill for skill in job_description_keywords if skill not in keywords]\n    return missing_skills\n\nif __name__ == '__main__':\n    # Example Usage:\n    job_description = \"We are looking for a software engineer with experience in Python, Django, and REST APIs.\"\n    candidate_response = \"I have some experience with Python and web development. I have built a few personal projects.\"\n    previous_questions = [\"Tell me about your experience with Python?\"]\n\n    follow_up_questions = generate_follow_up_questions(candidate_response, job_description, previous_questions)\n\n    print(\"Follow-up Questions:\")\n    for question in follow_up_questions:\n        print(f\"- {question}\")\n```"}
{"timestamp": "2026-05-26 16:22:33,726", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task3: ```python\nclass EvaluationEngine:\n    \"\"\"\n    A class for evaluating candidate answers based on relevance, depth,\n    confidence, and technical accuracy across different categories.\n    \"\"\"\n\n    def __init__(self, evaluation_criteria=None):\n        \"\"\"\n        Initializes the EvaluationEngine with optional custom evaluation criteria.\n\n        Args:\n            evaluation_criteria (dict, optional): A dictionary specifying custom\n                evaluation criteria. Defaults to None, which uses standard criteria.\n        \"\"\"\n        if evaluation_criteria is None:\n            self.evaluation_criteria = {\n                \"relevance\": \"How relevant is the answer to the question?\",\n                \"depth\": \"How deep is the answer and does it demonstrate sufficient understanding?\",\n                \"confidence\": \"How confidently is the answer delivered?\",\n                \"technical_accuracy\": \"How technically accurate is the answer?\",\n            }\n        else:\n            self.evaluation_criteria = evaluation_criteria\n\n    def score_answer(self, answer, expected_answer, category, scores=None, feedback=None):\n        \"\"\"\n        Scores a candidate's answer based on predefined criteria.\n\n        Args:\n            answer (str): The candidate's answer.\n            expected_answer (str): Expected answer or key concepts.\n            category (str): The category or skill being evaluated (e.g., \"Python\", \"Data Structures\").\n            scores (dict, optional): A dictionary to store the scores for each criteria\n                (relevance, depth, confidence, technical_accuracy). Defaults to None.\n            feedback (dict, optional): A dictionary to store feedback for each criteria.\n                Defaults to None.\n\n        Returns:\n            tuple: A tuple containing the scores (dict) and feedback (dict) for the answer.\n        \"\"\"\n\n        if scores is None:\n            scores = {}\n\n        if feedback is None:\n            feedback = {}\n\n        for criterion, description in self.evaluation_criteria.items():\n            score = self._get_score(answer, expected_answer, criterion, category)\n            scores[criterion] = score\n            feedback[criterion] = self._provide_feedback(answer, expected_answer, criterion, category, score)\n\n        return scores, feedback\n\n    def _get_score(self, answer, expected_answer, criterion, category):\n        \"\"\"\n        Calculates a score for a given criterion based on the candidate's answer.\n        This is a placeholder and should be replaced with a more sophisticated scoring mechanism.\n\n        Args:\n            answer (str): The candidate's answer.\n            expected_answer (str): Expected answer or key concepts.\n            criterion (str): The evaluation criterion (e.g., \"relevance\").\n            category (str): The category or skill being evaluated.\n\n        Returns:\n            int: A score between 1 and 5 (inclusive).\n        \"\"\"\n\n        # Placeholder logic: Replace with actual scoring logic\n        if criterion == \"relevance\":\n            if category in answer.lower():\n                return 4\n            elif any(keyword in answer.lower() for keyword in expected_answer.lower().split()):\n                return 3\n            else:\n                return 1\n        elif criterion == \"depth\":\n            if len(answer.split()) > len(expected_answer.split()):\n                 return 4\n            elif len(answer.split()) > 5:\n                return 3\n            else:\n                return 2\n\n        elif criterion == \"confidence\":\n            if \"I think\" not in answer and answer.strip():\n                return 4\n            elif answer.strip():\n                return 3\n            else:\n                return 1\n        elif criterion == \"technical_accuracy\":\n            if expected_answer.lower() in answer.lower():\n                return 5\n            elif any(keyword in answer.lower() for keyword in expected_answer.lower().split()):\n                return 4\n            else:\n                return 1\n\n        return 3 # Default score\n\n    def _provide_feedback(self, answer, expected_answer, criterion, category, score):\n        \"\"\"\n        Provides feedback on a candidate's answer based on the score.\n        This is a placeholder and should be replaced with more specific feedback.\n\n        Args:\n            answer (str): The candidate's answer.\n            expected_answer (str): Expected answer or key concepts.\n            criterion (str): The evaluation criterion (e.g., \"relevance\").\n            category (str): The category or skill being evaluated.\n            score (int): The score assigned to the answer for the criterion.\n\n        Returns:\n            str: Feedback on the answer.\n        \"\"\"\n\n        # Placeholder logic: Replace with actual feedback generation\n        if score <= 2:\n            return f\"The answer could be improved in terms of {criterion} for {category}.\"\n        elif score <= 4:\n            return f\"The answer demonstrates adequate {criterion} for {category}.\"\n        else:\n            return f\"The answer demonstrates excellent {criterion} for {category}.\"\n\n    def evaluate_candidate(self, interview_data):\n        \"\"\"\n        Evaluates the candidate based on interview data which includes question asked and answers.\n\n        Args:\n            interview_data (dict): A dictionary containing the interview data.  It should have question, answer and category.\n\n        Returns:\n            dict: A dictionary containing overall scores and feedback.\n        \"\"\"\n        overall_scores = {}\n        overall_feedback = {}\n\n        for question_data in interview_data:\n            question = question_data[\"question\"]\n            answer = question_data[\"answer\"]\n            expected_answer = question_data[\"expected_answer\"]\n            category = question_data[\"category\"]\n\n            scores, feedback = self.score_answer(answer, expected_answer, category)\n\n            overall_scores[question] = scores\n            overall_feedback[question] = feedback\n\n        return overall_scores, overall_feedback\n\n\nif __name__ == '__main__':\n    # Example Usage\n    engine = EvaluationEngine()\n\n    interview_data = [\n    {\n        \"question\": \"Explain the concept of inheritance in Python.\",\n        \"answer\": \"Inheritance is when a class derives properties from another class. It helps in code reuse.\",\n        \"expected_answer\": \"Inheritance allows a class (subclass or derived class) to inherit the properties and methods of another class (superclass or base class). This promotes code reusability and establishes an IS-A relationship.\",\n        \"category\": \"Python\"\n    },\n    {\n        \"question\": \"What is the time complexity of a binary search?\",\n        \"answer\": \"O(log n).\",\n        \"expected_answer\": \"O(log n)\",\n        \"category\": \"Data Structures\"\n    },\n    {\n        \"question\": \"Describe your experience with Agile methodologies.\",\n        \"answer\": \"I've used Scrum in my previous projects. We had daily stand-ups and sprint reviews.\",\n        \"expected_answer\": \"Agile methodologies are iterative approaches to software development that emphasize collaboration, flexibility, and continuous improvement. Scrum is a popular framework.\",\n        \"category\": \"Behavioral\"\n    }\n]\n\n    overall_scores, overall_feedback = engine.evaluate_candidate(interview_data)\n\n    for question, scores in overall_scores.items():\n        print(f\"Question: {question}\")\n        print(f\"Scores: {scores}\")\n        print(f\"Feedback: {overall_feedback[question]}\")\n        print(\"-\" * 30)\n```"}
{"timestamp": "2026-05-26 16:22:33,727", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task4: ```python\nimport smtplib\nfrom email.mime.text import MIMEText\nfrom datetime import datetime, timedelta\n\nclass EmailGenerator:\n    def __init__(self, smtp_server, smtp_port, sender_email, sender_password):\n        self.smtp_server = smtp_server\n        self.smtp_port = smtp_port\n        self.sender_email = sender_email\n        self.sender_password = sender_password\n\n    def create_invitation_email(self, recipient_email, candidate_name, role_name, interview_date, interview_time, interviewer_name, interview_details):\n        \"\"\"Generates an interview invitation email.\"\"\"\n        subject = f\"Interview Invitation for {role_name} at [Company Name]\"\n        body = f\"\"\"Dear {candidate_name},\n\nWe are pleased to invite you to an interview for the {role_name} position at [Company Name].\n\nDate: {interview_date}\nTime: {interview_time}\nInterviewer: {interviewer_name}\nDetails: {interview_details}\n\nPlease confirm your availability by replying to this email.\n\nWe look forward to speaking with you.\n\nSincerely,\n[Your Name]\n[Your Title]\n[Company Name]\n\"\"\"\n        return self.create_email(recipient_email, subject, body)\n\n    def create_followup_email(self, recipient_email, candidate_name, interviewer_name, role_name):\n        \"\"\"Generates a follow-up email after the interview.\"\"\"\n        subject = f\"Following Up on Your Interview for {role_name} at [Company Name]\"\n        body = f\"\"\"Dear {candidate_name},\n\nThank you for taking the time to interview for the {role_name} position at [Company Name] with {interviewer_name}.\n\nWe appreciate you sharing your experience and qualifications with us. We are currently reviewing all candidates and will be in touch soon regarding the next steps.\n\nSincerely,\n[Your Name]\n[Your Title]\n[Company Name]\n\"\"\"\n        return self.create_email(recipient_email, subject, body)\n\n    def create_rejection_email(self, recipient_email, candidate_name, role_name):\n        \"\"\"Generates a rejection email.\"\"\"\n        subject = f\"Update on Your Application for {role_name} at [Company Name]\"\n        body = f\"\"\"Dear {candidate_name},\n\nThank you for your interest in the {role_name} position at [Company Name]. We appreciate you taking the time to apply.\n\nWe have carefully reviewed your application and have decided to move forward with other candidates whose qualifications and experience are a closer match for the requirements of this role.\n\nWe wish you the best in your job search.\n\nSincerely,\n[Your Name]\n[Your Title]\n[Company Name]\n\"\"\"\n        return self.create_email(recipient_email, subject, body)\n\n    def create_offer_email(self, recipient_email, candidate_name, role_name, salary, start_date):\n      \"\"\"Generates an offer email.\"\"\"\n      subject = f\"Job Offer: {role_name} at [Company Name]\"\n      body = f\"\"\"Dear {candidate_name},\n\nWe are delighted to offer you the position of {role_name} at [Company Name]!\n\nWe were very impressed with your qualifications and experience during the interview process.\n\nHere are the details of the offer:\n\n* Role: {role_name}\n* Salary: {salary}\n* Start Date: {start_date}\n\nA formal offer letter with more details will follow shortly. Please let us know if you have any questions.\n\nWe are excited about the possibility of you joining our team!\n\nSincerely,\n[Your Name]\n[Your Title]\n[Company Name]\n\"\"\"\n      return self.create_email(recipient_email, subject, body)\n\n    def create_email(self, recipient_email, subject, body):\n        \"\"\"Creates and returns a MIMEText email object.\"\"\"\n        msg = MIMEText(body)\n        msg['Subject'] = subject\n        msg['From'] = self.sender_email\n        msg['To'] = recipient_email\n        return msg\n\n    def send_email(self, recipient_email, subject, body):\n        \"\"\"Sends an email.\"\"\"\n        msg = self.create_email(recipient_email, subject, body)\n        try:\n            with smtplib.SMTP(self.smtp_server, self.smtp_port) as server:\n                server.starttls()\n                server.login(self.sender_email, self.sender_password)\n                server.sendmail(self.sender_email, recipient_email, msg.as_string())\n            print(f\"Email sent to {recipient_email}\")\n        except Exception as e:\n            print(f\"Error sending email: {e}\")\n\n\nif __name__ == '__main__':\n    # Example Usage\n    smtp_server = 'smtp.gmail.com'  # Replace with your SMTP server\n    smtp_port = 587  # Replace with your SMTP port\n    sender_email = 'your_email@gmail.com'  # Replace with your email\n    sender_password = 'your_password'  # Replace with your password (or app password)\n\n    email_generator = EmailGenerator(smtp_server, smtp_port, sender_email, sender_password)\n\n    # Example: Sending an interview invitation\n    recipient_email = 'candidate@example.com'\n    candidate_name = 'Jane Smith'\n    role_name = 'Software Engineer'\n    interview_date = datetime.now() + timedelta(days=2)\n    interview_date_str = interview_date.strftime(\"%Y-%m-%d\")\n    interview_time = \"10:00 AM\"\n    interviewer_name = 'John Doe'\n    interview_details = \"Please join the Zoom meeting: [Zoom Link]\"\n\n    email_generator.send_email(recipient_email,\n                               f\"Interview Invitation for {role_name} at [Company Name]\",\n                               email_generator.create_invitation_email(recipient_email, candidate_name, role_name, interview_date_str, interview_time, interviewer_name, interview_details).get_payload()) #Fixed: Correctly pass recipient email, subject, and body\n\n    # Example: Sending a follow-up email\n    email_generator.send_email(recipient_email,\n                               f\"Following Up on Your Interview for {role_name} at [Company Name]\",\n                               email_generator.create_followup_email(recipient_email, candidate_name, interviewer_name, role_name).get_payload())\n    \n    # Example: Sending a rejection email\n    email_generator.send_email(recipient_email,\n                               f\"Update on Your Application for {role_name} at [Company Name]\",\n                               email_generator.create_rejection_email(recipient_email, candidate_name, role_name).get_payload())\n\n    # Example: Sending an offer email\n    email_generator.send_email(recipient_email,\n                               f\"Job Offer: {role_name} at [Company Name]\",\n                               email_generator.create_offer_email(recipient_email, candidate_name, role_name, \"$120,000\", \"2024-08-01\").get_payload())\n```"}
{"timestamp": "2026-05-26 16:22:33,727", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task5: ```python\nclass ReportGenerator:\n    def __init__(self, analysis_result, interview_summary, technical_assessment, behavioral_assessment, strengths, weaknesses, final_recommendation, candidate_name=\"Candidate\"):\n        self.analysis_result = analysis_result\n        self.interview_summary = interview_summary\n        self.technical_assessment = technical_assessment\n        self.behavioral_assessment = behavioral_assessment\n        self.strengths = strengths\n        self.weaknesses = weaknesses\n        self.final_recommendation = final_recommendation\n        self.candidate_name = candidate_name\n\n    def generate_report(self, filename=\"candidate_evaluation_report.txt\"):\n        with open(filename, \"w\") as f:\n            f.write(f\"Candidate Evaluation Report: {self.candidate_name}\\n\")\n            f.write(\"=========================================\\n\\n\")\n\n            f.write(\"I. Resume-Job Match Analysis\\n\")\n            f.write(\"-----------------------------------------\\n\")\n            f.write(f\"Match Score: {self.analysis_result['match_score']:.2f}%\\n\")\n            f.write(f\"Resume Summary: {self.analysis_result['resume_summary']}\\n\")\n            f.write(f\"Job Keywords: {', '.join(self.analysis_result['job_keywords'])}\\n\")\n            f.write(f\"Resume Keywords: {', '.join(self.analysis_result['resume_keywords'])}\\n\\n\")\n\n            f.write(\"II. Interview Summary\\n\")\n            f.write(\"-----------------------------------------\\n\")\n            f.write(f\"{self.interview_summary}\\n\\n\")\n\n            f.write(\"III. Technical Assessment\\n\")\n            f.write(\"-----------------------------------------\\n\")\n            f.write(f\"{self.technical_assessment}\\n\\n\")\n\n            f.write(\"IV. Behavioral Assessment\\n\")\n            f.write(\"-----------------------------------------\\n\")\n            f.write(f\"{self.behavioral_assessment}\\n\\n\")\n\n            f.write(\"V. Strengths\\n\")\n            f.write(\"-----------------------------------------\\n\")\n            f.write(f\"{self.strengths}\\n\\n\")\n\n            f.write(\"VI. Weaknesses\\n\")\n            f.write(\"-----------------------------------------\\n\")\n            f.write(f\"{self.weaknesses}\\n\\n\")\n\n            f.write(\"VII. Final Recommendation and Scoring Breakdown\\n\")\n            f.write(\"-----------------------------------------\\n\")\n            f.write(f\"{self.final_recommendation}\\n\")\n\n        return filename  # Return the filename of the generated report\n\n\nif __name__ == '__main__':\n    # Example Usage (mock data)\n    analysis_result = {\n        \"match_score\": 85.5,\n        \"resume_summary\": \"Strong match based on keywords and experience.\",\n        \"job_keywords\": [\"python\", \"django\", \"rest api\", \"database\", \"agile\"],\n        \"resume_keywords\": [\"python\", \"django\", \"rest api\", \"sql\", \"agile\"]\n    }\n\n    interview_summary = \"Candidate demonstrated good communication skills and a solid understanding of software development principles. Showed enthusiasm for the role.\"\n    technical_assessment = \"Candidate answered technical questions accurately, demonstrating a strong understanding of Python and Django. Performance on coding exercise was satisfactory.\"\n    behavioral_assessment = \"Candidate provided thoughtful responses to behavioral questions, highlighting teamwork and problem-solving skills.\"\n    strengths = \"Strong technical skills in Python/Django, good communication, team player.\"\n    weaknesses = \"Could improve on experience with large-scale systems. Lacks experience with specific cloud technologies.\"\n    final_recommendation = \"Recommend hiring. Overall score: 8.7/10. Strong technical foundation and good cultural fit.\"\n\n    report_generator = ReportGenerator(analysis_result, interview_summary, technical_assessment, behavioral_assessment, strengths, weaknesses, final_recommendation, candidate_name=\"John Doe\")\n    report_file = report_generator.generate_report()\n    print(f\"Report generated: {report_file}\")\n```"}
