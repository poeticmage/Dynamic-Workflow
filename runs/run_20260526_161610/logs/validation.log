"confidence_score\\\": 5\\n          },\\n          {\\n            \\\"follow_up_question\\\": \\\"What was the outcome, and what did you learn from the experience?\\\",\\n            \\\"candidate_response\\\": \\\"The team member's attitude improved after our conversation, and the team's overall productivity increased. I learned the importance of open communication and empathy when dealing with difficult people.\\\",\\n            \\\"relevance_score\\\": 5,\\n            \\\"depth_score\\\": 4,\\n            \\\"confidence_score\\\": 5\\n          }\\n        ]\\n      },\\n      {\\n        \\\"question\\\": \\\"Describe a situation where you had to learn a new technology or skill quickly. How did you approach it?\\\",\\n        \\\"candidate_response\\\": \\\"I had to learn React.js in a short timeframe for a new project.\\\",\\n        \\\"relevance_score\\\": 5,\\n        \\\"depth_score\\\": 3,\\n        \\\"confidence_score\\\": 5,\\n        \\\"follow_up_responses\\\": [\\n          {\\n            \\\"follow_up_question\\\": \\\"What resources did you use to learn the new technology or skill?\\\",\\n            \\\"candidate_response\\\": \\\"I used online courses, documentation, and tutorials. I also sought help from experienced colleagues.\\\",\\n            \\\"relevance_score\\\": 5,\\n            \\\"depth_score\\\": 4,\\n            \\\"confidence_score\\\": 5\\n          },\\n          {\\n            \\\"follow_up_question\\\": \\\"How did you apply what you learned to a real-world project?\\\",\\n            \\\"candidate_response\\\": \\\"I built a prototype application using React.js to gain hands-on experience.\\\",\\n            \\\"relevance_score\\\": 5,\\n            \\\"depth_score\\\": 4,\\n            \\\"confidence_score\\\": 5\\n          },\\n          {\\n            \\\"follow_up_question\\\": \\\"What challenges did you face, and how did you overcome them?\\\",\\n            \\\"candidate_response\\\": \\\"Understanding the component lifecycle was challenging. I overcame this by experimenting with different components and debugging issues.\\\",\\n            \\\"relevance_score\\\": 5,\\n            \\\"depth_score\\\": 4,\\n            \\\"confidence_score\\\": 5\\n          }\\n        ]\\n      },\\n      {\\n        \\\"question\\\": \\\"Tell me about a time you made a mistake at work. How did you handle it, and what did you learn from it?\\\",\\n        \\\"candidate_response\\\": \\\"I accidentally deleted a production database table.\\\",\\n        \\\"relevance_score\\\": 5,\\n        \\\"depth_score\\\": 3,\\n        \\\"confidence_score\\\": 5,\\n        \\\"follow_up_responses\\\": [\\n          {\\n            \\\"follow_up_question\\\": \\\"What were the consequences of the mistake?\\\",\\n            \\\"candidate_response\\\": \\\"The application was down, and users were unable to access their data.\\\",\\n            \\\"relevance_score\\\": 5,\\n            \\\"depth_score\\\": 4,\\n            \\\"confidence_score\\\": 5\\n          },\\n          {\\n            \\\"follow_up_question\\\": \\\"What steps did you take to rectify the situation?\\\",\\n            \\\"candidate_response\\\": \\\"I restored the table from a backup. Then, I worked with the team to prevent this from happening again.\\\",\\n            \\\"relevance_score\\\": 5,\\n            \\\"depth_score\\\": 4,\\n            \\\"confidence_score\\\": 5\\n          },\\n          {\\n            \\\"follow_up_question\\\": \\\"How did you prevent similar mistakes from happening in the future?\\\",\\n            \\\"candidate_response\\\": \\\"We implemented stricter access controls and automated backup procedures.\\\",\\n            \\\"relevance_score\\\": 5,\\n            \\\"depth_score\\\": 4,\\n            \\\"confidence_score\\\": 5\\n          }\\n        ]\\n      },\\n      {\\n        \\\"question\\\": \\\"Describe a project where you had to work under pressure to meet a tight deadline. How did yo