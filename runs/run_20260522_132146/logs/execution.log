m colors (corresponding to tetromino types)\nGEM_COLORS = {\n    \"I\": 1,  # Red\n    \"O\": 2,  # Green\n    \"T\": 3,  # Blue\n    \"L\": 4,  # Yellow\n    \"J\": 5,  # Magenta\n    \"S\": 6,  # Cyan\n    \"Z\": 7   # White\n}\n\nclass Grid:\n    def __init__(self, width, height):\n        self.width = width\n        self.height = height\n        self.grid = np.zeros((height, width), dtype=int)\n\n    def is_valid_move(self, tetromino, x, y, rotation):\n        \"\"\"Check if the tetromino's move is valid.\"\"\"\n        for px, py in TETROMINOS[tetromino][rotation]:\n            grid_x, grid_y = x + px, y + py\n            if (\n                grid_x < 0\n                or grid_x >= self.width\n                or grid_y < 0\n                or grid_y >= self.height\n                or self.grid[grid_y][grid_x] != 0\n            ):\n                return False\n        return True\n\n    def lock_tetromino(self, tetromino, x, y, rotation):\n        \"\"\"Lock the tetromino into the grid, converting to gem colors.\"\"\"\n        color = GEM_COLORS[tetromino]\n        for px, py in TETROMINOS[tetromino][rotation]:\n            self.grid[y + py][x + px] = color\n\n    def clear_lines(self):\n        \"\"\"Clear full lines in the grid.\"\"\"\n        lines_to_clear = []\n        for i in range(self.height):\n            if all(self.grid[i] != 0):\n                lines_to_clear.append(i)\n\n        if lines_to_clear:\n            self.grid = self.drop_lines(self.grid, lines_to_clear)\n        return len(lines_to_clear)\n\n    def drop_lines(self, grid, lines_to_clear):\n        \"\"\"Drop lines above cleared lines down.\"\"\"\n        for line in lines_to_clear:\n            grid = np.delete(grid, line, 0)\n            grid = np.insert(grid, 0, np.zeros(self.width), 0)\n        return grid\n\n    def find_matches(self):\n        \"\"\"Find all match-3 or more gems in the grid.\"\"\"\n        matches = []\n        # Horizontal matches\n        for y in range(self.height):\n            for x in range(self.width - 2):\n                if (\n                    self.grid[y][x] != 0\n                    and self.grid[y][x] == self.grid[y][x + 1]\n                    and self.grid[y][x] == self.grid[y][x + 2]\n                ):\n                    color = self.grid[y][x]\n                    match = [(x, y), (x + 1, y), (x + 2, y)]\n                    i = x + 3\n                    while i < self.width and self.grid[y][i] == color:\n                        match.append((i, y))\n                        i += 1\n                    matches.append(match)\n\n        # Vertical matches\n        for x in range(self.width):\n            for y in range(self.height - 2):\n                if (\n                    self.grid[y][x] != 0\n                    and self.grid[y][x] == self.grid[y + 1][x]\n                    and self.grid[y][x] == self.grid[y + 2][x]\n                ):\n                    color = self.grid[y][x]\n                    match = [(x, y), (x, y + 1), (x, y + 2)]\n                    i = y + 3\n                    while i < self.height and self.grid[i][x] == color:\n                        match.append((x, i))\n                        i += 1\n                    matches.append(match)\n\n        # Remove duplicate matches (handling overlapping matches)\n        unique_matches = []\n        for match in matches:\n            if match not in unique_matches:\n                unique_matches.append(match)\n\n        return unique_matches\n\n    def clear_matches(self, matches):\n        \"\"\"Clear the given matches from the grid.\"\"\"\n        cleared_count = 0\n        for match in matches:\n            for x, y in match:\n                if self.grid[y][x] != 0:\n                    self.grid[y][x] = 0\n                    cleared_count += 1\n        return cleared_count\n\n    def drop_floating_gems(self):\n        \"\"\"Drop gems down to fill empty spaces.\"\"\"\n        for x in range(self.width):\n            empty_positions = []\n            for y in range(self.height):\n                if self.grid[y][x] == 0:\n                    empty_positions.append(y)\n                elif empty_positions:\n                    # Move the gem down\n                    lowest_empty = empty_positions.pop(0)\n                    self.grid[lowest_empty][x] = self.grid[y][x]\n                    self.grid[y][x] = 0\n                    empty_positions.append(y)  # Add the vacated position back\n        return\n\nclass Tetromino:\n    def __init__(self, shape):\n        self.shape_type = shape\n        self.shape = TETROMINOS[shape]\n        self.color = GEM_COLORS[shape]\n        self.rotation = 0\n        self.x = GRID_WIDTH // 2 - 2  # Center the piece\n        self.y = 0\n\n    def rotate(self):\n        \"\"\"Rotate the tetromino.\"\"\"\n        self.rotation = (self.rotation + 1) % len(self.shape)\n\n    def get_current_shape(self):\n        \"\"\"Return the current rotation of the tetromino.\"\"\"\n        return self.shape[self.rotation]\n\nclass NextPieceQueue:\n    def __init__(self, initial_queue_length=3):\n        self.queue = self.generate_queue(initial_queue_length)\n\n    def generate_queue(self, queue_length):\n      \"\"\"Generate an initial queue of tetrominoes.\"\"\"\n      import random\n      tetromino_types = list(TETROMINOS.keys())\n      return [random.choice(tetromino_types) for _ in range(queue_length)]\n\n    def next_piece(self):\n        \"\"\"Get the next piece from the queue and add a new one.\"\"\"\n        import random\n        next_tetromino = self.queue.pop(0)\n        tetromino_types = list(TETROMINOS.keys())\n        self.queue.append(random.choice(tetromino_types))\n        return next_tetromino\n\nclass Game:\n    def __init__(self):\n        pygame.init()\n        self.grid = Grid(GRID_WIDTH, GRID_HEIGHT)\n        self.next_piece_queue = NextPieceQueue()\n        self.current_tetromino = Tetromino(self.next_piece_queue.next_piece())\n        self.score = 0\n        self.game_over = False\n        self.fall_speed = 1  # Blocks per second\n        self.last_fall_time = pygame.time.get_ticks()\n        self.screen_width = 600\n        self.screen_height = 800\n        self.screen = pygame.display.set_mode((self.screen_width, self.screen_height))\n        pygame.display.set_caption(\"TetrisBejeweled\")\n        self.cell_size = 30\n        self.clock = pygame.time.Clock()\n        self.font = pygame.font.Font(None, 36)\n        self.key_delay = 100\n        self.last_key_press = 0\n\n    def new_tetromino(self):\n        \"\"\"Generate a new tetromino.\"\"\"\n        self.current_tetromino = Tetromino(self.next_piece_queue.next_piece())\n        self.current_tetromino.x = GRID_WIDTH // 2 - 2\n        self.current_tetromino.y = 0\n        if not self.grid.is_valid_move(self.current_tetromino.shape_type, self.current_tetromino.x, self.current_tetromino.y, self.current_tetromino.rotation):\n            self.game_over = True\n\n    def move_tetromino(self, dx):\n        \"\"\"Move the tetromino horizontally.\"\"\"\n        new_x = self.current_tetromino.x + dx\n        if self.grid.is_valid_move(self.current_tetromino.shape_type, new_x, self.current_tetromino.y, self.current_tetromino.rotation):\n            self.current_tetromino.x = new_x\n\n    def rotate_tetromino(self):\n        \"\"\"Rotate the tetromino.\"\"\"\n        new_rotation = (self.current_tetromino.rotation + 1) % len(self.current_tetromino.shape)\n        if self.grid.is_valid_move(self.current_tetromino.shape_type, self.current_tetromino.x, self.current_tetromino.y, new_rotation):\n            self.current_tetromino.rotation = new_rotation\n\n    def drop_tetromino(self):\n        \"\"\"Move the tetromino down by one cell.\"\"\"\n        new_y = self.current_tetromino.y + 1\n        if self.grid.is_valid_move(self.current_tetromino.shape_type, self.current_tetromino.x, new_y, self.current_tetromino.rotation):\n            self.current_tetromino.y = new_y\n            return True\n        else:\n            return False\n\n    def lock_tetromino(self):\n        \"\"\"Lock the tetromino into the grid.\"\"\"\n        self.grid.lock_tetromino(self.current_tetromino.shape_type, self.current_tetromino.x, self.current_tetromino.y, self.current_tetromino.rotation)\n        self.new_tetromino()\n\n    def update_score(self, lines_cleared, matches_cleared):\n        \"\"\"Update the score based on lines and matches cleared.\"\"\"\n        line_score = lines_cleared * 100\n        match_score = matches_cleared * 50\n        self.score += line_score + match_score\n\n    def clear_board(self):\n        \"\"\"Clear lines and handle gem matching.\"\"\"\n        lines_cleared = self.grid.clear_lines()\n        matches = self.grid.find_matches()\n        matches_cleared = self.grid.clear_matches(matches)\n        self.grid.drop_floating_gems()\n        self.update_score(lines_cleared, matches_cleared)\n\n    def draw_grid(self):\n        \"\"\"Draw the grid on the screen.\"\"\"\n        for y in range(GRID_HEIGHT):\n            for x in range(GRID_WIDTH):\n                color = COLORS[self.grid.grid[y][x]]\n                pygame.draw.rect(self.screen, color, (x * self.cell_size, y * self.cell_size, self.cell_size, self.cell_size))\n                pygame.draw.rect(self.screen, (50, 50, 50), (x * self.cell_size, y * self.cell_size, self.cell_size, self.cell_size), 1) # Dark grey outline\n\n    def draw_tetromino(self):\n        \"\"\"Draw the current tetromino on the screen.\"\"\"\n        for px, py in self.current_tetromino.get_current_shape():\n            x = (self.current_tetromino.x + px) * self.cell_size\n            y = (self.current_tetromino.y + py) * self.cell_size\n            pygame.draw.rect(self.screen, COLORS[self.current_tetromino.color], (x, y, self.cell_size, self.cell_size))\n            pygame.draw.rect(self.screen, (50, 50, 50), (x, y, self.cell_size, self.cell_size), 1) # Dark grey outline\n\n    def draw_next_queue(self):\n        \"\"\"Draw the next piece queue.\"\"\"\n        queue_length = len(self.next_piece_queue.queue)\n        start_x = GRID_WIDTH * self.cell_size + 20\n        start_y = 20\n        text_surface = self.font.render(\"Next:\", True, (255, 255, 255))\n        self.screen.blit(text_surface, (start_x, start_y))\n\n        y_offset = 50\n\n        for i in range(min(queue_length,3)):  #Display a maximum of 3 next pieces\n            next_shape_type = self.next_piece_queue.queue[i]\n            next_shape = TETROMINOS[next_shape_type][0] # Use the first rotation\n            color = GEM_COLORS[next_shape_type]\n\n            for px, py in next_shape:\n                x = start_x + px * self.cell_size * 0.5 # Smaller size for preview\n                y = start_y + y_offset + py * self.cell_size * 0.5\n                pygame.draw.rect(self.screen, COLORS[color], (x, y, self.cell_size * 0.5, self.cell_size * 0.5))\n                pygame.draw.rect(self.screen, (50, 50, 50), (x, y, self.cell_size * 0.5, self.cell_size * 0.5), 1) # Dark grey outline\n            y_offset += 60  #Spacing between previews\n\n    def draw_score(self):\n        \"\"\"Draw the score on the screen.\"\"\"\n        text_surface = self.font.render(f\"Score: {self.score}\", True, (255, 255, 255))\n        self.screen.blit(text_surface, (GRID_WIDTH * self.cell_size + 20, self.screen_height - 50))\n\n    def handle_input(self):\n        \"\"\"Handle keyboard input for tetromino movement and rotation.\"\"\"\n        keys = pygame.key.get_pressed()\n        current_time = pygame.time.get_ticks()\n\n        if current_time - self.last_key_press > self.key_delay:\n            if keys[pygame.K_LEFT]:\n                self.move_tetromino(-1)\n                self.last_key_press = current_time\n            if keys[pygame.K_RIGHT]:\n                self.move_tetromino(1)\n                self.last_key_press = current_time\n            if keys[pygame.K_UP]:\n                self.rotate_tetromino()\n                self.last_key_press = current_time\n            if keys[pygame.K_DOWN]:\n                if not self.drop_tetromino():\n                    self.lock_tetromino()\n                    self.clear_board()\n                self.last_key_press = current_time\n\n    def run(self):\n        \"\"\"Main game loop.\"\"\"\n        running = True\n        while running:\n            for event in pygame.event.get():\n                if event.type == pygame.QUIT:\n                    running = False\n\n            self.handle_input()\n\n            # Gravity drop\n            time_now = pygame.time.get_ticks()\n            if time_now - self.last_fall_time > 1000 / self.fall_speed:\n                if not self.drop_tetromino():\n                    self.lock_tetromino()\n                    self.clear_board()\n                self.last_fall_time = time_now\n\n            # Drawing\n            self.screen.fill((0, 0, 0))  # Black background\n            self.draw_grid()\n            self.draw_tetromino()\n            self.draw_next_queue()\n            self.draw_score()\n\n            if self.game_over:\n                text_surface = self.font.render(\"Game Over\", True, (255, 0, 0))\n                text_rect = text_surface.get_rect(center=(self.screen_width // 2, self.screen_height // 2))\n                self.screen.blit(text_surface, text_rect)\n\n            pygame.display.flip()\n            self.clock.tick(60)  # Limit frame rate to 60 FPS\n\n        pygame.quit()\n\nif __name__ == \"__main__\":\n    game = Game()\n    game.run()\n```"}
