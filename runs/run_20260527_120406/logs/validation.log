 \\\"start_date\\\": \\\"string (YYYY-MM)\\\",\\n      \\\"end_date\\\": \\\"string (YYYY-MM)\\\",\\n      \\\"responsibilities\\\": [\\n        \\\"string\\\"\\n      ]\\n    }\\n  ],\\n  \\\"skills\\\": [\\n    \\\"string\\\"\\n  ],\\n  \\\"projects\\\": [\\n    {\\n      \\\"name\\\": \\\"string\\\",\\n      \\\"description\\\": \\\"string\\\",\\n      \\\"technologies\\\": [\\n        \\\"string\\\"\\n      ],\\n      \\\"link\\\": \\\"string\\\"\\n    }\\n  ],\\n  \\\"publications\\\": [\\n    {\\n      \\\"title\\\": \\\"string\\\",\\n      \\\"conference\\\": \\\"string\\\",\\n      \\\"date\\\": \\\"string (YYYY-MM)\\\"\\n    }\\n  ],\\n  \\\"awards_and_certifications\\\": [\\n    {\\n      \\\"name\\\": \\\"string\\\",\\n      \\\"date\\\": \\\"string (YYYY-MM)\\\"\\n    }\\n  ],\\n  \\\"volunteer_experience\\\": [\\n    {\\n      \\\"organization\\\": \\\"string\\\",\\n      \\\"role\\\": \\\"string\\\",\\n      \\\"start_date\\\": \\\"string (YYYY-MM)\\\",\\n      \\\"end_date\\\": \\\"string (YYYY-MM)\\\",\\n      \\\"description\\\": \\\"string\\\"\\n    }\\n  ],\\n  \\\"languages\\\": [\\n    {\\n      \\\"language\\\": \\\"string\\\",\\n      \\\"proficiency\\\": \\\"string\\\"\\n    }\\n  ],\\n  \\\"references\\\": [\\n    {\\n      \\\"name\\\": \\\"string\\\",\\n      \\\"relation\\\": \\\"string\\\",\\n      \\\"email\\\": \\\"string\\\",\\n      \\\"phone\\\": \\\"string\\\"\\n    }\\n  ]\\n}\\n```\\n\\nTask task4:\\n  Objective: Implement scoring engine to evaluate and score captured candidate responses\\n  Result: ```python\\nimport json\\nfrom typing import Dict, Any, Tuple\\n\\nclass ScoringEngine:\\n    def __init__(self,\\n                 rubric: Dict[str, Dict[str, int]],\\n                 weights: Dict[str, float],\\n                 scale_min: float = 0.0,\\n                 scale_max: float = 100.0):\\n        \\\"\\\"\\\"\\n        rubric: {\\n          question_id: { \\\"Excellent\\\":5, \\\"Good\\\":3, \\\"Fair\\\":2, \\\"Poor\\\":1 },\\n          ...\\n        }\\n        weights: {\\n          question_id: weight_value (sum should be 1.0),\\n          ...\\n        }\\n        scale_min, scale_max: normalization range\\n        \\\"\\\"\\\"\\n        self.rubric = rubric\\n        self.weights = weights\\n        self.scale_min = scale_min\\n        self.scale_max = scale_max\\n        self.raw_scores: Dict[str, float] = {}\\n        self.rationales: Dict[str, str] = {}\\n    \\n    def score_response(self, question_id: str, response: str) -> Tuple[float, str]:\\n        \\\"\\\"\\\"\\n        Stub scoring: choose level based on keyword counts. Replace with NLP logic as needed.\\n        \\\"\\\"\\\"\\n        levels = self.rubric.get(question_id, {})\\n        # Simple keyword-based assignment for demo\\n        resp_lower = response.lower()\\n        if \\\"excellent\\\" in resp_lower or len(resp_lower) > 200:\\n            level = \\\"Excellent\\\"\\n        elif \\\"good\\\" in resp_lower or len(resp_lower) > 100:\\n            level = \\\"Good\\\"\\n        elif \\\"fair\\\" in resp_lower or len(resp_lower) > 50:\\n            level = \\\"Fair\\\"\\n        else:\\n            level = \\\"Poor\\\"\\n        \\n        score = levels.get(level, 0)\\n        rationale = f\\\"Matched level '{level}' -> score {score}\\\"\\n        return score, rationale\\n\\n    def score_candidate(self, responses: Dict[str, str]) -> None:\\n        \\\"\\\"\\\"\\n        responses: { question_id: candidate_response, ... }\\n        Fills self.raw_scores and self.rationales\\n        \\\"\\\"\\\"\\n        for qid, resp in responses.items():\\n            score, rationale = self.score_response(qid, resp)\\n            self.raw_scores[qid] = score\\n            self.rationales[qid] = rationale\\n\\n    def normalize_scores(self) -> Dict[str, float]:\\n        \\\"\\\"\\\"\\n        Normalizes raw_scores to [scale_min, scale_max].\\n        \\\"\\\"\\\"\\n        max_raw = max(self.raw_scores.values(), default=0)\\n        min_raw = min(self.raw_scores.values(), default=0)\\n        normed: Dict[str, float] = {}\\n        for qid, raw in self.raw_scores.items():\\n            if max_raw == min_raw:\\n                norm = (self.scale_max + self.scale_min) / 2.0\\n            else:\\n                norm = ((raw - min_raw) / (max_raw - min_raw)) * (self.scale_max - self.scale_min) + self.scale_min\\n            normed[qid] = round(norm, 2)\\n        return normed\\n\\n    def overall_score(self, normalized_scores: Dict[str, float]) -> float:\\n        total = 0.0\\n        for qid, score in normalized_scores.items():\\n            weight = self.weights.get(qid, 0)\\n            total += score * weight\\n        return round(total, 2)\\n\\n    def adjust_score(self, question_id: str, new_score: float) -> None:\\n        \\\"\\\"\\\"\\n        Manual override for a question's raw score.\\n        \\\"\\\"\\\"\\n        self.raw_scores[question_id] = new_score\\n        self.rationales[question_id] = f\\\"Manually adjusted to {new_score}\\\"\\n\\n    def generate_report(self) -> Dict[str, Any]:\\n        \\\"\\\"\\\"\\n        Returns a structured report.\\n        \\\"\\\"\\\"\\n        normalized = self.normalize_scores()\\n        report = {\\n            \\\"raw_scores\\\": self.raw_scores,\\n            \\\"rationales\\\": self.rationales,\\n            \\\"normalized_scores\\\": normalized,\\n            \\\"overall_score\\\": self.overall_score(normalized)\\n        }\\n        return report\\n\\n    def save_scores(self, filepath: str) -> None:\\n        \\\"\\\"\\\"\\n        Securely store scores. Here we JSON-dump; replace with secure storage as needed.\\n        \\\"\\\"\\\"\\n        with open(filepath, \\\"w\\\") as f:\\n            json.dump(self.generate_report(), f, indent=2)\\n\\n\\n# Example usage\\nif __name__ == \\\"__main__\\\":\\n    # Define a sample rubric and weights\\n    rubric = {\\n        \\\"Q1\\\": {\\\"Excellent\\\": 5, \\\"Good\\\": 3, 