\\\\": [],\\\\n        \\\\\\\"location\\\\\\\": None\\\\n    }\\\\n    # Example extraction patterns\\\\n    title_match = re.search(r\\\\\\\"Job Title:\\\\\\\\s*(.+)\\\\\\\", text)\\\\n    if title_match:\\\\n        result[\\\\\\\"job_title\\\\\\\"] = title_match.group(1).strip()\\\\n    comp_match = re.search(r\\\\\\\"Company:\\\\\\\\s*(.+)\\\\\\\", text)\\\\n    if comp_match:\\\\n        result[\\\\\\\"company\\\\\\\"] = comp_match.group(1).strip()\\\\n    # Skills: look for lines starting with '- ' under a 'Required Skills' header\\\\n    req_skills_match = re.search(r\\\\\\\"Required Skills:(.*?)\\\\\\\\n\\\\\\\\n\\\\\\\", text, re.S)\\\\n    if req_skills_match:\\\\n        lines = req_skills_match.group(1).splitlines()\\\\n        for line in lines:\\\\n            item = line.lstrip('- ').strip()\\\\n            if item:\\\\n                result[\\\\\\\"required_skills\\\\\\\"].append(item)\\\\n    # Similar regex-based blocks can be added for experience, education, etc.\\\\n    return result\\\",\\n  \\\"output_schema\\\": {\\n    \\\"job_title\\\": \\\"string or null\\\",\\n    \\\"company\\\": \\\"string or null\\\",\\n    \\\"required_skills\\\": [\\\"string\\\", \\\"...\\\"],\\n    \\\"minimum_experience\\\": \\\"string or null\\\",\\n    \\\"education\\\": \\\"string or null\\\",\\n    \\\"key_responsibilities\\\": [\\\"string\\\", \\\"...\\\"],\\n    \\\"nice_to_have\\\": [\\\"string\\\", \\\"...\\\"],\\n    \\\"benefits\\\": [\\\"string\\\", \\\"...\\\"],\\n    \\\"location\\\": \\\"string or null\\\"\\n  }\\n}\\n```\"}"}
