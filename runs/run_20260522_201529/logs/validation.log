e\\n\\n    def is_row_full(self, row_index):\\n        \\\"\\\"\\\"Checks if a row is completely filled with gems (no None values).\\\"\\\"\\\"\\n        return all(self.grid[row_index])\\n\\n    def clear_row(self, row_index):\\n        \\\"\\\"\\\"Clears all cells in a given row.\\\"\\\"\\\"\\n        for x in range(self.width):\\n            self.grid[row_index][x] = None\\n\\n    def drop_row(self, row_index):\\n        \\\"\\\"\\\"Moves all rows above the given row down by one.\\\"\\\"\\\"\\n        for y in range(row_index, 0, -1):\\n            self.grid[y] = self.grid[y - 1][:]  # Copy the row above\\n        self.grid[0] = [None] * self.width  # Clear the top row\\n\\n    def clear_matches(self):\\n        \\\"\\\"\\\"Find and clear match-3 or more chains, return the cleared coordinates.\\\"\\\"\\\"\\n        matches = self.find_matches()\\n        cleared_coordinates = set()\\n        for x, y in matches:\\n            self.clear_cell(x, y)\\n            cleared_coordinates.add((x, y))\\n        return cleared_coordinates\\n\\n    def find_matches(self):\\n        \\\"\\\"\\\"Finds all horizontal and vertical match-3 or more chains.\\\"\\\"\\\"\\n        matches = set()\\n\\n        # Horizontal matches\\n        for y in range(self.height):\\n            for x in range(self.width - 2):\\n                color = self.get_cell_color(x, y)\\n                if color is None:\\n                    continue\\n                if (self.get_cell_color(x + 1, y) == color and\\n                        self.get_cell_color(x + 2, y) == color):\\n                    match_length = 3\\n                    while (x + match_length < self.width and\\n                           self.get_cell_color(x + match_length, y) == color):\\n                        match_length += 1\\n                    for i in range(match_length):\\n                        matches.add((x + i, y))\\n\\n        # Vertical matches\\n        for x in range(self.width):\\n            for y in range(self.height - 2):\\n                color = self.get_cell_color(x, y)\\n                if color is None:\\n                    continue\\n                if (self.get_cell_color(x, y + 1) == color and\\n                        self.get_cell_color(x, y + 2) == color):\\n                    match_length = 3\\n                    while (y + match_length < self.height and\\n                           self.get_cell_color(x, y + match_length) == color):\\n                        match_length += 1\\n                    for i in range(match_length):\\n                        matches.add((x, y + i))\\n\\n        return list(matches)\\n\\n    def apply_gravity(self):\\n        \\\"\\\"\\\"Applies gravity to the grid, moving floating gems down.\\\"\\\"\\\"\\n        for x in range(self.width):\\n            empty_space = -1\\n            for y in range(self.height):\\n                if self.grid[y][x] is None:\\n                    if empty_space == -1:\\n                        empty_space = y\\n                else:\\n                    if empty_space != -1:\\n                        self.grid[empty_space][x] = self.grid[y][x]\\n                        self.grid[y][x] = None\\n                        empty_space += 1\\n\\nclass Shape:\\n    def __init__(self, blocks, color):\\n        self.blocks = blocks  # List of (x, y, color) tuples relative to the shape's origin\\n        self.color = color\\n\\n    def rotate_clockwise(self):\\n        \\\"\\\"\\\"Rotates the shape 90 degrees clockwise around its origin.\\\"\\\"\\\"\\n        new_blocks = []\\n        for x, y, color in self.blocks:\\n            new_x = -y\\n            new_y = x\\n            new_blocks.append((new_x, new_y, color))\\n        self.blocks = new_blocks\\n\\n# Example usage (to be expanded in later tasks)\\nif __name__ == '__main__':\\n    grid_width = 10\\n    grid_height = 20\\n    grid = Grid(grid_width, grid_height)\\n\\n    # Example shape definition\\n    example_shape = Shape(\\n        blocks=[(