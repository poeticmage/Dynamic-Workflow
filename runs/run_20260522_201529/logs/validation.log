.width or\\n                grid_y < 0 or grid_y >= self.height or\\n                self.grid[grid_y][grid_x] is not None):\\n                return False\\n        return True\\n\\n    def place_shape(self, shape, offset_x, offset_y):\\n        for x, y in shape.get_current_shape():\\n            grid_x = x + offset_x\\n            grid_y = y + offset_y\\n            self.grid[grid_y][grid_x] = shape.color\\n\\n    # ... other methods (get_cell_color, set_cell_color, clear_cell, etc.) ...\\n\\n    def clear_matches(self):\\n        matches = self.find_matches()\\n        for x, y in matches:\\n            self.clear_cell(x, y)\\n        return matches\\n\\n    def find_matches(self):\\n        matches = set()\\n        # horizontal\\n        for y in range(self.height):\\n            x = 0\\n            while x < self.width - 2:\\n                c = self.get_cell_color(x, y)\\n                if c and self.get_cell_color(x+1, y) == c and self.get_cell_color(x+2, y) == c:\\n                    i = 0\\n                    while x+i < self.width and self.get_cell_color(x+i, y) == c:\\n                        matches.add((x+i, y))\\n                        i += 1\\n                    x += i\\n                else:\\n                    x += 1\\n        # vertical\\n        for x in range(self.width):\\n            y = 0\\n            while y < self.height - 2:\\n                c = self.get_cell_color(x, y)\\n                if c and self.get_cell_color(x, y+1) == c and self.get_cell_color(x, y+2) == c:\\n                    i = 0\\n                    while y+i < self.height and self.get_cell_color(x, y+i) == c:\\n                        matches.add((x, y+i))\\n                        i += 1\\n                    y += i\\n                else:\\n                    y += 1\\n        return matches\\n\\n    def apply_gravity(self):\\n        for x in range(self.width):\\n            stack = [self.grid[y][x] for y in range(self.height) if self.grid[y][x] is not None]\\n            for y in range(self.height-1, -1, -1):\\n                self.grid[y][x] = stack.pop() if stack else None\\n\\n    def clear_cell(self, x, y):\\n        if 0 <= x < self.width and 0 <= y < self.height:\\n            self.grid[y][x] = None\\n\\nclass Tetromino:\\n    TETROMINO_COLORS = {\\n        'I': (0, 255, 255), 'J': (0, 0, 255), 'L': (255, 165, 0),\\n        'O': (255, 255, 0), 'S': (0, 255, 0), 'T': (128, 0, 128),\\n        'Z': (255, 0, 0)\\n    }\\n    TETROMINO_SHAPES = {\\n        'I': [[(0,0),(1,0),(2,0),(3,0)], [(1,-1),(1,0),(1,1),(1,2)]],\\n        'J': [[(0,0),(0,1),(1,1),(2,1)], [(1,0),(2,0),(1,1),(1,2)],\\n              [(0,1),(1,1),(2,1),(2,2)], [(1,0),(1,1),(0,2),(1,2)]],\\n        'L': [[(2,0),(0,1),(1,1),(2,1)], [(1,0),(1,1),(1,2),(2,2)],\\n              [(0,1),(1,1),(2,1),(0,2)], [(0,0),(1,0),(1,1),(1,2)]],\\n        'O': [[(0,0),(1,0),(0,1),(1,1)]],\\n        'S': [[(1,0),(2,0),(0,1),(1,1)], [(0,0),(0,1),(1,1),(1,2)]],\\n        'T': [[(0,0),(1,0),(2,0),(1,1)], [(1,0),(0,1),(1,1),(1,2)],\\n              [(1,0),(0,1),(1,1),(2,1)], [(1,0),(1,1),(2,1),(1,2)]],\\n        'Z': [[(0,0),(1,0),(1,1),(2,1)], [(1,0),(0,1),(1,1),(0,2)]],\\n    }\\n\\n    def __init__(self, x, y, tet_type=None):\\n        import random\\n        if tet_type and tet_type in self.TETROMINO_SHAPES:\\n            self.type = tet_type\\n        else:\\n            self.type = random.choice(list(self.TETROMINO_SHAPES.keys()))\\n        self.orientations = self.TETROMINO_SHAPES[self.type]\\n        self.color = self.TETROMINO_COLORS[self.type]\\n        self.x = x\\n        self.y = y\\n        self.rotation = 0\\n\\n    def get_current_shape(self):\\n        return self.orientations[self.rotation]\\n\\n    def rotate(self, grid):\\n        old = self.rotation\\n        self.rotation = (self.rotation + 1) % len(self.orientations)\\n        if not grid.is_valid_move(self, self.x, self.y):\\n            self.rotation = old\\n\\n    def move(self, dx, dy, grid):\\n        if grid.is_valid_move(self, self.x+dx, self.y+dy):\\n            self.x += dx\\n            self.y += dy\\n            return True\\n        return False\\n\\nclass TetrominoGenerator:\\n    def __init__(self, grid_width):\\n        self.grid_width = grid_width\\n        self._bag = []\\n        self._refill_bag()\\n\\n    def _refill_bag(self):\\n        self._bag = list(Tetromino.TETROMINO_SHAPES.keys())\\n        random.shuffle(self._bag)\\n\\n    def next_tetromino(self):\\n        if not self._bag:\\n            self._refill_bag()\\n        tet_type = self._bag.pop()\\n        start_x = self.grid_width // 2 - 1\\n        return Tetromino(start_x, 0, tet_type)\\n\\n# -- MAIN GAME WITH KEYBOARD HANDLING --\\n\\nif __name__ == '__main__':\\n    pygame.init()\\n    CELL_SIZE = 30\\n    GRID_W, GRID_H = 10, 20\\n    SCREEN = pygame.display.set_mode((GRID_W * CELL_SIZE, GRID_H * CELL_SIZE))\\n    CLOCK = pygame.time.Clock()\\n    grid = Grid(GRID_W, GRID_H)\\n    generator = TetrominoGenerator(GRID_W)\\n    current = generator.next_tetromino()\\n    fall_event = pygame.USEREVENT + 1\\n    pygame.time.set_timer(fall_event, 500)  # automatic drop every 500ms\\n\\n    running = True\\n    while running:\\n        for event in pygame.event.get():\\n            if event.type == pygame.QUIT:\\n                running = False\\n\\n            elif event.type == pygame.KEYDOWN:\\n                if event.key == pygame.K_LEFT:\\n                    current.move(-1, 0, grid)\\n                elif event.key == pygame.K_RIGHT:\\n                    current.move(1, 0, grid)\\n                elif event.key == pygame.K_DOWN:\\n                    current.move(0, 1, grid)\\n                elif event.key == pygame.K_UP:\\n                    current.rotate(grid)\\n\\n            elif event.type == fall_event:\\n                if not current.move(0, 1, grid):\\n                    # lock piece\\n                    grid.place_shape(current, current.x, current.y)\\n                    grid.clear_matches()\\n                    grid.apply_gravity()\\n                    current = generator.next_tetromino()\\n\\n        # Drawing\\n        SCREEN.fill((0, 0, 0))\\n        # Draw placed gems\\n        for y in range(GRID_H):\\n            for x in range(GRID_W):\\n                color = grid.get_cell_color(x, y)\\n                if color:\\n                    rect = pygame.Rect(x*CELL_SIZE, y*CELL_SIZE, CELL_SIZE, CELL_SIZE)\\n                    pygame.draw.rect(SCREEN, color, rect)\\n                    pygame.draw.rect(SCREEN, (50, 50, 50), rect, 1)\\n        # Draw active tetromino\\n        for dx, dy in current.get_current_shape():\\n            px, py = current.x + dx, current.y + dy\\n            rect = pygame.Rect(px*CELL_SIZE, py*CELL_SIZE, CELL_SIZE, CELL_SIZE)\\n            pygame.draw.rect(SCREEN, current.color, rect)\\n            pygame.draw.rect(SCREEN, (255, 255, 255), rect, 1)\\n\\n        pygame.display.flip()\\n        CLOCK.tick(60)\\n\\n    pygame.quit()\\n```\"}"}
