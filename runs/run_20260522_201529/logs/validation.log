\\n            [(0, 0), (0, 1), (1, 1), (2, 1)],\\n            [(1, 0), (2, 0), (1, 1), (1, 2)],\\n            [(0, 1), (1, 1), (2, 1), (2, 2)],\\n            [(1, 0), (1, 1), (0, 2), (1, 2)]\\n        ],\\n        'L': [  # Orange L-shape\\n            [(2, 0), (0, 1), (1, 1), (2, 1)],\\n            [(1, 0), (1, 1), (1, 2), (2, 2)],\\n            [(0, 1), (1, 1), (2, 1), (0, 2)],\\n            [(0, 0), (1, 0), (1, 1), (1, 2)]\\n        ],\\n        'O': [\\n            [(0, 0), (1, 0), (0, 1), (1, 1)]\\n        ],\\n        'S': [\\n            [(1, 0), (2, 0), (0, 1), (1, 1)],\\n            [(0, 0), (0, 1), (1, 1), (1, 2)]\\n        ],\\n        'T': [\\n            [(0, 0), (1, 0), (2, 0), (1, 1)],\\n            [(1, 0), (0, 1), (1, 1), (1, 2)],\\n            [(1, 0), (0, 1), (1, 1), (2, 1)],\\n            [(1, 0), (1, 1), (2, 1), (1, 2)]\\n        ],\\n        'Z': [\\n            [(0, 0), (1, 0), (1, 1), (2, 1)],\\n            [(1, 0), (0, 1), (1, 1), (0, 2)]\\n        ]\\n    }\\n\\n    def __init__(self, x, y, tet_type=None):\\n        \\\"\\\"\\\"\\n        Initializes a Tetromino at (x, y). If tet_type is given, use it;\\n        otherwise pick one at random.\\n        \\\"\\\"\\\"\\n        if tet_type and tet_type in self.TETROMINO_SHAPES:\\n            self.type = tet_type\\n        else:\\n            self.type = random.choice(list(self.TETROMINO_SHAPES.keys()))\\n        self.orientations = self.TETROMINO_SHAPES[self.type]\\n        self.color = self.TETROMINO_COLORS[self.type]\\n        self.x = x\\n        self.y = y\\n        self.rotation = 0\\n\\n    def rotate(self, grid):\\n        \\\"\\\"\\\"\\n        Rotate to the next orientation (with collision check).\\n        \\\"\\\"\\\"\\n        original_rotation = self.rotation\\n        self.rotation = (self.rotation + 1) % len(self.orientations)\\n        if not grid.is_valid_move(self, self.x, self.y):\\n            self.rotation = original_rotation  # Revert rotation if invalid\\n\\n    def move(self, dx, dy, grid):\\n        \\\"\\\"\\\"\\n        Move the tetromino by dx, dy (with collision check).\\n        \\\"\\\"\\\"\\n        if grid.is_valid_move(self, self.x + dx, self.y + dy):\\n            self.x += dx\\n            self.y += dy\\n            return True\\n        return False\\n\\n    def get_current_shape(self):\\n        \\\"\\\"\\\"\\n        Get the list of (dx, dy) offsets for the current rotation.\\n        \\\"\\\"\\\"\\n        return self.orientations[self.rotation]\\n\\n    def get_coordinates(self):\\n        \\\"\\\"\\\"\\n        Get absolute grid coordinates for each block of the tetromino.\\n        \\\"\\\"\\\"\\n        shape = self.get_current_shape()\\n        return [(self.x + dx, self.y + dy) for dx, dy in shape]\\n\\n    def get_color(self):\\n        return self.color\\n\\n\\nclass TetrominoGenerator:\\n    \\\"\\\"\\\"\\n    Implements a 7-bag tetromino generator for more even distribution.\\n    \\\"\\\"\\\"\\n    def __init__(self, grid_width):\\n        self.grid_width = grid_width\\n        self._bag = []\\n        self._refill_bag()\\n\\n    def _refill_bag(self):\\n        self._bag = list(Tetromino.TETROMINO_SHAPES.keys())\\n        random.shuffle(self._bag)\\n\\n    def next_tetromino(self):\\n        \\\"\\\"\\\"\\n        Pop the next type from the bag and return a new Tetromino\\n        positioned at the top-center of the grid.\\n        \\\"\\\"\\\"\\n        if not self._bag:\\n            self._refill_bag()\\n        tet_type = self._bag.pop()\\n        start_x = self.grid_width // 2 - 1\\n        start_y = 0\\n        return Tetromino(start_x, start_y, tet_type)\\n\\n    def peek_next_type(self):\\n        \\\"\\\"\\\"\\n        Peek at the upcoming tetromino type without consuming it.\\n        \\\"\\\"\\\"\\n        if not self._bag:\\n            self._refill_bag()\\n        return self._bag[-1]\\n\\nif __name__ == '__main__':\\n    grid_width = 10\\n    grid_height = 20\\n    grid = Grid(grid_width, grid_height)\\n    generator = TetrominoGenerator(grid_width)\\n    current_tetromino = generator.next_tetromino()\\n    \\n    # Example of movement\\n    if current_tetromino.move(1, 0, grid):\\n        print(\\\"Moved right!\\\")\\n    else:\\n        print(\\\"Can't move right!\\\")\\n\\n    # Example of rotation\\n    current_tetromino.rotate(grid)\\n    print(\\\"Rotated!\\\")\\n```\\nTask task1:\\n  Objective: Define Tetromino module with shape definitions, rotation logic, and next-piece generation\\n  Result: ```python\\nimport random\\n\\nclass Tetromino:\\n    \\\"\\\"\\\"\\n    Represents a Tetromino with its shape orientations, color, and rotation logic.\\n    \\\"\\\"\\\"\\n\\n    TETROMINO_COLORS = {\\n        'I': (0, 255, 255),   # Cyan\\n        'J': (0, 0, 255),     # Blue\\n        'L': (255, 165, 0),   # Orange\\n        'O': (255, 255, 0),   # Yellow\\n        'S': (0, 255, 0),     # Green\\n        'T': (128, 0, 128),   # Purple\\n        'Z': (255, 0, 0)      # Red\\n    }\\n\\n    TETROMINO_SHAPES = {\\n        'I': [\\n            [(0, 0), (1, 0), (2, 0), (3, 0)],\\n            [(1, -1), (1, 0), (1, 1), (1, 2)]\\n        ],\\n        'J': [  # Blue J-shape\\n            [(0, 0), (0, 1), (1, 1), (2, 1)],\\n            [(1, 0), (2, 0), (1, 1), (1, 2)],\\n            [(0, 1), (1, 1), (2, 1), (2, 2)],\\n            [(1, 0), (1, 1), (0, 2), (1, 2)]\\n        ],\\n        'L': [  # Orange L-shape\\n            [(2, 0), (0, 1), (1, 1), (2, 1)],\\n            [(1, 0), (1, 1), (1, 2), (2, 2)],\\n            [(0, 1), (1, 1), (2, 1), (0, 2)],\\n            [(0, 0), (1, 0), (1, 1), (1, 2)]\\n        ],\\n        'O': [\\n            [(0, 0), (1, 0), (0, 1), (1, 1)]\\n        ],\\n        'S': [\\n            [(1, 0), (2, 0), (0, 1), (1, 1)],\\n            [(0, 0), (0, 1), (1, 1), (1, 2)]\\n        ],\\n        'T': [\\n            [(0, 0), (1, 0), (2, 0), (1, 1)],\\n            [(1, 0), (0, 1), (1, 1), (1, 2)],\\n            [(1, 0), (0, 1), (1, 1), (2, 1)],\\n            [(1, 0), (1, 1), (2, 1), (1, 2)]\\n        ],\\n        'Z': [\\n            [(0, 0), (1, 0), (1, 1), (2, 1)],\\n            [(1, 0), (0, 1), (1, 1), (0, 2)]\\n        ]\\n    }\\n\\n    def __init__(self, x, y, tet_type=None):\\n        \\\"\\\"\\\"\\n        Initializes a Tetromino at (x, y). If tet_type is given, use it;\\n        otherwise pick one at random.\\n        \\\"\\\"\\\"\\n        if tet_type and tet_type in self.TETROMINO_SHAPES:\\n            self.type = tet_type\\n        else:\\n            self.type = random.choice(list(self.TETROMINO_SHAPES.keys()))\\n        self.orientations = self.TETROMINO_SHAPES[self.type]\\n        self.color = self.TETROMINO_COLORS[self.type]\\n        self.x = x\\n        self.y = y\\n        self.rotation = 0\\n\\n    def rotate(self):\\n        \\\"\\\"\\\"\\n        Rotate to the next orientation (no wall-kick logic included).\\n        \\\"\\\"\\\"\\n        self.rotation = (self.rotation + 1) % len(self.orientations)\\n\\n    def get_current_shape(self):\\n        \\\"\\\"\\\"\\n        Get the list of (dx, dy) offsets for the current rotation.\\n        \\\"\\\"\\\"\\n        return self.orientations[self.rotation]\\n\\n    def get_coordinates(self):\\n        \\\"\\\"\\\"\\n        Get absolute grid coordinates for each block of the tetromino.\\n        \\\"\\\"\\\"\\n        shape = self.get_current_shape()\\n        return [(self.x + dx, self.y + dy) for dx, dy in shape]\\n\\n    def get_color(self):\\n        return self.color\\n\\n\\nclass TetrominoGenerator:\\n    \\\"\\\"\\\"\\n    Implements a 7-bag tetromino generator for more even distribution.\\n    \\\"\\\"\\\"\\n    def __init__(self, grid_width):\\n        self.grid_width = grid_width\\n        self._bag = []\\n        self._refill_bag()\\n\\n    def _refill_bag(self):\\n        self._bag = list(Tetromino.TETROMINO_SHAPES.keys())\\n        random.shuffle(self._bag)\\n\\n    def next_tetromino(self):\\n        \\\"\\\"\\\"\\n        Pop the next type from the bag and return a new Tetromino\\n        positioned at the top-center of the grid.\\n        \\\"\\\"\\\"\\n        if not self._bag:\\n            self._refill_bag()\\n        tet_type = self._bag.pop()\\n        start_x = self.grid_width // 2 - 1\\n        start_y = 0\\n        return Tetromino(start_x, start_y, tet_type)\\n\\n    def peek_next_type(self):\\n        \\\"\\\"\\\"\\n        Peek at the upcoming tetromino type without consuming it.\\n        \\\"\\\"\\\"\\n        if not self._bag:\\n            self._refill_bag()\\n        return self._bag[-1]\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task4:\\n  Objective: Build clearing mechanics: detect Tetris line clears and Bejeweled match-3 chains, remove gems, apply gravity, and update score\\n\\n---\\n# **Current Task Requirements**\\nImplement locking behavior: detect landing, convert tetromino blocks into colored gems in the grid\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport pygame\\nimport random\\n\\n# Initialize Pygame\\npygame.init()\\n\\n# Constants\\nGRID_WIDTH = 10\\nGRID_HEIGHT = 20\\nCELL_SIZE = 30\\nSCREEN_WIDTH = GRID_WIDTH * CELL_SIZE\\nSCREEN_HEIGHT = GRID_HEIGHT * CELL_SIZE\\nWHITE = (255, 255, 255)\\nBLACK = (0, 0, 0)\\nFPS = 30\\n\\n# Set up the screen\\nscreen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\\npygame.display.set_caption(\\\"Tetris Bejeweled\\\")\\nclock = pygame.time.Clock()\\n\\nclass Grid:\\n    def __init__(self, width, height):\\n        self.width = width\\n        self.height = height\\n        self.grid = [[None for _ in range(width)] for _ in range(height)]\\n\\n    def is_valid_move(self, shape, x, y):\\n        for dx, dy in shape.get_current_shape():\\n            gx, gy = x + dx, y + dy\\n            if gx < 0 or gx >= self.width or gy < 0 or gy >= self.height:\\n                return False\\n            if gy >= 0 and self.grid[gy][gx] is not None:\\n                return False\\n        return True\\n\\n    def lock_shape(self, shape):\\n        \\\"\\\"\\\"Convert the tetromino blocks into gems in the grid.\\\"\\\"\\\"\\n        for gx, gy in shape.get_coordinates():\\n            if 0 <= gx < self.width and 0 <= gy < self.height:\\n                self.grid[gy][gx] = shape.color\\n\\n    def clear_full_rows(self):\\n        \\\"\\\"\\\"Clear any full rows (Tetris) and return count of cleared rows.\\\"\\\"\\\"\\n        cleared = 0\\n        new_grid = []\\n        for row in self.grid:\\n            if all(cell is not None for cell in row):\\n                cleared += 1\\n            else:\\n                new_grid.append(row)\\n        # Add empty rows at top\\n        for _ in range(cleared):\\n            new_grid.insert(0, [None]*self.width)\\n        self.grid = new_grid\\n        return cleared\\n\\n    def find_matches(self):\\n        \\\"\\\"\\\"Return set of (x,y) cells that form match-3+ horizontally or vertically.\\\"\\\"\\\"\\n        matches = set()\\n        # Horizontal\\n        for y in range(self.height):\\n            x = 0\\n            while x < self.width:\\n                color = self.grid[y][x]\\n                if color is None:\\n                    x += 1\\n                    continue\\n                length = 1\\n                while x+length < self.width and self.grid[y][x+length] == color:\\n                    length += 1\\n                if length >= 3:\\n                    for i in range(length):\\n                        matches.add((x+i, y))\\n                x += length\\n        # Vertical\\n        for x in range(self.width):\\n            y = 0\\n            while y < self.height:\\n                color = self.grid[y][x]\\n                if color is None:\\n                    y += 1\\n                    continue\\n                length = 1\\n                while y+length < self.height and self.grid[y+length][x] == color:\\n                    length += 1\\n                if length >= 3:\\n                    for i in range(length):\\n                        matches.add((x, y+i))\\n                y += length\\n        return matches\\n\\n    def clear_matches(self):\\n        \\\"\\\"\\\"Clear all match-3+ gems, return number of cleared gems.\\\"\\\"\\\"\\n        matches = self.find_matches()\\n        for x, y in matches:\\n            self.grid[y][x] = None\\n        return len(matches)\\n\\n    def apply_gravity(self):\\n        \\\"\\\"\\\"Drop gems down into empty spaces.\\\"\\\"\\\"\\n        for x in range(self.width):\\n            write_row = self.height - 1\\n            for y in range(self.height-1, -1, -1):\\n                if self.grid[y][x] is not None:\\n                    self.grid[write_row][x] = self.grid[y][x]\\n                    if write_row != y:\\n                        self.grid[y][x] = None\\n                    write_row -= 1\\n\\n    def draw(self, screen):\\n        for y in range(self.height):\\n            for x in range(self.width):\\n                if self.grid[y][x]:\\n                    pygame.draw.rect(screen, self.grid[y][x], (x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE))\\n                    pygame.draw.rect(screen, BLACK, (x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE), 1)  # Grid lines\\n\\n\\nclass Tetromino:\\n    TETROMINO_COLORS = {\\n        'I': (0,255,255), 'J': (0,0,255), 'L': (255,165,0),\\n        'O': (255,255,0), 'S': (0,255,0), 'T': (128,0,128), 'Z': (255,0,0)\\n    }\\n    TETROMINO_SHAPES = {\\n        'I': [[(0,0),(1,0),(2,0),(3,0)], [(1,-1),(1,0),(1,1),(1,2)]],\\n        'J': [[(0,0),(0,1),(1,1),(2,1)], [(1,0),(2,0),(1,1),(1,2)],\\n              [(0,1),(1,1),(2,1),(2,2)], [(1,0),(1,1),(0,2),(1,2)]],\\n        'L': [[(2,0),(0,1),(1,1),(2,1)], [(1,0),(1,1),(1,2),(2,2)],\\n              [(0,1),(1,1),(2,1),(0,2)], [(0,0),(1,0),(1,1),(1,2)]],\\n        'O': [[(0,0),(1,0),(0,1),(1,1)]],\\n        'S': [[(1,0),(2,0),(0,1),(1,1)], [(0,0),(0,1),(1,1),(1,2)]],\\n        'T': [[(0,0),(1,0),(2,0),(1,1)], [(1,0),(0,1),(1,1),(1,2)],\\n              [(1,0),(0,1),(1,1),(2,1)], [(1,0),(1,1),(2,1),(1,2)]],\\n        'Z': [[(0,0),(1,0),(1,1),(2,1)], [(1,0),(0,1),(1,1),(0,2)]]\\n    }\\n\\n    def __init__(self, x, y, tet_type=None):\\n        if tet_type in self.TETROMINO_SHAPES:\\n            self.type = tet_type\\n        else:\\n            self.type = random.choice(list(self.TETROMINO_SHAPES))\\n        self.orientations = self.TETROMINO_SHAPES[self.type]\\n        self.color = self.TETROMINO_COLORS[self.type]\\n        self.rotation = 0\\n        self.x = x\\n        self.y = y\\n\\n    def get_current_shape(self):\\n        return self.orientations[self.rotation]\\n\\n    def get_coordinates(self):\\n        return [(self.x+dx, self.y+dy) for dx,dy in self.get_current_shape()]\\n\\n    def move(self, dx, dy, grid):\\n        if grid.is_valid_move(self, self.x+dx, self.y+dy):\\n            self.x += dx\\n            self.y += dy\\n            return True\\n        return False\\n\\n    def rotate(self, grid):\\n        old_rot = self.rotation\\n        self.rotation = (self.rotation+1) % len(self.orientations)\\n        if not grid.is_valid_move(self, self.x, self.y):\\n            self.rotation = old_rot\\n\\n    def draw(self, screen):\\n        for x, y in self.get_coordinates():\\n            pygame.draw.rect(screen, self.color, (x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE))\\n            pygame.draw.rect(screen, BLACK, (x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE), 1)  # Grid lines\\n\\nclass TetrominoGenerator:\\n    def __init__(self, grid_width):\\n        self.grid_width = grid_width\\n        self._bag = []\\n        self._refill()\\n    def _refill(self):\\n        self._bag = list(Tetromino.TETROMINO_SHAPES.keys())\\n        random.shuffle(self._bag)\\n    def next(self):\\n        if not self._bag:\\n            self._refill()\\n        t = self._bag.pop()\\n        start_x = self.grid_width//2 - 1\\n        return Tetromino(start_x, 0, t)\\n\\n\\nclass Game:\\n    def __init__(self, width=GRID_WIDTH, height=GRID_HEIGHT):\\n        self.grid = Grid(width, height)\\n        self.generator = TetrominoGenerator(width)\\n        self.current = self.generator.next()\\n        self.score = 0\\n        self.drop_speed = 30 # frames\\n        self.drop_counter = 0\\n\\n    def update(self):\\n        \\\"\\\"\\\"Drop the current tetromino by 1. If it lands, lock it, clear, gravity, spawn next.\\\"\\\"\\\"\\n        self.drop_counter += 1\\n        if self.drop_counter >= self.drop_speed:\\n            self.drop_counter = 0\\n            if self.current.move(0, 1, self.grid):\\n                return  # still falling\\n            # lock when it cannot move down\\n            self.grid.lock_shape(self.current)\\n            # Tetris line clear\\n            lines = self.grid.clear_full_rows()\\n            self.score += lines * 100\\n            # Bejeweled matches + gravity, allow chain reactions\\n            while True:\\n                cleared = self.grid.clear_matches()\\n                if cleared == 0:\\n                    break\\n                self.score += cleared * 10\\n                self.grid.apply_gravity()\\n            # spawn next\\n            self.current = self.generator.next()\\n            # if new piece collides immediately, game over\\n            if not self.grid.is_valid_move(self.current, self.current.x, self.current.y):\\n                raise Exception(\\\"Game Over\\\")\\n\\n    def handle_input(self, event):\\n        if event.type == pygame.KEYDOWN:\\n            if event.key == pygame.K_LEFT:\\n                self.current.move(-1, 0, self.grid)\\n            elif event.key == pygame.K_RIGHT:\\n                self.current.move(1, 0, self.grid)\\n            elif event.key == pygame.K_DOWN:\\n                self.current.move(0, 1, self.grid)\\n            elif event.key == pygame.K_UP:\\n                self.current.rotate(self.grid)\\n\\n    def draw(self, screen):\\n        self.grid.draw(screen)\\n        self.current.draw(screen)\\n        font = pygame.font.Font(None, 36)\\n        text = font.render(f\\\"Score: {self.score}\\\", True, WHITE)\\n        screen.blit(text, (10, 10))\\n\\n# Game loop\\nif __name__ == '__main__':\\n    game = Game()\\n    running = True\\n\\n    while running:\\n        screen.fill(BLACK)\\n        for event in pygame.event.get():\\n            if event.type == pygame.QUIT:\\n                running = False\\n            game.handle_input(event)\\n\\n        try:\\n            game.update()\\n        except Exception as e:\\n            print(e, \\\"Score:\\\", game.score)\\n            running = False\\n\\n        game.draw(screen)\\n        pygame.display.flip()\\n        clock.tick(FPS)\\n\\n    pygame.quit()\\n```\",\n  \"timestamp\": \"2026-05-22T20:18:40.900422\"\n}"}
