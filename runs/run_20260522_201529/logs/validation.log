f, x, y, color):\\n         \\\"\\\"\\\"Sets the color of the gem at the given coordinates.\\\"\\\"\\\"\\n         if 0 <= x < self.width and 0 <= y < self.height:\\n             self.grid[y][x] = color\\n             \\n    def clear_cell(self, x, y):\\n        \\\"\\\"\\\"Clears the cell at the given coordinates by setting it to None.\\\"\\\"\\\"\\n        if 0 <= x < self.width and 0 <= y < self.height:\\n            self.grid[y][x] = None\\n\\n    def is_row_full(self, row_index):\\n        \\\"\\\"\\\"Checks if a row is completely filled with gems (no None values).\\\"\\\"\\\"\\n        return all(self.grid[row_index])\\n\\n    def clear_row(self, row_index):\\n        \\\"\\\"\\\"Clears all cells in a given row.\\\"\\\"\\\"\\n        for x in range(self.width):\\n            self.grid[row_index][x] = None\\n\\n    def drop_row(self, row_index):\\n        \\\"\\\"\\\"Moves all rows above the given row down by one.\\\"\\\"\\\"\\n        for y in range(row_index, 0, -1):\\n            self.grid[y] = self.grid[y - 1][:]  # Copy the row above\\n        self.grid[0] = [None] * self.width  # Clear the top row\\n\\n    def clear_matches(self):\\n        \\\"\\\"\\\"Find and clear match-3 or more chains, return the cleared coordinates.\\\"\\\"\\\"\\n        matches = self.find_matches()\\n        cleared_coordinates = set()\\n        for x, y in matches:\\n            self.clear_cell(x, y)\\n            cleared_coordinates.add((x, y))\\n        return cleared_coordinates\\n\\n    def find_matches(self):\\n        \\\"\\\"\\\"Finds all horizontal and vertical match-3 or more chains.\\\"\\\"\\\"\\n        matches = set()\\n\\n        # Horizontal matches\\n        for y in range(self.height):\\n            for x in range(self.width - 2):\\n                color = self.get_cell_color(x, y)\\n                if color is None:\\n                    continue\\n                if (self.get_cell_color(x + 1, y) == color and\\n                        self.get_cell_color(x + 2, y) == color):\\n                    match_length = 3\\n                    while (x + match_length < self.width and\\n                           self.get_cell_color(x + match_length, y) == color):\\n                        match_length += 1\\n                    for i in range(match_length):\\n                        matches.add((x + i, y))\\n\\n        # Vertical matches\\n        for x in range(self.width):\\n            for y in range(self.height - 2):\\n                color = self.get_cell_color(x, y)\\n                if color is None:\\n                    continue\\n                if (self.get_cell_color(x, y + 1) == color and\\n                        self.get_cell_color(x, y + 2) == color):\\n                    match_length = 3\\n                    while (y + match_length < self.height and\\n                           self.get_cell_color(x, y + match_length) == color):\\n                        match_length += 1\\n                    for i in range(match_length):\\n                        matches.add((x, y + i))\\n\\n        return list(matches)\\n\\n    def apply_gravity(self):\\n        \\\"\\\"\\\"Applies gravity to the grid, moving floating gems down.\\\"\\\"\\\"\\n        for x in range(self.width):\\n            empty_space = -1\\n            for y in range(self.height):\\n                if self.grid[y][x] is None:\\n                    if empty_space == -1:\\n                        empty_space = y\\n                else:\\n                    if empty_space != -1:\\n                        self.grid[empty_space][x] = self.grid[y][x]\\n                        self.grid[y][x] = None\\n                        empty_space += 1\\n\\nclass Tetromino:\\n    \\\"\\\"\\\"\\n    Represents a Tetromino with its shape orientations, color, and rotation logic.\\n    \\\"\\\"\\\"\\n\\n    TETROMINO_COLORS = {\\n        'I': (0, 255, 255),   # Cyan\\n        'J': (0, 0, 255),     # Blue\\n        'L': (255, 165, 0),   # Orange\\n        'O': (255, 255, 0),   # Yellow\\n        'S': (0, 255, 0),     # Green\\n        'T': (128, 0, 128),   # Purple\\n        'Z': (255, 0, 0)      # Red\\n    }\\n\\n    TETROMINO_SHAPES = {\\n        'I': [\\n            [(0, 0), (1, 0), (2, 0), (3, 0)],\\n            [(1, -1), (1, 0), (1, 1), (1, 2)]\\n        ],\\n        'J': [  # Blue J-shape\\n            [(0, 0), (0, 1), (1, 1), (2, 1)],\\n            [(1, 0), (2, 0), (1, 1), (1, 2)],\\n            [(0, 1), (1, 1), (2, 1), (2, 2)],\\n            [(1, 0), (1, 1), (0, 2), (1, 2)]\\n        ],\\n        'L': [  # Orange L-shape\\n            [(2, 0), (0, 1), (1, 1), (2, 1)],\\n            [(1, 0), (1, 1), (1, 2), (2, 2)],\\n            [(0, 1), (1, 1), (2, 1), (0, 2)],\\n            [(0, 0), (1, 0), (1, 1), (1, 2)]\\n        ],\\n        'O': [\\n            [(0, 0), (1, 0), (0, 1), (1, 1)]\\n        ],\\n        'S': [\\n            [(1, 0), (2, 0), (0, 1), (1, 1)],\\n            [(0, 0), (0, 1), (1, 1), (1, 2)]\\n        ],\\n        'T': [\\n            [(0, 0), (1, 0), (2, 0), (1, 1)],\\n            [(1, 0), (0, 1), (1, 1), (1, 2)],\\n            [(1, 0), (0, 1), (1, 1), (2, 1)],\\n            [(1, 0), (1, 1), (2, 1), (1, 2)]\\n        ],\\n        'Z': [\\n            [(0, 0), (1, 0), (1, 1), (2, 1)],\\n            [(1, 0), (0, 1), (1, 1), (0, 2)]\\n        ]\\n    }\\n\\n    def __init__(self, x, y, tet_type=None):\\n        \\\"\\\"\\\"\\n        Initializes a Tetromino at (x, y). If tet_type is given, use it;\\n        otherwise pick one at random.\\n        \\\"\\\"\\\"\\n        if tet_type and tet_type in self.TETROMINO_SHAPES:\\n            self.type = tet_type\\n        else:\\n            self.type = random.choice(list(self.TETROMINO_SHAPES.keys()))\\n        self.orientations = self.TETROMINO_SHAPES[self.type]\\n        self.color = self.TETROMINO_COLORS[self.type]\\n        self.x = x\\n        self.y = y\\n        self.rotation = 0\\n\\n    def rotate(self, grid):\\n        \\\"\\\"\\\"\\n        Rotate to the next orientation (with collision check).\\n        \\\"\\\"\\\"\\n        original_rotation = self.rotation\\n        self.rotation = (self.rotation + 1) % len(self.orientations)\\n        if not grid.is_valid_move(self, self.x, self.y):\\n            self.rotation = original_rotation  # Revert rotation if invalid\\n\\n    def move(self, dx, dy, grid):\\n        \\\"\\\"\\\"\\n        Move the tetromino by dx, dy (with collision check).\\n        \\\"\\\"\\\"\\n        if grid.is_valid_move(self, self.x + dx, self.y + dy):\\n            self.x += dx\\n            self.y += dy\\n            return True\\n        return False\\n\\n    def get_current_shape(self):\\n        \\\"\\\"\\\"\\n        Get the list of (dx, dy) offsets for the current rotation.\\n        \\\"\\\"\\\"\\n        return self.orientations[self.rotation]\\n\\n    def get_coordinates(self):\\n        \\\"\\\"\\\"\\n        Get absolute grid coordinates for each block of the tetromino.\\n        \\\"\\\"\\\"\\n        shape = self.get_current_shape()\\n        return [(self.x + dx, self.y + dy) for dx, dy in shape]\\n\\n    def get_color(self):\\n        return self.color\\n\\n\\nclass TetrominoGenerator:\\n    \\\"\\\"\\\"\\n    Implements a 7-bag tetromino generator for more even distribution.\\n    \\\"\\\"\\\"\\n    def __init__(self, grid_width):\\n        self.grid_width = grid_width\\n        self._bag = []\\n        self._refill_bag()\\n\\n    def _refill_bag(self):\\n        self._bag = list(Tetromino.TETROMINO_SHAPES.keys())\\n        random.shuffle(self._bag)\\n\\n    def next_tetromino(self):\\n        \\\"\\\"\\\"\\n        Pop the next type from the bag and return a new Tetromino\\n        positioned at the top-center of the grid.\\n        \\\"\\\"\\\"\\n        if not self._bag:\\n            self._refill_bag()\\n        tet_type = self._bag.pop()\\n        start_x = self.grid_width // 2 - 1\\n        start_y = 0\\n        return Tetromino(start_x, start_y, tet_type)\\n\\n    def peek_next_type(self):\\n        \\\"\\\"\\\"\\n        Peek at the upcoming tetromino type without consuming it.\\n        \\\"\\\"\\\"\\n        if not self._bag:\\n            self._refill_bag()\\n        return self._bag[-1]\\n\\nif __name__ == '__main__':\\n    grid_width = 10\\n    grid_height = 20\\n    grid = Grid(grid_width, grid_height)\\n    generator = TetrominoGenerator(grid_width)\\n    current_tetromino = generator.next_tetromino()\\n    \\n    # Example of movement\\n    if current_tetromino.move(1, 0, grid):\\n        print(\\\"Moved right!\\\")\\n    else:\\n        print(\\\"Can't move right!\\\")\\n\\n    # Example of rotation\\n    current_tetromino.rotate(grid)\\n    print(\\\"Rotated!\\\")\\n```\\nTask task1:\\n  Objective: Define Tetromino module with shape definitions, rotation logic, and next-piece generation\\n  Result: ```python\\nimport random\\n\\nclass Tetromino:\\n    \\\"\\\"\\\"\\n    Represents a Tetromino with its shape orientations, color, and rotation logic.\\n    \\\"\\\"\\\"\\n\\n    TETROMINO_COLORS = {\\n        'I': (0, 255, 255),   # Cyan\\n        'J': (0, 0, 255),     # Blue\\n        'L': (255, 165, 0),   # Orange\\n        'O': (255, 255, 0),   # Yellow\\n        'S': (0, 255, 0),     # Green\\n        'T': (128, 0, 128),   # Purple\\n        'Z': (255, 0, 0)      # Red\\n    }\\n\\n    TETROMINO_SHAPES = {\\n        'I': [\\n            [(0, 0), (1, 0), (2, 0), (3, 0)],\\n            [(1, -1), (1, 0), (1, 1), (1, 2)]\\n        ],\\n        'J': [  # Blue J-shape\\n            [(0, 0), (0, 1), (1, 1), (2, 1)],\\n            [(1, 0), (2, 0), (1, 1), (1, 2)],\\n            [(0, 1), (1, 1), (2, 1), (2, 2)],\\n            [(1, 0), (1, 1), (0, 2), (1, 2)]\\n        ],\\n        'L': [  # Orange L-shape\\n            [(2, 0), (0, 1), (1, 1), (2, 1)],\\n            [(1, 0), (1, 1), (1, 2), (2, 2)],\\n            [(0, 1), (1, 1), (2, 1), (0, 2)],\\n            [(0, 0), (1, 0), (1, 1), (1, 2)]\\n        ],\\n        'O': [\\n            [(0, 0), (1, 0), (0, 1), (1, 1)]\\n        ],\\n        'S': [\\n            [(1, 0), (2, 0), (0, 1), (1, 1)],\\n            [(0, 0), (0, 1), (1, 1), (1, 2)]\\n        ],\\n        'T': [\\n            [(0, 0), (1, 0), (2, 0), (1, 1)],\\n            [(1, 0), (0, 1), (1, 1), (1, 2)],\\n            [(1, 0), (0, 1), (1, 1), (2, 1)],\\n            [(1, 0), (1, 1), (2, 1), (1, 2)]\\n        ],\\n        'Z': [\\n            [(0, 0), (1, 0), (1, 1), (2, 1)],\\n            [(1, 0), (0, 1), (1, 1), (0, 2)]\\n        ]\\n    }\\n\\n    def __init__(self, x, y, tet_type=None):\\n        \\\"\\\"\\\"\\n        Initializes a Tetromino at (x, y). If tet_type is given, use it;\\n        otherwise pick one at random.\\n        \\\"\\\"\\\"\\n        if tet_type and tet_type in self.TETROMINO_SHAPES:\\n            self.type = tet_type\\n        else:\\n            self.type = random.choice(list(self.TETROMINO_SHAPES.keys()))\\n        self.orientations = self.TETROMINO_SHAPES[self.type]\\n        self.color = self.TETROMINO_COLORS[self.type]\\n        self.x = x\\n        self.y = y\\n        self.rotation = 0\\n\\n    def rotate(self):\\n        \\\"\\\"\\\"\\n        Rotate to the next orientation (no wall-kick logic included).\\n        \\\"\\\"\\\"\\n        self.rotation = (self.rotation + 1) % len(self.orientations)\\n\\n    def get_current_shape(self):\\n        \\\"\\\"\\\"\\n        Get the list of (dx, dy) offsets for the current rotation.\\n        \\\"\\\"\\\"\\n        return self.orientations[self.rotation]\\n\\n    def get_coordinates(self):\\n        \\\"\\\"\\\"\\n        Get absolute grid coordinates for each block of the tetromino.\\n        \\\"\\\"\\\"\\n        shape = self.get_current_shape()\\n        return [(self.x + dx, self.y + dy) for dx, dy in shape]\\n\\n    def get_color(self):\\n        return self.color\\n\\n\\nclass TetrominoGenerator:\\n    \\\"\\\"\\\"\\n    Implements a 7-bag tetromino generator for more even distribution.\\n    \\\"\\\"\\\"\\n    def __init__(self, grid_width):\\n        self.grid_width = grid_width\\n        self._bag = []\\n        self._refill_bag()\\n\\n    def _refill_bag(self):\\n        self._bag = list(Tetromino.TETROMINO_SHAPES.keys())\\n        random.shuffle(self._bag)\\n\\n    def next_tetromino(self):\\n        \\\"\\\"\\\"\\n        Pop the next type from the bag and return a new Tetromino\\n        positioned at the top-center of the grid.\\n        \\\"\\\"\\\"\\n        if not self._bag:\\n            self._refill_bag()\\n        tet_type = self._bag.pop()\\n        start_x = self.grid_width // 2 - 1\\n        start_y = 0\\n        return Tetromino(start_x, start_y, tet_type)\\n\\n    def peek_next_type(self):\\n        \\\"\\\"\\\"\\n        Peek at the upcoming tetromino type without consuming it.\\n        \\\"\\\"\\\"\\n        if not self._bag:\\n            self._refill_bag()\\n        return self._bag[-1]\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task4:\\n  Objective: Build clearing mechanics: detect Tetris line clears and Bejeweled match-3 chains, remove gems, apply gravity, and update score\\n\\n---\\n# **Current Task Requirements**\\nImplement locking behavior: detect landing, convert tetromino blocks into colored gems in the grid\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport pygame\\nimport random\\n\\nclass Grid:\\n    def __init__(self, width, height):\\n        self.width = width\\n        self.height = height\\n        self.grid = [[None for _ in range(width)] for _ in range(height)]\\n\\n    def is_valid_move(self, shape, offset_x, offset_y):\\n        \\\"\\\"\\\"Checks if the shape can be placed at the given offset without collisions or going out of bounds.\\\"\\\"\\\"\\n        for x, y in shape.get_current_shape():\\n            grid_x = x + offset_x\\n            grid_y = y + offset_y\\n\\n            if grid_x < 0 or grid_x >= self.width or grid_y < 0 or grid_y >= self.height or self.grid[grid_y][grid_x] is not None:\\n                return False\\n        return True\\n        \\n    def place_shape(self, shape, offset_x, offset_y):\\n        \\\"\\\"\\\"Places the shape's blocks (converted to gem colors) onto the grid.\\\"\\\"\\\"\\n        for x, y in shape.get_current_shape():\\n            grid_x = x + offset_x\\n            grid_y = y + offset_y\\n            self.grid[grid_y][grid_x] = shape.color  # Store color as gem type\\n\\n    def get_cell_color(self, x, y):\\n        \\\"\\\"\\\"Returns the color of the gem at the given coordinates, or None if the cell is empty.\\\"\\\"\\\"\\n        if 0 <= x < self.width and 0 <= y < self.height:\\n            return self.grid[y][x]\\n        else:\\n            return None  # Out of bounds\\n            \\n    def set_cell_color(self, x, y, color):\\n         \\\"\\\"\\\"Sets the color of the gem at the given coordinates.\\\"\\\"\\\"\\n         if 0 <= x < self.width and 0 <= y < self.height:\\n             self.grid[y][x] = color\\n             \\n    def clear_cell(self, x, y):\\n        \\\"\\\"\\\"Clears the cell at the given coordinates by setting it to None.\\\"\\\"\\\"\\n        if 0 <= x < self.width and 0 <= y < self.height:\\n            self.grid[y][x] = None\\n\\n    def is_row_full(self, row_index):\\n        \\\"\\\"\\\"Checks if a row is completely filled with gems (no None values).\\\"\\\"\\\"\\n        return all(self.grid[row_index])\\n\\n    def clear_row(self, row_index):\\n        \\\"\\\"\\\"Clears all cells in a given row.\\\"\\\"\\\"\\n        for x in range(self.width):\\n            self.grid[row_index][x] = None\\n\\n    def drop_row(self, row_index):\\n        \\\"\\\"\\\"Moves all rows above the given row down by one.\\\"\\\"\\\"\\n        for y in range(row_index, 0, -1):\\n            self.grid[y] = self.grid[y - 1][:]  # Copy the row above\\n        self.grid[0] = [None] * self.width  # Clear the top row\\n\\n    def clear_matches(self):\\n        \\\"\\\"\\\"Find and clear match-3 or more chains, return the cleared coordinates.\\\"\\\"\\\"\\n        matches = self.find_matches()\\n        cleared_coordinates = set()\\n        for x, y in matches:\\n            self.clear_cell(x, y)\\n            cleared_coordinates.add((x, y))\\n        return cleared_coordinates\\n\\n    def find_matches(self):\\n        \\\"\\\"\\\"Finds all horizontal and vertical match-3 or more chains.\\\"\\\"\\\"\\n        matches = set()\\n\\n        # Horizontal matches\\n        for y in range(self.height):\\n            for x in range(self.width - 2):\\n                color = self.get_cell_color(x, y)\\n                if color is None:\\n                    continue\\n                if (self.get_cell_color(x + 1, y) == color and\\n                        self.get_cell_color(x + 2, y) == color):\\n                    match_length = 3\\n                    while (x + match_length < self.width and\\n                           self.get_cell_color(x + match_length, y) == color):\\n                        match_length += 1\\n                    for i in range(match_length):\\n                        matches.add((x + i, y))\\n\\n        # Vertical matches\\n        for x in range(self.width):\\n            for y in range(self.height - 2):\\n                color = self.get_cell_color(x, y)\\n                if color is None:\\n                    continue\\n                if (self.get_cell_color(x, y + 1) == color and\\n                        self.get_cell_color(x, y + 2) == color):\\n                    match_length = 3\\n                    while (y + match_length < self.height and\\n                           self.get_cell_color(x, y + match_length) == color):\\n                        match_length += 1\\n                    for i in range(match_length):\\n                        matches.add((x, y + i))\\n\\n        return list(matches)\\n\\n    def apply_gravity(self):\\n        \\\"\\\"\\\"Applies gravity to the grid, moving floating gems down.\\\"\\\"\\\"\\n        for x in range(self.width):\\n            empty_space = -1\\n            for y in range(self.height):\\n                if self.grid[y][x] is None:\\n                    if empty_space == -1:\\n                        empty_space = y\\n                else:\\n                    if empty_space != -1:\\n                        self.grid[empty_space][x] = self.grid[y][x]\\n                        self.grid[y][x] = None\\n                        empty_space += 1\\n                        \\n    def lock_shape(self, shape, offset_x, offset_y):\\n        \\\"\\\"\\\"Locks the shape onto the grid.\\\"\\\"\\\"\\n        for x, y in shape.get_current_shape():\\n            grid_x = x + offset_x\\n            grid_y = y + offset_y\\n            if 0 <= grid_x < self.width and 0 <= grid_y < self.height:\\n                self.grid[grid_y][grid_x] = shape.color\\n\\nclass Tetromino:\\n    \\\"\\\"\\\"\\n    Represents a Tetromino with its shape orientations, color, and rotation logic.\\n    \\\"\\\"\\\"\\n\\n    TETROMINO_COLORS = {\\n        'I': (0, 255, 255),   # Cyan\\n        'J': (0, 0, 255),     # Blue\\n        'L': (255, 165, 0),   # Orange\\n        'O': (255, 255, 0),   # Yellow\\n        'S': (0, 255, 0),     # Green\\n        'T': (128, 0, 128),   # Purple\\n        'Z': (255, 0, 0)      # Red\\n    }\\n\\n    TETROMINO_SHAPES = {\\n        'I': [\\n            [(0, 0), (1, 0), (2, 0), (3, 0)],\\n            [(1, -1), (1, 0), (1, 1), (1, 2)]\\n        ],\\n        'J': [  # Blue J-shape\\n            [(0, 0), (0, 1), (1, 1), (2, 1)],\\n            [(1, 0), (2, 0), (1, 1), (1, 2)],\\n            [(0, 1), (1, 1), (2, 1), (2, 2)],\\n            [(1, 0), (1, 1), (0, 2), (1, 2)]\\n        ],\\n        'L': [  # Orange L-shape\\n            [(2, 0), (0, 1), (1, 1), (2, 1)],\\n            [(1, 0), (1, 1), (1, 2), (2, 2)],\\n            [(0, 1), (1, 1), (2, 1), (0, 2)],\\n            [(0, 0), (1, 0), (1, 1), (1, 2)]\\n        ],\\n        'O': [\\n            [(0, 0), (1, 0), (0, 1), (1, 1)]\\n        ],\\n        'S': [\\n            [(1, 0), (2, 0), (0, 1), (1, 1)],\\n            [(0, 0), (0, 1), (1, 1), (1, 2)]\\n        ],\\n        'T': [\\n            [(0, 0), (1, 0), (2, 0), (1, 1)],\\n            [(1, 0), (0, 1), (1, 1), (1, 2)],\\n            [(1, 0), (0, 1), (1, 1), (2, 1)],\\n            [(1, 0), (1, 1), (2, 1), (1, 2)]\\n        ],\\n        'Z': [\\n            [(0, 0), (1, 0), (1, 1), (2, 1)],\\n            [(1, 0), (0, 1), (1, 1), (0, 2)]\\n        ]\\n    }\\n\\n    def __init__(self, x, y, tet_type=None):\\n        \\\"\\\"\\\"\\n        Initializes a Tetromino at (x, y). If tet_type is given, use it;\\n        otherwise pick one at random.\\n        \\\"\\\"\\\"\\n        if tet_type and tet_type in self.TETROMINO_SHAPES:\\n            self.type = tet_type\\n        else:\\n            self.type = random.choice(list(self.TETROMINO_SHAPES.keys()))\\n        self.orientations = self.TETROMINO_SHAPES[self.type]\\n        self.color = self.TETROMINO_COLORS[self.type]\\n        self.x = x\\n        self.y = y\\n        self.rotation = 0\\n\\n    def rotate(self, grid):\\n        \\\"\\\"\\\"\\n        Rotate to the next orientation (with collision check).\\n        \\\"\\\"\\\"\\n        original_rotation = self.rotation\\n        self.rotation = (self.rotation + 1) % len(self.orientations)\\n        if not grid.is_valid_move(self, self.x, self.y):\\n            self.rotation = original_rotation  # Revert rotation if invalid\\n\\n    def move(self, dx, dy, grid):\\n        \\\"\\\"\\\"\\n        Move the tetromino by dx, dy (with collision check).\\n        \\\"\\\"\\\"\\n        if grid.is_valid_move(self, self.x + dx, self.y + dy):\\n            self.x += dx\\n            self.y += dy\\n            return True\\n        return False\\n    \\n    def can_move(self, dx, dy, grid):\\n        \\\"\\\"\\\"\\n        Check if the tetromino can move by dx, dy without collision (without actually moving).\\n        \\\"\\\"\\\"\\n        return grid.is_valid_move(self, self.x + dx, self.y + dy)\\n\\n    def get_current_shape(self):\\n        \\\"\\\"\\\"\\n        Get the list of (dx, dy) offsets for the current rotation.\\n        \\\"\\\"\\\"\\n        return self.orientations[self.rotation]\\n\\n    def get_coordinates(self):\\n        \\\"\\\"\\\"\\n        Get absolute grid coordinates for each block of the tetromino.\\n        \\\"\\\"\\\"\\n        shape = self.get_current_shape()\\n        return [(self.x + dx, self.y + dy) for dx, dy in shape]\\n\\n    def get_color(self):\\n        return self.color\\n\\n\\nclass TetrominoGenerator:\\n    \\\"\\\"\\\"\\n    Implements a 7-bag tetromino generator for more even distribution.\\n    \\\"\\\"\\\"\\n    def __init__(self, grid_width):\\n        self.grid_width = grid_width\\n        self._bag = []\\n        self._refill_bag()\\n\\n    def _refill_bag(self):\\n        self._bag = list(Tetromino.TETROMINO_SHAPES.keys())\\n        random.shuffle(self._bag)\\n\\n    def next_tetromino(self):\\n        \\\"\\\"\\\"\\n        Pop the next type from the bag and return a new Tetromino\\n        positioned at the top-center of the grid.\\n        \\\"\\\"\\\"\\n        if not self._bag:\\n            self._refill_bag()\\n        tet_type = self._bag.pop()\\n        start_x = self.grid_width // 2 - 1\\n        start_y = 0\\n        return Tetromino(start_x, start_y, tet_type)\\n\\n    def peek_next_type(self):\\n        \\\"\\\"\\\"\\n        Peek at the upcoming tetromino type without consuming it.\\n        \\\"\\\"\\\"\\n        if not self._bag:\\n            self._refill_bag()\\n        return self._bag[-1]\\n\\nif __name__ == '__main__':\\n    grid_width = 10\\n    grid_height = 20\\n    grid = Grid(grid_width, grid_height)\\n    generator = TetrominoGenerator(grid_width)\\n    current_tetromino = generator.next_tetromino()\\n    \\n    # Example of movement\\n    if current_tetromino.move(1, 0, grid