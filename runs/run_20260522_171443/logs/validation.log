llState.GEM\\n                grid[y][x].color = self.color\\n\\n\\nclass GameState:\\n    def __init__(self, width: int = GRID_WIDTH, height: int = GRID_HEIGHT):\\n        self.grid = create_grid(width, height)\\n        self.current_tetromino = self.new_tetromino()\\n        self.next_tetromino = self.new_tetromino()\\n        self.score = 0\\n        self.game_over = False\\n\\n    def new_tetromino(self) -> Tetromino:\\n        \\\"\\\"\\\"Creates a new tetromino randomly.\\\"\\\"\\\"\\n        return Tetromino(random.choice(list(TETROMINO_SHAPES.keys())))\\n\\n    def spawn_tetromino(self):\\n        \\\"\\\"\\\"Spawns the next tetromino and updates the next tetromino.\\\"\\\"\\\"\\n        self.current_tetromino = self.next_tetromino\\n        self.next_tetromino = self.new_tetromino()\\n        self.current_tetromino.x = GRID_WIDTH // 2 - 2\\n        self.current_tetromino.y = 0\\n\\n        if self.current_tetromino.collides(self.grid):\\n            self.game_over = True\\n            return False\\n        return True\\n\\n\\n    def move_tetromino_down(self) -> bool:\\n        \\\"\\\"\\\"Moves the current tetromino down by one cell.\\\"\\\"\\\"\\n        if not self.current_tetromino.collides(self.grid, dy=1):\\n            self.current_tetromino.clear_from_grid(self.grid)\\n            self.current_tetromino.y += 1\\n            self.current_tetromino.place_on_grid(self.grid)\\n            return True\\n        else:\\n            return False\\n\\n\\n    def move_tetromino_sideways(self, dx: int):\\n        \\\"\\\"\\\"Moves the current tetromino left or right by one cell.\\\"\\\"\\\"\\n        if not self.current_tetromino.collides(self.grid, dx=dx):\\n            self.current_tetromino.clear_from_grid(self.grid)\\n            self.current_tetromino.x += dx\\n            self.current_tetromino.place_on_grid(self.grid)\\n\\n    def rotate_tetromino(self):\\n        \\\"\\\"\\\"Rotates the current tetromino clockwise if possible.\\\"\\\"\\\"\\n        original_matrix = [row[:] for row in self.current_tetromino.matrix] # Store the original matrix\\n        self.current_tetromino.clear_from_grid(self.grid) # Clear current pos\\n        self.current_tetromino.rotate()\\n        if self.current_tetromino.collides(self.grid):\\n            self.current_tetromino.matrix = original_matrix # Restore\\n        self.current_tetromino.place_on_grid(self.grid)\\n\\n    def drop_tetromino(self):\\n        \\\"\\\"\\\"Drops the tetromino to the lowest possible position.\\\"\\\"\\\"\\n        while not self.current_tetromino.collides(self.grid, dy=1):\\n            self.current_tetromino.clear_from_grid(self.grid)\\n            self.current_tetromino.y += 1\\n            self.current_tetromino.place_on_grid(self.grid)\\n\\n    def lock_tetromino(self):\\n      \\\"\\\"\\\"Locks the tetromino into the grid and spawns a new one.\\\"\\\"\\\"\\n      self.current_tetromino.lock_into_grid(self.grid)\\n\\ndef clear_grid_of_falling(grid: List[List[Cell]]):\\n    \\\"\\\"\\\"Clears the grid of any cells marked as 'FALLING'.\\\"\\\"\\\"\\n    for row in grid:\\n        for cell in row:\\n            if cell.state == CellState.FALLING:\\n                cell.state = CellState.EMPTY\\n                cell.color = None\\n\\n```\",\n  \"timestamp\": \"2026-05-22T17:15:43.259032\"\n}"}
