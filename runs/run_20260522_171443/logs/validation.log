y))\\n        return cells\\n\\n    def place_on_grid(self, grid: List[List[Cell]]):\\n        for x, y in self.get_cells():\\n            if 0 <= x < GRID_WIDTH and 0 <= y < GRID_HEIGHT:\\n                grid[y][x].state = CellState.FALLING\\n                grid[y][x].color = self.color\\n\\n    def clear_from_grid(self, grid: List[List[Cell]]):\\n        for x, y in self.get_cells():\\n            if 0 <= x < GRID_WIDTH and 0 <= y < GRID_HEIGHT:\\n                grid[y][x].reset()\\n\\n    def collides(self, grid: List[List[Cell]], dx: int = 0, dy: int = 0) -> bool:\\n        for x, y in self.get_cells():\\n            nx, ny = x + dx, y + dy\\n            # Boundary checks\\n            if nx < 0 or nx >= GRID_WIDTH or ny >= GRID_HEIGHT:\\n                return True\\n            # Only check collisions inside visible grid\\n            if ny >= 0:\\n                cell = grid[ny][nx]\\n                if not cell.is_empty() and not cell.is_falling():\\n                    return True\\n        return False\\n\\n    def lock_into_grid(self, grid: List[List[Cell]]):\\n        for x, y in self.get_cells():\\n            if 0 <= x < GRID_WIDTH and 0 <= y < GRID_HEIGHT:\\n                grid[y][x].state = CellState.GEM\\n                grid[y][x].color = self.color\\n\\n\\ndef clear_falling(grid: List[List[Cell]]):\\n    for row in grid:\\n        for cell in row:\\n            if cell.state == CellState.FALLING:\\n                cell.reset()\\n\\n\\nclass GameState:\\n    def __init__(self):\\n        self.grid = create_grid()\\n        self.current_tetromino = None\\n        self.next_tetromino = self._new_tetromino()\\n        self.score = 0\\n        self.game_over = False\\n        self.spawn_tetromino()  # spawn & place first piece\\n\\n    def _new_tetromino(self) -> Tetromino:\\n        return Tetromino(random.choice(list(TETROMINO_SHAPES.keys())))\\n\\n    def spawn_tetromino(self) -> bool:\\n        clear_falling(self.grid)\\n        self.current_tetromino = self.next_tetromino\\n        self.next_tetromino = self._new_tetromino()\\n        # reset position\\n        self.current_tetromino.x = GRID_WIDTH // 2 - 2\\n        self.current_tetromino.y = 0\\n        if self.current_tetromino.collides(self.grid):\\n            self.game_over = True\\n            return False\\n        self.current_tetromino.place_on_grid(self.grid)\\n        return True\\n\\n    def move_tetromino_down(self) -> bool:\\n        if not self.current_tetromino.collides(self.grid, dy=1):\\n            self.current_tetromino.clear_from_grid(self.grid)\\n            self.current_tetromino.y += 1\\n            self.current_tetromino.place_on_grid(self.grid)\\n            return True\\n        return False\\n\\n    def move_tetromino_sideways(self, dx: int):\\n        if not self.current_tetromino.collides(self.grid, dx=dx):\\n            self.current_tetromino.clear_from_grid(self.grid)\\n            self.current_tetromino.x += dx\\n            self.current_tetromino.place_on_grid(self.grid)\\n\\n    def rotate_tetromino(self):\\n        original = [row[:] for row in self.current_tetromino.matrix]\\n        self.current_tetromino.clear_from_grid(self.grid)\\n        self.current_tetromino.rotate()\\n        if self.current_tetromino.collides(self.grid):\\n            self.current_tetromino.matrix = original\\n        self.current_tetromino.place_on_grid(self.grid)\\n\\n    def hard_drop(self):\\n        while self.move_tetromino_down():\\n            pass\\n\\n    def lock_and_spawn(self):\\n        self.current_tetromino.lock_into_grid(self.grid)\\n        self.spawn_tetromino()\\n\\n    def tick(self):\\n        \\\"\\\"\\\"\\n        One game tick: apply gravity; if it can't move,\\n        lock it and spawn next.\\n        \\\"\\\"\\\"\\n        clear_falling(self.grid)\\n        if not self.move_tetromino_down():\\n            self.lock_and_spawn()\\n            self.clear_lines_and_matches()\\n            if self.game_over:\\n                return\\n        else:\\n            self.current_tetromino.place_on_grid(self.grid)\\n\\n\\n    def get_grid_copy(self) -> List[List[Cell]]:\\n        \\\"\\\"\\\"Returns a copy of the grid.\\\"\\\"\\\"\\n        return [[Cell(cell.state, cell.color) for cell in row] for row in self.grid]\\n\\n    def clear_lines_and_matches(self):\\n        \\\"\\\"\\\"\\n        Detects and clears full lines (Tetris) and 3+ gem matches (Bejeweled).\\n        \\\"\\\"\\\"\\n        lines_cleared = self.clear_lines()\\n        matches_cleared = self.clear_matches()\\n        # Award points based on lines and matches cleared\\n        self.score += lines_cleared * 100\\n        self.score += matches_cleared * 50\\n        # Trigger chain reactions (recursively clear until no more matches)\\n        if lines_cleared > 0 or matches_cleared > 0:\\n            self.clear_lines_and_matches()\\n\\n    def clear_lines(self) -> int:\\n        \\\"\\\"\\\"\\n        Clears full horizontal lines from the grid.\\n        Returns the number of lines cleared.\\n        \\\"\\\"\\\"\\n        lines_cleared = 0\\n        for y in range(GRID_HEIGHT):\\n            if all(not self.grid[y][x].is_empty() for x in range(GRID_WIDTH)):\\n                # Clear the line\\n                for x in range(GRID_WIDTH):\\n                    self.grid[y][x].reset()\\n                # Move down all rows above the cleared line\\n                for yy in range(y, 0, -1):\\n                    for x in range(GRID_WIDTH):\\n                        self.grid[yy][x].state = self.grid[yy-1][x].state\\n                        self.grid[yy][x].color = self.grid[yy-1][x].color\\n                # Clear the top line\\n                for x in range(GRID_WIDTH):\\n                    self.grid[0][x].reset()\\n                lines_cleared += 1\\n        return lines_cleared\\n\\n    def clear_matches(self) -> int:\\n        \\\"\\\"\\\"\\n        Detects and clears 3+ gem matches in the grid.\\n        Returns the number of matches cleared.\\n        \\\"\\\"\\\"\\n        matches = self.find_matches()\\n        for x, y in matches:\\n            self.grid[y][x].reset()\\n        return len(matches)\\n\\n    def find_matches(self) -> List[Tuple[int, int]]:\\n        \\\"\\\"\\\"\\n        Finds all 3+ gem matches in the grid (horizontal and vertical).\\n        Returns a list of (x, y) coordinates of matched gems.\\n        \\\"\\\"\\\"\\n        matches = set()\\n\\n        # Horizontal matches\\n        for y in range(GRID_HEIGHT):\\n            for x in range(GRID_WIDTH - 2):\\n                if (self.grid[y][x].is_gem() and\\n                        self.grid[y][x].color == self.grid[y][x+1].color == self.grid[y][x+2].color):\\n                    color = self.grid[y][x].color\\n                    match_length = 3\\n                    while x + match_length < GRID_WIDTH and self.grid[y][x + match_length].is_gem() and self.grid[y][x + match_length].color == color:\\n                        match_length += 1\\n                    for i in range(match_length):\\n                        matches.add((x + i, y))\\n\\n        # Vertical matches\\n        for x in range(GRID_WIDTH):\\n            for y in range(GRID_HEIGHT - 2):\\n                if (self.grid[y][x].is_gem() and\\n                        self.grid[y][x].color == self.grid[y+1][x].color == self.grid[y+2][x].color):\\n                    color = self.grid[y][x].color\\n                    match_length = 3\\n                    while y + match_length < GRID_HEIGHT and self.grid[y + match_length][x].is_gem() and self.grid[y + match_length][x].color == color:\\n                        match_length += 1\\n                    for i in range(match_length):\\n                        matches.add((x, y + i))\\n\\n        return list(matches)\\n\\n# Example usage in a Pygame loop would call GameState.tick()\\n# and map arrow keys to move_side / rotate_current / hard_drop as needed.\\n```\",\n  \"timestamp\": \"2026-05-