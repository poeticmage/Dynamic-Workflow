\\n\\n    \\\"L\\\": [[0, 0, 0, 0],\\n          [3, 3, 3, 0],\\n          [3, 0, 0, 0],\\n          [0, 0, 0, 0]],\\n\\n    \\\"O\\\": [[0, 0, 0, 0],\\n          [0, 4, 4, 0],\\n          [0, 4, 4, 0],\\n          [0, 0, 0, 0]],\\n\\n    \\\"S\\\": [[0, 0, 0, 0],\\n          [0, 5, 5, 0],\\n          [5, 5, 0, 0],\\n          [0, 0, 0, 0]],\\n\\n    \\\"T\\\": [[0, 0, 0, 0],\\n          [6, 6, 6, 0],\\n          [0, 6, 0, 0],\\n          [0, 0, 0, 0]],\\n\\n    \\\"Z\\\": [[0, 0, 0, 0],\\n          [7, 7, 0, 0],\\n          [0, 7, 7, 0],\\n          [0, 0, 0, 0]],\\n}\\n\\nTETROMINO_COLORS = {\\n    \\\"I\\\": CYAN,\\n    \\\"J\\\": BLUE,\\n    \\\"L\\\": ORANGE,\\n    \\\"O\\\": YELLOW,\\n    \\\"S\\\": GREEN,\\n    \\\"T\\\": MAGENTA,\\n    \\\"Z\\\": RED,\\n}\\n\\n\\nclass Tetromino:\\n    def __init__(self, shape):\\n        self.shape = TETROMINOES[shape]\\n        self.color = TETROMINO_COLORS[shape]\\n        self.x = GRID_WIDTH // 2 - 2\\n        self.y = 0\\n        self.rotation = 0  # 0, 1, 2, 3 (90-degree increments)\\n\\n    def rotate(self):\\n        # Rotate the shape matrix 90 degrees clockwise\\n        rotated_shape = list(zip(*self.shape[::-1]))\\n        self.shape = [list(row) for row in rotated_shape]\\n\\n    def get_cells(self):\\n        # Get the grid cells occupied by the tetromino\\n        cells = []\\n        for i in range(4):\\n            for j in range(4):\\n                if self.shape[i][j] != 0:\\n                    cells.append((self.x + j, self.y + i))\\n        return cells\\n```\",\n  \"timestamp\": \"2026-05-22T17:15:03.010179\"\n}"}
