```python\\nimport json\\nfrom typing import List, Dict, Any\\n\\nclass TechnicalInterviewInterface:\\n    \\\"\\\"\\\"\\n    A simple command-line interface for conducting technical interviews.\\n    Presents questions, captures responses, and stores them.\\n    \\\"\\\"\\\"\\n\\n    def __init__(self, questions: List[Dict[str, Any]]):\\n        \\\"\\\"\\\"\\n        Initialize with a list of questions.\\n        Each question dict must include:\\n            - \\\"id\\\": unique identifier\\n            - \\\"question\\\": question text\\n            - Optional \\\"options\\\": list of choices\\n        \\\"\\\"\\\"\\n        self.questions = questions\\n        self.responses: Dict[str, str] = {}\\n\\n    def conduct_interview(self) -> Dict[str, str]:\\n        \\\"\\\"\\\"\\n        Presents questions via CLI, captures answers, returns a dict.\\n        \\\"\\\"\\\"\\n        print(\\\"\\\\n=== Starting Technical Interview ===\\\\n\\\")\\n        for idx, q in enumerate(self.questions, start=1):\\n            print(f\\\"Q{idx} [{q['id']}]: {q['question']}\\\")\\n            if \\\"options\\\" in q and isinstance(q[\\\"options\\\"], list):\\n                for opt_idx, opt in enumerate(q[\\\"options\\\"], start=1):\\n                    print(f\\\"  {opt_idx}. {opt}\\\")\\n            answer = input(\\\"Your response: \\\").strip()\\n            self.responses[q[\\\"id\\\"]] = answer\\n            print()\\n        print(\\\"=== Interview Complete ===\\\\n\\\")\\n        return self.responses\\n\\n    def get_responses(self) -> Dict[str, str]:\\n        \\\"\\\"\\\"\\n        Returns the captured responses.\\n        \\\"\\\"\\\"\\n        return self.responses\\n\\n    def save_responses(self, filepath: str) -> None:\\n        \\\"\\\"\\\"\\n        Saves the responses to a JSON file.\\n        \\\"\\\"\\\"\\n        with open(filepath, 'w', encoding='utf-8') as f:\\n            json.dump(self.responses, f, indent=2)\\n        print(f\\\"Responses saved to {filepath}\\\")\\n\\nif __name__ == \\\"__main__\\\":\\n    # Demo usage with sample questions\\n    sample_questions = [\\n        {\\\"id\\\": \\\"q1\\\", \\\"question\\\": \\\"What is a Python list comprehension?\\\"},\\n        {\\n            \\\"id\\\": \\\"q2\\\",\\n            \\\"question\\\": \\\"Explain the difference between a list and a tuple.\\\",\\n            \\\"options\\\": [\\n                \\\"Lists are immutable, tuples are mutable\\\",\\n                \\\"Lists are mutable, tuples are immutable\\\",\\n                \\\"Both are immutable\\\",\\n                \\\"Both are mutable\\\",\\n            ],\\n        },\\n        {\\\"id\\\": \\\"q3\\\", \\\"question\\\": \\\"Write a function to reverse a string in Python.\\\"},\\n    ]\\n\\n    interface = TechnicalInterviewInterface(sample_questions)\\n    responses = interface.conduct_interview()\\n    print(\\\"Captured Responses:\\\")\\n    print(json.dumps(responses, indent=2))\\n\\n    # Optionally save to file\\n    interface.save_responses(\\\"candidate_responses.json\\\")\\n```\\nTask task5:\\n  Objective: Implement the Final Evaluation Report Generator that compiles parsed data and scores into a summary.\\n  Result: ```python\\nimport json\\nfrom datetime import datetime\\n\\nclass FinalEvaluationReportGenerator:\\n    \\\"\\\"\\\"\\n    Compiles parsed data, interview feedback, and scores into a summary report.\\n    \\\"\\\"\\\"\\n\\n    def __init__(self, job_description: dict, candidate_records: list):\\n        \\\"\\\"\\\"\\n        job_description: dict containing job title, requirements, etc.\\n        candidate_records: list of dicts, each with:\\n            - 'name': candidate name\\n            - 'parsed_resume': dict of resume fields\\n            - 'interview_feedback': list of feedback strings\\n            - 'score': numeric score or dict of criteria:scores\\n        \\\"\\\"\\\"\\n        self.job = job_description\\n        self.candidates = candidate_records\\n\\n    def _format_header(self) -> str:\\n        header = []\\n        header.append(f\\\"Final Evaluation Report\\\")\\n        header.append(f\\\"Generated on: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\\\")\\n        header.append(\\\"=\\\" * 50)\\n        header.append(f\\\"Job Title: {self.job.get('title', 'N/A')}\\\")\\n        header.append(f\\\"Job ID: {self.job.get('id', 'N/A')}\\\")\\n        header.append(\\\"Requirements:\\\")\\n        for req in self.job.get('requirements', []):\\n            header.append(f\\\"  - {req}\\\")\\n        header.append(\\\"=\\\" * 50)\\n        return \\\"\\\\n\\\".join(header)\\n\\n    def _format_candidate(self, record: dict) -> str:\\n        lines = []\\n        name = record.get('name', 'Unknown Candidate')\\n        lines.append(f\\\"Candidate: {name}\\\")\\n        lines.append(\\\"-\\\" * 40)\\n        # Parsed resume summary\\n        resume = record.get('parsed_resume', {})\\n        for field, value in resume.items():\\n            lines.append(f\\\"{field.capitalize()}: {value}\\\")\\n        # Interview feedback\\n        lines.append(\\\"\\\\nInterview Feedback:\\\")\\n        feedbacks = record.get('interview_feedback', [])\\n        if feedbacks:\\n            for fb in feedbacks:\\n                lines.append(f\\\"  - {fb}\\\")\\n        else:\\n            lines.append(\\\"  No feedback available.\\\")\\n        # Scores\\n        lines.append(\\\"\\\\nScores:\\\")\\n        score = record.get('score')\\n        if isinstance(score, dict):\\n            for crit, val in score.items():\\n                lines.append(f\\\"  {crit}: {val}\\\")\\n        else:\\n            lines.append(f\\\"  Overall Score: {score}\\\")\\n        lines.append(\\\"=\\\" * 50)\\n        return \\\"\\\\n\\\".join(lines)\\n\\n    def generate_report(self) -> str:\\n        \\\"\\\"\\\"\\n        Generate the full report as a string.\\n        \\\"\\\"\\\"\\n        parts = [self._format_header()]\\n        for cand in self.candidates:\\n            parts.append(self._format_candidate(cand))\\n        return \\\"\\\\n\\\\n\\\".join(parts)\\n\\n    def save_to_file(self, file_path: str):\\n        \\\"\\\"\\\"\\n        Save the generated report to a .txt file.\\n        \\\"\\\"\\\"\\n        report = self.generate_report()\\n        with open(file_path, 'w', encoding='utf-8') as f:\\n            f.write(report)\\n        print(f\\\"Final evaluation report saved to {file_path}\\\")\\n\\nclass WorkflowPlanner:\\n    def __init__(self):\\n        self.steps = []\\n\\n    def add_step(self, step_description):\\n        self.steps.append(step_description)\\n\\n    def get_workflow(self):\\n        return \\\"\\\\n\\\".join(self.steps)\\n\\n# Instantiate the WorkflowPlanner\\nplanner = WorkflowPlanner()\\n\\n# Add steps to the workflow\\nplanner.add_step(\\\"1. Analyze the job description: Use JobDescriptionParser to extract job requirements.\\\")\\nplanner.add_step(\\\"2. Analyze candidate resumes: Use resume_parsing_module to extract candidate data from resumes.\\\")\\nplanner.add_step(\\\"3. Conduct initial screening: Review parsed resume data against job requirements.\\\")\\nplanner.add_step(\\\"4. Shortlist candidates: Select candidates who meet the minimum qualifications.\\\")\\nplanner.add_step(\\\"5. Send interview invitations: Use Email Notification Service to send interview invitations to shortlisted candidates.\\\")\\nplanner.add_step(\\\"6. Conduct technical interviews: Perform structured interviews with a predefined set of questions.\\\")\\nplanner.add_step(\\\"7. Score candidate responses: Use ScoringEngine to score candidate responses based on predefined criteria.\\\")\\nplanner.add_step(\\\"8. Send follow-up emails: Use Email Notification Service to send follow-up emails after each interview round.\\\")\\nplanner.add_step(\\\"9. Generate final evaluation report: Compile parsed data, interview feedback, and scores into a summary report using FinalEvaluationReportGenerator.\\\")\\nplanner.add_step(\\\"10. Make hiring decision: Review the final evaluation report and make a hiring decision.\\\")\\nplanner.add_step(\\\"11. Send offer letter: Use Email Notification Service to send an offer letter to the selected candidate.\\\")\\nplanner.add_step(\\\"12. Send rejection emails: Use Email Notification Service to send rejection emails to unsuccessful candidates.\\\")\\n\\n# Get the complete workflow\\nworkflow = planner.get_workflow()\\n\\n# Output the workflow to a .txt file\\nwith open(\\\"workflow.txt\\\", \\\"w\\\") as f:\\n    f.write(workflow)\\n\\nprint(\\\"Workflow plan saved to workflow.txt\\\")\\n\\n# Example usage\\nif __name__ == \\\"__main__\\\":\\n    # Sample parsed job description\\n    job_desc = {\\n        \\\"id\\\": \\\"JD-1234\\\",\\n        \\\"title\\\": \\\"Senior Python Developer\\\",\\n        \\\"requirements\\\": [\\n            \\\"5+ years Python experience\\\",\\n            \\\"Familiarity with Django or Flask\\\",\\n            \\\"Experience with REST APIs\\\",\\n            \\\"Strong testing skills\\\"\\n        ]\\n    }\\n\\n    # Sample candidate records\\n    candidates = [\\n        {\\n            \\\"name\\\": \\\"Alice Smith\\\",\\n            \\\"parsed_resume\\\": {\\n                \\\"experience_years\\\": 6,\\n                \\\"frameworks\\\": \\\"Django, Flask\\\",\\n                \\\"api_experience\\\": \\\"REST, GraphQL\\\"\\n            },\\n            \\\"interview_feedback\\\": [\\n                \\\"Strong coding skills\\\",\\n                \\\"Good problem-solving approach\\\",\\n                \\\"Needs improvement in test coverage\\\"\\n            ],\\n            \\\"score\\\": {\\n                \\\"technical\\\": 8.5,\\n                \\\"communication\\\": 7.0,\\n                \\\"culture_fit\\\": 8.0\\n            }\\n        },\\n        {\\n            \\\"name\\\": \\\"Bob Johnson\\\",\\n            \\\"parsed_resume\\\": {\\n                \\\"experience_years\\\": 4,\\n                \\\"frameworks\\\": \\\"Flask\\\",\\n                \\\"api_experience\\\": \\\"REST\\\"\\n            },\\n            \\\"interview_feedback\\\": [\\n                \\\"Solid fundamentals\\\",\\n                \\\"Fairly weak in advanced Python features\\\"\\n            ],\\n            \\\"score\\\": 7.0  # Overall score\\n        }\\n    ]\\n\\n    # Generate and save the report\\n    generator = FinalEvaluationReportGenerator(job_desc, candidates)\\n    generator.save_to_file(\\\"final_evaluation_report.txt\\\")\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nNo downstream objectives available.\\n\\n---\\n# **Current Task Requirements**\\nImplement the Email Notification Service for sending automated messages at key workflow events.\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport smtplib\\nfrom email.mime.text import MIMEText\\nfrom typing import Dict\\n\\nclass EmailNotificationService:\\n    \\\"\\\"\\\"\\n    A service for sending automated email notifications.\\n    \\\"\\\"\\\"\\n\\n    def __init__(self, smtp_server: str, smtp_port: int, sender_email: str, sender_password: str):\\n        \\\"\\\"\\\"\\n        Initialize the service with SMTP server details and sender credentials.\\n        \\\"\\\"\\\"\\n        self.smtp_server = smtp_server\\n        self.smtp_port = smtp_port\\n        self.sender_email = sender_email\\n        self.sender_password = sender_password\\n\\n    def send_email(self, recipient_email: str, subject: str, body: str) -> bool:\\n        \\\"\\\"\\\"\\n        Sends an email to the specified recipient.\\n\\n        Args:\\n            recipient_email (str): The email address of the recipient.\\n            subject (str): The subject of the email.\\n            body (str): The body of the email.\\n\\n        Returns:\\n            bool: True if the email was sent successfully, False otherwise.\\n        \\\"\\\"\\\"\\n        msg = MIMEText(body)\\n        msg['Subject'] = subject\\n        msg['From'] = self.sender_email\\n        msg['To'] = recipient_email\\n\\n        try:\\n            with smtplib.SMTP(self.smtp_server, self.smtp_port) as server:\\n                server.starttls()  # Secure the connection\\n                server.login(self.sender_email, self.sender_password)\\n                server.sendmail(self.sender_email, recipient_email, msg.as_string())\\n            print(f\\\"Email sent successfully to {recipient_email}\\\")\\n            return True\\n        except Exception as e:\\n            print(f\\\"Error sending email to {recipient_email}: {e}\\\")\\n            return False\\n\\n    def send_interview_invitation(self, recipient_email: str, candidate_name: str, interview_time: str, interview_link: str) -> bool:\\n        \\\"\\\"\\\"\\n        Sends an interview invitation email to the candidate.\\n        \\\"\\\"\\\"\\n        subject = \\\"Interview Invitation\\\"\\n        body = f\\\"\\\"\\\"\\n        Dear {candidate_name},\\n\\n        You are invited to an interview at {interview_time}. Please join using the following link: {interview_link}\\n\\n        Best regards,\\n        The Hiring Team\\n        \\\"\\\"\\\"\\n        return self.send_email(recipient_email, subject, body)\\n\\n    def send_rejection_email(self, recipient_email: str, candidate_name: str) -> bool:\\n        \\\"\\\"\\\"\\n        Sends a rejection email to the candidate.\\n        \\\"\\\"\\\"\\n        subject = \\\"Update on Your Application\\\"\\n        body = f\\\"\\\"\\\"\\n        Dear {candidate_name},\\n\\n        Thank you for your interest in our company. We regret to inform you that we will not be moving forward with your application.\\n\\n        We wish you the best in your job search.\\n\\n        Best regards,\\n        The Hiring Team\\n        \\\"\\\"\\\"\\n        return self.send_email(recipient_email, subject, body)\\n\\n    def send_offer_letter(self, recipient_email: str, candidate_name: str, salary: str, start_date: str) -> bool:\\n        \\\"\\\"\\\"\\n        Sends an offer letter to the candidate.\\n        \\\"\\\"\\\"\\n        subject = \\\"Job Offer\\\"\\n        body = f\\\"\\\"\\\"\\n        Dear {candidate_name},\\n\\n        We are pleased to offer you the position with a salary of {salary} starting on {start_date}.\\n\\n        Please let us know if you accept the offer.\\n\\n        Best regards,\\n        The Hiring Team\\n        \\\"\\\"\\\"\\n        return self.send_email(recipient_email, subject, body)\\n\\n\\nif __name__ == '__main__':\\n    # Example Usage (replace with your actual credentials)\\n    smtp_server = \\\"your_smtp_server.com\\\"  # e.g., \\\"smtp.gmail.com\\\"\\n    smtp_port = 587  # or 465 for SSL\\n    sender_email = \\\"your_email@example.com\\\"\\n    sender_password = \\\"your_password\\\"\\n\\n    email_service = EmailNotificationService(smtp_server, smtp_port, sender_email, sender_password)\\n\\n    # Test sending an interview invitation\\n    recipient_email = \\\"candidate@example.com\\\"\\n    candidate_name = \\\"John Doe\\\"\\n    interview_time = \\\"2024-01-15 10:00 AM\\\"\\n    interview_link = \\\"https://example.com/interview\\\"\\n    email_service.send_interview_invitation(recipient_email, candidate_name, interview_time, interview_link)\\n\\n    # Test sending a rejection email\\n    email_service.send_rejection_email(recipient_email, candidate_name)\\n\\n    # Test sending an offer letter\\n    salary = \\\"$100,000\\\"\\n    start_date = \\\"2024-02-01\\\"\\n    email_service.send_offer_letter(recipient_email, candidate_name, salary, start_date)\\n```\\n\",\n  \"timestamp\": \"2026-05-27T18:06:23.702643\"\n}"}
