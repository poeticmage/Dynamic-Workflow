ef send_evaluation_report(self, recipient_email, report, is_html=False):\\n        subject = \\\"Final Evaluation Report\\\"\\n        self.send_email(recipient_email, subject, report, is_html)\\n\\nif __name__ == '__main__':\\n    # Set environment variables before running:\\n    # export EMAIL_SMTP_SERVER=\\\"smtp.gmail.com\\\"\\n    # export EMAIL_SMTP_PORT=\\\"587\\\"\\n    # export EMAIL_SENDER_ADDRESS=\\\"your_email@gmail.com\\\"\\n    # export EMAIL_SENDER_PASSWORD=\\\"your_app_password\\\"\\n    service = EmailNotificationService()\\n\\n    candidate = \\\"candidate@example.com\\\"\\n    service.send_job_description(candidate, \\\"Role: Software Engineer...\\\")\\n    service.send_interview_invitation(candidate, \\\"2023-10-27 10:00 AM\\\", \\\"John Doe\\\")\\n    service.send_interview_reminder(candidate, \\\"2023-10-27 10:00 AM\\\")\\n    tech_instructions = \\\"<p>Please join the Zoom meeting at <a href='...'>link</a></p>\\\"\\n    service.send_technical_instructions(candidate, tech_instructions, is_html=True)\\n    service.send_rejection_email(candidate)\\n    service.send_offer_letter(candidate, \\\"$120,000\\\", \\\"2023-11-13\\\")\\n    final_report = \\\"Candidate scored 85/100. Recommended for hire.\\\"\\n    service.send_evaluation_report(candidate, final_report)\\n```\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"# **The Overall Goal**\\nYou are a workflow planning agent.\\nYour task is to:\\n-\\\"Analyze the job description\\\",\\n    \\\"Analyze the candidate resume\\\",\\n    \\\"Conduct technical interview\\\",\\n    \\\"Send emails as and when needed\\\",\\n    \\\"Score candidate responses\\\",\\n    \\\"Generate final evaluation report\\\"\\n\\nReturn the output as a .txt file of all the steps taken to perform the tasks.\\n\\n\\n\\n\\n---\\n# **Context from Upstream Tasks**\\nNo completed previous tasks context available.\\n\\n---\\n# **Downstream Tasks Objectives**\\nNo downstream objectives available.\\n\\n---\\n# **Cu