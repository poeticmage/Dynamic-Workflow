```python\\nimport json\\nfrom typing import List, Dict, Any\\n\\nclass TechnicalInterviewInterface:\\n    \\\"\\\"\\\"\\n    A simple command-line interface for conducting technical interviews.\\n    Presents questions, captures responses, and stores them.\\n    \\\"\\\"\\\"\\n\\n    def __init__(self, questions: List[Dict[str, Any]]):\\n        \\\"\\\"\\\"\\n        Initialize with a list of questions.\\n        Each question dict must include:\\n            - \\\"id\\\": unique identifier\\n            - \\\"question\\\": question text\\n            - Optional \\\"options\\\": list of choices\\n        \\\"\\\"\\\"\\n        self.questions = questions\\n        self.responses: Dict[str, str] = {}\\n\\n    def conduct_interview(self) -> Dict[str, str]:\\n        \\\"\\\"\\\"\\n        Presents questions via CLI, captures answers, returns a dict.\\n        \\\"\\\"\\\"\\n        print(\\\"\\\\n=== Starting Technical Interview ===\\\\n\\\")\\n        for idx, q in enumerate(self.questions, start=1):\\n            print(f\\\"Q{idx} [{q['id']}]: {q['question']}\\\")\\n            if \\\"options\\\" in q and isinstance(q[\\\"options\\\"], list):\\n                for opt_idx, opt in enumerate(q[\\\"options\\\"], start=1):\\n                    print(f\\\"  {opt_idx}. {opt}\\\")\\n            answer = input(\\\"Your response: \\\").strip()\\n            self.responses[q[\\\"id\\\"]] = answer\\n            print()\\n        print(\\\"=== Interview Complete ===\\\\n\\\")\\n        return self.responses\\n\\n    def get_responses(self) -> Dict[str, str]:\\n        \\\"\\\"\\\"\\n        Returns the captured responses.\\n        \\\"\\\"\\\"\\n        return self.responses\\n\\n    def save_responses(self, filepath: str) -> None:\\n        \\\"\\\"\\\"\\n        Saves the responses to a JSON file.\\n        \\\"\\\"\\\"\\n        with open(filepath, 'w', encoding='utf-8') as f:\\n            json.dump(self.responses, f, indent=2)\\n        print(f\\\"Responses saved to {filepath}\\\")\\n\\nif __name__ == \\\"__main__\\\":\\n    # Demo usage with sample questions\\n    sample_questions = [\\n        {\\\"id\\\": \\\"q1\\\", \\\"question\\\": \\\"What is a Python list comprehension?\\\"},\\n        {\\n            \\\"id\\\": \\\"q2\\\",\\n            \\\"question\\\": \\\"Explain the difference between a list and a tuple.\\\",\\n            \\\"options\\\": [\\n                \\\"Lists are immutable, tuples are mutable\\\",\\n                \\\"Lists are mutable, tuples are immutable\\\",\\n                \\\"Both are immutable\\\",\\n                \\\"Both are mutable\\\",\\n            ],\\n        },\\n        {\\\"id\\\": \\\"q3\\\", \\\"question\\\": \\\"Write a function to reverse a string in Python.\\\"},\\n    ]\\n\\n    interface = TechnicalInterviewInterface(sample_questions)\\n    responses = interface.conduct_interview()\\n    print(\\\"Captured Responses:\\\")\\n    print(json.dumps(responses, indent=2))\\n\\n    # Optionally save to file\\n    interface.save_responses(\\\"candidate_responses.json\\\")\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task5:\\n  Objective: Implement the Final Evaluation Report Generator that compiles parsed data and scores into a summary.\\n\\n---\\n# **Current Task Requirements**\\nImplement the Scoring Engine to evaluate captured interview responses against criteria.\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport json\\nfrom typing import List, Dict, Any\\n\\nclass ScoringEngine:\\n    \\\"\\\"\\\"\\n    A scoring engine to evaluate candidate responses based on predefined criteria.\\n    \\\"\\\"\\\"\\n\\n    def __init__(self, scoring_criteria: Dict[str, Dict[str, Any]]):\\n        \\\"\\\"\\\"\\n        Initialize with scoring criteria.\\n\\n        The scoring_criteria should be a dictionary where:\\n            - keys are question IDs\\n            - values are dictionaries containing:\\n                - \\\"type\\\": \\\"keyword\\\", \\\"regex\\\", or \\\"function\\\"\\n                - \\\"positive_keywords\\\": list of keywords for positive scoring (if type is \\\"keyword\\\")\\n                - \\\"negative_keywords\\\": list of keywords for negative scoring (if type is \\\"keyword\\\")\\n                - \\\"regex_pattern\\\": regex pattern for matching (if type is \\\"regex\\\")\\n                - \\\"scoring_function\\\": a callable that takes the response and returns a score (if type is \\\"function\\\")\\n                - \\\"max_score\\\": maximum possible score for the question\\n        \\\"\\\"\\\"\\n        self.scoring_criteria = scoring_criteria\\n\\n    def score_response(self, question_id: str, response: str) -> int:\\n        \\\"\\\"\\\"\\n        Scores a single response based on the scoring criteria for the given question.\\n        \\\"\\\"\\\"\\n        if question_id not in self.scoring_criteria:\\n            print(f\\\"Warning: No scoring criteria found for question {question_id}\\\")\\n            return 0  # Or raise an exception, depending on the desired behavior\\n\\n        criteria = self.scoring_criteria[question_id]\\n        score_type = criteria[\\\"type\\\"]\\n        max_score = criteria.get(\\\"max_score\\\", 1)  # Default max score is 1 if not specified\\n\\n        if score_type == \\\"keyword\\\":\\n            positive_keywords = criteria.get(\\\"positive_keywords\\\", [])\\n            negative_keywords = criteria.get(\\\"negative_keywords\\\", [])\\n            score = 0\\n            for keyword in positive_keywords:\\n                if keyword.lower() in response.lower():\\n                    score += 1\\n            for keyword in negative_keywords:\\n                if keyword.lower() in response.lower():\\n                    score -= 1\\n            return min(max(score, 0), max_score)  # Ensure score is within [0, max_score]\\n\\n        elif score_type == \\\"regex\\\":\\n            import re\\n            regex_pattern = criteria[\\\"regex_pattern\\\"]\\n            if re.search(regex_pattern, response, re.IGNORECASE):\\n                return max_score\\n            else:\\n                return 0\\n\\n        elif score_type == \\\"function\\\":\\n            scoring_function = criteria[\\\"scoring_function\\\"]\\n            try:\\n                score = scoring_function(response)\\n                return min(max(score, 0), max_score)  # Ensure score is within [0, max_score]\\n            except Exception as e:\\n                print(f\\\"Error during scoring function execution for question {question_id}: {e}\\\")\\n                return 0\\n\\n        else:\\n            print(f\\\"Warning: Unknown scoring type {score_type} for question {question_id}\\\")\\n            return 0\\n\\n    def score_responses(self, responses: Dict[str, str]) -> Dict[str, int]:\\n        \\\"\\\"\\\"\\n        Scores all responses and returns a dictionary of question IDs to scores.\\n        \\\"\\\"\\\"\\n        scores = {}\\n        for question_id, response in responses.items():\\n            scores[question_id] = self.score_response(question_id, response)\\n        return scores\\n\\n    def calculate_overall_score(self, scores: Dict[str, int]) -> float:\\n          \\\"\\\"\\\"\\n          Calculates the overall score based on the individual question scores and their maximum possible scores.\\n          \\\"\\\"\\\"\\n          total_score = sum(scores.values())\\n          total_max_score = sum(self.scoring_criteria[q_id].get(\\\"max_score\\\", 1) for q_id in scores.keys()) # Default max_score is 1\\n          if total_max_score == 0:\\n              return 0.0  # Avoid division by zero if no questions have max_score defined\\n\\n          return (total_score / total_max_score) * 100\\n\\nif __name__ == \\\"__main__\\\":\\n    # Example Usage\\n    sample_scoring_criteria = {\\n        \\\"q1\\\": {\\n            \\\"type\\\": \\\"keyword\\\",\\n            \\\"positive_keywords\\\": [\\\"list comprehension\\\", \\\"concise\\\", \\\"readable\\\"],\\n            \\\"negative_keywords\\\": [\\\"loop\\\"],\\n            \\\"max_score\\\": 3,\\n        },\\n        \\\"q2\\\": {\\n            \\\"type\\\": \\\"keyword\\\",\\n            \\\"positive_keywords\\\": [\\\"mutable\\\", \\\"immutable\\\"],\\n            \\\"max_score\\\": 2,\\n        },\\n        \\\"q3\\\": {\\n            \\\"type\\\": \\\"regex\\\",\\n            \\\"regex_pattern\\\": r\\\"def\\\\s+reverse_string\\\\(.*?\\\\):\\\\s*return\\\\s*.*?\\\\[::-1\\\\]\\\",\\n            \\\"max_score\\\": 5,\\n        },\\n        \\\"q4\\\": { #Example of function-based scoring\\n            \\\"type\\\": \\\"function\\\",\\n            \\\"scoring_function\\\": lambda response: 5 if \\\"example\\\" in response.lower() else 0,\\n            \\\"max_score\\\": 5\\n        }\\n    }\\n\\n    engine = ScoringEngine(sample_scoring_criteria)\\n\\n    sample_responses = {\\n        \\\"q1\\\": \\\"List comprehension is a concise way to create lists in Python.\\\",\\n        \\\"q2\\\": \\\"Lists are mutable, tuples are immutable.\\\",\\n        \\\"q3\\\": \\\"def reverse_string(s):\\\\n  return s[::-1]\\\",\\n        \\\"q4\\\": \\\"This is an example response.\\\"\\n    }\\n\\n    scores = engine.score_responses(sample_responses)\\n    print(\\\"Individual Scores:\\\", scores)\\n\\n    overall_score = engine.calculate_overall_score(scores)\\n    print(\\\"Overall Score:\\\", overall_score)\\n```\\n\",\n  \"timestamp\": \"2026-05-27T18:05:36.539410\"\n}"}
