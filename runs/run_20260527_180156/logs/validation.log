d']}): {q['question']}\\\")\\n            if \\\"options\\\" in q and isinstance(q[\\\"options\\\"], list):\\n                for opt_idx, opt in enumerate(q[\\\"options\\\"], start=1):\\n                    print(f\\\"  {opt_idx}. {opt}\\\")\\n            answer = input(\\\"Your response: \\\").strip()\\n            self.responses[q[\\\"id\\\"]] = answer\\n            print()\\n        print(\\\"=== Interview Complete ===\\\\n\\\")\\n        return self.responses\\n\\n    def get_responses(self) -> Dict[str, str]:\\n        \\\"\\\"\\\"\\n        Returns the captured responses.\\n        \\\"\\\"\\\"\\n        return self.responses\\n\\n    def save_responses(self, filepath: str) -> None:\\n        \\\"\\\"\\\"\\n        Saves responses to a JSON file at the given path.\\n        \\\"\\\"\\\"\\n        with open(filepath, 'w', encoding='utf-8') as f:\\n            json.dump(self.responses, f, indent=2)\\n        print(f\\\"Responses saved to {filepath}\\\")\\n\\nif __name__ == \\\"__main__\\\":\\n    # Example usage with sample questions\\n    sample_questions = [\\n        {\\n            \\\"id\\\": \\\"q1\\\",\\n            \\\"question\\\": \\\"What is a Python list comprehension?\\\"\\n        },\\n        {\\n            \\\"id\\\": \\\"q2\\\",\\n            \\\"question\\\": \\\"Explain the difference between a list and a tuple.\\\",\\n            \\\"options\\\": [\\n                \\\"Lists are immutable, tuples are mutable\\\",\\n                \\\"Lists are mutable, tuples are immutable\\\",\\n                \\\"Both are immutable\\\",\\n                \\\"Both are mutable\\\"\\n            ]\\n        },\\n        {\\n            \\\"id\\\": \\\"q3\\\",\\n            \\\"question\\\": \\\"Write a function to reverse a string in Python.\\\"\\n        }\\n    ]\\n\\n    interface = TechnicalInterviewInterface(sample_questions)\\n    responses = interface.conduct_interview()\\n    print(\\\"Captured Responses:\\\")\\n    print(json.dumps(responses, ind