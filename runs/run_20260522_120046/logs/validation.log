\\n    # Standard Tetris line clear base scores\\n    TETRIS_SCORES = {1: 100, 2: 300, 3: 500, 4: 800}\\n\\n    def __init__(self, match_base_score=50, combo_increment=0.5):\\n        self.match_base_score = match_base_score\\n        self.combo_increment = combo_increment\\n        self._score = 0\\n        self._combo = 0\\n        self._last_award = 0\\n\\n    def add_line_clear(self, lines_cleared: int):\\n        \\\"\\\"\\\"\\n        Award points for clearing lines.\\n        lines_cleared: number of lines cleared at once (1–4).\\n        \\\"\\\"\\\"\\n        base = self.TETRIS_SCORES.get(lines_cleared, 100 * lines_cleared)\\n        self._apply_award(base)\\n\\n    def add_match_clear(self, gems_matched: int):\\n        \\\"\\\"\\\"\\n        Award points for matching gems.\\n        gems_matched: number of gems cleared in a single match (≥3).\\n        \\\"\\\"\\\"\\n        base = self.match_base_score * gems_matched\\n        self._apply_award(base)\\n\\n    def _apply_award(self, base_points: float):\\n        \\\"\\\"\\\"\\n        Internal: applies combo bonus and updates the total score.\\n        \\\"\\\"\\\"\\n        multiplier = 1 + self._combo * self.combo_increment\\n        awarded = int(base_points * multiplier)\\n        self._score += awarded\\n        self._last_award = awarded\\n        self._combo += 1\\n\\n    def reset_combo(self):\\n        \\\"\\\"\\\"Reset combo counter—call this when a drop yields no clear.\\\"\\\"\\\"\\n        self._combo = 0\\n\\n    def reset_score(self):\\n        \\\"\\\"\\\"Reset both score and combo to zero.\\\"\\\"\\\"\\n        self._score = 0\\n        self._combo = 0\\n        self._last_award = 0\\n\\n    def get_score(self) -> int:\\n        \\\"\\\"\\\"Return the current total score.\\\"\\\"\\\"\\n        return self._score\\n\\n    def get_combo(self) -> int:\\n        \\\"\\\"\\\"Return the current combo level.\\\"\\\"\\\"\\n        return self._combo\\n\\n    def get_last_award(self) -> int:\\n        \\\"\\\"\\\"Return the points awarded by the last clear.\\\"\\\"\\\"\\n        return self._last_award\\n```\"}"}
