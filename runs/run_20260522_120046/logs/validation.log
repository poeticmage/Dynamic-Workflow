or y in range(self.height):\\n            for x in range(self.width):\\n                self.cells[y][x] = None\\n\\nclass GameRenderer:\\n    def __init__(self, grid: Grid, cell_size: int = 30,  preview_size: int = 20):\\n        self.grid = grid\\n        self.cell_size = cell_size\\n        self.preview_size = preview_size\\n        self.width = grid.width * cell_size\\n        self.height = grid.height * cell_size\\n        self.screen_width = self.width + 200  # Add space for score and next piece\\n        self.screen_height = self.height\\n        self.screen = pg.display.set_mode((self.screen_width, self.screen_height))\\n        pg.display.set_caption(\\\"TetrisBejeweled\\\")\\n        self.font = pg.font.Font(None, 30) # Default font, size 30\\n\\n    def draw_grid(self):\\n        for x in range(self.grid.width):\\n            for y in range(self.grid.height):\\n                rect = pg.Rect(x * self.cell_size, y * self.cell_size, self.cell_size, self.cell_size)\\n                pg.draw.rect(self.screen, (50, 50, 50), rect, 1)  # Dark gray grid lines\\n\\n                gem = self.grid.get_cell(x, y)\\n                if gem:\\n                    color = GEM_COLORS[gem.color]\\n                    pg.draw.rect(self.screen, color, rect.inflate(-2, -2)) # slightly smaller rect\\n\\n    def draw_tetromino(self, tetromino: Tetromino):\\n        for x, y in tetromino.current_blocks():\\n            if self.grid.in_bounds(x, y):\\n                gem_color = random.choice(list(GEM_COLORS.keys()))  # Assign random color to tetromino\\n                color = GEM_COLORS[gem_color]\\n                rect = pg.Rect(x * self.cell_size, y * self.cell_size, self.cell_size, self.cell_size)\\n                pg.draw.rect(self.screen, color, rect.inflate(-2, -2))\\n\\n    def draw_next_tetromino(self, tetromino: Tetromino):\\n        # Display the next tetromino in the sidebar\\n        text_surface = self.font.render(\\\"Next Piece:\\\", True, (255, 255, 255))\\n        self.screen.blit(text_surface, (self.width + 10, 10))\\n\\n        # Calculate the center position for the preview\\n        center_x = self.width + 100\\n        center_y = 100\\n\\n        # Draw the next tetromino's blocks with adjusted coordinates and smaller size\\n        for x, y in tetromino.current_blocks():\\n            block_x = center_x + (x * self.preview_size) - (self.preview_size * 2)  # Adjust to center\\n            block_y = center_y + (y * self.preview_size) - (self.preview_size * 2)  # Adjust to center\\n\\n            color = GEM_COLORS[random.choice(list(GEM_COLORS.keys()))] #randomize the color\\n            rect = pg.Rect(block_x, block_y, self.preview_size, self.preview_size)\\n            pg.draw.rect(self.screen, color, rect.inflate(-2, -2))\\n\\n    def draw_score(self, score: int):\\n        text_surface = self.font.render(f\\\"Score: {score}\\\", True, (255, 255, 255))\\n        self.screen.blit(text_surface, (self.width + 10, self.screen_height - 50))\\n\\n    def render(self, current_tetromino: Optional[Tetromino] = None, next_tetromino: Optional[Tetromino] = None, score: int = 0):\\n        self.screen.fill((0, 0, 0))  # Black background\\n        self.draw_grid()\\n        if current_tetromino:\\n            self.draw_tetromino(current_tetromino)\\n        if next_tetromino:\\n            self.draw_next_tetromino(next_tetromino)\\n        self.draw_score(score)\\n        pg.display.flip()\\n\\n\\nif __name__ == '__main__':\\n    pg.init()\\n\\n    # Example usage:\\n    grid = Grid(width=10, height=20)\\n    renderer = GameRenderer(grid)\\n\\n    # Create a dummy tetromino\\n    current_tetromino = Tetromino(type=TetrominoType.T, x=5, y=2)\\n    next_tetromino = Tetromino(type=TetrominoType.L, x=0, y=0) #example for next piece\\n\\n    score = 12345 #example score\\n\\n    running = True\\n    while running:\\n        for event in pg.event.get():\\n            if event.type == pg.QUIT:\\n                running = False\\n\\n   