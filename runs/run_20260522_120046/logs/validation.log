       [(-1,0),(0,0),(1,0),(-1,-1)],\\n        [(0,-1),(0,0),(0,1),(-1,1)]\\n    ]\\n}\\n\\n@dataclass\\nclass Tetromino:\\n    type: TetrominoType\\n    rotation: int = 0         # 0-3 index into rotation states\\n    x: int = 0                # column position of pivot\\n    y: int = 0                # row position of pivot\\n\\n    def current_blocks(self) -> List[Tuple[int,int]]:\\n        shape = TETROMINO_SHAPES[self.type][self.rotation % 4]\\n        return [(self.x + dx, self.y + dy) for dx, dy in shape]\\n\\n    def rotate(self, clockwise: bool = True) -> None:\\n        self.rotation = (self.rotation + (1 if clockwise else -1)) % 4\\n\\n# Game Grid\\nclass Grid:\\n    def __init__(self, width: int = 10, height: int = 20):\\n        self.width: int = width\\n        self.height: int = height\\n        self.cells: List[List[Optional[Gem]]] = [\\n            [None for _ in range(self.width)] for _ in range(self.height)\\n        ]\\n\\n    def in_bounds(self, x: int, y: int) -> bool:\\n        return 0 <= x < self.width and 0 <= y < self.height\\n\\n    def get_cell(self, x: int, y: int) -> Optional[Gem]:\\n        if not self.in_bounds(x, y):\\n            return None\\n        return self.cells[y][x]\\n\\n    def set_cell(self, x: int, y: int, gem: Optional[Gem]) -> None:\\n        if self.in_bounds(x, y):\\n            self.cells[y][x] = gem\\n\\n    def clear_cell(self, x: int, y: int) -> None:\\n        if self.in_bounds(x, y):\\n            self.cells[y][x] = None\\n\\n    def reset(self) -> None:\\n        for y in range(self.height):\\n            for x in range(self.width):\\n                self.cells[y][x] = None\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task6:\\n  Objective: Assemble the main game loop tying together piece logic, clearing, scoring, input, and rendering into a cohesive runnable application\\n\\n---\\n# **Current Task Requirements**\\nCreate scoring system to award points for line clears, match clears, and combo/chain bonuses\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nclass ScoringSystem:\\n    def __init__(self, line_clear_score=100, match_clear_score=50, combo_multiplier=1.5):\\n        self.line_clear_score = line_clear_score\\n        self.match_clear_score = match_clear_score\\n        self.combo_multiplier = combo_multiplier\\n        self.current_score = 0\\n        self.combo_level = 0\\n\\n    def add_line_clear(self, num_lines):\\n        score = self.line_clear_score * num_lines\\n        if self.combo_level > 0:\\n            score *= (self.combo_multiplier ** self.combo_level)\\n        self.current_score += int(score)\\n        self.combo_level += 1\\n\\n    def add_match_clear(self, num_matches):\\n        score = self.match_clear_score * num_matches\\n        if self.combo_level > 0:\\n            score *= (self.combo_multiplier ** self.combo_level)\\n        self.current_score += int(score)\\n        self.combo_level += 1\\n\\n    def reset_combo(self):\\n        self.combo_level = 0\\n\\n    def get_score(self):\\n        return self.current_score\\n```\",\n  \"timestamp\": \"2026-05-22T12:01:23.944061\"\n}"}
