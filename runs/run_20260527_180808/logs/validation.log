se,\\n    attach them to the data, log each step, and return the scored data.\\n    \\n    Expected rubric JSON format:\\n    {\\n        \\\"questions\\\": {\\n            \\\"q1\\\": {\\n                \\\"max_score\\\": 5,\\n                \\\"keywords\\\": [\\\"function\\\", \\\"loop\\\", \\\"recursion\\\"]\\n            },\\n            \\\"q2\\\": {\\n                \\\"max_score\\\": 3,\\n                \\\"keywords\\\": [\\\"class\\\", \\\"inheritance\\\"]\\n            },\\n            ...\\n        }\\n    }\\n    \\n    Expected interview_data JSON format:\\n    {\\n        \\\"candidate_email\\\": \\\"candidate@example.com\\\",\\n        \\\"responses\\\": [\\n            {\\\"question_id\\\": \\\"q1\\\", \\\"response\\\": \\\"I would use a loop...\\\"},\\n            {\\\"question_id\\\": \\\"q2\\\", \\\"response\\\": \\\"I define a class...\\\"},\\n            ...\\n        ]\\n    }\\n    \\\"\\\"\\\"\\n    append_log(\\\"START scoring\\\", steps_log_path)\\n    \\n    # Load data\\n    interview_data = load_json(interview_data_path)\\n    append_log(f\\\"Loaded interview data from {interview_data_path}\\\", steps_log_path)\\n    rubric = load_json(rubric_path)\\n    append_log(f\\\"Loaded rubric from {rubric_path}\\\", steps_log_path)\\n    \\n    scored_responses = []\\n    total_score = 0\\n    total_max = 0\\n    \\n    for resp in interview_data.get(\\\"responses\\\", []):\\n        qid = resp.get(\\\"question_id\\\")\\n        answer = resp.get(\\\"response\\\", \\\"\\\").lower()\\n        append_log(f\\\"Scoring response for question {qid}\\\", steps_log_path)\\n        \\n        question_rubric = rubric.get(\\\"questions\\\", {}).get(qid)\\n        if not question_rubric:\\n            append_log(f\\\"No rubric found for question {qid}, assigning score 0\\\", steps_log_path)\\n            score = 0\\n            max_score = 0\\n        else:\\n            keywords = question_rubric.get(\\\"keywords\\\", [])\\n            max_score = question_rubric.get(\\\"max_score\\\", 0)\\n            # Count keyword matches\\n            match_count = 0\\n            for kw in keywords:\\n                # simple word boundary match\\n                if re.search(rf\\\"\\\\b{re.escape(kw.lower())}\\\\b\\\", answer):\\n                    match_count += 1\\n                    append_log(f\\\"  found keyword '{kw}'\\\", steps_log_path)\\n            # score is proportional to matched keywords\\n            if keywords:\\n                score = round((match_count / len(keywords)) * max_score, 2)\\n            else:\\n                score = 0\\n            append_log(f\\\"  matched {match_count}/{len(keywords)} keywords, score={score}/{max_score}\\\", steps_log_path)\\n        \\n        total_score += score\\n        total_max += max_score\\n        scored_responses.append({\\n            \\\"question_id\\\": qid,\\n            \\\"response\\\": resp.get(\\\"response\\\", \\\"\\\"),\\n            \\\"score_awarded\\\": score,\\n            \\\"max_score\\\": max_score\\n        })\\n    \\n    # Compute aggregate\\n    overall_percentage = round((total_score / total_max) * 100, 2) if total_max > 0 else 0.0\\n    append_log(f\\\"Total score {total_score}/{total_max}, overall % = {overall_percentage}\\\", steps_log_path)\\n    \\n    # Attach scoring to interview_data\\n    interview_data[\\\"scored_responses\\\"] = scored_responses\\n    interview_data[\\\"total_score\\\"] = total_score\\n    interview_data[\\\"total_max\\\"] = total_max\\n    interview_data[\\\"overall_percentage\\\"] = overall_percentage\\n    \\n    append_log(\\\"END scoring\\\", steps_log_path)\\n    return interview_data\\n\\n# Example usage:\\nif __name__ == \\\"__main__\\\":\\n    # Paths (these would be actual file paths in practice)\\n    INTERVIEW_DATA_PATH = \\\"interview_data.json\\\"\\n    RUBRIC_PATH = \\\"rubric.json\\\"\\n    STEPS_LOG_PATH = \\\"steps.log\\\"\\n    OUTPUT_SCORED_PATH = \\\"scored_interview.json\\\"\\n    \\n    # Ensure log file exists\\n    if not os.path.exists(STEPS_LOG_PATH):\\n        open(STEPS_LOG_PATH, \\\"w\\\").close()\\n    \\n    scored = score_candidate_responses(INTERVIEW_DATA_PATH, RUBRIC_PATH, STEPS_LOG_PATH)\\n    \\n    # Save the scored interview data\\n    with open(OUTPUT_SCORED_PATH, \\\"w\\\") as out_f:\\n        json.dump(scored, out_f, indent=2)\\n    append_log(f\\\"Saved scored data to {OUTPUT_SCORED_PATH}\\\", STEPS_LOG_PATH)\\n```\"}"}
