ns = json.load(f)\\n    log_step(steps_log_path, f\\\"Loaded {len(questions)} interview questions from {questions_path}.\\\")\\n\\n    # 4. Conduct the technical interview\\n    interview_start = datetime.utcnow().isoformat() + \\\"Z\\\"\\n    log_step(steps_log_path, f\\\"Interview started at {interview_start}.\\\")\\n    send_email(candidate_email, \\\"Interview Started\\\",\\n               \\\"The technical interview has started via our system.\\\")\\n    log_step(steps_log_path, f\\\"Sent 'Interview Started' email to {candidate_email}.\\\")\\n\\n    responses = []\\n    for idx, question in enumerate(questions, 1):\\n        print(f\\\"\\\\nQuestion {idx}: {question}\\\")\\n        q_start = datetime.utcnow().isoformat() + \\\"Z\\\"\\n        answer = input(\\\"Candidate's response: \\\")\\n        q_end = datetime.utcnow().isoformat() + \\\"Z\\\"\\n        responses.append({\\n            \\\"question_number\\\": idx,\\n            \\\"question\\\": question,\\n            \\\"response\\\": answer,\\n            \\\"start_time\\\": q_start,\\n            \\\"end_time\\\": q_end\\n        })\\n        log_step(steps_log_path, f\\\"Recorded response to question {idx}.\\\")\\n\\n    interview_end = datetime.utcnow().isoformat() + \\\"Z\\\"\\n    log_step(steps_log_path, f\\\"Interview ended at {interview_end}.\\\")\\n    send_email(candidate_email, \\\"Interview Finished\\\",\\n               \\\"The technical interview has finished. Thank you.\\\")\\n    log_step(steps_log_path, f\\\"Sent 'Interview Finished' email to {candidate_email}.\\\")\\n\\n    # 5. Save interview data to JSON\\n    interview_data = {\\n        \\\"job_description_path\\\": job_description_path,\\n        \\\"resume_path\\\": resume_path,\\n        \\\"questions_path\\\": questions_path,\\n        \\\"interview_start\\\": interview_start,\\n        \\\"interview_end\\\": interview_end,\\n        \\\"responses\\\": responses\\n    }\\n    try:\\n        with open(output_path, 'w', encoding='utf-8') as out_f:\\n            json.dump(interview_data, out_f, indent=2)\\n        log_step(steps_log_path, f\\\"Interview data saved to JSON at {output_path}.\\\")\\n    except IOError as e:\\n        sys.exit(f\\\"Error writing interview data to {output_path}: {e}\\\")\\n\\n    return interview_data\\n\\ndef send_email(to_email, subject, body):\\n    \\\"\\\"\\\"\\n    Sends an email notification.\\n    \\\"\\\"\\\"\\n    from_email = \\\"your_email@example.com\\\"\\n    from_password = \\\"your_password\\\"\\n    msg = MIMEText(body)\\n    msg['Subject'] = subject\\n    msg['From'] = from_email\\n    msg['To'] = to_email\\n    try:\\n        with smtplib.SMTP_SSL('smtp.gmail.com', 465) as smtp:\\n            smtp.login(from_email, from_password)\\n            smtp.send_message(msg)\\n    except Exception as e:\\n        print(f\\\"Warning: Error sending email: {e}\\\")\\n\\ndef score_candidate_responses(interview_data, rubric_path, steps_log_path):\\n    \\\"\\\"\\\"\\n    Scores the candidate's responses based on a predefined rubric and logs steps.\\n    \\\"\\\"\\\"\\n    log_step(steps_log_path, \\\"Started scoring candidate responses.\\\")\\n    try:\\n        with open(rubric_path, 'r', encoding='utf-8') as rf:\\n            rubric = json.load(rf)\\n        log_step(steps_log_path, f\\\"Loaded scoring rubric from {rubric_path}.\\\")\\n    except Exception as e:\\n        sys.exit(f\\\"Error reading rubric: {e}\\\")\\n\\n    scored = []\\n    for resp in interview_data['responses']:\\n        q = resp['question']\\n        score = rubric.get(q, {}).get(\\\"base_score\\\", 0)\\n        scored.append({**resp, \\\"score\\\": score})\\n        log_step(steps_log_path, f\\\"Scored question {resp['question_number']} with {score}.\\\")\\n    interview_data['responses'] = scored\\n    return interview_data\\n\\ndef generate_evaluation_report(interview_data, report_path, steps_log_path):\\n    \\\"\\\"\\\"\\n    Generates a final evaluation report and logs the step.\\n    \\\"\\\"\\\"\\n    log_step(steps_log_path, \\\"Generating final evaluation report.\\\")\\n    total, count = 0, 0\\n    with open(report_path, 'w', encoding='utf-8') as rf:\\n        rf.write(\\\"=== Interview Evaluation Report ===\\\\n\\\\n\\\")\\n        rf.write(f\\\"Start: {interview_data['interview_start']}\\\\n\\\")\\n        rf.write(f\\\"End:   {interview_data['interview_end']}\\\\n\\\\n\\\")\\n        for r in interview_data['responses']:\\n            rf.write(f\\\"Q{r['question_number']}: {r['question']}\\\\n\\\")\\n            rf.write(f\\\" A: {r['response']}\\\\n\\\")\\n            rf.write(f\\\" Score: {r['score']}\\\\n\\\\n\\\")\\n            if isinstance(r['score'], (int, float)):\\n                total += r['score']; count += 1\\n        avg = total/count if count else 0\\n        rf.write(f\\\"Average Score: {avg:.2f}\\\\n\\\")\\n    log_step(steps_log_path, f\\\"Saved evaluation report to {report_path}.\\\")\\n\\ndef parse_args():\\n    p = argparse.ArgumentParser(description=\\\"Run technical interview component.\\\")\\n    p.add_argument(\\\"-j\\\", \\\"--job-description\\\", required=True)\\n    p.add_argument(\\\"-r\\\", \\\"--resume\\\", required=True)\\n    p.add_argument(\\\"-q\\\", \\\"--questions\\\", required=True)\\n    p.add_argument(\\\"-o\\\", \\\"--output\\\", default=\\\"interview_data.json\\\")\\n    p.add_argument(\\\"-e\\\", \\\"--candidate-email\\\", required=True)\\n    p.add_argument(\\\"-l\\\", \\\"--steps-log\\\", default=\\\"steps_log.txt\\\",\\n                   help=\\\"Path for the .txt step-by-step log.\\\")\\n    p.add_argument(\\\"--rubric\\\", default=\\\"scoring_rubric.json\\\")\\n    p.add_argument(\\\"--report\\\", default=\\\"evaluation_report.txt\\\")\\n    return p.parse_args()\\n\\nif __name__ == \\\"__main__\\\":\\n    args = parse_args()\\n    data = conduct_technical_interview(\\n        args.job_description, args.resume, args.questions,\\n        args.output, args.candidate_email, args.steps_log\\n    )\\n    scored = score_candidate_responses(data, args.rubric, args.steps_log)\\n    generate_evaluation_report(scored, args.report, args.steps_log)\\n    print(f\\\"All steps logged to {args.steps_log}\\\")\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task5:\\n  Objective: Generate final evaluation report in .txt format summarizing scores and recommendations\\n\\n---\\n# **Current Task Requirements**\\nCreate scoring engine to evaluate and score candidate interview responses according to predefined criteria\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```text\\ndef conduct_technical_interview(job_description_path, resume_path, questions_path, \\n                                output_path, candidate_email, steps_log_path):\\n    # 1. Analyze the job description\\n    # 2. Analyze the candidate's resume\\n    # 3. Load questions\\n    # 4. Conduct the technical interview\\n    # 5. Save interview data to JSON\\n\\ndef score_candidate_responses(interview_data, rubric_path, steps_log_path):\\n    # Scoring candidate responses based on a predefined rubric and logs steps.\\n\\ndef generate_evaluation_report(interview_data, report_path, steps_log_path):\\n    # Generating final evaluation report and logs the step.\\n```\",\n  \"timestamp\": \"2026-05-27T18:13:35.802000\"\n}"}
