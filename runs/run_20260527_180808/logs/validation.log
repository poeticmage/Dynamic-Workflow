\\"name\\\": \\\"SendInterviewConfirmationEmail\\\",\\n      \\\"description\\\": \\\"Send an email to the candidate confirming the interview details (date, time, meeting link).\\\",\\n      \\\"input\\\": {\\n        \\\"candidate_name\\\": \\\"John Doe\\\",\\n        \\\"email\\\": \\\"john.doe@example.com\\\",\\n        \\\"interview_time\\\": \\\"2024-01-16 10:00 AM\\\",\\n        \\\"meeting_link\\\": \\\"https://example.com/interview\\\"\\n      },\\n      \\\"output\\\": \\\"Email sent successfully.\\\",\\n      \\\"email_template\\\": \\\"Dear {candidate_name},\\\\n\\\\nThis email confirms your technical interview on {interview_time} at {meeting_link}.\\\\n\\\\nBest regards,\\\\nThe Hiring Team\\\"\\n    },\\n    {\\n      \\\"step_number\\\": 5,\\n      \\\"name\\\": \\\"ConductTechnicalInterview\\\",\\n      \\\"description\\\": \\\"Conduct the technical interview by asking the tailored questions and recording the candidate's responses.\\\",\\n      \\\"input\\\": {\\n        \\\"tailored_questions\\\": \\\"tailored_questions\\\"\\n      },\\n      \\\"output\\\": \\\"interview_transcript\\\",\\n      \\\"process\\\": \\\"For each question in tailored_questions, ask the question to the candidate, record their response, and note any follow-up questions asked.\\\"\\n    },\\n    {\\n      \\\"step_number\\\": 6,\\n      \\\"name\\\": \\\"ScoreCandidateResponses\\\",\\n      \\\"description\\\": \\\"Evaluate the candidate's responses based on predefined criteria and benchmarks. Assign a score to each response and document the rationale.\\\",\\n      \\\"input\\\": \\\"interview_transcript\\\",\\n      \\\"output\\\": \\\"interview_transcript (with scores and rationales)\\\",\\n      \\\"scoring_criteria\\\": {\\n        \\\"Correctness\\\": 4,\\n        \\\"Completeness\\\": 3,\\n        \\\"Clarity\\\": 2,\\n        \\\"ProblemSolving\\\": 1\\n      },\\n      \\\"benchmarks\\\": {\\n        \\\"Q2\\\": \\\"A good answer would explain the architectural differences, data fetching approaches, and use cases for REST and GraphQL.\\\",\\n        \\\"Q3\\\": \\\"Candidate should mention threading, multiprocessing, asyncio, and GIL limitations in Python.\\\"\\n      },\\n      \\\"process\\\": \\\"For each question response in interview_transcript, evaluate against scoring_criteria and benchmarks. Provide a score (out of 10) and rationale.\\\"\\n    },\\n    {\\n      \\\"step_number\\\": 7,\\n      \\\"name\\\": \\\"SendThankYouEmail\\\",\\n      \\\"description\\\": \\\"Send a thank-you email to the candidate after the interview.\\\",\\n      \\\"input\\\": {\\n        \\\"candidate_name\\\": \\\"John Doe\\\",\\n        \\\"email\\\": \\\"john.doe@example.com\\\"\\n      },\\n      \\\"output\\\": \\\"Email sent successfully.\\\",\\n      \\\"email_template\\\": \\\"Dear {candidate_name},\\\\n\\\\nThank you for your time interviewing for the Software Engineer position. We will be in touch soon regarding the next steps.\\\\n\\\\nBest regards,\\\\nThe Hiring Team\\\"\\n    },\\n    {\\n      \\\"step_number\\\": 8,\\n      \\\"name\\\": \\\"GenerateEvaluationReport\\\",\\n      \\\"description\\\": \\\"Generate a final evaluation report summarizing the candidate's performance, including overall score, strengths, weaknesses, and recommendation.\\\",\\n      \\\"input\\\": {\\n        \\\"job_title\\\": \\\"Software Engineer\\\",\\n        \\\"candidate_name\\\": \\\"John Doe\\\",\\n        \\\"interview_transcript\\\": \\\"interview_transcript\\\"\\n      },\\n      \\\"output\\\": \\\"evaluation_report\\\",\\n      \\\"algorithm\\\": \\\"Calculate overall_score based on average of individual question scores. Identify strengths based on high-scoring responses. Identify weaknesses based on low-scoring responses and skill gaps. Provide a recommendation based on overall performance and alignment with job requirements.\\\"\\n    },\\n    {\\n      \\\"step_number\\\": 9,\\n      \\\"name\\\": \\\"OutputResults\\\",\\n      \\\"description\\\": \\\"Output the interview transcript and evaluation report.\\\",\\n      \\\"output\\\": [\\\"interview_transcript\\\", \\\"evaluation_report\\\"]\\n    }\\n  ]\\n}\\n```\",\n  \"timestamp\": \"2026-05-27T18:10:19.202246\"\n}"}
