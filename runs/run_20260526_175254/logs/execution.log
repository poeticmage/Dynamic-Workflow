{"timestamp": "2026-05-26 17:55:32,848", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task2: ```python\nimport smtplib\nfrom email.mime.text import MIMEText\nfrom email.mime.multipart import MIMEMultipart\n\nclass EmailNotifier:\n    \"\"\"\n    A module to send notification emails at specified workflow stages.\n    \"\"\"\n\n    def __init__(self, smtp_server, smtp_port, smtp_user, smtp_password, use_tls=True):\n        self.smtp_server = smtp_server\n        self.smtp_port = smtp_port\n        self.smtp_user = smtp_user\n        self.smtp_password = smtp_password\n        self.use_tls = use_tls\n\n        # Define email templates per workflow stage\n        self.templates = {\n            \"job_description_analyzed\": {\n                \"subject\": \"Job Description Analysis Complete\",\n                \"body\": (\n                    \"Hello {name},\\n\\n\"\n                    \"The job description for '{job_title}' has been analyzed.\\n\"\n                    \"Next, we'll analyze your resume.\\n\\n\"\n                    \"Best regards,\\n\"\n                    \"Recruitment Team\"\n                )\n            },\n            \"resume_analyzed\": {\n                \"subject\": \"Resume Analysis Complete\",\n                \"body\": (\n                    \"Hello {name},\\n\\n\"\n                    \"We have completed analyzing your resume for '{job_title}'.\\n\"\n                    \"Up next: technical interview scheduling.\\n\\n\"\n                    \"Best regards,\\n\"\n                    \"Recruitment Team\"\n                )\n            },\n            \"technical_interview_scheduled\": {\n                \"subject\": \"Technical Interview Scheduled\",\n                \"body\": (\n                    \"Hello {name},\\n\\n\"\n                    \"Your technical interview for '{job_title}' is scheduled on {interview_date}.\\n\"\n                    \"Please confirm your availability.\\n\\n\"\n                    \"Best regards,\\n\"\n                    \"Recruitment Team\"\n                )\n            },\n            \"score_submitted\": {\n                \"subject\": \"Interview Score Submitted\",\n                \"body\": (\n                    \"Hello {name},\\n\\n\"\n                    \"Your interview has been scored.\\n\"\n                    \"Score: {score}\\n\\n\"\n                    \"Thank you for your time.\\n\\n\"\n                    \"Best regards,\\n\"\n                    \"Recruitment Team\"\n                )\n            },\n            \"final_evaluation\": {\n                \"subject\": \"Final Evaluation Report\",\n                \"body\": (\n                    \"Hello {name},\\n\\n\"\n                    \"The final evaluation for '{job_title}' is complete.\\n\"\n                    \"Result: {result}\\n\\n\"\n                    \"Best regards,\\n\"\n                    \"Recruitment Team\"\n                )\n            }\n        }\n\n    def send_email(self, recipient, subject, body, sender=None):\n        \"\"\"\n        Sends an email using SMTP.\n        \"\"\"\n        sender = sender or self.smtp_user\n        msg = MIMEMultipart()\n        msg[\"From\"] = sender\n        msg[\"To\"] = recipient\n        msg[\"Subject\"] = subject\n        msg.attach(MIMEText(body, \"plain\"))\n\n        server = smtplib.SMTP(self.smtp_server, self.smtp_port)\n        try:\n            if self.use_tls:\n                server.starttls()\n            server.login(self.smtp_user, self.smtp_password)\n            server.sendmail(sender, recipient, msg.as_string())\n        finally:\n            server.quit()\n\n    def notify(self, stage, recipient_email, context):\n        \"\"\"\n        Send a notification email for the given workflow stage.\n        `stage` must be one of the keys in self.templates.\n        `context` is a dict with template variables (e.g., name, job_title).\n        \"\"\"\n        template = self.templates.get(stage)\n        if not template:\n            raise ValueError(f\"No email template defined for stage '{stage}'\")\n\n        subject = template[\"subject\"]\n        body = template[\"body\"].format(**context)\n        self.send_email(recipient_email, subject, body)\n```"}
{"timestamp": "2026-05-26 17:55:32,848", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task3: ```python\nfrom typing import List, Dict\n\nclass TechnicalInterviewManager:\n    def __init__(self):\n        # Internal storage for questions and candidate responses\n        self.questions: List[str] = []\n        self.responses: Dict[str, str] = {}\n\n    def generate_questions(self, job_description: str, resume: str) -> List[str]:\n        \"\"\"\n        Generate a list of technical interview questions based on job requirements\n        and the candidate's resume.\n        This is a stub implementation; in a real system you could integrate an AI model\n        or a question bank.\n        \"\"\"\n        # Example stub logic: pick keywords and create simple questions\n        keywords = set(job_description.lower().split()) | set(resume.lower().split())\n        base_questions = [\n            \"Explain your experience with {}.\",\n            \"How would you solve a problem involving {}?\",\n            \"Describe a project where you used {}.\"\n        ]\n        # Generate up to 5 questions\n        generated = []\n        for i, kw in enumerate(keywords):\n            if i >= 5:\n                break\n            fmt = base_questions[i % len(base_questions)]\n            generated.append(fmt.format(kw))\n        self.questions = generated\n        return generated\n\n    def conduct_interview(self, candidate_answers: Dict[str, str]) -> None:\n        \"\"\"\n        Record the candidate's answers. We assume `candidate_answers` maps each question\n        to its provided answer.\n        \"\"\"\n        for question, answer in candidate_answers.items():\n            self.record_response(question, answer)\n\n    def record_response(self, question: str, response: str) -> None:\n        \"\"\"\n        Store a single question-response pair.\n        \"\"\"\n        self.responses[question] = response\n\n    def get_responses(self) -> Dict[str, str]:\n        \"\"\"\n        Return all stored candidate responses.\n        \"\"\"\n        return self.responses\n\n# Example usage (would be removed or commented out in production):\nif __name__ == \"__main__\":\n    manager = TechnicalInterviewManager()\n    job_desc = \"We need a Python developer with experience in Django REST and SQL\"\n    resume_text = \"Worked on Flask, SQL, data pipelines\"\n    questions = manager.generate_questions(job_desc, resume_text)\n    print(\"Interview Questions:\")\n    for q in questions:\n        print(\"-\", q)\n\n    # Simulate candidate's answers\n    sample_answers = {\n        questions[0]: \"I have used Python extensively in web development.\",\n        questions[1]: \"I would use Django REST framework with serializers.\",\n    }\n    manager.conduct_interview(sample_answers)\n    print(\"\\nRecorded Responses:\")\n    for q, a in manager.get_responses().items():\n        print(f\"{q} -> {a}\")\n```"}
{"timestamp": "2026-05-26 17:55:32,848", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task4: ```python\nfrom typing import Dict, List\n\nclass ScoringEngine:\n    def __init__(self, criteria: Dict[str, int]):\n        \"\"\"\n        Initialize the scoring engine with predefined criteria.\n\n        Args:\n            criteria (Dict[str, int]): A dictionary where keys are criteria\n                                         and values are maximum possible scores for each.\n        \"\"\"\n        self.criteria = criteria\n\n    def score_response(self, response: str, question: str) -> Dict[str, int]:\n        \"\"\"\n        Scores a candidate's response based on the predefined criteria.\n\n        Args:\n            response (str): The candidate's response to a question.\n            question (str): The question that the candidate answered.\n\n        Returns:\n            Dict[str, int]: A dictionary containing scores for each criterion.\n                             The keys are the criterion names, and the values are the scores.\n        \"\"\"\n        scores = {}\n        for criterion, max_score in self.criteria.items():\n            # This is a placeholder for actual scoring logic.\n            # In a real implementation, you would use NLP techniques,\n            # regular expressions, or other methods to analyze the response\n            # and assign scores based on how well it meets the criterion.\n            # The following is a very basic example:\n            if criterion.lower() in response.lower():\n                scores[criterion] = max_score\n            else:\n                scores[criterion] = 0\n        return scores\n\n    def calculate_total_score(self, scores: Dict[str, Dict[str, int]]) -> int:\n        \"\"\"\n        Calculates the total score for all responses.\n\n        Args:\n            scores (Dict[str, Dict[str, int]]): A dictionary where keys are question strings\n                                                  and values are dictionaries of criterion scores.\n\n        Returns:\n            int: The total score across all questions and criteria.\n        \"\"\"\n        total_score = 0\n        for question_scores in scores.values():\n            total_score += sum(question_scores.values())\n        return total_score\n\n    def evaluate_candidate(self, responses: Dict[str, str], questions: List[str]) -> Dict[str, Dict[str, int]]:\n        \"\"\"\n        Evaluates a candidate's responses to a list of questions.\n\n        Args:\n            responses (Dict[str, str]): A dictionary of question-response pairs.\n            questions (List[str]): A list of the questions asked.\n\n        Returns:\n            Dict[str, Dict[str, int]]: A nested dictionary. The outer dictionary's keys are the questions.\n                                         The inner dictionary contains the scores for each criterion for that question.\n        \"\"\"\n        all_scores = {}\n        for question in questions:\n            if question in responses:\n                response = responses[question]\n                all_scores[question] = self.score_response(response, question)\n            else:\n                all_scores[question] = {criterion: 0 for criterion in self.criteria}  # No response, score 0\n        return all_scores\n\n# Example Usage (to be removed or commented out in production)\nif __name__ == \"__main__\":\n    # Define the scoring criteria and their maximum scores\n    scoring_criteria = {\n        \"Technical Accuracy\": 10,\n        \"Code Quality\": 5,\n        \"Problem Solving\": 7,\n        \"Communication\": 3,\n    }\n\n    # Create a scoring engine instance\n    engine = ScoringEngine(criteria=scoring_criteria)\n\n    # Example responses and questions\n    example_questions = [\n        \"Explain your experience with SQL.\",\n        \"How would you solve a problem involving data pipelines?\",\n    ]\n    example_responses = {\n        example_questions[0]: \"I have extensive experience with SQL, including complex queries and database design.\",\n        example_questions[1]: \"I would use a combination of tools like Apache Kafka and Spark for data pipelines.\",\n    }\n\n    # Evaluate the candidate\n    candidate_scores = engine.evaluate_candidate(example_responses, example_questions)\n\n    # Print the scores\n    for question, scores in candidate_scores.items():\n        print(f\"Question: {question}\")\n        for criterion, score in scores.items():\n            print(f\"- {criterion}: {score}\")\n\n    # Calculate and print the total score\n    total_score = engine.calculate_total_score(candidate_scores)\n    print(f\"\\nTotal Score: {total_score}\")\n```"}
{"timestamp": "2026-05-26 17:55:32,848", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task5: ```python\nfrom typing import Dict, List\n\nclass EvaluationReportGenerator:\n    def __init__(self, scoring_engine):\n        \"\"\"\n        Initializes the EvaluationReportGenerator with a scoring engine.\n\n        Args:\n            scoring_engine: An instance of the ScoringEngine class.\n        \"\"\"\n        self.scoring_engine = scoring_engine\n\n    def generate_report(self,\n                        candidate_name: str,\n                        responses: Dict[str, str],\n                        questions: List[str]\n                       ) -> List[str]:\n        \"\"\"\n        Generates a final evaluation report for a candidate as a list of strings.\n\n        Args:\n            candidate_name (str): The name of the candidate.\n            responses (Dict[str, str]): A dictionary of question-response pairs.\n            questions (List[str]): A list of the questions asked.\n\n        Returns:\n            List[str]: The evaluation report as a list of lines.\n        \"\"\"\n        report_lines: List[str] = []\n        all_scores = self.scoring_engine.evaluate_candidate(responses, questions)\n        total_score = self.scoring_engine.calculate_total_score(all_scores)\n\n        report_lines.append(f\"Evaluation Report for {candidate_name}\")\n        report_lines.append(\"\")\n\n        for question in questions:\n            report_lines.append(f\"Question: {question}\")\n            scores = all_scores.get(question, {})\n            if scores:\n                for criterion, score in scores.items():\n                    report_lines.append(f\"- {criterion}: {score}\")\n            else:\n                report_lines.append(\"- No response provided.\")\n            report_lines.append(\"\")  # blank line between questions\n\n        report_lines.append(f\"Total Score: {total_score}\")\n        report_lines.append(\"\")\n        report_lines.append(\"Overall Assessment:\")\n        report_lines.append(self.generate_assessment(total_score))\n\n        return report_lines\n\n    def generate_assessment(self, total_score: int) -> str:\n        \"\"\"\n        Generates an overall assessment based on the total score.\n\n        Args:\n            total_score (int): The total score of the candidate.\n\n        Returns:\n            str: An overall assessment of the candidate's performance.\n        \"\"\"\n        if total_score >= 80:\n            return \"Highly recommended. The candidate demonstrated excellent skills and knowledge.\"\n        elif 60 <= total_score < 80:\n            return \"Recommended. The candidate is proficient and meets the requirements.\"\n        elif 40 <= total_score < 60:\n            return \"Consider with reservations. The candidate has some skills but needs improvement.\"\n        else:\n            return \"Not recommended. The candidate lacks the required skills and knowledge.\"\n\nif __name__ == \"__main__\":\n    # Example ScoringEngine implementation\n    class ScoringEngine:\n        def __init__(self, criteria: Dict[str, int]):\n            self.criteria = criteria\n\n        def score_response(self, response: str, question: str) -> Dict[str, int]:\n            scores = {}\n            for criterion, max_score in self.criteria.items():\n                # Placeholder logic: full marks if keyword present\n                if criterion.lower() in response.lower():\n                    scores[criterion] = max_score\n                else:\n                    scores[criterion] = 0\n            return scores\n\n        def calculate_total_score(self, scores: Dict[str, Dict[str, int]]) -> int:\n            total_score = 0\n            for question_scores in scores.values():\n                total_score += sum(question_scores.values())\n            return total_score\n\n        def evaluate_candidate(self,\n                               responses: Dict[str, str],\n                               questions: List[str]\n                              ) -> Dict[str, Dict[str, int]]:\n            all_scores = {}\n            for question in questions:\n                if question in responses:\n                    all_scores[question] = self.score_response(responses[question], question)\n                else:\n                    # No response: zero scores for all criteria\n                    all_scores[question] = {c: 0 for c in self.criteria}\n            return all_scores\n\n    # Define scoring criteria\n    scoring_criteria = {\n        \"Technical Accuracy\": 10,\n        \"Code Quality\": 5,\n        \"Problem Solving\": 7,\n        \"Communication\": 3,\n    }\n    scoring_engine = ScoringEngine(criteria=scoring_criteria)\n    report_generator = EvaluationReportGenerator(scoring_engine)\n\n    # Example candidate data\n    candidate_name = \"John Doe\"\n    example_questions = [\n        \"Explain your experience with SQL.\",\n        \"How would you solve a problem involving data pipelines?\",\n    ]\n    example_responses = {\n        example_questions[0]: \"I have extensive experience with SQL, including complex queries and database design.\",\n        example_questions[1]: \"I would use a combination of tools like Apache Kafka and Spark for data pipelines.\",\n    }\n\n    # Generate and print the report as a list of strings\n    report_lines = report_generator.generate_report(candidate_name, example_responses, example_questions)\n    for line in report_lines:\n        print(line)\n```"}
