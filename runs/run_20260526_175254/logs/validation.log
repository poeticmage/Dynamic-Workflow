ate_answers` maps each question\\n        to its provided answer.\\n        \\\"\\\"\\\"\\n        for question, answer in candidate_answers.items():\\n            self.record_response(question, answer)\\n\\n    def record_response(self, question: str, response: str) -> None:\\n        \\\"\\\"\\\"\\n        Store a single question-response pair.\\n        \\\"\\\"\\\"\\n        self.responses[question] = response\\n\\n    def get_responses(self) -> Dict[str, str]:\\n        \\\"\\\"\\\"\\n        Return all stored candidate responses.\\n        \\\"\\\"\\\"\\n        return self.responses\\n\\n# Example usage (would be removed or commented out in production):\\nif __name__ == \\\"__main__\\\":\\n    manager = TechnicalInterviewManager()\\n    job_desc = \\\"We need a Python developer with experience in Django REST and SQL\\\"\\n    resume_text = \\\"Worked on Flask, SQL, data pipelines\\\"\\n    questions = manager.generate_questions(job_desc, resume_text)\\n    print(\\\"Interview Questions:\\\")\\n    for q in questions:\\n        print(\\\"-\\\", q)\\n\\n    # Simulate candidate's answers\\n    sample_answers = {\\n        questions[0]: \\\"I have used Python extensively in web development.\\\",\\n        questions[1]: \\\"I would use Django REST framework with serializers.\\\",\\n    }\\n    manager.conduct_interview(sample_answers)\\n    print(\\\"\\\\nRecorded Responses:\\\")\\n    for q, a in manager.get_responses().items():\\n        print(f\\\"{q} -> {a}\\\")\\n```\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"# **The Overall Goal**\\nYou are a workflow planning agent.\\nYour task is to:\\n-\\\"Analyze the job description\\\",\\n    \\\"Analyze the candidate resume\\\",\\n    \\\"Conduct technical interview\\\",\\n    \\\"Send emails as and when needed\\\",\\n    \\\"Score candidate responses\\\",\\n    \\\"Generate final evaluation report\\\"\\n\\nReturn the output as a Python list of strings.\\n\\n\\n\\n\\n---\\n# **Context from Upstr