ping import List, Dict\\n\\nclass TechnicalInterviewManager:\\n    def __init__(self):\\n        # Internal storage for questions and candidate responses\\n        self.questions: List[str] = []\\n        self.responses: Dict[str, str] = {}\\n\\n    def generate_questions(self, job_description: str, resume: str) -> List[str]:\\n        \\\"\\\"\\\"\\n        Generate a list of technical interview questions based on job requirements\\n        and the candidate's resume.\\n        This is a stub implementation; in a real system you could integrate an AI model\\n        or a question bank.\\n        \\\"\\\"\\\"\\n        # Example stub logic: pick keywords and create simple questions\\n        keywords = set(job_description.lower().split()) | set(resume.lower().split())\\n        base_questions = [\\n            \\\"Explain your experience with {}.\\\",\\n            \\\"How would you solve a problem involving {}?\\\",\\n            \\\"Describe a project where you used {}.\\\"\\n        ]\\n        # Generate up to 5 questions\\n        generated = []\\n        for i, kw in enumerate(keywords):\\n            if i >= 5:\\n                break\\n            fmt = base_questions[i % len(base_questions)]\\n            generated.append(fmt.format(kw))\\n        self.questions = generated\\n        return generated\\n\\n    def conduct_interview(self, candidate_answers: Dict[str, str]) -> None:\\n        \\\"\\\"\\\"\\n        Record the candidate's answers. We assume `candidate_answers` maps each question\\n        to its provided answer.\\n        \\\"\\\"\\\"\\n        for question, answer in candidate_answers.items():\\n            self.record_response(question, answer)\\n\\n    def record_response(self, question: str, response: str) -> None:\\n        \\\"\\\"\\\"\\n        Store a single question-response pair.\\n        \\\"\\\"\\\"\\n        self.responses[question] = response\\n\\n    def get_responses(self) -> Dict[str, str]:\\n        \\\"\\\"\\\"\\n        Return all stored candidate responses.\\n        \\\"\\\"\\\"\\n        return self.responses\\n\\n# Example usage (would be removed or commented out in production):\\nif __name__ == \\\"__main__\\\":\\n    manager = TechnicalInterviewManager()\\n    job_desc = \\\"We need a Python developer with experience in Django REST and SQL\\\"\\n    resume_text = \\\"Worked on Flask, SQL, data pipelines\\\"\\n    questions = manager.generate_questions(job_desc, resume_text)\\n    print(\\\"Interview Questions:\\\")\\n    for q in questions:\\n        print(\\\"-\\\", q)\\n\\n    # Simulate candidate's answers\\n    sample_answers = {\\n        questions[0]: \\\"I have used Python extensively in web development.\\\",\\n        questions[1]: \\\"I would use Django REST framework with serializers.\\\",\\n    }\\n    manager.conduct_interview(sample_answers)\\n    print(\\\"\\\\nRecorded Responses:\\\")\\n    for q, a in manager.get_responses().items():\\n        print(f\\\"{q} -> {a}\\\")\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task5:\\n  Objective: Implement the final evaluation report generator to compile scores and analysis into a summary\\n\\n---\\n# **Current Task Requirements**\\nBuild a scoring engine to evaluate candidate responses against predefined criteria\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nfrom typing import Dict, List\\n\\nclass ScoringEngine:\\n    def __init__(self, criteria: Dict[str, int]):\\n        \\\"\\\"\\\"\\n        Initialize the scoring engine with predefined criteria.\\n\\n        Args:\\n            criteria (Dict[str, int]): A dictionary where keys are criteria\\n                                         and values are maximum possible scores for each.\\n        \\\"\\\"\\\"\\n        self.criteria = criteria\\n\\n    def score_response(self, response: str, question: str) -> Dict[str, int]:\\n        \\\"\\\"\\\"\\n        Scores a candidate's response based on the predefined criteria.\\n\\n        Args:\\n            response (str): The candidate's response to a question.\\n            question (str): The question that the candidate answered.\\n\\n        Returns:\\n            Dict[str, int]: A dictionary containing scores for each criterion.\\n                             The keys are the criterion names, and the values are the scores.\\n        \\\"\\\"\\\"\\n        scores = {}\\n        for criterion, max_score in self.criteria.items():\\n            # This is a placeholder for actual scoring logic.\\n            # In a real implementation, you would use NLP techniques,\\n            # regular expressions, or other methods to analyze the response\\n            # and assign scores based on how well it meets the criterion.\\n            # The following is a very basic example:\\n            if criterion.lower() in response.lower():\\n                scores[criterion] = max_score\\n            else:\\n                scores[criterion] = 0\\n        return scores\\n\\n    def calculate_total_score(self, scores: Dict[str, Dict[str, int]]) -> int:\\n        \\\"\\\"\\\"\\n        Calculates the total score for all responses.\\n\\n        Args:\\n            scores (Dict[str, Dict[str, int]]): A dictionary where keys are question strings\\n                                                  and values are dictionaries of criterion scores.\\n\\n        Returns:\\n            int: The total score across all questions and criteria.\\n        \\\"\\\"\\\"\\n        total_score = 0\\n        for question_scores in scores.values():\\n            total_score += sum(question_scores.values())\\n        return total_score\\n\\n    def evaluate_candidate(self, responses: Dict[str, str], questions: List[str]) -> Dict[str, Dict[str, int]]:\\n        \\\"\\\"\\\"\\n        Evaluates a candidate's responses to a list of questions.\\n\\n        Args:\\n            responses (Dict[str, str]): A dictionary of question-response pairs.\\n            questions (List[str]): A list of the questions asked.\\n\\n        Returns:\\n            Dict[str, Dict[str, int]]: A nested dictionary. The outer dictionary's keys are the questions.\\n                                         The inner dictionary contains the scores for each criterion for that question.\\n        \\\"\\\"\\\"\\n        all_scores = {}\\n        for question in questions:\\n            if question in responses:\\n                response = responses[question]\\n                all_scores[question] = self.score_response(response, question)\\n            else:\\n                all_scores[question] = {criterion: 0 for criterion in self.criteria}  # No response, score 0\\n        return all_scores\\n\\n# Example Usage (to be removed or commented out in production)\\nif __name__ == \\\"__main__\\\":\\n    # Define the scoring criteria and their maximum scores\\n    scoring_criteria = {\\n        \\\"Technical Accuracy\\\": 10,\\n        \\\"Code Quality\\\": 5,\\n        \\\"Problem Solving\\\": 7,\\n        \\\"Communication\\\": 3,\\n    }\\n\\n    # Create a scoring engine instance\\n    engine = ScoringEngine(criteria=scoring_criteria)\\n\\n    # Example responses and questions\\n    example_questions = [\\n        \\\"Explain your experience with SQL.\\\",\\n        \\\"How would you solve a problem involving data pipelines?\\\",\\n    ]\\n    example_responses = {\\n        example_questions[0]: \\\"I have extensive experience with SQL, including complex queries and database design.\\\",\\n        example_questions[1]: \\\"I would use a combination of tools like Apache Kafka and Spark for data pipelines.\\\",\\n    }\\n\\n    # Evaluate the candidate\\n    candidate_scores = engine.evaluate_candidate(example_responses, example_questions)\\n\\n    # Print the scores\\n    for question, scores in candidate_scores.items():\\n        print(f\\\"Question: {question}\\\")\\n        for criterion, score in scores.items():\\n            print(f\\\"- {criterion}: {score}\\\")\\n\\n    # Calculate and print the total score\\n    total_score = engine.calculate_total_score(candidate_scores)\\n    print(f\\\"\\\\nTotal Score: {total_score}\\\")\\n```\",\n  \"timestamp\": \"2026-05-26T17:55:00.792867\"\n}"}
