      self.color = COLOR_MAP[shape_key]\\n        self.position = [GRID_WIDTH // 2 - 2, 0]  # x, y on the grid\\n\\n    @property\\n    def blocks(self):\\n        return [(self.position[0] + x, self.position[1] + y)\\n                for (x, y) in self.rotations[self.rotation_index]]\\n\\n    def rotate(self):\\n        self.rotation_index = (self.rotation_index + 1) % len(self.rotations)\\n\\n    def move(self, dx, dy):\\n        self.position[0] += dx\\n        self.position[1] += dy\\n```\\nTask task2:\\n  Objective: Develop lock-in logic: integrate falling tetromino blocks into the grid and convert them into colored gems.\\n  Result: ```python\\nimport pygame\\nimport random\\n\\nfrom task0 import GRID_WIDTH, GRID_HEIGHT, TETROMINO_SHAPES, COLOR_MAP, Gem, Tetromino, get_empty_grid\\n\\n\\nclass GameState:\\n    def __init__(self):\\n        self.grid = get_empty_grid()\\n        self.current_tetromino = self.new_tetromino()\\n        self.next_tetromino = self.new_tetromino()\\n        self.score = 0\\n        self.game_over = False\\n\\n    def new_tetromino(self):\\n        shape_key = random.choice(list(TETROMINO_SHAPES.keys()))\\n        tetromino = Tetromino(shape_key)\\n        tetromino.position = [GRID_WIDTH // 2 - 2, 0]\\n        return tetromino\\n\\n    def hard_drop(self):\\n        while self.is_valid_move(self.current_tetromino, 0, 1):\\n            self.current_tetromino.move(0, 1)\\n        self.lock_tetromino()\\n\\n    def move_tetromino(self, dx):\\n        if self.is_valid_move(self.current_tetromino, dx, 0):\\n            self.current_tetromino.move(dx, 0)\\n\\n    def rotate_tetromino(self):\\n        \\\"\\\"\\\"\\n        Rotate current tetromino. On invalid rotation, restore its previous state.\\n        Optionally attempt simple wall kicks (left/right shifts).\\n        \\\"\\\"\\\"\\n        # Snapshot state\\n        old_rotation = self.current_tetromino.rotation_index\\n        old_blocks = [(x,y) for x, y in self.current_tetromino.blocks]  # Create a copy\\n\\n        # Perform rotation\\n        self.current_tetromino.rotate()\\n\\n        # If rotation collides, try simple wall kicks\\n        if not self.is_valid_move(self.current_tetromino, 0, 0):\\n            kicked = False\\n            for dx in (-1, 1):  # try shifts left/right; reduced search for simplicity\\n                if self.is_valid_move(self.current_tetromino, dx, 0):\\n                    self.current_tetromino.move(dx, 0)\\n                    kicked = True\\n                    break\\n\\n            # If still invalid, restore original\\n            if not kicked:\\n                self.current_tetromino.rotation_index = old_rotation\\n                self.current_tetromino.blocks = [(x,y) for x, y in old_blocks]\\n\\n    def is_valid_move(self, tetromino, dx, dy):\\n        \\\"\\\"\\\"\\n        Check if moving tetromino by (dx, dy) would cause collision or go out of bounds.\\n        \\\"\\\"\\\"\\n        for x, y in tetromino.blocks:\\n            new_x = x + dx\\n            new_y = y + dy\\n\\n            # Check horizontal bounds\\n            if new_x < 0 or new_x >= GRID_WIDTH:\\n                return False\\n            # Check bottom bound\\n            if new_y >= GRID_HEIGHT:\\n                return False\\n\\n            #Check if block is above the grid\\n            if new_y < 0:\\n                continue\\n            # Check existing blocks in grid\\n            if self.grid[new_y][new_x] is not None:\\n                return False\\n        return True\\n\\n    def drop_tetromino(self):\\n        \\\"\\\"\\\"\\n        Advance tetromino down by one. Lock if it cannot move further.\\n        Returns True if moved, False if locked.\\n        \\\"\\\"\\\"\\n        if self.is_valid_move(self.current_tetromino, 0, 1):\\n            self.current_tetromino.move(0, 1)\\n            return True\\n        else:\\n            self.lock_tetromino()\\n            return False\\n\\n    def lock_tetromino(self):\\n        \\\"\\\"\\\"\\n        Place current tetromino into the grid as gems, spawn next, and clear lines.\\n        \\\"\\\"\\\"\\n        for x, y in self.current_tetromino.blocks:\\n            # If any part is above the grid, it's game over\\n            if y < 0:\\n                self.game_over = True\\n                return\\n            self.grid[y][x] = Gem(self.current_tetromino.color)\\n\\n        # Spawn next piece\\n        self.current_tetromino = self.next_tetromino\\n        self.current_tetromino.position = [GRID_WIDTH // 2 - 2, 0] # Reset position\\n        self.next_tetromino = self.new_tetromino()\\n\\n        # Run line-clearing\\n        self.clear_lines()\\n\\n    def clear_lines(self):\\n        \\\"\\\"\\\"\\n        Clear any full rows in Tetris style, shift above rows down,\\n        and award score per line cleared.\\n        \\\"\\\"\\\"\\n        lines_to_clear = []\\n        for row in range(GRID_HEIGHT):\\n            if all(self.grid[row][col] is not None for col in range(GRID_WIDTH)):\\n                lines_to_clear.append(row)\\n\\n        for row in reversed(lines_to_clear):\\n            del self.grid[row]\\n            self.grid.insert(0, [None] * GRID_WIDTH)\\n            self.score += 100  # base points per line (adjust as desired)\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task4:\\n  Objective: Create scoring system: calculate points for line clears, gem matches, and bonus combos in chain reactions.\\nTask task5:\\n  Objective: Implement Pygame GUI: render grid, falling pieces, gem animations, score display, next-piece preview, and keyboard controls.\\n\\n---\\n# **Current Task Requirements**\\nBuild clearing mechanics: detect and clear full lines (Tetris) and match-3 gem patterns, triggering chain reactions.\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport pygame\\nimport random\\n\\nfrom task0 import GRID_WIDTH, GRID_HEIGHT, TETROMINO_SHAPES, COLOR_MAP, Gem, Tetromino, get_empty_grid\\n\\n\\nclass GameState:\\n    def __init__(self):\\n        self.grid = get_empty_grid()\\n        self.current_tetromino = self.new_tetromino()\\n        self.next_tetromino = self.new_tetromino()\\n        self.score = 0\\n        self.game_over = False\\n\\n    def new_tetromino(self):\\n        shape_key = random.choice(list(TETROMINO_SHAPES.keys()))\\n        tetromino = Tetromino(shape_key)\\n        tetromino.position = [GRID_WIDTH // 2 - 2, 0]\\n        return tetromino\\n\\n    def hard_drop(self):\\n        while self.is_valid_move(self.current_tetromino, 0, 1):\\n            self.current_tetromino.move(0, 1)\\n        self.lock_tetromino()\\n\\n    def move_tetromino(self, dx):\\n        if self.is_valid_move(self.current_tetromino, dx, 0):\\n            self.current_tetromino.move(dx, 0)\\n\\n    def rotate_tetromino(self):\\n        \\\"\\\"\\\"\\n        Rotate current tetromino. On invalid rotation, restore its previous state.\\n        Optionally attempt simple wall kicks (left/right shifts).\\n        \\\"\\\"\\\"\\n        # Snapshot state\\n        old_rotation = self.current_tetromino.rotation_index\\n        old_blocks = [(x,y) for x, y in self.current_tetromino.blocks]  # Create a copy\\n\\n        # Perform rotation\\n        self.current_tetromino.rotate()\\n\\n        # If rotation collides, try simple wall kicks\\n        if not self.is_valid_move(self.current_tetromino, 0, 0):\\n            kicked = False\\n            for dx in (-1, 1):  # try shifts left/right; reduced search for simplicity\\n                if self.is_valid_move(self.current_tetromino, dx, 0):\\n                    self.current_tetromino.move(dx, 0)\\n                    kicked = True\\n                    break\\n\\n            # If still invalid, restore original\\n            if not kicked:\\n                self.current_tetromino.rotation_index = old_rotation\\n                self.current_tetromino.blocks = [(x,y) for x, y in old_blocks]\\n\\n    def is_valid_move(self, tetromino, dx, dy):\\n        \\\"\\\"\\\"\\n        Check if moving tetromino by (dx, dy) would cause collision or go out of bounds.\\n        \\\"\\\"\\\"\\n        for x, y in tetromino.blocks:\\n            new_x = x + dx\\n            new_y = y + dy\\n\\n            # Check horizontal bounds\\n            if new_x < 0 or new_x >= GRID_WIDTH:\\n                return False\\n            # Check bottom bound\\n            if new_y >= GRID_HEIGHT:\\n                return False\\n\\n            #Check if block is above the grid\\n            if new_y < 0:\\n                continue\\n            # Check existing blocks in grid\\n            if self.grid[new_y][new_x] is not None:\\n                return False\\n        return True\\n\\n    def drop_tetromino(self):\\n        \\\"\\\"\\\"\\n        Advance tetromino down by one. Lock if it cannot move further.\\n        Returns True if moved, False if locked.\\n        \\\"\\\"\\\"\\n        if self.is_valid_move(self.current_tetromino, 0, 1):\\n            self.current_tetromino.move(0, 1)\\n            return True\\n        else:\\n            self.lock_tetromino()\\n            return False\\n\\n    def lock_tetromino(self):\\n        \\\"\\\"\\\"\\n        Place current tetromino into the grid as gems, spawn next, and clear lines.\\n        \\\"\\\"\\\"\\n        for x, y in self.current_tetromino.blocks:\\n            # If any part is above the grid, it's game over\\n            if y < 0:\\n                self.game_over = True\\n                return\\n            self.grid[y][x] = Gem(self.current_tetromino.color)\\n\\n        # Spawn next piece\\n        self.current_tetromino = self.next_tetromino\\n        self.current_tetromino.position = [GRID_WIDTH // 2 - 2, 0] # Reset position\\n        self.next_tetromino = self.new_tetromino()\\n\\n        # Run line-clearing and match-3 clearing\\n        lines_cleared = self.clear_lines()\\n        matches_cleared = self.clear_matches()\\n\\n        # Trigger chain reactions (simplified: just clear again if anything was cleared)\\n        if lines_cleared or matches_cleared:\\n            self.clear_lines()\\n            self.clear_matches()\\n\\n    def clear_lines(self):\\n        \\\"\\\"\\\"\\n        Clear any full rows in Tetris style, shift above rows down,\\n        and award score per line cleared.  Return number of lines cleared.\\n        \\\"\\\"\\\"\\n        lines_to_clear = []\\n        for row in range(GRID_HEIGHT):\\n            if all(self.grid[row][col] is not None for col in range(GRID_WIDTH)):\\n                lines_to_clear.append(row)\\n\\n        for row in reversed(lines_to_clear):\\n            del self.grid[row]\\n            self.grid.insert(0, [None] * GRID_WIDTH)\\n            self.score += 100  # base points per line (adjust as desired)\\n        return len(lines_to_clear)\\n\\n    def clear_matches(self):\\n        \\\"\\\"\\\"\\n        Detect and clear 3-or-more gem matches, both horizontal and vertical.\\n        Return number of matches cleared.\\n        \\\"\\\"\\\"\\n        matches = []\\n\\n        # Horizontal matches\\n        for row in range(GRID_HEIGHT):\\n            for col in range(GRID_WIDTH - 2):\\n                if (self.grid[row][col] is not None and\\n                        self.grid[row][col + 1] is not None and\\n                        self.grid[row][col + 2] is not None):\\n                    color1 = self.grid[row][col].color\\n                    color2 = self.grid[row][col + 1].color\\n                    color3 = self.grid[row][col + 2].color\\n                    if color1 == color2 == color3:\\n                        matches.append(((row, col), (row, col + 1), (row, col + 2)))\\n\\n        # Vertical matches\\n        for col in range(GRID_WIDTH):\\n            for row in range(GRID_HEIGHT - 2):\\n                if (self.grid[row][col] is not None and\\n                        self.grid[row + 1][col] is not None and\\n                        self.grid[row + 2][col] is not None):\\n                    color1 = self.grid[row][col].color\\n                    color2 = self.grid[row + 1][col].color\\n                    color3 = self.grid[row + 2][col].color\\n                    if color1 == color2 == color3:\\n                        matches.append(((row, col), (row + 1, col), (row + 2, col)))\\n\\n        # Remove Duplicates\\n        unique_matches = []\\n        for match in matches:\\n            if match not in unique_matches:\\n                unique_matches.append(match)\\n                \\n        # Clear the matches from the grid\\n        cleared_count = 0\\n        for match in unique_matches:\\n            for row, col in match:\\n                if self.grid[row][col] is not None:  # Double check in case of cascading clears\\n                    self.grid[row][col] = None\\n                    cleared_count += 1\\n                    self.score += 50 #Points per gem\\n        return cleared_count\\n```\",\n  \"timestamp\": \"2026-05-22T12:36:09.591508\"\n}"}
