APES.keys()))\\n        tetromino = Tetromino(shape_key)\\n        tetromino.position = [GRID_WIDTH // 2 - 2, 0]\\n        return tetromino\\n\\n    def hard_drop(self):\\n        while self.is_valid_move(self.current_tetromino, 0, 1):\\n            self.current_tetromino.move(0, 1)\\n        self.lock_tetromino()\\n\\n    def move_tetromino(self, dx):\\n        if self.is_valid_move(self.current_tetromino, dx, 0):\\n            self.current_tetromino.move(dx, 0)\\n\\n    def rotate_tetromino(self):\\n        old_rotation = self.current_tetromino.rotation_index\\n        old_blocks = list(self.current_tetromino.blocks)\\n        self.current_tetromino.rotate()\\n        if not self.is_valid_move(self.current_tetromino, 0, 0):\\n            # simple wall-kick\\n            for dx in (-1, 1):\\n                if self.is_valid_move(self.current_tetromino, dx, 0):\\n                    self.current_tetromino.move(dx, 0)\\n                    return\\n            # revert\\n            self.current_tetromino.rotation_index = old_rotation\\n            self.current_tetromino.blocks = old_blocks\\n\\n    def is_valid_move(self, tetromino, dx, dy):\\n        for x, y in tetromino.blocks:\\n            nx, ny = x + dx, y + dy\\n            if nx < 0 or nx >= GRID_WIDTH or ny >= GRID_HEIGHT:\\n                return False\\n            if ny < 0:\\n                continue\\n            if self.grid[ny][nx] is not None:\\n                return False\\n        return True\\n\\n    def drop_tetromino(self):\\n        if self.is_valid_move(self.current_tetromino, 0, 1):\\n            self.current_tetromino.move(0, 1)\\n            return True\\n        else:\\n            self.lock_tetromino()\\n            return False\\n\\n    def lock_tetromino(self):\\n        for x, y in self.current_tetromino.blocks:\\n            if y < 0:\\n                self.game_over = True\\n                return\\n            self.grid[y][x] = Gem(self.current_tetromino.color)\\n\\n        # spawn next\\n        self.current_tetromino = self.next_tetromino\\n        self.current_tetromino.position = [GRID_WIDTH // 2 - 2, 0]\\n        self.next_tetromino = self.new_tetromino()\\n\\n        # process clears with full chain reactions\\n        self.process_clears_and_chains()\\n\\n    def process_clears_and_chains(self):\\n        while True:\\n            lines = self.clear_lines()\\n            matches = self.clear_matches()\\n            if lines == 0 and matches == 0:\\n                break\\n            # after any clear, let gems fall\\n            self.apply_gravity()\\n\\n    def clear_lines(self):\\n        lines_to_clear = [\\n            r for r in range(GRID_HEIGHT)\\n            if all(self.grid[r][c] is not None for c in range(GRID_WIDTH))\\n        ]\\n        for row in reversed(lines_to_clear):\\n            del self.grid[row]\\n            self.grid.insert(0, [None] * GRID_WIDTH)\\n            self.score += 100  # points per line\\n        return len(lines_to_clear)\\n\\n    def clear_matches(self):\\n        to_clear = set()\\n        # horizontal runs\\n        for r in range(GRID_HEIGHT):\\n            c = 0\\n            while c < GRID_WIDTH:\\n                if self.grid[r][c] is None:\\n                    c += 1\\n                    continue\\n                color = self.grid[r][c].color\\n                run_len = 1\\n                while c + run_len < GRID_WIDTH and self.grid[r][c + run_len] is not None and self.grid[r][c + run_len].color == color:\\n                    run_len += 1\\n                if run_len >= 3:\\n                    for k in range(run_len):\\n                        to_clear.add((r, c + k))\\n                c += run_len\\n\\n        # vertical runs\\n        for c in range(GRID_WIDTH):\\n            r = 0\\n            while r < GRID_HEIGHT:\\n                if self.grid[r][c] is None:\\n                    r += 1\\n                    continue\\n                color = self.grid[r][c].color\\n                run_len = 1\\n                while r + run_len < GRID_HEIGHT and self.grid[r + run_len][c] is not None and self.grid[r + run_len][c].color == color:\\n                    run_len += 1\\n                if run_len >= 3:\\n                    for k in range(run_len):\\n                        to_clear.add((r + k, c))\\n                r += run_len\\n\\n        # clear and score\\n        for (r, c) in to_clear:\\n            self.grid[r][c] = None\\n        self.score += 50 * len(to_clear)\\n        return len(to_clear)\\n\\n    def apply_gravity(self):\\n        for c in range(GRID_WIDTH):\\n            stack = [self.grid[r][c] for r in range(GRID_HEIGHT) if self.grid[r][c] is not None]\\n            empties = [None] * (GRID_HEIGHT - len(stack))\\n            col_cells = empties + stack\\n            for r in range(GRID_HEIGHT):\\n                self.grid[r][c] = col_cells[r]\\n```\"}"}
