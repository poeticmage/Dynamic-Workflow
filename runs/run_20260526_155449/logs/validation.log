\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                question:\\n                  type: string\\n                  description: The question being answered.\\n                response:\\n                  type: string\\n                  description: The candidate's answer to the question\\n              example:\\n                question: \\\"Explain the difference between '==' and '===' in Javascript.\\\"\\n                response: \\\"'==' compares values, while '===' compares values and types.\\\"\\n      responses:\\n        '200':\\n          description: Response submitted successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  next_question:\\n                    type: string\\n                    nullable: true\\n                    description: The next question to ask, or null if the interview is complete\\n                  evaluation:\\n                    type: object\\n                    description: Evaluation of the response\\n                    properties:\\n                      relevance:\\n                        type: number\\n                        format: float\\n                        description: Relevance score (0-1)\\n                      depth:\\n                        type: number\\n                        format: float\\n                        description: Depth score (0-1)\\n                      confidence:\\n                        type: number\\n                        format: float\\n                        description: Confidence score (0-1)\\n                      technical_accuracy:\\n                        type: number\\n                        format: float\\n                        description: Technical accuracy score (0-1)\\n                    example:\\n                      relevance: 0.9\\n                      depth: 0.8\\n                      confidence: 0.7\\n                      technical_accuracy: 0.95\\n                example:\\n                  next_question: \\\"How would you optimize a slow SQL query?\\\"\\n                  evaluation:\\n                    relevance: 0.9\\n                    depth: 0.8\\n                    confidence: 0.7\\n                    technical_accuracy: 0.95\\n        '400':\\n          description: Invalid request\\n        '404':\\n          description: Interview not found\\n\\n  /interviews/{interview_id}/scores:\\n    get:\\n      summary: Retrieve the candidate's scores for the interview\\n      parameters:\\n        - in: path\\n          name: interview_id\\n          required: true\\n          schema:\\n            type: string\\n          description: Unique identifier for the interview session\\n      responses:\\n        '200':\\n          description: Scores retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  technical_score:\\n                    type: number\\n                    format: float\\n                    description: Overall technical score\\n                  behavioral_score:\\n                    type: number\\n                    format: float\\n                    description: Overall behavioral score\\n                  overall_score:\\n                    type: number\\n                    format: float\\n                    description: Overall score\\n                  category_scores:\\n                    type: object\\n                    description: Scores for individual categories\\n                    properties:\\n                      problem_solving:\\n                        type: number\\n                        format: float\\n                        description: Problem-solving score\\n                      communication:\\n                        type: number\\n                        format: float\\n                        description: Communication score\\n                    example:\\n                      problem_solving: 0.85\\n                      communication: 0.9\\n                example:\\n                  technical_score: 0.8\\n                  behavioral_score: 0.9\\n                  overall_score: 0.85\\n                  category_scores:\\n                    problem_solving: 0.85\\n                    communication: 0.9\\n        '404':\\n          description: Interview not found\\n\\n  /emails/invite:\\n    post:\\n      summary: Generate and send an interview invitation email\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                candidate_email:\\n                  type: string\\n                  format: email\\n                  description: Candidate's email address\\n                job_title:\\n                  type: string\\n                  description: Job title\\n                interview_date:\\n                  type: string\\n                  format: date-time\\n                  description: Date and time of the interview\\n                interviewer_name:\\n                  type: string\\n                  description: Name of the interviewer\\n              example:\\n                candidate_email: john.doe@example.com\\n                job_title: Software Engineer\\n                interview_date: \\\"2024-01-20T10:00:00Z\\\"\\n                interviewer_name: Jane Smith\\n      responses:\\n        '200':\\n          description: Email sent successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  message:\\n                    type: string\\n                    description: Confirmation message\\n                example:\\n                  message: \\\"Interview invitation email sent to john.doe@example.com\\\"\\n        '400':\\n          description: Invalid request\\n        '500':\\n          description: Email sending failed\\n\\n  /emails/followup:\\n    post:\\n      summary: Generate and send a follow-up email to the candidate\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                candidate_email:\\n                  type: string\\n                  format: email\\n                  description: Candidate's email address\\n                interview_id:\\n                  type: string\\n                  description: Interview ID\\n              example:\\n                candidate_email: john.doe@example.com\\n                interview_id: interview789\\n      responses:\\n        '200':\\n          description: Email sent successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  message:\\n                    type: string\\n                    description: Confirmation message\\n                example:\\n                  message: \\\"Follow-up email sent to john.doe@example.com\\\"\\n        '400':\\n          description: Invalid request\\n        '500':\\n          description: Email sending failed\\n\\n  /reports/{interview_id}:\\n    get:\\n      summary: Retrieve the final candidate evaluation report\\n      parameters:\\n        - in: path\\n          name: interview_id\\n          required: true\\n          schema:\\n            type: string\\n          description: Unique identifier for the interview session\\n      responses:\\n        '200':\\n          description: Report retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  resume_job_match_analysis:\\n                    type: string\\n                    description: Analysis of how well the resume matches the job description\\n                  interview_summary:\\n                    type: string\\n                    description: Summary of the interview\\n                  technical_assessment:\\n                    type: string\\n                    description: Assessment of the candidate's technical skills\\n                  behavioral_assessment:\\n                    type: string\\n                    description: Assessment of the candidate's behavioral traits\\n                  strengths:\\n                    type: array\\n                    items:\\n                      type: string\\n                    description: List of the candidate's strengths\\n                  weaknesses:\\n                    type: array\\n                    items:\\n                      type: string\\n                    description: List of the candidate's weaknesses\\n                  final_recommendation:\\n                    type: string\\n                    description: Final recommendation (Hire/No Hire/Maybe)\\n                  scoring_breakdown:\\n                    type: object\\n                    description: Detailed breakdown of the candidate's scores\\n                    properties:\\n                      technical_score:\\n                        type: number\\n                        format: float\\n                        description: Overall technical score\\n                      behavioral_score:\\n                        type: number\\n                        format: float\\n                        description: Overall behavioral score\\n                      overall_score:\\n                        type: number\\n                        format: float\\n                        description: Overall score\\n                    example:\\n                      technical_score: 0.8\\n                      behavioral_score: 0.9\\n                      overall_score: 0.85\\n                example:\\n                  resume_job_match_analysis: \\\"The candidate's resume closely matches the job description, with strong skills in Python and Javascript.\\\"\\n                  interview_summary: \\\"The candidate performed well in the interview, demonstrating strong technical knowledge and communication skills.\\\"\\n                  technical_assessment: \\\"The candidate has a solid understanding of software engineering principles and is proficient in Python and Javascript.\\\"\\n                  behavioral_assessment: \\\"The candidate is a good communicator and works well in a team environment.\\\"\\n                  strengths: [\\\"Technical Skills\\\", \\\"Communication\\\", \\\"Problem Solving\\\"]\\n                  weaknesses: [\\\"Lack of experience with AWS\\\"]\\n                  final_recommendation: \\\"Hire\\\"\\n                  scoring_breakdown:\\n                    technical_score: 0.8\\n                    behavioral_score: 0.9\\n                    overall_score: 0.85\\n        '404':\\n          description: Report not found\\ncomponents:\\n  schemas:\\n    Error:\\n      type: object\\n      properties:\\n        message:\\n          type: string\\n          description: Error message\\n      example:\\n        message: \\\"An error occurred\\\"\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nNo downstream objectives available.\\n\\n---\\n# **Current Task Requirements**\\nCreate the Email Generation Module: define templates and AI prompt flows for automated interview invitations and follow-up communications.\\n\\n---\\n\\n# **Required Output Format**\\nPython code (module)\"\n    }\n  ],\n  \"gpt_response\": \"```python\\n# email_generation_module.py\\n\\nfrom typing import Dict\\nimport datetime\\n\\nclass EmailGenerator:\\n    \\\"\\\"\\\"\\n    Generates email content for interview invitations and follow-ups.\\n    \\\"\\\"\\\"\\n\\n    def __init__(self, llm_client=None):\\n        \\\"\\\"\\\"\\n        Initializes the EmailGenerator with an optional LLM client.\\n\\n        Args:\\n            llm_client: An optional client for interacting with a Language Model.\\n        \\\"\\\"\\\"\\n        self.llm_client = llm_client\\n\\n    def generate_invitation_email(self, candidate_email: str, job_title: str, interview_date: datetime.datetime, interviewer_name: str) -> Dict[str, str]:\\n        \\\"\\\"\\\"\\n        Generates an interview invitation email.\\n\\n        Args:\\n            candidate_email: The candidate's email address.\\n            job_title: The title of the job.\\n            interview_date: The date and time of the interview.\\n            interviewer_name: The name of the interviewer.\\n\\n        Returns:\\n            A dictionary containing the subject and body of the email.\\n        \\\"\\\"\\\"\\n        subject = f\\\"Interview Invitation for {job_title} at [Company Name]\\\"\\n        body = f\\\"\\\"\\\"\\n        Dear {candidate_email.split('@')[0]},\\n\\n        We are pleased to invite you to an interview for the {job_title} position at [Company Name].\\n\\n        The interview is scheduled for {interview_date.strftime(\\\"%Y-%m-%d at %H:%M\\\")}.\\n        The interviewer will be {interviewer_name}.\\n\\n        Please confirm your availability by replying to this email.\\n\\n        We look forward to meeting you!\\n\\n        Best regards,\\n        [Your Name/Company Name]\\n        \\\"\\\"\\\"\\n        return {\\\"subject\\\": subject, \\\"body\\\": body}\\n\\n    def generate_followup_email(self, candidate_email: str) -> Dict[str, str]:\\n        \\\"\\\"\\\"\\n        Generates a follow-up email after the interview.  Optionally uses an LLM\\n        to personalize the message.\\n\\n        Args:\\n            candidate_email: The candidate's email address.\\n\\n        Returns:\\n            A dictionary containing the subject and body of the email.\\n        \\\"\\\"\\\"\\n        subject = \\\"Following Up on Your Interview\\\"\\n\\n        if self.llm_client:\\n            # Example of using an LLM to generate a personalized follow-up\\n            prompt = f\\\"\\\"\\\"\\n            Write a short, professional follow-up email to a candidate with email {candidate_email} after an interview.  Express gratitude for their time and mention that the team is reviewing candidates. Keep it concise (under 100 words).\\n            \\\"\\\"\\\"\\n            try:\\n                body = self.llm_client.generate_text(prompt) # Assuming llm_client has a generate_text method\\n            except Exception as e:\\n                print(f\\\"Error generating follow-up with LLM: {e}\\\")\\n                body = f\\\"\\\"\\\"\\n                Dear {candidate_email.split('@')[0]},\\n\\n                Thank you for taking the time to interview with us.  We are currently reviewing all candidates and will be in touch soon.\\n\\n                Sincerely,\\n                [Your Name/Company Name]\\n                \\\"\\\"\\\"\\n        else:\\n            body = f\\\"\\\"\\\"\\n            Dear {candidate_email.split('@')[0]},\\n\\n            Thank you for taking the time to interview with us. We appreciate you learning more about the {candidate_email} role with out team. We are currently reviewing all candidates and will be in touch soon.\\n\\n            Sincerely,\\n            [Your Name/Company Name]\\n            \\\"\\\"\\\"\\n        return {\\\"subject\\\": subject, \\\"body\\\": body}\\n\\n\\nclass AIPoweredEmailGenerator:\\n    \\\"\\\"\\\"\\n    Generates email content with more sophisticated AI prompts.\\n    Leverages LLMs for dynamic content creation.\\n    \\\"\\\"\\\"\\n\\n    def __init__(self, llm_client):\\n        \\\"\\\"\\\"\\n        Initializes the AIPoweredEmailGenerator with an LLM client.\\n\\n        Args:\\n            llm_client: A client for interacting with a Language Model (required).\\n        \\\"\\\"\\\"\\n        self.llm_client = llm_client\\n        if not self.llm_client:\\n            raise ValueError(\\\"LLM client is required for AIPoweredEmailGenerator\\\")\\n\\n\\n    def generate_personalized_invitation(self, candidate_name: str, job_title: str, interview_date: str, job_description: str, company_culture: str) -> Dict[str, str]:\\n        \\\"\\\"\\\"\\n        Generates highly personalized invitation emails, referencing job details\\n        and company culture to engage candidates.\\n\\n        Args:\\n            candidate_name (str): Name of candidate.\\n            job_title (str): Job title.\\n            interview_date (str): Interview date and time.\\n            job_description (str): Description of the job.\\n            company_culture (str): Brief description of the company culture.\\n\\n        Returns:\\n            Dict[str, str]: Subject and body of the email.\\n        \\\"\\\"\\\"\\n        prompt = f\\\"\\\"\\\"\\n        Compose a personalized interview invitation email to {candidate_name} for the {job_title} position.\\n        Mention the interview is scheduled for {interview_date}.\\n        Briefly highlight key aspects of the job from this description: {job_description}.\\n        Incorporate a sentence about our company culture: {company_culture}.\\n        The email should be professional, enthusiastic, and encourage the candidate to confirm their attendance.\\n        Keep it concise (around 150 words).\\n        \\\"\\\"\\\"\\n        email_content = self.llm_client.generate_text(prompt)\\n        subject_prompt = f\\\"Write subject line for the following email content: {email_content}\\\"\\n        subject = self.llm_client.generate_text(subject_prompt)\\n\\n\\n        return {\\\"subject\\\": subject, \\\"body\\\": email_content}\\n\\n\\n    def generate_interview_feedback_request(self, interviewer_name: str, candidate_name: str, job_title: str) -> Dict[str, str]:\\n        \\\"\\\"\\\"\\n        Generates an email requesting feedback from the interviewer after\\n        the interview.\\n\\n        Args:\\n            interviewer_name (str): Name of the interviewer.\\n            candidate_name (str): Name of the candidate.\\n            job_title (str): Job title.\\n\\n        Returns:\\n            Dict[str, str]: Subject and body of the feedback request email.\\n        \\\"\\\"\\\"\\n        prompt = f\\\"\\\"\\\"\\n        Compose an email to {interviewer_name} requesting feedback on the interview with {candidate_name} for the {job_title} position.\\n        Ask for specific feedback on the candidate's technical skills, communication abilities, and overall fit for the role.\\n        Mention the importance of their feedback in the decision-making process.\\n        Set a deadline for providing feedback (e.g., within 2 days).\\n        Keep the email concise and professional.\\n        \\\"\\\"\\\"\\n        email_content = self.llm_client.generate_text(prompt)\\n        subject_prompt = f\\\"Write subject line for the following email content: {email_content}\\\"\\n        subject = self.llm_client.generate_text(subject_prompt)\\n\\n        return {\\\"subject\\\": subject, \\\"body\\\": email_content}\\n\\n\\nclass ExampleLLMClient:  # Dummy LLM client for testing purposes\\n    def generate_text(self, prompt: str) -> str:\\n        \\\"\\\"\\\"\\n        A mock LLM client that returns a canned response.\\n\\n        Args:\\n            prompt: The prompt provided\\n\\n        Returns:\\n            A string containing the generated text.\\n        \\\"\\\"\\\"\\n        if \\\"follow-up email\\\" in prompt:\\n            return \\\"Dear [Candidate Name], Thank you for your time. We are reviewing applications.\\\"\\n        elif \\\"invitation email\\\" in prompt:\\n            return \\\"Dear [Candidate Name], We invite you to interview on [Date].\\\"\\n        elif \\\"Write subject line\\\" in prompt:\\n            return \\\"Generated Subject Line\\\"\\n        elif \\\"interview feedback\\\" in prompt:\\n             return \\\"Dear [Interviewer Name], Please provide feedback on [Candidate Name].\\\"\\n        else:\\n            return f\\\"LLM Response to: {prompt}\\\"\\n\\n\\n\\nif __name__ == '__main__':\\n    # Example Usage\\n    generator = EmailGenerator()\\n    invitation = generator.generate_invitation_email(\\n        \\\"test@example.com\\\", \\\"Software Engineer\\\", datetime.datetime(2024, 1, 20, 10, 0, 0), \\\"Jane Smith\\\"\\n    )\\n    print(\\\"Invitation Email:\\\")\\n    print(f\\\"Subject: {invitation['subject']}\\\")\\n    print(f\\\"Body: {invitation['body']}\\\")\\n\\n    followup = generator.generate_followup_email(\\\"test@example.com\\\")\\n    print(\\\"\\\\nFollow-up Email:\\\")\\n    print(f\\\"Subject: {followup['subject']}\\\")\\n    print(f\\\"Body: {followup['body']}\\\")\\n\\n    # Example Usage with LLM\\n    llm_client = ExampleLLMClient()\\n    ai_generator = EmailGenerator(llm_client=llm_client)\\n    followup_llm = ai_generator.generate_followup_email(\\\"test@example.com\\\")\\n    print(\\\"\\\\nFollow-up Email (with LLM):\\\")\\n    print(f\\\"Subject: {followup_llm['subject']}\\\")\\n    print(f\\\"Body: {followup_llm['body']}\\\")\\n\\n    # Example Usage of AIPoweredEmailGenerator\\n    advanced_generator = AIPoweredEmailGenerator(llm_client=llm_client)\\n    personalized_invitation = advanced_generator.generate_personalized_invitation(\\n        candidate_name=\\\"Alice Johnson\\\",\\n        job_title=\\\"Data Scientist\\\",\\n        interview_date=\\\"January 25, 2024\\\",\\n        job_description=\\\"Analyze large datasets and build machine learning models.\\\",\\n        company_culture=\\\"Innovative, collaborative, and data-driven.\\\"\\n    )\\n\\n    print(\\\"\\\\nPersonalized Invitation (AIPoweredEmailGenerator):\\\")\\n    print(f\\\"Subject: {personalized_invitation['subject']}\\\")\\n    print(f\\\"Body: {personalized_invitation['body']}\\\")\\n\\n    feedback_request = advanced_generator.generate_interview_feedback_request(\\n        interviewer_name=\\\"Bob Williams\\\",\\n        candidate_name=\\\"Alice Johnson\\\",\\n        job_title=\\\"Data Scientist\\\"\\n    )\\n\\n    print(\\\"\\\\nInterview Feedback Request (AIPoweredEmailGenerator):\\\")\\n    print(f\\\"Subject: {feedback_request['subject']}\\\")\\n    print(f\\\"Body: {feedback_request['body']}\\\")\\n```\\n\",\n  \"timestamp\": \"2026-05-26T15:55:45.651218\"\n}"}
