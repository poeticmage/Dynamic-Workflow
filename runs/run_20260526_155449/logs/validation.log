rt containing:\\n    - Resume-job match analysis\\n    - Interview summary\\n    - Technical assessment\\n    - Behavioral assessment\\n    - Strengths and weaknesses\\n    - Final recommendation and scoring breakdown\\n\\nThe workflow should support modular AI task execution and dynamic task delegation without hardcoded routing.\\n\\nProvide:\\n- Backend workflow architecture\\n- AI orchestration logic\\n- API structure examples\\n- Database schema suggestions\\n- Candidate scoring logic\\n- Example interview flows\\n- Example final evaluation reports\\n\\nThe output should be production-oriented and implementation-focused.\\n\\n---\\n# **Context from Upstream Tasks**\\nTask task0:\\n  Objective: Define the database schema for job descriptions, candidate resumes, interview sessions, AI-generated questions, candidate responses, evaluation scores, email logs, and final reports.\\n  Result: ```json\\n{\\n  \\\"schemas\\\": {\\n    \\\"job_descriptions\\\": {\\n      \\\"type\\\": \\\"object\\\",\\n      \\\"properties\\\": {\\n        \\\"job_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Unique identifier for the job description\\\",\\n          \\\"primaryKey\\\": true\\n        },\\n        \\\"title\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Job title\\\"\\n        },\\n        \\\"description\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Full job description text\\\"\\n        },\\n        \\\"requirements\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Job requirements\\\"\\n        },\\n        \\\"responsibilities\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Job responsibilities\\\"\\n        },\\n        \\\"department\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Department the job belongs to\\\"\\n        },\\n        \\\"location\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Job location\\\"\\n        },\\n        \\\"date_posted\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"format\\\": \\\"date\\\",\\n          \\\"description\\\": \\\"Date the job was posted\\\"\\n        },\\n        \\\"embedding\\\": {\\n          \\\"type\\\": \\\"array\\\",\\n          \\\"items\\\": {\\n            \\\"type\\\": \\\"number\\\"\\n          },\\n          \\\"description\\\": \\\"Vector embedding of the job description\\\"\\n        }\\n      },\\n      \\\"required\\\": [\\n        \\\"job_id\\\",\\n        \\\"title\\\",\\n        \\\"description\\\"\\n      ]\\n    },\\n    \\\"candidate_resumes\\\": {\\n      \\\"type\\\": \\\"object\\\",\\n      \\\"properties\\\": {\\n        \\\"candidate_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Unique identifier for the candidate\\\",\\n          \\\"primaryKey\\\": true\\n        },\\n        \\\"name\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Candidate's full name\\\"\\n        },\\n        \\\"email\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Candidate's email address\\\"\\n        },\\n        \\\"phone\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Candidate's phone number\\\"\\n        },\\n        \\\"resume_text\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Full text of the candidate's resume\\\"\\n        },\\n        \\\"skills\\\": {\\n          \\\"type\\\": \\\"array\\\",\\n          \\\"items\\\": {\\n            \\\"type\\\": \\\"string\\\"\\n          },\\n          \\\"description\\\": \\\"List of skills extracted from the resume\\\"\\n        },\\n        \\\"experience\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Candidate's work experience\\\"\\n        },\\n        \\\"education\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Candidate's education details\\\"\\n        },\\n        \\\"embedding\\\": {\\n          \\\"type\\\": \\\"array\\\",\\n          \\\"items\\\": {\\n            \\\"type\\\": \\\"number\\\"\\n          },\\n          \\\"description\\\": \\\"Vector embedding of the resume\\\"\\n        }\\n      },\\n      \\\"required\\\": [\\n        \\\"candidate_id\\\",\\n        \\\"name\\\",\\n        \\\"email\\\",\\n        \\\"resume_text\\\"\\n      ]\\n    },\\n    \\\"interview_sessions\\\": {\\n      \\\"type\\\": \\\"object\\\",\\n      \\\"properties\\\": {\\n        \\\"session_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Unique identifier for the interview session\\\",\\n          \\\"primaryKey\\\": true\\n        },\\n        \\\"candidate_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing candidate_resumes\\\"\\n        },\\n        \\\"job_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing job_descriptions\\\"\\n        },\\n        \\\"start_time\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"format\\\": \\\"date-time\\\",\\n          \\\"description\\\": \\\"Timestamp of when the interview started\\\"\\n        },\\n        \\\"end_time\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"format\\\": \\\"date-time\\\",\\n          \\\"description\\\": \\\"Timestamp of when the interview ended\\\"\\n        },\\n        \\\"status\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"enum\\\": [\\n            \\\"scheduled\\\",\\n            \\\"in_progress\\\",\\n            \\\"completed\\\",\\n            \\\"cancelled\\\"\\n          ],\\n          \\\"description\\\": \\\"Status of the interview session\\\"\\n        }\\n      },\\n      \\\"required\\\": [\\n        \\\"session_id\\\",\\n        \\\"candidate_id\\\",\\n        \\\"job_id\\\",\\n        \\\"start_time\\\"\\n      ]\\n    },\\n    \\\"ai_generated_questions\\\": {\\n      \\\"type\\\": \\\"object\\\",\\n      \\\"properties\\\": {\\n        \\\"question_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Unique identifier for the question\\\",\\n          \\\"primaryKey\\\": true\\n        },\\n        \\\"session_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing interview_sessions\\\"\\n        },\\n        \\\"question_text\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"The text of the question generated by AI\\\"\\n        },\\n        \\\"question_type\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"enum\\\": [\\n            \\\"technical\\\",\\n            \\\"behavioral\\\",\\n            \\\"follow_up\\\"\\n          ],\\n          \\\"description\\\": \\\"Type of question\\\"\\n        },\\n        \\\"expected_answer\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"The expected answer or keywords for the question\\\"\\n        },\\n         \\\"topic\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Topic of the question\\\"\\n        },\\n        \\\"difficulty\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"enum\\\": [\\\"easy\\\", \\\"medium\\\", \\\"hard\\\"],\\n          \\\"description\\\": \\\"Difficulty level of the question\\\"\\n         }\\n      },\\n      \\\"required\\\": [\\n        \\\"question_id\\\",\\n        \\\"session_id\\\",\\n        \\\"question_text\\\",\\n        \\\"question_type\\\"\\n      ]\\n    },\\n    \\\"candidate_responses\\\": {\\n      \\\"type\\\": \\\"object\\\",\\n      \\\"properties\\\": {\\n        \\\"response_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Unique identifier for the response\\\",\\n          \\\"primaryKey\\\": true\\n        },\\n        \\\"session_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing interview_sessions\\\"\\n        },\\n        \\\"question_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing ai_generated_questions\\\"\\n        },\\n        \\\"response_text\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"The candidate's answer to the question\\\"\\n        },\\n        \\\"timestamp\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"format\\\": \\\"date-time\\\",\\n          \\\"description\\\": \\\"Timestamp of when the response was recorded\\\"\\n        }\\n      },\\n      \\\"required\\\": [\\n        \\\"response_id\\\",\\n        \\\"session_id\\\",\\n        \\\"question_id\\\",\\n        \\\"response_text\\\"\\n      ]\\n    },\\n    \\\"evaluation_scores\\\": {\\n      \\\"type\\\": \\\"object\\\",\\n      \\\"properties\\\": {\\n        \\\"score_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Unique identifier for the score\\\",\\n          \\\"primaryKey\\\": true\\n        },\\n        \\\"session_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing interview_sessions\\\"\\n        },\\n         \\\"question_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing ai_generated_questions\\\"\\n        },\\n        \\\"category\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"enum\\\": [\\n            \\\"relevance\\\",\\n            \\\"depth\\\",\\n            \\\"confidence\\\",\\n            \\\"technical_accuracy\\\",\\n            \\\"communication_skills\\\",\\n            \\\"problem_solving\\\"\\n          ],\\n          \\\"description\\\": \\\"Category being evaluated\\\"\\n        },\\n        \\\"score\\\": {\\n          \\\"type\\\": \\\"number\\\",\\n          \\\"description\\\": \\\"Score for the category (e.g., 1-5 scale)\\\"\\n        },\\n        \\\"justification\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Explanation or justification for the score\\\"\\n        }\\n      },\\n      \\\"required\\\": [\\n        \\\"score_id\\\",\\n        \\\"session_id\\\",\\n        \\\"category\\\",\\n        \\\"score\\\"\\n      ]\\n    },\\n    \\\"email_logs\\\": {\\n      \\\"type\\\": \\\"object\\\",\\n      \\\"properties\\\": {\\n        \\\"email_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Unique identifier for the email\\\",\\n          \\\"primaryKey\\\": true\\n        },\\n        \\\"candidate_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing candidate_resumes\\\"\\n        },\\n        \\\"email_type\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"enum\\\": [\\n            \\\"invitation\\\",\\n            \\\"follow_up\\\",\\n            \\\"rejection\\\",\\n            \\\"offer\\\"\\n          ],\\n          \\\"description\\\": \\\"Type of email\\\"\\n        },\\n        \\\"subject\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Email subject\\\"\\n        },\\n        \\\"body\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Email body text\\\"\\n        },\\n        \\\"timestamp\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"format\\\": \\\"date-time\\\",\\n          \\\"description\\\": \\\"Timestamp of when the email was sent\\\"\\n        }\\n      },\\n      \\\"required\\\": [\\n        \\\"email_id\\\",\\n        \\\"candidate_id\\\",\\n        \\\"email_type\\\",\\n        \\\"subject\\\",\\n        \\\"body\\\",\\n        \\\"timestamp\\\"\\n      ]\\n    },\\n    \\\"final_reports\\\": {\\n      \\\"type\\\": \\\"object\\\",\\n      \\\"properties\\\": {\\n        \\\"report_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Unique identifier for the final report\\\",\\n          \\\"primaryKey\\\": true\\n        },\\n        \\\"candidate_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing candidate_resumes\\\"\\n        },\\n        \\\"job_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing job_descriptions\\\"\\n        },\\n        \\\"session_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing interview_sessions\\\"\\n        },\\n        \\\"resume_job_match_analysis\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Analysis of how well the resume matches the job description\\\"\\n        },\\n        \\\"interview_summary\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Summary of the interview session\\\"\\n        },\\n        \\\"technical_assessment\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Assessment of the candidate's technical skills\\\"\\n        },\\n        \\\"behavioral_assessment\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Assessment of the candidate's behavioral traits\\\"\\n        },\\n        \\\"strengths\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"List of the candidate's strengths\\\"\\n        },\\n        \\\"weaknesses\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"List of the candidate's weaknesses\\\"\\n        },\\n        \\\"final_recommendation\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Final recommendation (e.g., hire, no hire, further review)\\\"\\n        },\\n        \\\"overall_score\\\": {\\n          \\\"type\\\": \\\"number\\\",\\n          \\\"description\\\": \\\"Overall score for the candidate\\\"\\n        },\\n        \\\"scoring_breakdown\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Detailed breakdown of the scoring across different categories (JSON format)\\\"\\n        },\\n         \\\"report_generation_date\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"format\\\": \\\"date-time\\\",\\n          \\\"description\\\": \\\"Timestamp of when the report was generated\\\"\\n        }\\n      },\\n      \\\"required\\\": [\\n        \\\"report_id\\\",\\n        \\\"candidate_id\\\",\\n        \\\"job_id\\\",\\n        \\\"session_id\\\"\\n      ]\\n    }\\n  }\\n}\\n```\\nTask task1:\\n  Objective: Design the RESTful API specification (endpoints, request/response models) for core operations: ingesting jobs/resumes, orchestrating interviews, submitting responses, scoring, emailing, and retrieving reports.\\n  Result: ```yaml\\nopenapi: 3.0.0\\ninfo:\\n  title: AI-Driven Interview and Candidate Evaluation System API\\n  version: 1.0.0\\n  description: RESTful API for managing jobs, resumes, interviews, evaluations, and reports.\\n\\npaths:\\n  /jobs:\\n    post:\\n      summary: Ingest a new job description\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                job_title:\\n                  type: string\\n                  description: Title of the job\\n                job_description:\\n                  type: string\\n                  description: Detailed description of the job\\n                department:\\n                  type: string\\n                  description: Department for the job\\n                location:\\n                  type: string\\n                  description: Job location\\n                skills:\\n                  type: array\\n                  items:\\n                    type: string\\n                  description: List of required skills\\n              example:\\n                job_title: Software Engineer\\n                job_description: Develop and maintain software applications.  Experience with Python and Javascript required.\\n                department: Engineering\\n                location: New York, NY\\n                skills: [Python, Javascript, React, AWS]\\n      responses:\\n        '201':\\n          description: Job created successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  job_id:\\n                    type: string\\n                    description: Unique identifier for the job\\n                example:\\n                  job_id: job123\\n        '400':\\n          description: Invalid request\\n\\n    get:\\n      summary: Retrieve a list of all jobs\\n      responses:\\n        '200':\\n          description: List of jobs retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: array\\n                items:\\n                  type: object\\n                  properties:\\n                    job_id:\\n                      type: string\\n                      description: Unique identifier for the job\\n                    job_title:\\n                      type: string\\n                      description: Title of the job\\n                    job_description:\\n                      type: string\\n                      description: Detailed description of the job\\n                    department:\\n                      type: string\\n                      description: Department for the job\\n                    location:\\n                      type: string\\n                      description: Job location\\n                    skills:\\n                      type: array\\n                      items:\\n                        type: string\\n                      description: List of required skills\\n                  example:\\n                    job_id: job123\\n                    job_title: Software Engineer\\n                    job_description: Develop and maintain software applications.  Experience with Python and Javascript required.\\n                    department: Engineering\\n                    location: New York, NY\\n                    skills: [Python, Javascript, React, AWS]\\n\\n  /jobs/{job_id}:\\n    get:\\n      summary: Retrieve a specific job by ID\\n      parameters:\\n        - in: path\\n          name: job_id\\n          required: true\\n          schema:\\n            type: string\\n          description: Unique identifier for the job\\n      responses:\\n        '200':\\n          description: Job retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  job_id:\\n                    type: string\\n                    description: Unique identifier for the job\\n                  job_title:\\n                    type: string\\n                    description: Title of the job\\n                  job_description:\\n                    type: string\\n                    description: Detailed description of the job\\n                  department:\\n                    type: string\\n                    description: Department for the job\\n                  location:\\n                    type: string\\n                    description: Job location\\n                  skills:\\n                    type: array\\n                    items:\\n                      type: string\\n                    description: List of required skills\\n                example:\\n                  job_id: job123\\n                  job_title: Software Engineer\\n                  job_description: Develop and maintain software applications.  Experience with Python and Javascript required.\\n                  department: Engineering\\n                  location: New York, NY\\n                  skills: [Python, Javascript, React, AWS]\\n        '404':\\n          description: Job not found\\n\\n  /resumes:\\n    post:\\n      summary: Ingest a new candidate resume\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                candidate_name:\\n                  type: string\\n                  description: Name of the candidate\\n                resume_text:\\n                  type: string\\n                  description: Text content of the resume\\n                email:\\n                  type: string\\n                  format: email\\n                  description: Candidate's email address\\n                skills:\\n                  type: array\\n                  items:\\n                    type: string\\n                  description: List of skills extracted from the resume\\n              example:\\n                candidate_name: John Doe\\n                resume_text: Experienced software engineer with Python and Javascript skills.\\n                email: john.doe@example.com\\n                skills: [Python, Javascript, SQL]\\n      responses:\\n        '201':\\n          description: Resume created successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  resume_id:\\n                    type: string\\n                    description: Unique identifier for the resume\\n                example:\\n                  resume_id: resume456\\n        '400':\\n          description: Invalid request\\n    get:\\n      summary: Retrieve a list of all resumes\\n      responses:\\n        '200':\\n          description: List of resumes retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: array\\n                items:\\n                  type: object\\n                  properties:\\n                    resume_id:\\n                      type: string\\n                      description: Unique identifier for the resume\\n                    candidate_name:\\n                      type: string\\n                      description: Name of the candidate\\n                    resume_text:\\n                      type: string\\n                      description: Text content of the resume\\n                    email:\\n                      type: string\\n                      format: email\\n                      description: Candidate's email address\\n                    skills:\\n                      type: array\\n                      items:\\n                        type: string\\n                      description: List of skills extracted from the resume\\n                  example:\\n                    resume_id: resume456\\n                    candidate_name: John Doe\\n                    resume_text: Experienced software engineer with Python and Javascript skills.\\n                    email: john.doe@example.com\\n                    skills: [Python, Javascript, SQL]\\n\\n  /resumes/{resume_id}:\\n    get:\\n      summary: Retrieve a specific resume by ID\\n      parameters:\\n        - in: path\\n          name: resume_id\\n          required: true\\n          schema:\\n            type: string\\n          description: Unique identifier for the resume\\n      responses:\\n        '200':\\n          description: Resume retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  resume_id:\\n                    type: string\\n                    description: Unique identifier for the resume\\n                  candidate_name:\\n                    type: string\\n                    description: Name of the candidate\\n                  resume_text:\\n                    type: string\\n                    description: Text content of the resume\\n                  email:\\n                    type: string\\n                    format: email\\n                    description: Candidate's email address\\n                  skills:\\n                    type: array\\n                    items:\\n                      type: string\\n                    description: List of skills extracted from the resume\\n                example:\\n                  resume_id: resume456\\n                  candidate_name: John Doe\\n                  resume_text: Experienced software engineer with Python and Javascript skills.\\n                  email: john.doe@example.com\\n                  skills: [Python, Javascript, SQL]\\n        '404':\\n          description: Resume not found\\n\\n  /interviews:\\n    post:\\n      summary: Start a new interview session\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                job_id:\\n                  type: string\\n                  description: ID of the job for the interview\\n                resume_id:\\n                  type: string\\n                  description: ID of the candidate's resume\\n              example:\\n                job_id: job123\\n                resume_id: resume456\\n      responses:\\n        '201':\\n          description: Interview session started successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  interview_id:\\n                    type: string\\n                    description: Unique identifier for the interview session\\n                  first_question:\\n                    type: string\\n                    description: The first question to ask the candidate\\n                example:\\n                  interview_id: interview789\\n                  first_question: \\\"Tell me about your experience with Python.\\\"\\n        '400':\\n          description: Invalid request\\n        '404':\\n          description: Job or Resume not found\\n\\n  /interviews/{interview_id}/questions:\\n    get:\\n      summary: Get the current or next question in the interview\\n      parameters:\\n        - in: path\\n          name: interview_id\\n          required: true\\n          schema:\\n            type: string\\n          description: Unique identifier for the interview session\\n      responses:\\n        '200':\\n          description: Question retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  question:\\n                    type: string\\n                    description: The question to ask the candidate\\n                example:\\n                  question: \\\"Explain the difference between '==' and '===' in Javascript.\\\"\\n        '404':\\n          description: Interview not found\\n\\n  /interviews/{interview_id}/responses:\\n    post:\\n      summary: Submit a candidate's response to a question\\n      parameters:\\n        - in: path\\n          name: interview_id\\n          required: true\\n          schema:\\n            type: string\\n          description: Unique identifier for the interview session\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                question:\\n                  type: string\\n                  description: The question being answered.\\n                response:\\n                  type: string\\n                  description: The candidate's answer to the question\\n              example:\\n                question: \\\"Explain the difference between '==' and '===' in Javascript.\\\"\\n                response: \\\"'==' compares values, while '===' compares values and types.\\\"\\n      responses:\\n        '200':\\n          description: Response submitted successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  next_question:\\n                    type: string\\n                    nullable: true\\n                    description: The next question to ask, or null if the interview is complete\\n                  evaluation:\\n                    type: object\\n                    description: Evaluation of the response\\n                    properties:\\n                      relevance:\\n                        type: number\\n                        format: float\\n                        description: Relevance score (0-1)\\n                      depth:\\n                        type: number\\n                        format: float\\n                        description: Depth score (0-1)\\n                      confidence:\\n                        type: number\\n                        format: float\\n                        description: Confidence score (0-1)\\n                      technical_accuracy:\\n                        type: number\\n                        format: float\\n                        description: Technical accuracy score (0-1)\\n                    example:\\n                      relevance: 0.9\\n                      depth: 0.8\\n                      confidence: 0.7\\n                      technical_accuracy: 0.95\\n                example:\\n                  next_question: \\\"How would you optimize a slow SQL query?\\\"\\n                  evaluation:\\n                    relevance: 0.9\\n                    depth: 0.8\\n                    confidence: 0.7\\n                    technical_accuracy: 0.95\\n        '400':\\n          description: Invalid request\\n        '404':\\n          description: Interview not found\\n\\n  /interviews/{interview_id}/scores:\\n    get:\\n      summary: Retrieve the candidate's scores for the interview\\n      parameters:\\n        - in: path\\n          name: interview_id\\n          required: true\\n          schema:\\n            type: string\\n          description: Unique identifier for the interview session\\n      responses:\\n        '200':\\n          description: Scores retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  technical_score:\\n                    type: number\\n                    format: float\\n                    description: Overall technical score\\n                  behavioral_score:\\n                    type: number\\n                    format: float\\n                    description: Overall behavioral score\\n                  overall_score:\\n                    type: number\\n                    format: float\\n                    description: Overall score\\n                  category_scores:\\n                    type: object\\n                    description: Scores for individual categories\\n                    properties:\\n                      problem_solving:\\n                        type: number\\n                        format: float\\n                        description: Problem-solving score\\n                      communication:\\n                        type: number\\n                        format: float\\n                        description: Communication score\\n                    example:\\n                      problem_solving: 0.85\\n                      communication: 0.9\\n                example:\\n                  technical_score: 0.8\\n                  behavioral_score: 0.9\\n                  overall_score: 0.85\\n                  category_scores:\\n                    problem_solving: 0.85\\n                    communication: 0.9\\n        '404':\\n          description: Interview not found\\n\\n  /emails/invite:\\n    post:\\n      summary: Generate and send an interview invitation email\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                candidate_email:\\n                  type: string\\n                  format: email\\n                  description: Candidate's email address\\n                job_title:\\n                  type: string\\n                  description: Job title\\n                interview_date:\\n                  type: string\\n                  format: date-time\\n                  description: Date and time of the interview\\n                interviewer_name:\\n                  type: string\\n                  description: Name of the interviewer\\n              example:\\n                candidate_email: john.doe@example.com\\n                job_title: Software Engineer\\n                interview_date: \\\"2024-01-20T10:00:00Z\\\"\\n                interviewer_name: Jane Smith\\n      responses:\\n        '200':\\n          description: Email sent successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  message:\\n                    type: string\\n                    description: Confirmation message\\n                example:\\n                  message: \\\"Interview invitation email sent to john.doe@example.com\\\"\\n        '400':\\n          description: Invalid request\\n        '500':\\n          description: Email sending failed\\n\\n  /emails/followup:\\n    post:\\n      summary: Generate and send a follow-up email to the candidate\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                candidate_email:\\n                  type: string\\n                  format: email\\n                  description: Candidate's email address\\n                interview_id:\\n                  type: string\\n                  description: Interview ID\\n              example:\\n                candidate_email: john.doe@example.com\\n                interview_id: interview789\\n      responses:\\n        '200':\\n          description: Email sent successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  message:\\n                    type: string\\n                    description: Confirmation message\\n                example:\\n                  message: \\\"Follow-up email sent to john.doe@example.com\\\"\\n        '400':\\n          description: Invalid request\\n        '500':\\n          description: Email sending failed\\n\\n  /reports/{interview_id}:\\n    get:\\n      summary: Retrieve the final candidate evaluation report\\n      parameters:\\n        - in: path\\n          name: interview_id\\n          required: true\\n          schema:\\n            type: string\\n          description: Unique identifier for the interview session\\n      responses:\\n        '200':\\n          description: Report retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  resume_job_match_analysis:\\n                    type: string\\n                    description: Analysis of how well the resume matches the job description\\n                  interview_summary:\\n                    type: string\\n                    description: Summary of the interview\\n                  technical_assessment:\\n                    type: string\\n                    description: Assessment of the candidate's technical skills\\n                  behavioral_assessment:\\n                    type: string\\n                    description: Assessment of the candidate's behavioral traits\\n                  strengths:\\n                    type: array\\n                    items:\\n                      type: string\\n                    description: List of the candidate's strengths\\n                  weaknesses:\\n                    type: array\\n                    items:\\n                      type: string\\n                    description: List of the candidate's weaknesses\\n                  final_recommendation:\\n                    type: string\\n                    description: Final recommendation (Hire/No Hire/Maybe)\\n                  scoring_breakdown:\\n                    type: object\\n                    description: Detailed breakdown of the candidate's scores\\n                    properties:\\n                      technical_score:\\n                        type: number\\n                        format: float\\n                        description: Overall technical score\\n                      behavioral_score:\\n                        type: number\\n                        format: float\\n                        description: Overall behavioral score\\n                      overall_score:\\n                        type: number\\n                        format: float\\n                        description: Overall score\\n                    example:\\n                      technical_score: 0.8\\n                      behavioral_score: 0.9\\n                      overall_score: 0.85\\n                example:\\n                  resume_job_match_analysis: \\\"The candidate's resume closely matches the job description, with strong skills in Python and Javascript.\\\"\\n                  interview_summary: \\\"The candidate performed well in the interview, demonstrating strong technical knowledge and communication skills.\\\"\\n                  technical_assessment: \\\"The candidate has a solid understanding of software engineering principles and is proficient in Python and Javascript.\\\"\\n                  behavioral_assessment: \\\"The candidate is a good communicator and works well in a team environment.\\\"\\n                  strengths: [\\\"Technical Skills\\\", \\\"Communication\\\", \\\"Problem Solving\\\"]\\n                  weaknesses: [\\\"Lack of experience with AWS\\\"]\\n                  final_recommendation: \\\"Hire\\\"\\n                  scoring_breakdown:\\n                    technical_score: 0.8\\n                    behavioral_score: 0.9\\n                    overall_score: 0.85\\n        '404':\\n          description: Report not found\\ncomponents:\\n  schemas:\\n    Error:\\n      type: object\\n      properties:\\n        message:\\n          type: string\\n          description: Error message\\n      example:\\n        message: \\\"An error occurred\\\"\\n```\\nTask task2:\\n  Objective: Implement the Resume–Job Matching Module: parse and embed job descriptions and resumes, compute semantic similarity scores, and expose matching interface.\\n  Result: ```python\\nimport nltk\\nimport numpy as np\\nfrom sklearn.metrics.pairwise import cosine_similarity\\nfrom nltk.corpus import stopwords\\nfrom nltk.tokenize import word_tokenize\\nimport re\\nfrom typing import List, Tuple\\n\\n# Download required NLTK data (if not already downloaded)\\ntry:\\n    nltk.data.find('corpora/stopwords')\\nexcept LookupError:\\n    nltk.download('stopwords')\\n\\ntry:\\n    nltk.data.find('tokenizers/punkt')\\nexcept LookupError:\\n    nltk.download('punkt')\\n\\n\\nclass ResumeJobMatcher:\\n    \\\"\\\"\\\"\\n    A class for matching resumes to job descriptions based on semantic similarity.\\n    \\\"\\\"\\\"\\n\\n    def __init__(self, embedding_model=None):\\n        \\\"\\\"\\\"\\n        Initializes the ResumeJobMatcher with an optional embedding model.\\n\\n        Args:\\n            embedding_model:  A pre-trained word embedding model (e.g., Word2Vec, GloVe).\\n                              If None, a simple TF-IDF based approach is used.  Must have a 'encode' method.\\n        \\\"\\\"\\\"\\n        self.embedding_model = embedding_model\\n        self.stop_words = set(stopwords.words('english'))\\n\\n    def preprocess_text(self, text: str) -> str:\\n        \\\"\\\"\\\"\\n        Preprocesses the input text by removing special characters,\\n        converting to lowercase, and removing stop words.\\n\\n        Args:\\n            text (str): The input text to preprocess.\\n\\n        Returns:\\n            str: The preprocessed text.\\n        \\\"\\\"\\\"\\n        text = re.sub(r'[^\\\\w\\\\s]', '', text)\\n        text = text.lower()\\n        tokens = word_tokenize(text)\\n        tokens = [w for w in tokens if not w in self.stop_words]\\n        return \\\" \\\".join(tokens)\\n\\n    def compute_similarity(self, embedding1: np.ndarray, embedding2: np.ndarray) -> float:\\n        \\\"\\\"\\\"\\n        Computes the cosine similarity between two embeddings.\\n\\n        Args:\\n            embedding1 (np.ndarray): The first embedding.\\n            embedding2 (np.ndarray): The second embedding.\\n\\n        Returns:\\n            float: The cosine similarity score.\\n        \\\"\\\"\\\"\\n        if np.linalg.norm(embedding1) == 0 or np.linalg.norm(embedding2) == 0:\\n            return 0.0  # Handle zero vector case\\n        return cosine_similarity(embedding1.reshape(1, -1), embedding2.reshape(1, -1))[0][0]\\n\\n    def match(self, job_description: str, resume_text: str) -> float:\\n        \\\"\\\"\\\"\\n        Matches a job description to a resume based on semantic similarity\\n        of their embeddings.\\n\\n        Args:\\n            job_description (str): The job description text.\\n            resume_text (str): The resume text.\\n\\n        Returns:\\n            float: The similarity score between the job description and resume.\\n        \\\"\\\"\\\"\\n        preprocessed_job_description = self.preprocess_text(job_description)\\n        preprocessed_resume_text = self.preprocess_text(resume_text)\\n\\n        if self.embedding_model:\\n            job_embedding = self.embedding_model.encode(preprocessed_job_description)\\n            resume_embedding = self.embedding_model.encode(preprocessed_resume_text)\\n        else:\\n            raise ValueError(\\\"Embedding model not provided\\\")\\n\\n\\n        similarity_score = self.compute_similarity(job_embedding, resume_embedding)\\n        return similarity_score\\n\\n    def extract_skills(self, text: str) -> List[str]:\\n        \\\"\\\"\\\"\\n        Extracts skills from the given text (resume or job description).  This is a placeholder;\\n        a real implementation would use NLP techniques or a skills database.\\n\\n        Args:\\n            text (str): The text to extract skills from.\\n\\n        Returns:\\n            List[str]: A list of skills found in the text.\\n        \\\"\\\"\\\"\\n        # Placeholder implementation: split the text into words and return unique words\\n        # In a real implementation, use NLP techniques to identify skills\\n        words = self.preprocess_text(text).split()\\n        return list(set(words))\\n\\n\\n    def analyze_match(self, job_description: str, resume_text: str) -> Tuple[float, List[str], List[str]]:\\n        \\\"\\\"\\\"\\n        Analyzes the match between a job description and a resume, returning the similarity score,\\n        skills found in the job description, and skills found in the resume.\\n\\n        Args:\\n            job_description (str): The job description text.\\n            resume_text (str): The resume text.\\n\\n        Returns:\\n            Tuple[float, List[str], List[str]]: A tuple containing the similarity score,\\n                                                 list of job description skills, and list of resume skills.\\n        \\\"\\\"\\\"\\n        similarity_score = self.match(job_description, resume_text)\\n        job_skills = self.extract_skills(job_description)\\n        resume_skills = self.extract_skills(resume_text)\\n        return similarity_score, job_skills, resume_skills\\n\\n\\nif __name__ == '__main__':\\n    # Example Usage (requires a dummy embedding model for testing)\\n    class DummyEmbeddingModel:\\n        def encode(self, text):\\n            # Replace with actual embedding logic in production\\n            return np.random.rand(100)  # Return a random vector as a placeholder\\n\\n    job_description = \\\"Software Engineer with experience in Python and Javascript\\\"\\n    resume_text = \\\"Experienced software engineer proficient in Python, Javascript, and SQL\\\"\\n\\n    embedding_model = DummyEmbeddingModel()\\n    matcher = ResumeJobMatcher(embedding_model=embedding_model)\\n\\n    similarity_score, job_skills, resume_skills = matcher.analyze_match(job_description, resume_text)\\n\\n    print(f\\\"Similarity Score: {similarity_score}\\\")\\n    print(f\\\"Job Description Skills: {job_skills}\\\")\\n    print(f\\\"Resume Skills: {resume_skills}\\\")\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nNo downstream objectives available.\\n\\n---\\n# **Current Task Requirements**\\nBuild the Interview Orchestration Engine: manage dynamic question flows, call AI services to generate technical and behavioral questions (including follow-ups), and track session state.\\n\\n---\\n\\n# **Required Output Format**\\nPython code (module)\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport json\\nimport logging\\nfrom typing import Dict, List, Optional, Tuple\\nimport random\\n\\n# Configure logging\\nlogging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')\\n\\n\\nclass InterviewOrchestrator:\\n    \\\"\\\"\\\"\\n    Orchestrates the interview process, managing question generation,\\n    tracking session state, and handling AI service calls.\\n    \\\"\\\"\\\"\\n\\n    def __init__(\\n        self,\\n        job_id: int,\\n        candidate_id: int,\\n        session_id: int,\\n        question_generator,  # Dependency Injection for AI question generation\\n        evaluation_service,  # Dependency Injection for evaluation\\n        database_client,  # Dependency Injection for database interaction\\n        initial_question_count: int = 3,\\n        technical_question_ratio: float = 0.6,\\n    ):\\n        \\\"\\\"\\\"\\n        Initializes the InterviewOrchestrator.\\n\\n        Args:\\n            job_id (int): The ID of the job being interviewed for.\\n            candidate_id (int): The ID of the candidate being interviewed.\\n            session_id (int): The ID of the interview session.\\n            question_generator: An AI service for generating interview questions. It should have a 'generate_question' method.\\n            evaluation_service: An AI service for evaluating candidate responses. It should have an 'evaluate_response' method.\\n            database_client: Client for interacting with the database.  It should have methods like 'get_job_details', 'get_candidate_details', 'store_question', 'store_response'.\\n            initial_question_count (int): The number of initial questions to generate (default: 3).\\n            technical_question_ratio (float): The ratio of technical questions to behavioral questions (default: 0.6).\\n        \\\"\\\"\\\"\\n        self.job_id = job_id\\n        self.candidate_id = candidate_id\\n        self.session_id = session_id\\n        self.question_generator = question_generator\\n        self.evaluation_service = evaluation_service\\n        self.database_client = database_client\\n        self.question_history: List[int] = []  # List of question IDs already asked.\\n        self.initial_question_count = initial_question_count\\n        self.technical_question_ratio = technical_question_ratio\\n        self.current_question_id: Optional[int] = None  # ID of the question currently being asked.\\n        self.interview_complete = False\\n\\n        self.job_details = self.database_client.get_job_details(job_id)\\n        self.candidate_details = self.database_client.get_candidate_details(candidate_id)\\n\\n        if not self.job_details or not self.candidate_details:\\n            raise ValueError(\\\"Job or Candidate details not found in the database.\\\")\\n\\n        self.context = {\\n            \\\"job_title\\\": self.job_details[\\\"title\\\"],\\n            \\\"job_description\\\": self.job_details[\\\"description\\\"],\\n            \\\"candidate_name\\\": self.candidate_details[\\\"name\\\"],\\n            \\\"candidate_resume\\\": self.candidate_details[\\\"resume_text\\\"],\\n        }\\n\\n        self.interview_data = {  # Stores cumulative interview data for reporting.\\n            \\\"questions\\\": [],  # List of question dictionaries\\n            \\\"responses\\\": [],  # List of response dictionaries\\n            \\\"evaluations\\\": [],  # List of evaluation dictionaries\\n        }\\n\\n    def _generate_initial_questions(self) -> None:\\n        \\\"\\\"\\\"\\n        Generates the initial set of questions for the interview.\\n        \\\"\\\"\\\"\\n        num_technical = int(self.initial_question_count * self.technical_question_ratio)\\n        num_behavioral = self.initial_question_count - num_technical\\n\\n        technical_questions = self._generate_questions(num_technical, \\\"technical\\\")\\n        behavioral_questions = self._generate_questions(num_behavioral, \\\"behavioral\\\")\\n\\n        initial_questions = technical_questions + behavioral_questions\\n        random.shuffle(initial_questions)  # Randomize the order\\n\\n        for question in initial_questions:\\n            self.question_history.append(question[\\\"question_id\\\"])\\n\\n    def _generate_questions(self, num_questions: int, question_type: str) -> List[Dict]:\\n        \\\"\\\"\\\"\\n        Helper function to generate a list of questions of a specific type.\\n\\n        Args:\\n            num_questions (int): The number of questions to generate.\\n            question_type (str): The type of question (\\\"technical\\\" or \\\"behavioral\\\").\\n\\n        Returns:\\n            List[Dict]: A list of question dictionaries.\\n        \\\"\\\"\\\"\\n        questions = []\\n        for _ in range(num_questions):\\n            question_data = self.question_generator.generate_question(\\n                self.job_details[\\\"description\\\"],\\n                self.candidate_details[\\\"resume_text\\\"],\\n                question_type,\\n            )\\n\\n            if not question_data:\\n                logging.warning(f\\\"Failed to generate {question_type} question.\\\")\\n                continue\\n\\n            question_data[\\\"session_id\\\"] = self.session_id  # Add session ID\\n            question_id = self.database_client.store_question(question_data)\\n            question_data[\\\"question_id\\\"] = question_id  # Update with the stored ID\\n            questions.append(question_data)\\n        return questions\\n\\n    def start_interview(self) -> Dict:\\n        \\\"\\\"\\\"\\n        Starts the interview session by generating initial questions.\\n\\n        Returns:\\n            Dict: The first question to ask the candidate.\\n        \\\"\\\"\\\"\\n        self._generate_initial_questions()\\n        if not self.question_history:\\n            logging.error(\\\"No questions generated for the interview.\\\")\\n            self.interview_complete = True\\n            return {\\\"message\\\": \\\"No questions available. Interview cannot start.\\\"}\\n\\n        self.current_question_id = self.question_history.pop(0)  # Get the first question.\\n        question = self.database_client.get_question(self.current_question_id)\\n        self.interview_data[\\\"questions\\\"].append(question) # Add to the interview data\\n\\n        return {\\\"question\\\": question[\\\"question_text\\\"]}\\n\\n    def get_next_question(self) -> Dict:\\n        \\\"\\\"\\\"\\n        Gets the next question to ask the candidate.\\n\\n        Returns:\\n            Dict: The next question or a message if the interview is complete.\\n        \\\"\\\"\\\"\\n        if self.interview_complete:\\n            return {\\\"message\\\": \\\"Interview is complete.\\\"}\\n\\n        if not self.question_history:\\n            self.interview_complete = True  # No more pre-generated questions.\\n            return {\\\"message\\\": \\\"Interview is complete. No more questions available.\\\"}\\n\\n        self.current_question_id = self.question_history.pop(0)\\n        question = self.database_client.get_question(self.current_question_id)\\n\\n        if not question:\\n            logging.error(f\\\"Question with ID {self.current_question_id} not found.\\\")\\n            return {\\\"message\\\": \\\"Error: Question not found.\\\"}\\n\\n        self.interview_data[\\\"questions\\\"].append(question)\\n        return {\\\"question\\\": question[\\\"question_text\\\"]}\\n\\n    def submit_response(self, question: str, response: str) -> Dict:\\n        \\\"\\\"\\\"\\n        Submits the candidate's response to the current question, evaluates the response,\\n        and generates a follow-up question if needed.\\n\\n        Args:\\n            question (str): The question being answered.\\n            response (str): The candidate's response.\\n\\n        Returns:\\n            Dict: A dictionary containing the next question (if any) and the evaluation of the response.\\n        \\\"\\\"\\\"\\n        if self.interview_complete:\\n            return {\\\"message\\\": \\\"Interview is complete.\\\"}\\n\\n        if not self.current_question_id:\\n            logging.error(\\\"No current question ID set.\\\")\\n            return {\\\"message\\\": \\\"Error: No current question.\\\"}\\n\\n        current_question = self.database_client.get_question(self.current_question_id)\\n\\n        if not current_question or current_question[\\\"question_text\\\"] != question:\\n            logging.error(\\\"Invalid question submitted.\\\")\\n            return {\\\"message\\\": \\\"Error: Invalid question.\\\"}\\n\\n        # Store the response in the database\\n        response_data = {\\n            \\\"session_id\\\": self.session_id,\\n            \\\"question_id\\\": self.current_question_id,\\n            \\\"response_text\\\": response,\\n        }\\n        response_id = self.database_client.store_response(response_data)\\n        response_data[\\\"response_id\\\"] = response_id # Add the response_id\\n\\n        # Evaluate the response\\n        evaluation = self.evaluation_service.evaluate_response(\\n            question=question, response=response, job_description=self.job_details[\\\"description\\\"], candidate_resume=self.candidate_details[\\\"resume_text\\\"]\\n        )\\n\\n        if not evaluation:\\n            logging.warning(\\\"Failed to evaluate the response.\\\")\\n            evaluation = {}  # Provide an empty dict to avoid errors\\n\\n        # Store evaluation in database\\n        evaluation_data = {\\n            \\\"session_id\\\": self.session_id,\\n            \\\"question_id\\\": self.current_question_id,\\n            \\\"category\\\": \\\"overall\\\",  # You might want to break this down into categories.\\n            \\\"score\\\": evaluation.get(\\\"overall_score\\\", 0.0), # Default to 0 if missing\\n            \\\"justification\\\": evaluation.get(\\\"justification\\\", \\\"N/A\\\"),\\n        }\\n        evaluation_id = self.database_client.store_evaluation(evaluation_data)\\n        evaluation_data[\\\"evaluation_id\\\"] = evaluation_id # Add the evaluation id\\n\\n        self.interview_data[\\\"responses\\\"].append(response_data)\\n        self.interview_data[\\\"evaluations\\\"].append(evaluation_data)\\n\\n        # Determine next steps (follow-up or next question)\\n        if evaluation.get(\\\"follow_up_required\\\", False):\\n            follow_up_question_data = self.question_generator.generate_question(\\n                self.job_details[\\\"description\\\"],\\n                self.candidate_details[\\\"resume_text\\\"],\\n                \\\"follow_up\\\",\\n                context=response,  # Pass the response as context for follow-up.\\n            )\\n\\n            if follow_up_question_data:\\n                follow_up_question_data[\\\"session_id\\\"] = self.session_id\\n                follow_up_question_id = self.database_client.store_question(follow_up_question_data)\\n                follow_up_question_data[\\\"question_id\\\"] = follow_up_question_id\\n\\n                self.question_history.insert(0, follow_up_question_id)  # Add to the front\\n                next_question_data = {\\\"question\\\": follow_up_question_data[\\\"question_text\\\"]}\\n            else:\\n                next_question_data = self.get_next_question()  # Fallback to the next question if follow-up generation fails\\n\\n        else:\\n            next_question_data = self.get_next_question()\\n\\n        return {\\\"evaluation\\\": evaluation, **next_question_data}\\n\\n    def get_interview_data(self) -> Dict:\\n        \\\"\\\"\\\"\\n        Returns all interview data collected during the session.\\n\\n        Returns:\\n            Dict: A dictionary containing all questions, responses, and evaluations.\\n        \\\"\\\"\\\"\\n        return self.interview_data\\n\\n    def end_interview(self) -> None:\\n        \\\"\\\"\\\"\\n        Marks the interview as complete.\\n        \\\"\\\"\\\"\\n        self.interview_complete = True\\n\\n\\nclass DummyQuestionGenerator:  # For testing\\n    \\\"\\\"\\\"\\n    A dummy question generator for testing purposes.\\n    \\\"\\\"\\\"\\n\\n    def generate_question(self, job_description: str, resume_text: str, question_type: str, context: str = None) -> Dict:\\n        \\\"\\\"\\\"\\n        Generates a dummy question based on the question type.\\n\\n        Args:\\n            job_description (str): The job description.\\n            resume_text (str): The resume text.\\n            question_type (str): The type of question (\\\"technical\\\", \\\"behavioral\\\", or \\\"follow_up\\\").\\n            context (str, optional): The context for generating follow-up questions. Defaults to None.\\n\\n        Returns:\\n            Dict: A dictionary containing the question details.\\n        \\\"\\\"\\\"\\n        if question_type == \\\"technical\\\":\\n            question = \\\"Explain the concept of polymorphism.\\\"\\n        elif question_type == \\\"behavioral\\\":\\n            question = \\\"Tell me about a time you failed.\\\"\\n        elif question_type == \\\"follow_up\\\":\\n            question = f\\\"Follow-up: Elaborate on '{context[:20]}...'\\\"  # Shorten the context for brevity.\\n        else:\\n            return None\\n\\n        return {\\n            \\\"question_text\\\": question,\\n            \\\"question_type\\\": question_type,\\n            \\\"expected_answer\\\": \\\"Some expected answer\\\",\\n            \\\"topic\\\": \\\"General\\\",\\n            \\\"difficulty\\\": \\\"medium\\\",\\n        }\\n\\n\\nclass DummyEvaluationService:  # For testing\\n    \\\"\\\"\\\"\\n    A dummy evaluation service for testing purposes.\\n    \\\"\\\"\\\"\\n\\n    def evaluate_response(self, question: str, response: str, job_description: str, candidate_resume: str) -> Dict:\\n        \\\"\\\"\\\"\\n        Evaluates a dummy response and returns a score.\\n\\n        Args:\\n            question (str): The question being answered.\\n            response (str): The candidate's response.\\n            job_description (str): The job description.\\n            candidate_resume (str): The candidate's resume.\\n\\n        Returns:\\n            Dict: A dictionary containing the evaluation results.\\n        \\\"\\\"\\\"\\n        # Simulate follow-up requirement (50% chance)\\n        follow_up_required = random.random() < 0.5\\n\\n        return {\\n            \\\"relevance\\\": 0.8,\\n            \\\"depth\\\": 0.7,\\n            \\\"confidence\\\": 0.9,\\n            \\\"technical_accuracy\\\": 0.75,\\n            \\\"overall_score\\\": 0.8,\\n            \\\"justification\\\": \\\"The candidate provided a good response.\\\",\\n            \\\"follow_up_required\\\": follow_up_required,\\n        }\\n\\n\\nclass DummyDatabaseClient:\\n    \\\"\\\"\\\"\\n    A dummy database client for testing purposes.\\n    \\\"\\\"\\\"\\n\\n    def __init__(self):\\n        self.questions = {}\\n        self.responses = {}\\n        self.evaluations = {}\\n        self.question_id_counter = 1\\n        self.response_id_counter = 1\\n        self.evaluation_id_counter = 1\\n        self.job_details = {\\n            123: {\\n                \\\"job_id\\\": 123,\\n                \\\"title\\\": \\\"Software Engineer\\\",\\n                \\\"description\\\": \\\"Looking for a software engineer with Python and Javascript skills.\\\",\\n            }\\n        }\\n        self.candidate_details = {\\n            456: {\\n                \\\"candidate_id\\\": 456,\\n                \\\"name\\\": \\\"John Doe\\\",\\n                \\\"resume_text\\\": \\\"Experienced in Python and Javascript.\\\",\\n            }\\n        }\\n\\n    def store_question(self, question_data: Dict) -> int:\\n        \\\"\\\"\\\"Stores a question in the dummy database.\\\"\\\"\\\"\\n        question_id = self.question_id_counter\\n        self.questions[question_id] = question_data\\n        self.question_id_counter += 1\\n        logging.info(f\\\"Stored question with ID {question_id}: {question_data['question_text']}\\\")\\n        return question_id\\n\\n    def store_response(self, response_data: Dict) -> int:\\n        \\\"\\\"\\\"Stores a response in the dummy database.\\\"\\\"\\\"\\n        response_id = self.response_id_counter\\n        self.responses[response_id] = response_data\\n        self.response_id_counter += 1\\n        logging.info(f\\\"Stored response with ID {response_id}: {response_data['response_text']}\\\")\\n        return response_id\\n\\n    def store_evaluation(self, evaluation_data: Dict) -> int:\\n        \\\"\\\"\\\"Stores evaluation data in the dummy database.\\\"\\\"\\\"\\n        evaluation_id = self.evaluation_id_counter\\n        self.evaluations[evaluation_id] = evaluation_data\\n        self.evaluation_id_counter += 1\\n        logging.info(f\\\"Stored evaluation with ID {evaluation_id}: {evaluation_data}\\\")\\n        return evaluation_id\\n\\n    def get_question(self, question_id: int) -> Optional[Dict]:\\n        \\\"\\\"\\\"Retrieves a question from the dummy database.\\\"\\\"\\\"\\n        return self.questions.get(question_id)\\n\\n    def get_job_details(self, job_id: int) -> Optional[Dict]:\\n        \\\"\\\"\\\"Retrieves job details from the dummy database.\\\"\\\"\\\"\\n        return self.job_details.get(job_id)\\n\\n    def get_candidate_details(self, candidate_id: int) -> Optional[Dict]:\\n        \\\"\\\"\\\"Retrieves candidate details from the dummy database.\\\"\\\"\\\"\\n        return self.candidate_details.get(candidate_id)\\n\\n\\nif __name__ == \\\"__main__\\\":\\n    # Example Usage:\\n    job_id = 123\\n    candidate_id = 456\\n    session_id = 789\\n\\n    # Initialize the dummy services\\n    question_generator = DummyQuestionGenerator()\\n    evaluation_service = DummyEvaluationService()\\n    database_