ve unused imports or parameters, and ensure `to_dict()` really flattens all nested dataclasses.\\n\\nhere are the changes:\\n```python\\n# final_report_generator.py\\n\\nfrom dataclasses import dataclass, asdict, field\\nfrom typing import List, Dict, Any\\nimport json\\nimport logging\\nfrom datetime import datetime\\n\\nfrom jinja2 import Environment, BaseLoader\\n\\n# If you have modules for matching/evaluation, import them here:\\n# from candidate_evaluation import ScoringConfig, CandidateEvaluator\\n# from resume_job_matcher import ResumeJobMatcher, DummyEmbeddingModel\\n\\nlogging.basicConfig(level=logging.INFO)\\nlogger = logging.getLogger(__name__)\\n\\n# ----------------------------\\n# Data Models\\n# ----------------------------\\n\\n@dataclass\\nclass ResumeJobMatchData:\\n    score: float = 0.0\\n    highlights: List[str] = field(default_factory=list)\\n    details: str = \\\"\\\"\\n    job_skills: List[str] = field(default_factory=list)\\n    resume_skills: List[str] = field(default_factory=list)\\n\\n@dataclass\\nclass InterviewSummaryData:\\n    summary_text: str = \\\"\\\"\\n    questions_and_answers: List[Dict[str, str]] = field(default_factory=list)\\n\\n@dataclass\\nclass AssessmentData:\\n    score: float = 0.0\\n    comments: str = \\\"\\\"\\n    scoring_breakdown: Dict[str, float] = field(default_factory=dict)\\n    justification: str = \\\"\\\"\\n\\n@dataclass\\nclass ReportData:\\n    candidate_name: str = \\\"\\\"\\n    job_title: str = \\\"\\\"\\n    resume_job_match: ResumeJobMatchData = field(default_factory=ResumeJobMatchData)\\n    interview_summary: InterviewSummaryData = field(default_factory=InterviewSummaryData)\\n    technical_assessment: AssessmentData = field(default_factory=AssessmentData)\\n    behavioral_assessment: AssessmentData = field(default_factory=AssessmentData)\\n    strengths: List[str] = field(default_factory=list)\\n    weaknesses: List[str] = field(default_factory=list)\\n    final_recommendation: str = \\\"\\\"\\n    overall_score: float = 0.0\\n    scoring_breakdown: Dict[str, float] = field(default_factory=dict)\\n    generated_at: str = field(default_factory=lambda: datetime.now().isoformat())\\n    job_id: int = 0\\n    candidate_id: int = 0\\n    session_id: int = 0\\n\\n    def to_dict(self) -> Dict[str, Any]:\\n        \\\"\\\"\\\"Return a fully serializable dict of the report.\\\"\\\"\\\"\\n        data = asdict(self)\\n        # Explicitly re-flatten nested dataclasses\\n        data[\\\"resume_job_match\\\"] = asdict(self.resume_job_match)\\n        data[\\\"interview_summary\\\"] = {\\n            \\\"summary_text\\\": self.interview_summary.summary_text,\\n            \\\"questions_and_answers\\\": self.interview_summary.questions_and_answers\\n        }\\n        data[\\\"technical_assessment\\\"] = asdict(self.technical_assessment)\\n        data[\\\"behavioral_assessment\\\"] = asdict(self.behavioral_assessment)\\n        # scoring_breakdown stays as-is (it’s already a dict)\\n        return data\\n\\n    def to_json(self, **kwargs) -> str:\\n        \\\"\\\"\\\"Return JSON string of the report.\\\"\\\"\\\"\\n        return json.dumps(self.to_dict(), indent=2, sort_keys=True, default=str, **kwargs)\\n\\n# ----------------------------\\n# Report Generator\\n# ----------------------------\\n\\nclass FinalReportGenerator:\\n    MARKDOWN_TEMPLATE = \\\"\\\"\\\"\\n# Final Candidate Evaluation Report\\n\\n**Report Date:** {{ generated_at }}\\n\\n**Candidate:** {{ candidate_name }}  \\n**Job Title:** {{ job_title }}\\n\\n---\\n\\n## 1. Resume-Job Match Analysis  \\n**Score:** {{ resume_job_match.score }}  \\n**Highlights:**\\n{% for h in resume_job_match.highlights -%}\\n- {{ h }}\\n{% endfor %}\\n**Details:**  \\n{{ resume_job_match.details }}\\n\\n**Job Skills:**\\n{% for skill in resume_job_match.job_skills -%}\\n- {{ skill }}\\n{% endfor %}\\n\\n**Resume Skills:**\\n{% for skill in resume_job_match.resume_skills -%}\\n- {{ skill }}\\n{% endfor %}\\n\\n---\\n\\n## 2. Interview Summary  \\n{{ interview_summary.summary_text }}\\n\\n**Questions & Answers:**\\n{% for qa in interview_summary.questions_and_answers -%}\\n- Q: {{ qa.question }}\\n  A: {{ qa.answer }}\\n{% endfor %}\\n\\n---\\n\\n## 3. Technical Assessment  \\n**Score:** {{ technical_assessment.score }}  \\n**Comments:**  \\n{{ technical_assessment.comments }}\\n\\n**Scoring Breakdown:**\\n```json\\n{{ technical_assessment.scoring_breakdown | tojson(indent=2) }}\\n```\\n**Justification:**  \\n{{ technical_assessment.justification }}\\n\\n---\\n\\n## 4. Behavioral Assessment  \\n**Score:** {{ behavioral_assessment.score }}  \\n**Comments:**  \\n{{ behavioral_assessment.comments }}\\n\\n**Scoring Breakdown:**\\n```json\\n{{ behavioral_assessment.scoring_breakdown | tojson(indent=2) }}\\n```\\n**Justification:**  \\n{{ behavioral_assessment.justification }}\\n\\n---\\n\\n## 5. Strengths\\n{% for s in strengths -%}\\n- {{ s }}\\n{% endfor %}\\n\\n## 6. Weaknesses\\n{% for w in weaknesses -%}\\n- {{ w }}\\n{% endfor %}\\n\\n---\\n\\n## 7. Final Recommendation  \\n{{ final_recommendation }}\\n\\n---\\n\\n## 8. Overall Score  \\n{{ overall_score }}\\n\\n## 9. Scoring Breakdown  \\n```json\\n{{ scoring_breakdown | tojson(indent=2) }}\\n```\\n\\\"\\\"\\\"\\n\\n    def __init__(self):\\n        # Setup Jinja with a safe tojson filter that accepts indent\\n        self.jinja_env = Environment(loader=BaseLoader(), trim_blocks=True, lstrip_blocks=True)\\n        def _tojson(obj, indent=2):\\n            return json.dumps(obj, indent=indent, default=str)\\n        self.jinja_env.filters['tojson'] = _tojson\\n\\n    def generate_dict(self, data: ReportData) -> Dict[str, Any]:\\n        try:\\n            return data.to_dict()\\n        except Exception as e:\\n            logger.error(f\\\"Failed to generate report dict: {e}\\\")\\n            raise\\n\\n    def generate_json(self, data: ReportData) -> str:\\n        try:\\n            return data.to_json()\\n        except Exception as e:\\n            logger.error(f\\\"Failed to generate report JSON: {e}\\\")\\n            raise\\n\\n    def generate_markdown(self, data: ReportData) -> str:\\n        try:\\n            # Flatten data into context\\n            context = data.to_dict()\\n            template = self.jinja_env.from_string(self.MARKDOWN_TEMPLATE)\\n            return template.render(**context)\\n        except Exception as e:\\n            logger.error(f\\\"Failed to generate report Markdown: {e}\\\")\\n            raise\\n\\n    def save_to_file(self, content: str, filename: str) -> None:\\n        try:\\n            with open(filename, \\\"w\\\", encoding=\\\"utf-8\\\") as f:\\n                f.write(content)\\n            logger.info(f\\\"Report saved to {filename}\\\")\\n        except Exception as e:\\n            logger.error(f\\\"Failed to save report to file {filename}: {e}\\\")\\n            raise\\n\\n# ----------------------------\\n# Example Usage\\n# ----------------------------\\n\\nif __name__ == \\\"__main__\\\":\\n    # Populate ReportData (dummy or real)...\\n    report_data = ReportData(\\n        candidate_name=\\\"John Doe\\\",\\n        job_title=\\\"Software Engineer\\\",\\n        resume_job_match=ResumeJobMatchData(\\n            score=0.92,\\n            highlights=[\\\"Python expert\\\", \\\"Built 3 full-stack apps\\\"],\\n            details=\\\"Strong fit, slight AWS gap.\\\",\\n            job_skills=[\\\"Python\\\", \\\"JavaScript\\\", \\\"SQL\\\"],\\n            resume_skills=[\\\"Python\\\", \\\"JavaScript\\\"]\\n        ),\\n        interview_summary=InterviewSummaryData(\\n            summary_text=\\\"Demonstrated solid technical knowledge and communication.\\\",\\n            questions_and_answers=[\\n                {\\\"question\\\": \\\"Explain quicksort.\\\", \\\"answer\\\": \\\"Pivot partitioning...\\\"},\\n                {\\\"question\\\": \\\"CI/CD practices?\\\", \\\"answer\\\": \\\"Use Jenkins pipelines.\\\"}\\n            ]\\n        ),\\n        technical_assessment=AssessmentData(\\n            score=0.88,\\n            comments=\\\"Understands algorithms well.\\\",\\n            scoring_breakdown={\\\"algorithms\\\": 0.9, \\\"architecture\\\": 0.85},\\n            justification=\\\"Clear explanation of sorting.\\\"\\n        ),\\n        behavioral_assessment=AssessmentData(\\n            score=0.93,\\n            comments=\\\"Great team player.\\\",\\n            scoring_breakdown={\\\"communication\\\": 0.95, \\\"adaptability\\\": 0.9},\\n            justification=\\\"Provided real-world examples.\\\"\\n        ),\\n        strengths=[\\\"Algorithms\\\", \\\"System Design\\\", \\\"Teamwork\\\"],\\n        weaknesses=[\\\"AWS experience\\\"],\\n        final_recommendation=\\\"Strong Hire\\\",\\n        overall_score=0.905,\\n        scoring_breakdown={\\n            \\\"technical\\\": 0.88,\\n            \\\"behavioral\\\": 0.93,\\n            \\\"problem_solving\\\": 0.90,\\n            \\\"communication\\\": 0.92\\n        },\\n        job_id=1,\\n        candidate_id=101,\\n        session_id=201\\n    )\\n\\n    generator = FinalReportGenerator()\\n\\n    # JSON output\\n    report_json = generator.generate_json(report_data)\\n    print(report_json)\\n    generator.save_to_file(report_json, \\\"candidate_report.json\\\")\\n\\n    # Markdown output\\n    report_md = generator.generate_markdown(report_data)\\n    print(report_md)\\n    generator.save_to_file(report_md, \\\"candidate_report.md\\\")\\n```\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"# **The Overall Goal**\\nICreate an AI-driven interview and candidate evaluation system for recruitment workflows.\\n\\nThe system should:\\n- Analyze job descriptions and candidate resumes\\n- Conduct dynamic AI-based interviews with technical and behavioral questions\\n- Generate follow-up questions based on candidate responses\\n- Evaluate candidate answers for relevance, depth, confidence, and technical accuracy\\n- Score candidates across multiple evaluation categories\\n- Generate recruiter communication emails such as interview invitations and follow-ups\\n- Produce a final candidate evaluation report containing:\\n    - Resume-job match analysis\\n    - Interview summary\\n    - Technical assessment\\n    - Behavioral assessment\\n    - Strengths and weaknesses\\n    - Final recommendation and scoring breakdown\\n\\nThe workflow should support modular AI task execution and dynamic task delegation without hardcoded routing.\\n\\nProvide:\\n- Backend workflow architecture\\n- AI orchestration logic\\n- API structure examples\\n- Database schema suggestions\\n- Candidate scoring logic\\n- Example interview flows\\n- Example final evaluation reports\\n\\nThe output should be production-oriented and implementation-focused.\\n\\n---\\n# **Context from Upstream Tasks**\\nTask task0:\\n  Objective: Define the database schema for job descriptions, candidate resumes, interview sessions, AI-generated questions, candidate responses, evaluation scores, email logs, and final reports.\\n  Result: ```json\\n{\\n  \\\"schemas\\\": {\\n    \\\"job_descriptions\\\": {\\n      \\\"type\\\": \\\"object\\\",\\n      \\\"properties\\\": {\\n        \\\"job_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Unique identifier for the job description\\\",\\n          \\\"primaryKey\\\": true\\n        },\\n        \\\"title\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Job title\\\"\\n        },\\n        \\\"description\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Full job description text\\\"\\n        },\\n        \\\"requirements\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Job requirements\\\"\\n        },\\n        \\\"responsibilities\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Job responsibilities\\\"\\n        },\\n        \\\"department\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Department the job belongs to\\\"\\n        },\\n        \\\"location\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Job location\\\"\\n        },\\n        \\\"date_posted\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"format\\\": \\\"date\\\",\\n          \\\"description\\\": \\\"Date the job was posted\\\"\\n        },\\n        \\\"embedding\\\": {\\n          \\\"type\\\": \\\"array\\\",\\n          \\\"items\\\": {\\n            \\\"type\\\": \\\"number\\\"\\n          },\\n          \\\"description\\\": \\\"Vector embedding of the job description\\\"\\n        }\\n      },\\n      \\\"required\\\": [\\n        \\\"job_id\\\",\\n        \\\"title\\\",\\n        \\\"description\\\"\\n      ]\\n    },\\n    \\\"candidate_resumes\\\": {\\n      \\\"type\\\": \\\"object\\\",\\n      \\\"properties\\\": {\\n        \\\"candidate_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Unique identifier for the candidate\\\",\\n          \\\"primaryKey\\\": true\\n        },\\n        \\\"name\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Candidate's full name\\\"\\n        },\\n        \\\"email\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Candidate's email address\\\"\\n        },\\n        \\\"phone\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Candidate's phone number\\\"\\n        },\\n        \\\"resume_text\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Full text of the candidate's resume\\\"\\n        },\\n        \\\"skills\\\": {\\n          \\\"type\\\": \\\"array\\\",\\n          \\\"items\\\": {\\n            \\\"type\\\": \\\"string\\\"\\n          },\\n          \\\"description\\\": \\\"List of skills extracted from the resume\\\"\\n        },\\n        \\\"experience\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Candidate's work experience\\\"\\n        },\\n        \\\"education\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Candidate's education details\\\"\\n        },\\n        \\\"embedding\\\": {\\n          \\\"type\\\": \\\"array\\\",\\n          \\\"items\\\": {\\n            \\\"type\\\": \\\"number\\\"\\n          },\\n          \\\"description\\\": \\\"Vector embedding of the resume\\\"\\n        }\\n      },\\n      \\\"required\\\": [\\n        \\\"candidate_id\\\",\\n        \\\"name\\\",\\n        \\\"email\\\",\\n        \\\"resume_text\\\"\\n      ]\\n    },\\n    \\\"interview_sessions\\\": {\\n      \\\"type\\\": \\\"object\\\",\\n      \\\"properties\\\": {\\n        \\\"session_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Unique identifier for the interview session\\\",\\n          \\\"primaryKey\\\": true\\n        },\\n        \\\"candidate_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing candidate_resumes\\\"\\n        },\\n        \\\"job_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing job_descriptions\\\"\\n        },\\n        \\\"start_time\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"format\\\": \\\"date-time\\\",\\n          \\\"description\\\": \\\"Timestamp of when the interview started\\\"\\n        },\\n        \\\"end_time\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"format\\\": \\\"date-time\\\",\\n          \\\"description\\\": \\\"Timestamp of when the interview ended\\\"\\n        },\\n        \\\"status\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"enum\\\": [\\n            \\\"scheduled\\\",\\n            \\\"in_progress\\\",\\n            \\\"completed\\\",\\n            \\\"cancelled\\\"\\n          ],\\n          \\\"description\\\": \\\"Status of the interview session\\\"\\n        }\\n      },\\n      \\\"required\\\": [\\n        \\\"session_id\\\",\\n        \\\"candidate_id\\\",\\n        \\\"job_id\\\",\\n        \\\"start_time\\\"\\n      ]\\n    },\\n    \\\"ai_generated_questions\\\": {\\n      \\\"type\\\": \\\"object\\\",\\n      \\\"properties\\\": {\\n        \\\"question_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Unique identifier for the question\\\",\\n          \\\"primaryKey\\\": true\\n        },\\n        \\\"session_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing interview_sessions\\\"\\n        },\\n        \\\"question_text\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"The text of the question generated by AI\\\"\\n        },\\n        \\\"question_type\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"enum\\\": [\\n            \\\"technical\\\",\\n            \\\"behavioral\\\",\\n            \\\"follow_up\\\"\\n          ],\\n          \\\"description\\\": \\\"Type of question\\\"\\n        },\\n        \\\"expected_answer\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"The expected answer or keywords for the question\\\"\\n        },\\n         \\\"topic\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Topic of the question\\\"\\n        },\\n        \\\"difficulty\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"enum\\\": [\\\"easy\\\", \\\"medium\\\", \\\"hard\\\"],\\n          \\\"description\\\": \\\"Difficulty level of the question\\\"\\n         }\\n      },\\n      \\\"required\\\": [\\n        \\\"question_id\\\",\\n        \\\"session_id\\\",\\n        \\\"question_text\\\",\\n        \\\"question_type\\\"\\n      ]\\n    },\\n    \\\"candidate_responses\\\": {\\n      \\\"type\\\": \\\"object\\\",\\n      \\\"properties\\\": {\\n        \\\"response_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Unique identifier for the response\\\",\\n          \\\"primaryKey\\\": true\\n        },\\n        \\\"session_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing interview_sessions\\\"\\n        },\\n        \\\"question_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing ai_generated_questions\\\"\\n        },\\n        \\\"response_text\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"The candidate's answer to the question\\\"\\n        },\\n        \\\"timestamp\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"format\\\": \\\"date-time\\\",\\n          \\\"description\\\": \\\"Timestamp of when the response was recorded\\\"\\n        }\\n      },\\n      \\\"required\\\": [\\n        \\\"response_id\\\",\\n        \\\"session_id\\\",\\n        \\\"question_id\\\",\\n        \\\"response_text\\\"\\n      ]\\n    },\\n    \\\"evaluation_scores\\\": {\\n      \\\"type\\\": \\\"object\\\",\\n      \\\"properties\\\": {\\n        \\\"score_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Unique identifier for the score\\\",\\n          \\\"primaryKey\\\": true\\n        },\\n        \\\"session_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing interview_sessions\\\"\\n        },\\n         \\\"question_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing ai_generated_questions\\\"\\n        },\\n        \\\"category\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"enum\\\": [\\n            \\\"relevance\\\",\\n            \\\"depth\\\",\\n            \\\"confidence\\\",\\n            \\\"technical_accuracy\\\",\\n            \\\"communication_skills\\\",\\n            \\\"problem_solving\\\"\\n          ],\\n          \\\"description\\\": \\\"Category being evaluated\\\"\\n        },\\n        \\\"score\\\": {\\n          \\\"type\\\": \\\"number\\\",\\n          \\\"description\\\": \\\"Score for the category (e.g., 1-5 scale)\\\"\\n        },\\n        \\\"justification\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Explanation or justification for the score\\\"\\n        }\\n      },\\n      \\\"required\\\": [\\n        \\\"score_id\\\",\\n        \\\"session_id\\\",\\n        \\\"category\\\",\\n        \\\"score\\\"\\n      ]\\n    },\\n    \\\"email_logs\\\": {\\n      \\\"type\\\": \\\"object\\\",\\n      \\\"properties\\\": {\\n        \\\"email_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Unique identifier for the email\\\",\\n          \\\"primaryKey\\\": true\\n        },\\n        \\\"candidate_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing candidate_resumes\\\"\\n        },\\n        \\\"email_type\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"enum\\\": [\\n            \\\"invitation\\\",\\n            \\\"follow_up\\\",\\n            \\\"rejection\\\",\\n            \\\"offer\\\"\\n          ],\\n          \\\"description\\\": \\\"Type of email\\\"\\n        },\\n        \\\"subject\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Email subject\\\"\\n        },\\n        \\\"body\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Email body text\\\"\\n        },\\n        \\\"timestamp\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"format\\\": \\\"date-time\\\",\\n          \\\"description\\\": \\\"Timestamp of when the email was sent\\\"\\n        }\\n      },\\n      \\\"required\\\": [\\n        \\\"email_id\\\",\\n        \\\"candidate_id\\\",\\n        \\\"email_type\\\",\\n        \\\"subject\\\",\\n        \\\"body\\\",\\n        \\\"timestamp\\\"\\n      ]\\n    },\\n    \\\"final_reports\\\": {\\n      \\\"type\\\": \\\"object\\\",\\n      \\\"properties\\\": {\\n        \\\"report_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Unique identifier for the final report\\\",\\n          \\\"primaryKey\\\": true\\n        },\\n        \\\"candidate_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing candidate_resumes\\\"\\n        },\\n        \\\"job_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing job_descriptions\\\"\\n        },\\n        \\\"session_id\\\": {\\n          \\\"type\\\": \\\"integer\\\",\\n          \\\"description\\\": \\\"Foreign key referencing interview_sessions\\\"\\n        },\\n        \\\"resume_job_match_analysis\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Analysis of how well the resume matches the job description\\\"\\n        },\\n        \\\"interview_summary\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Summary of the interview session\\\"\\n        },\\n        \\\"technical_assessment\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Assessment of the candidate's technical skills\\\"\\n        },\\n        \\\"behavioral_assessment\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Assessment of the candidate's behavioral traits\\\"\\n        },\\n        \\\"strengths\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"List of the candidate's strengths\\\"\\n        },\\n        \\\"weaknesses\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"List of the candidate's weaknesses\\\"\\n        },\\n        \\\"final_recommendation\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Final recommendation (e.g., hire, no hire, further review)\\\"\\n        },\\n        \\\"overall_score\\\": {\\n          \\\"type\\\": \\\"number\\\",\\n          \\\"description\\\": \\\"Overall score for the candidate\\\"\\n        },\\n        \\\"scoring_breakdown\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"description\\\": \\\"Detailed breakdown of the scoring across different categories (JSON format)\\\"\\n        },\\n         \\\"report_generation_date\\\": {\\n          \\\"type\\\": \\\"string\\\",\\n          \\\"format\\\": \\\"date-time\\\",\\n          \\\"description\\\": \\\"Timestamp of when the report was generated\\\"\\n        }\\n      },\\n      \\\"required\\\": [\\n        \\\"report_id\\\",\\n        \\\"candidate_id\\\",\\n        \\\"job_id\\\",\\n        \\\"session_id\\\"\\n      ]\\n    }\\n  }\\n}\\n```\\nTask task1:\\n  Objective: Design the RESTful API specification (endpoints, request/response models) for core operations: ingesting jobs/resumes, orchestrating interviews, submitting responses, scoring, emailing, and retrieving reports.\\n  Result: ```yaml\\nopenapi: 3.0.0\\ninfo:\\n  title: AI-Driven Interview and Candidate Evaluation System API\\n  version: 1.0.0\\n  description: RESTful API for managing jobs, resumes, interviews, evaluations, and reports.\\n\\npaths:\\n  /jobs:\\n    post:\\n      summary: Ingest a new job description\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                job_title:\\n                  type: string\\n                  description: Title of the job\\n                job_description:\\n                  type: string\\n                  description: Detailed description of the job\\n                department:\\n                  type: string\\n                  description: Department for the job\\n                location:\\n                  type: string\\n                  description: Job location\\n                skills:\\n                  type: array\\n                  items:\\n                    type: string\\n                  description: List of required skills\\n              example:\\n                job_title: Software Engineer\\n                job_description: Develop and maintain software applications.  Experience with Python and Javascript required.\\n                department: Engineering\\n                location: New York, NY\\n                skills: [Python, Javascript, React, AWS]\\n      responses:\\n        '201':\\n          description: Job created successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  job_id:\\n                    type: string\\n                    description: Unique identifier for the job\\n                example:\\n                  job_id: job123\\n        '400':\\n          description: Invalid request\\n\\n    get:\\n      summary: Retrieve a list of all jobs\\n      responses:\\n        '200':\\n          description: List of jobs retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: array\\n                items:\\n                  type: object\\n                  properties:\\n                    job_id:\\n                      type: string\\n                      description: Unique identifier for the job\\n                    job_title:\\n                      type: string\\n                      description: Title of the job\\n                    job_description:\\n                      type: string\\n                      description: Detailed description of the job\\n                    department:\\n                      type: string\\n                      description: Department for the job\\n                    location:\\n                      type: string\\n                      description: Job location\\n                    skills:\\n                      type: array\\n                      items:\\n                        type: string\\n                      description: List of required skills\\n                  example:\\n                    job_id: job123\\n                    job_title: Software Engineer\\n                    job_description: Develop and maintain software applications.  Experience with Python and Javascript required.\\n                    department: Engineering\\n                    location: New York, NY\\n                    skills: [Python, Javascript, React, AWS]\\n\\n  /jobs/{job_id}:\\n    get:\\n      summary: Retrieve a specific job by ID\\n      parameters:\\n        - in: path\\n          name: job_id\\n          required: true\\n          schema:\\n            type: string\\n          description: Unique identifier for the job\\n      responses:\\n        '200':\\n          description: Job retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  job_id:\\n                    type: string\\n                    description: Unique identifier for the job\\n                  job_title:\\n                    type: string\\n                    description: Title of the job\\n                  job_description:\\n                    type: string\\n                    description: Detailed description of the job\\n                  department:\\n                    type: string\\n                    description: Department for the job\\n                  location:\\n                    type: string\\n                    description: Job location\\n                  skills:\\n                    type: array\\n                    items:\\n                      type: string\\n                    description: List of required skills\\n                example:\\n                  job_id: job123\\n                  job_title: Software Engineer\\n                  job_description: Develop and maintain software applications.  Experience with Python and Javascript required.\\n                  department: Engineering\\n                  location: New York, NY\\n                  skills: [Python, Javascript, React, AWS]\\n        '404':\\n          description: Job not found\\n\\n  /resumes:\\n    post:\\n      summary: Ingest a new candidate resume\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                candidate_name:\\n                  type: string\\n                  description: Name of the candidate\\n                resume_text:\\n                  type: string\\n                  description: Text content of the resume\\n                email:\\n                  type: string\\n                  format: email\\n                  description: Candidate's email address\\n                skills:\\n                  type: array\\n                  items:\\n                    type: string\\n                  description: List of skills extracted from the resume\\n              example:\\n                candidate_name: John Doe\\n                resume_text: Experienced software engineer with Python and Javascript skills.\\n                email: john.doe@example.com\\n                skills: [Python, Javascript, SQL]\\n      responses:\\n        '201':\\n          description: Resume created successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  resume_id:\\n                    type: string\\n                    description: Unique identifier for the resume\\n                example:\\n                  resume_id: resume456\\n        '400':\\n          description: Invalid request\\n    get:\\n      summary: Retrieve a list of all resumes\\n      responses:\\n        '200':\\n          description: List of resumes retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: array\\n                items:\\n                  type: object\\n                  properties:\\n                    resume_id:\\n                      type: string\\n                      description: Unique identifier for the resume\\n                    candidate_name:\\n                      type: string\\n                      description: Name of the candidate\\n                    resume_text:\\n                      type: string\\n                      description: Text content of the resume\\n                    email:\\n                      type: string\\n                      format: email\\n                      description: Candidate's email address\\n                    skills:\\n                      type: array\\n                      items:\\n                        type: string\\n                      description: List of skills extracted from the resume\\n                  example:\\n                    resume_id: resume456\\n                    candidate_name: John Doe\\n                    resume_text: Experienced software engineer with Python and Javascript skills.\\n                    email: john.doe@example.com\\n                    skills: [Python, Javascript, SQL]\\n\\n  /resumes/{resume_id}:\\n    get:\\n      summary: Retrieve a specific resume by ID\\n      parameters:\\n        - in: path\\n          name: resume_id\\n          required: true\\n          schema:\\n            type: string\\n          description: Unique identifier for the resume\\n      responses:\\n        '200':\\n          description: Resume retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  resume_id:\\n                    type: string\\n                    description: Unique identifier for the resume\\n                  candidate_name:\\n                    type: string\\n                    description: Name of the candidate\\n                  resume_text:\\n                    type: string\\n                    description: Text content of the resume\\n                  email:\\n                    type: string\\n                    format: email\\n                    description: Candidate's email address\\n                  skills:\\n                    type: array\\n                    items:\\n                      type: string\\n                    description: List of skills extracted from the resume\\n                example:\\n                  resume_id: resume456\\n                  candidate_name: John Doe\\n                  resume_text: Experienced software engineer with Python and Javascript skills.\\n                  email: john.doe@example.com\\n                  skills: [Python, Javascript, SQL]\\n        '404':\\n          description: Resume not found\\n\\n  /interviews:\\n    post:\\n      summary: Start a new interview session\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                job_id:\\n                  type: string\\n                  description: ID of the job for the interview\\n                resume_id:\\n                  type: string\\n                  description: ID of the candidate's resume\\n              example:\\n                job_id: job123\\n                resume_id: resume456\\n      responses:\\n        '201':\\n          description: Interview session started successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  interview_id:\\n                    type: string\\n                    description: Unique identifier for the interview session\\n                  first_question:\\n                    type: string\\n                    description: The first question to ask the candidate\\n                example:\\n                  interview_id: interview789\\n                  first_question: \\\"Tell me about your experience with Python.\\\"\\n        '400':\\n          description: Invalid request\\n        '404':\\n          description: Job or Resume not found\\n\\n  /interviews/{interview_id}/questions:\\n    get:\\n      summary: Get the current or next question in the interview\\n      parameters:\\n        - in: path\\n          name: interview_id\\n          required: true\\n          schema:\\n            type: string\\n          description: Unique identifier for the interview session\\n      responses:\\n        '200':\\n          description: Question retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  question:\\n                    type: string\\n                    description: The question to ask the candidate\\n                example:\\n                  question: \\\"Explain the difference between '==' and '===' in Javascript.\\\"\\n        '404':\\n          description: Interview not found\\n\\n  /interviews/{interview_id}/responses:\\n    post:\\n      summary: Submit a candidate's response to a question\\n      parameters:\\n        - in: path\\n          name: interview_id\\n          required: true\\n          schema:\\n            type: string\\n          description: Unique identifier for the interview session\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                question:\\n                  type: string\\n                  description: The question being answered.\\n                response:\\n                  type: string\\n                  description: The candidate's answer to the question\\n              example:\\n                question: \\\"Explain the difference between '==' and '===' in Javascript.\\\"\\n                response: \\\"'==' compares values, while '===' compares values and types.\\\"\\n      responses:\\n        '200':\\n          description: Response submitted successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  next_question:\\n                    type: string\\n                    nullable: true\\n                    description: The next question to ask, or null if the interview is complete\\n                  evaluation:\\n                    type: object\\n                    description: Evaluation of the response\\n                    properties:\\n                      relevance:\\n                        type: number\\n                        format: float\\n                        description: Relevance score (0-1)\\n                      depth:\\n                        type: number\\n                        format: float\\n                        description: Depth score (0-1)\\n                      confidence:\\n                        type: number\\n                        format: float\\n                        description: Confidence score (0-1)\\n                      technical_accuracy:\\n                        type: number\\n                        format: float\\n                        description: Technical accuracy score (0-1)\\n                    example:\\n                      relevance: 0.9\\n                      depth: 0.8\\n                      confidence: 0.7\\n                      technical_accuracy: 0.95\\n                example:\\n                  next_question: \\\"How would you optimize a slow SQL query?\\\"\\n                  evaluation:\\n                    relevance: 0.9\\n                    depth: 0.8\\n                    confidence: 0.7\\n                    technical_accuracy: 0.95\\n        '400':\\n          description: Invalid request\\n        '404':\\n          description: Interview not found\\n\\n  /interviews/{interview_id}/scores:\\n    get:\\n      summary: Retrieve the candidate's scores for the interview\\n      parameters:\\n        - in: path\\n          name: interview_id\\n          required: true\\n          schema:\\n            type: string\\n          description: Unique identifier for the interview session\\n      responses:\\n        '200':\\n          description: Scores retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  technical_score:\\n                    type: number\\n                    format: float\\n                    description: Overall technical score\\n                  behavioral_score:\\n                    type: number\\n                    format: float\\n                    description: Overall behavioral score\\n                  overall_score:\\n                    type: number\\n                    format: float\\n                    description: Overall score\\n                  category_scores:\\n                    type: object\\n                    description: Scores for individual categories\\n                    properties:\\n                      problem_solving:\\n                        type: number\\n                        format: float\\n                        description: Problem-solving score\\n                      communication:\\n                        type: number\\n                        format: float\\n                        description: Communication score\\n                    example:\\n                      problem_solving: 0.85\\n                      communication: 0.9\\n                example:\\n                  technical_score: 0.8\\n                  behavioral_score: 0.9\\n                  overall_score: 0.85\\n                  category_scores:\\n                    problem_solving: 0.85\\n                    communication: 0.9\\n        '404':\\n          description: Interview not found\\n\\n  /emails/invite:\\n    post:\\n      summary: Generate and send an interview invitation email\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                candidate_email:\\n                  type: string\\n                  format: email\\n                  description: Candidate's email address\\n                job_title:\\n                  type: string\\n                  description: Job title\\n                interview_date:\\n                  type: string\\n                  format: date-time\\n                  description: Date and time of the interview\\n                interviewer_name:\\n                  type: string\\n                  description: Name of the interviewer\\n              example:\\n                candidate_email: john.doe@example.com\\n                job_title: Software Engineer\\n                interview_date: \\\"2024-01-20T10:00:00Z\\\"\\n                interviewer_name: Jane Smith\\n      responses:\\n        '200':\\n          description: Email sent successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  message:\\n                    type: string\\n                    description: Confirmation message\\n                example:\\n                  message: \\\"Interview invitation email sent to john.doe@example.com\\\"\\n        '400':\\n          description: Invalid request\\n        '500':\\n          description: Email sending failed\\n\\n  /emails/followup:\\n    post:\\n      summary: Generate and send a follow-up email to the candidate\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                candidate_email:\\n                  type: string\\n                  format: email\\n                  description: Candidate's email address\\n                interview_id:\\n                  type: string\\n                  description: Interview ID\\n              example:\\n                candidate_email: john.doe@example.com\\n                interview_id: interview789\\n      responses:\\n        '200':\\n          description: Email sent successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  message:\\n                    type: string\\n                    description: Confirmation message\\n                example:\\n                  message: \\\"Follow-up email sent to john.doe@example.com\\\"\\n        '400':\\n          description: Invalid request\\n        '500':\\n          description: Email sending failed\\n\\n  /reports/{interview_id}:\\n    get:\\n      summary: Retrieve the final candidate evaluation report\\n      parameters:\\n        - in: path\\n          name: interview_id\\n          required: true\\n          schema:\\n            type: string\\n          description: Unique identifier for the interview session\\n      responses:\\n        '200':\\n          description: Report retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  resume_job_match_analysis:\\n                    type: string\\n                    description: Analysis of how well the resume matches the job description\\n                  interview_summary:\\n                    type: string\\n                    description: Summary of the interview\\n                  technical_assessment:\\n                    type: string\\n                    description: Assessment of the candidate's technical skills\\n                  behavioral_assessment:\\n                    type: string\\n                    description: Assessment of the candidate's behavioral traits\\n                  strengths:\\n                    type: array\\n                    items:\\n                      type: string\\n                    description: List of the candidate's strengths\\n                  weaknesses:\\n                    type: array\\n                    items:\\n                      type: string\\n                    description: List of the candidate's weaknesses\\n                  final_recommendation:\\n                    type: string\\n                    description: Final recommendation (Hire/No Hire/Maybe)\\n                  scoring_breakdown:\\n                    type: object\\n                    description: Detailed breakdown of the candidate's scores\\n                    properties:\\n                      technical_score:\\n                        type: number\\n                        format: float\\n                        description: Overall technical score\\n                      behavioral_score:\\n                        type: number\\n                        format: float\\n                        description: Overall behavioral score\\n                      overall_score:\\n                        type: number\\n                        format: float\\n                        description: Overall score\\n                    example:\\n                      technical_score: 0.8\\n                      behavioral_score: 0.9\\n                      overall_score: 0.85\\n                example:\\n                  resume_job_match_analysis: \\\"The candidate's resume closely matches the job description, with strong skills in Python and Javascript.\\\"\\n                  interview_summary: \\\"The candidate performed well in the interview, demonstrating strong technical knowledge and communication skills.\\\"\\n                  technical_assessment: \\\"The candidate has a solid understanding of software engineering principles and is proficient in Python and Javascript.\\\"\\n                  behavioral_assessment: \\\"The candidate is a good communicator and works well in a team environment.\\\"\\n                  strengths: [\\\"Technical Skills\\\", \\\"Communication\\\", \\\"Problem Solving\\\"]\\n                  weaknesses: [\\\"Lack of experience with AWS\\\"]\\n                  final_recommendation: \\\"Hire\\\"\\n                  scoring_breakdown:\\n                    technical_score: 0.8\\n                    behavioral_score: 0.9\\n                    overall_score: 0.85\\n        '404':\\n          description: Report not found\\ncomponents:\\n  schemas:\\n    Error:\\n      type: object\\n      properties:\\n        message:\\n          type: string\\n          description: Error message\\n      example:\\n        message: \\\"An error occurred\\\"\\n```\\nTask task2:\\n  Objective: Implement the Resume–Job Matching Module: parse and embed job descriptions and resumes, compute semantic similarity scores, and expose matching interface.\\n  Result: ```python\\nimport nltk\\nimport numpy as np\\nfrom sklearn.metrics.pairwise import cosine_similarity\\nfrom nltk.corpus import stopwords\\nfrom nltk.tokenize import word_tokenize\\nimport re\\nfrom typing import List, Tuple\\n\\n# Download required NLTK data (if not already downloaded)\\ntry:\\n    nltk.data.find('corpora/stopwords')\\nexcept LookupError:\\n    nltk.download('stopwords')\\n\\ntry:\\n    nltk.data.find('tokenizers/punkt')\\nexcept LookupError:\\n    nltk.download('punkt')\\n\\n\\nclass ResumeJobMatcher:\\n    \\\"\\\"\\\"\\n    A class for matching resumes to job descriptions based on semantic similarity.\\n    \\\"\\\"\\\"\\n\\n    def __init__(self, embedding_model=None):\\n        \\\"\\\"\\\"\\n        Initializes the ResumeJobMatcher with an optional embedding model.\\n\\n        Args:\\n            embedding_model:  A pre-trained word embedding model (e.g., Word2Vec, GloVe).\\n                              If None, a simple TF-IDF based approach is used.  Must have a 'encode' method.\\n        \\\"\\\"\\\"\\n        self.embedding_model = embedding_model\\n        self.stop_words = set(stopwords.words('english'))\\n\\n    def preprocess_text(self, text: str) -> str:\\n        \\\"\\\"\\\"\\n        Preprocesses the input text by removing special characters,\\n        converting to lowercase, and removing stop words.\\n\\n        Args:\\n            text (str): The input text to preprocess.\\n\\n        Returns:\\n            str: The preprocessed text.\\n        \\\"\\\"\\\"\\n        text = re.sub(r'[^\\\\w\\\\s]', '', text)\\n        text = text.lower()\\n        tokens = word_tokenize(text)\\n        tokens = [w for w in tokens if not w in self.stop_words]\\n        return \\\" \\\".join(tokens)\\n\\n    def compute_similarity(self, embedding1: np.ndarray, embedding2: np.ndarray) -> float:\\n        \\\"\\\"\\\"\\n        Computes the cosine similarity between two embeddings.\\n\\n        Args:\\n            embedding1 (np.ndarray): The first embedding.\\n            embedding2 (np.ndarray): The second embedding.\\n\\n        Returns:\\n            float: The cosine similarity score.\\n        \\\"\\\"\\\"\\n        if np.linalg.norm(embedding1) == 0 or np.linalg.norm(embedding2) == 0:\\n            return 0.0  # Handle zero vector case\\n        return cosine_similarity(embedding1.reshape(1, -1), embedding2.reshape(1, -1))[0][0]\\n\\n    def match(self, job_description: str, resume_text: str) -> float:\\n        \\\"\\\"\\\"\\n        Matches a job description to a resume based on semantic similarity\\n        of their embeddings.\\n\\n        Args:\\n            job_description (str): The job description text.\\n            resume_text (str): The resume text.\\n\\n        Returns:\\n            float: The similarity score between the job description and resume.\\n        \\\"\\\"\\\"\\n        preprocessed_job_description = self.preprocess_text(job_description)\\n        preprocessed_resume_text = self.preprocess_text(resume_text)\\n\\n        if self.embedding_model:\\n            job_embedding = self.embedding_model.encode(preprocessed_job_description)\\n            resume_embedding = self.embedding_model.encode(preprocessed_resume_text)\\n        else:\\n            raise ValueError(\\\"Embedding model not provided\\\")\\n\\n\\n        similarity_score = self.compute_similarity(job_embedding, resume_embedding)\\n        return similarity_score\\n\\n    def extract_skills(self, text: str) -> List[str]:\\n        \\\"\\\"\\\"\\n        Extracts skills from the given text (resume or job description).  This is a placeholder;\\n        a real implementation would use NLP techniques or a skills database.\\n\\n        Args:\\n            text (str): The text to extract skills from.\\n\\n        Returns:\\n            List[str]: A list of skills found in the text.\\n        \\\"\\\"\\\"\\n        # Placeholder implementation: split the text into words and return unique words\\n        # In a real implementation, use NLP techniques to identify skills\\n        words = self.preprocess_text(text).split()\\n        return list(set(words))\\n\\n\\n    def analyze_match(self, job_description: str, resume_text: str) -> Tuple[float, List[str], List[str]]:\\n        \\\"\\\"\\\"\\n        Analyzes the match between a job description and a resume, returning the similarity score,\\n        skills found in the job description, and skills found in the resume.\\n\\n        Args:\\n            job_description (str): The job description text.\\n            resume_text (str): The resume text.\\n\\n        Returns:\\n            Tuple[float, List[str], List[str]]: A tuple containing the similarity score,\\n                                                 list of job description skills, and list of resume skills.\\n        \\\"\\\"\\\"\\n        similarity_score = self.match(job_description, resume_text)\\n        job_skills = self.extract_skills(job_description)\\n        resume_skills = self.extract_skills(resume_text)\\n        return similarity_score, job_skills, resume_skills\\n\\n\\nif __name__ == '__main__':\\n    # Example Usage (requires a dummy embedding model for testing)\\n    class DummyEmbeddingModel:\\n        def encode(self, text):\\n            # Replace with actual embedding logic in production\\n            return np.random.rand(100)  # Return a random vector as a placeholder\\n\\n    job_description = \\\"Software Engineer with experience in Python and Javascript\\\"\\n    resume_text = \\\"Experienced software engineer proficient in Python, Javascript, and SQL\\\"\\n\\n    embedding_model = DummyEmbeddingModel()\\n    matcher = ResumeJobMatcher(embedding_model=embedding_model)\\n\\n    similarity_score, job_skills, resume_skills = matcher.analyze_match(job_description, resume_text)\\n\\n    print(f\\\"Similarity Score: {similarity_score}\\\")\\n    print(f\\\"Job Description Skills: {job_skills}\\\")\\n    print(f\\\"Resume Skills: {resume_skills}\\\")\\n```\\nTask task4:\\n  Objective: Develop the Candidate Evaluation & Scoring Logic: analyze candidate responses for relevance, depth, confidence, and technical accuracy; compute composite scores across defined categories.\\n  Result: ```python\\n# candidate_evaluation.py\\n\\nfrom dataclasses import dataclass, field\\nfrom typing import Dict, List\\nimport numpy as np\\nfrom sentence_transformers import SentenceTransformer, util\\nfrom sklearn.feature_extraction.text import TfidfVectorizer\\nimport logging\\nimport json  # Import for handling JSON-formatted scoring breakdown\\nfrom enum import Enum\\n\\nlogging.basicConfig(level=logging.INFO)\\nlogger = logging.getLogger(__name__)\\n\\nclass QuestionType(str, Enum):\\n    TECHNICAL = \\\"technical\\\"\\n    BEHAVIORAL = \\\"behavioral\\\"\\n    FOLLOW_UP = \\\"follow_up\\\"\\n\\n@dataclass\\nclass ScoringConfig:\\n    relevance_weight: float = 0.8\\n    depth_weight: float = 0.7\\n    confidence_weight: float = 0.6\\n    technical_accuracy_weight: float = 0.9\\n\\n    # Composite weights\\n    technical_skills_weights: Dict[str, float] = field(default_factory=lambda: {\\n        \\\"depth\\\": 0.5,\\n        \\\"technical_accuracy\\\": 0.5\\n    })\\n    communication_skills_weights: Dict[str, float] = field(default_factory=lambda: {\\n        \\\"relevance\\\": 0.6,\\n        \\\"confidence\\\": 0.4\\n    })\\n    problem_solving_weights: Dict[str, float] = field(default_factory=lambda: {\\n        \\\"relevance\\\": 0.4,\\n        \\\"depth\\\": 0.3,\\n        \\\"technical_accuracy\\\": 0.3\\n    })\\n    overall_weights: Dict[str, float] = field(default_factory=lambda: {\\n        \\\"technical_skills\\\": 0.35,\\n        \\\"communication_skills\\\": 0.35,\\n        \\\"problem_solving\\\": 0.30\\n    })\\n    behavioral_weights: Dict[str, float] = field(default_factory=lambda: {\\n        \\\"relevance\\\": 0.5,\\n        \\\"depth\\\": 0.25,\\n        \\\"confidence\\\": 0.25\\n    })\\n\\n    # Models\\n    embedding_model_name: str = 'all-MiniLM-L6-v2'\\n    confidence_lexicon: Dict[str, float] = field(default_factory=lambda: {\\n        \\\"confident\\\": 0.8, \\\"certainly\\\": 0.7, \\\"definitely\\\": 0.9, \\\"sure\\\": 0.6, \\\"experience\\\": 0.5,\\n        \\\"I am confident\\\": 0.9, \\\"I know\\\": 0.7, \\\"I have experience\\\": 0.8\\n    })\\n    hesitant_lexicon: Dict[str, float] = field(default_factory=lambda: {\\n        \\\"I think\\\": -0.3, \\\"I believe\\\": -0.2, \\\"maybe\\\": -0.5, \\\"possibly\\\": -0.4, \\\"not sure\\\": -0.6\\n    })\\n\\nclass CandidateEvaluator:\\n    def __init__(self, config: ScoringConfig):\\n        self.config = config\\n        try:\\n            self.embed_model = SentenceTransformer(config.embedding_model_name)\\n        except Exception as e:\\n            logger.error(f\\\"Failed to load embedding model: {e}\\\")\\n            raise\\n        self.tfidf_vectorizer = TfidfVectorizer()\\n\\n    def _semantic_similarity(self, texts1: List[str], texts2: List[str]) -> float:\\n        \\\"\\\"\\\"Compute cosine similarity between two lists of texts using embeddings.\\\"\\\"\\\"\\n        if not texts1 or not texts2:\\n            return 0.0\\n        try:\\n            emb1 = self.embed_model.encode(texts1, convert_to_tensor=True)\\n            emb2 = self.embed_model.encode(texts2, convert_to_tensor=True)\\n            sim = util.cos_sim(emb1, emb2).item()\\n            return float(np.clip(sim, 0.0, 1.0))\\n        except Exception as e:\\n            logger.error(f\\\"Semantic similarity calculation failed: {e}\\\")\\n            return 0.0\\n\\n    def calculate_relevance_score(self, response: str, expected_answer: str, job_description: str) -> float:\\n        \\\"\\\"\\\"Semantic similarity between response and combined context.\\\"\\\"\\\"\\n        try:\\n            context = expected_answer + \\\" \\\" + job_description\\n            score = self._semantic_similarity([response], [context])\\n            return score * self.config.relevance_weight\\n        except Exception as e:\\n            logger.error(f\\\"Relevance score calculation failed: {e}\\\")\\n            return 0.0\\n\\n    def calculate_depth_score(self, response: str, expected_answer: str) -> float:\\n        \\\"\\\"\\\"Combines response length ratio and TF-IDF concept richness.\\\"\\\"\\\"\\n        try:\\n            resp_len = len(response.split())\\n            exp_len = max(1, len(expected_answer.split()))\\n            length_ratio = min(resp_len / exp_len, 1.0)\\n\\n            corpus = [expected_answer, response]\\n            tfidf = self.tfidf_vectorizer.fit_transform(corpus)\\n            tfidf_array = tfidf.toarray()\\n\\n            richness = tfidf_array[1].sum() / (tfidf_array[0].sum() + 1e-6)\\n            richness_norm = min(richness, 1.0)\\n\\n            raw = 0.5 * length_ratio + 0.5 * richness_norm\\n            depth_score = 1 / (1 + np.exp(-10 * (raw - 0.5)))\\n            return float(depth_score * self.config.depth_weight)\\n        except Exception as e:\\n            logger.error(f\\\"Depth score calculation failed: {e}\\\")\\n            return 0.0\\n\\n    def calculate_confidence_score(self, response: str) -> float:\\n        \\\"\\\"\\\"Confidence via lexicon and sentiment polarity.\\\"\\\"\\\"\\n        try:\\n            resp_lower = response.lower()\\n            lexical_score = 0.0\\n            for kw, weight in self.config.confidence_lexicon.items():\\n                if kw.lower() in resp_lower:\\n                    lexical_score += weight\\n            for kw, weight in self.config.hesitant_lexicon.items():\\n                if kw.lower() in resp_lower:\\n                    lexical_score += weight\\n\\n            lexical_score = np.clip(lexical_score, -1.0, 1.0)\\n            lexical_score = (lexical_score + 1) / 2  # Normalize to 0-1 range\\n\\n            dist = 1 - self._semantic_similarity([response], [\\\"I am not confident\\\"])\\n            sem_score = dist\\n\\n            combined = 0.5 * lexical_score + 0.5 * sem_score\\n            return float(np.clip(combined * self.config.confidence_weight, 0.0, 1.0))\\n        except Exception as e:\\n            logger.error(f\\\"Confidence score calculation failed: {e}\\\")\\n            return 0.0\\n\\n    def calculate_technical_accuracy_score(self, response: str, expected_answer: str) -> float:\\n        \\\"\\\"\\\"Technical accuracy as semantic similarity.\\\"\\\"\\\"\\n        try:\\n            score = self._semantic_similarity([response], [expected_answer])\\n            return float(score * self.config.technical_accuracy_weight)\\n        except Exception as e:\\n            logger.error(f\\\"Technical accuracy score calculation failed: {e}\\\")\\n            return 0.0\\n    \\n    def calculate_behavioral_score(self, scores: Dict[str, float]) -> float:\\n        \\\"\\\"\\\"Calculate overall behavioral score using configured weights.\\\"\\\"\\\"\\n        try:\\n            behavioral_score = sum(scores[k] * w for k, w in self.config.behavioral_weights.items())\\n            return float(np.clip(behavioral_score, 0.0, 1.0))\\n        except Exception as e:\\n            logger.error(f\\\"Behavioral score calculation failed: {e}\\\")\\n            return 0.0\\n\\n    def compute_composite_scores(self, scores: Dict[str, float]) -> Dict[str, float]:\\n        \\\"\\\"\\\"Build composite categories using configurable weights.\\\"\\\"\\\"\\n        try:\\n            tech = sum(scores[k] * w for k, w in self.config.technical_skills_weights.items())\\n            comm = sum(scores[k] * w for k, w in self.config.communication_skills_weights.items())\\n            prob = sum(scores[k] * w for k, w in self.config.problem_solving_weights.items())\\n\\n            technical_skills = float(np.clip(tech, 0.0, 1.0))\\n            communication_skills = float(np.clip(comm, 0.0, 1.0))\\n            problem_solving = float(np.clip(prob, 0.0, 1.0))\\n\\n            overall = sum(val * self.config.overall_weights[key] for key, val in {\\n                \\\"technical_skills\\\": technical_skills,\\n                \\\"communication_skills\\\": communication_skills,\\n                \\\"problem_solving\\\": problem_solving\\n            }.items())\\n\\n            return {\\n                \\\"technical_skills\\\": technical_skills,\\n                \\\"communication_skills\\\": communication_skills,\\n                \\\"problem_solving\\\": problem_solving,\\n                \\\"overall_score\\\": float(np.clip(overall, 0.0, 1.0))\\n            }\\n        except Exception as e:\\n            logger.error(f\\\"Composite score calculation failed: {e}\\\")\\n            return {\\n                \\\"technical_skills\\\": 0.0,\\n                \\\"communication_skills\\\": 0.0,\\n                \\\"problem_solving\\\": 0.0,\\n                \\\"overall_score\\\": 0.0\\n            }\\n\\n    def evaluate(self, response: str, expected_answer: str, job_description: str, question_type: QuestionType = QuestionType.TECHNICAL) -> Dict[str, float]:\\n        \\\"\\\"\\\"Run full evaluation pipeline.\\\"\\\"\\\"\\n        response = response or \\\"\\\"\\n        expected_answer = expected_answer or \\\"\\\"\\n        job_description = job_description or \\\"\\\"\\n\\n        try:\\n            scores = {\\n                \\\"relevance\\\": self.calculate_relevance_score(response, expected_answer, job_description),\\n                \\\"depth\\\": self.calculate_depth_score(response, expected_answer),\\n                \\\"confidence\\\": self.calculate_confidence_score(response),\\n                \\\"technical_accuracy\\\": self.calculate_technical_accuracy_score(response, expected_answer)\\n            }\\n\\n            composite_scores = self.compute_composite_scores(scores)\\n\\n            # Include behavioral score if question type is behavioral\\n            if question_type == QuestionType.BEHAVIORAL:\\n                behavioral_score = self.calculate_behavioral_score(scores)\\n                composite_scores[\\\"behavioral_score\\\"] = behavioral_score\\n\\n            return {**scores, **composite_scores}\\n        except Exception as e:\\n            logger.error(f\\\"Overall evaluation failed: {e}\\\")\\n            return {\\n                \\\"relevance\\\": 0.0,\\n                \\\"depth\\\": 0.0,\\n                \\\"confidence\\\": 0.0,\\n                \\\"technical_accuracy\\\": 0.0,\\n                \\\"technical_skills\\\": 0.0,\\n                \\\"communication_skills\\\": 0.0,\\n                \\\"problem_solving\\\": 0.0,\\n                \\\"overall_score\\\": 0.0,\\n                \\\"behavioral_score\\\": 0.0 if question_type == QuestionType.BEHAVIORAL else None\\n            }\\n\\n    def generate_scoring_breakdown_json(self, evaluation_results: Dict[str, float]) -> str:\\n        \\\"\\\"\\\"\\n        Generates a JSON string representing the scoring breakdown.\\n        \\\"\\\"\\\"\\n        try:\\n            return json.dumps(evaluation_results, indent=2)\\n        except Exception as e:\\n            logger.error(f\\\"Failed to generate scoring breakdown JSON: {e}\\\")\\n            return \\\"{}\\\"\\n\\n\\nif __name__ == \\\"__main__\\\":\\n    cfg = ScoringConfig()\\n    evaluator = CandidateEvaluator(cfg)\\n    resp = (\\\"I have experience building microservices in Python, \\\"\\n            \\\"using Docker and Kubernetes. I'm confident in designing scalable APIs.\\\")\\n    expected = (\\\"Experience with Python, Docker, Kubernetes, and API design is required.\\\")\\n    jd = (\\\"We need a backend engineer skilled in Python, containerization, \\\"\\n          \\\"and scalable system architecture.\\\")\\n\\n    # Example Usage for technical question\\n    results_technical = evaluator.evaluate(resp, expected, jd, QuestionType.TECHNICAL)\\n    print(\\\"Technical Evaluation Results:\\\", results_technical)\\n    scoring_breakdown_technical = evaluator.generate_scoring_breakdown_json(results_technical)\\n    print(\\\"Technical Scoring Breakdown JSON:\\\\n\\\", scoring_breakdown_technical)\\n\\n    # Example Usage for behavioral question\\n    resp_behavioral = \\\"I work well in teams and can effectively communicate technical concepts.\\\"\\n    expected_behavioral = \\\"Demonstrates teamwork and communication skills.\\\"\\n    jd_behavioral = \\\"Looking for team players with good communication abilities.\\\"\\n    results_behavioral = evaluator.evaluate(resp_behavioral, expected_behavioral, jd_behavioral, QuestionType.BEHAVIORAL)\\n    print(\\\"\\\\nBehavioral Evaluation Results:\\\", results_behavioral)\\n    scoring_breakdown_behavioral = evaluator.generate_scoring_breakdown_json(results_behavioral)\\n    print(\\\"Behavioral Scoring Breakdown JSON:\\\\n\\\", scoring_breakdown_behavioral)\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nNo downstream objectives available.\\n\\n---\\n# **Current Task Requirements**\\nImplement the Final Report Generation Module: assemble resume-job match data, interview summaries, technical and behavioral assessments, strengths/weaknesses, and recommendations into a structured report.\\n\\n---\\n\\n# **Required Output Format**\\nPython code (module)\"\n    }\n  ],\n  \"gpt_response\": \"```python\\n# final_report_generator.py\\n\\nfrom dataclasses import dataclass, asdict, field\\nfrom typing import List, Dict, Any\\nimport json\\nimport logging\\nfrom datetime import datetime\\n\\nfrom jinja2 import Environment, BaseLoader\\n\\n# Assuming candidate_evaluation and resume_job_matcher are in the same directory or PYTHONPATH\\n# from candidate_evaluation import ScoringConfig, CandidateEvaluator\\n# from resume_job_matcher import ResumeJobMatcher, DummyEmbeddingModel\\n\\nlogging.basicConfig(level=logging.INFO)\\nlogger = logging.getLogger(__name__)\\n\\n# ----------------------------\\n# Data Models\\n# ----------------------------\\n\\n@dataclass\\nclass ResumeJobMatchData:\\n    score: float = 0.0\\n    highlights: List[str] = field(default_factory=list)\\n    details: str = \\\"\\\"\\n    job_skills: List[str] = field(default_factory=list)\\n    resume_skills: List[str] = field(default_factory=list)\\n\\n@dataclass\\nclass InterviewSummaryData:\\n    summary_text: str = \\\"\\\"\\n    questions_and_answers: List[Dict[str, str]] = field(default_factory=list)\\n\\n@dataclass\\nclass AssessmentData:\\n    score: float = 0.0\\n    comments: str = \\\"\\\"\\n    scoring_breakdown: Dict[str, float] = field(default_factory=dict)\\n    justification: str = \\\"\\\"\\n\\n@dataclass\\nclass ReportData:\\n    candidate_name: str = \\\"\\\"\\n    job_title: str = \\\"\\\"\\n    resume_job_match: ResumeJobMatchData = field(default_factory=ResumeJobMatchData)\\n    interview_summary: InterviewSummaryData = field(default_factory=InterviewSummaryData)\\n    technical_assessment: AssessmentData = field(default_factory=AssessmentData)\\n    behavioral_assessment: AssessmentData = field(default_factory=AssessmentData)\\n    strengths: List[str] = field(default_factory=list)\\n    weaknesses: List[str] = field(default_factory=list)\\n    final_recommendation: str = \\\"\\\"\\n    overall_score: float = 0.0\\n    scoring_breakdown: Dict[str, float] = field(default_factory=dict)\\n    generated_at: str = field(default_factory=lambda: datetime.now().isoformat())\\n    job_id: int = 0\\n    candidate_id: int = 0\\n    session_id: int = 0\\n\\n    def to_dict(self) -> Dict[str, Any]:\\n        \\\"\\\"\\\"Return a fully serializable dict of the report.\\\"\\\"\\\"\\n        data = asdict(self)\\n        # Explicitly re-flatten nested dataclasses\\n        data[\\\"resume_job_match\\\"] = asdict(self.resume_job_match)\\n        data[\\\"interview_summary\\\"] = {\\n            \\\"summary_text\\\": self.interview_summary.summary_text,\\n            \\\"questions_and_answers\\\": self.interview_summary.questions_and_answers\\n        }\\n        data[\\\"technical_assessment\\\"] = asdict(self.technical_assessment)\\n        data[\\\"behavioral_assessment\\\"] = asdict(self.behavioral_assessment)\\n        # scoring_breakdown stays as-is (it’s already a dict)\\n        return data\\n\\n    def to_json(self, **kwargs) -> str:\\n        \\\"\\\"\\\"Return JSON string of the report.\\\"\\\"\\\"\\n        return json.dumps(self.to_dict(), indent=2, sort_keys=True, default=str, **kwargs)\\n\\n# ----------------------------\\n# Report Generator\\n# ----------------------------\\n\\nclass FinalReportGenerator:\\n    MARKDOWN_TEMPLATE = \\\"\\\"\\\"\\n# Final Candidate Evaluation Report\\n\\n**Report Date:** {{ generated_at }}\\n\\n**Candidate:** {{ candidate_name }}  \\n**Job Title:** {{ job_title }}\\n\\n---\\n\\n## 1. Resume-Job Match Analysis  \\n**Score:** {{ resume_job_match.score }}  \\n**Highlights:**\\n{% for h in resume_job_match.highlights -%}\\n- {{ h }}\\n{% endfor %}\\n**Details:**  \\n{{ resume_job_match.details }}\\n\\n**Job Skills:**\\n{% for skill in resume_job_match.job_skills -%}\\n- {{ skill }}\\n{% endfor %}\\n\\n**Resume Skills:**\\n{% for skill in resume_job_match.resume_skills -%}\\n- {{ skill }}\\n{% endfor %}\\n\\n---\\n\\n## 2. Interview Summary  \\n{{ interview_summary.summary_text }}\\n\\n**Questions & Answers:**\\n{% for qa in interview_summary.questions_and_answers -%}\\n- Q: {{ qa.question }}\\n  A: {{ qa.answer }}\\n{% endfor %}\\n\\n---\\n\\n## 3. Technical Assessment  \\n**Score:** {{ technical_assessment.score }}  \\n**Comments:**  \\n{{ technical_assessment.comments }}\\n\\n**Scoring Breakdown:**\\n```json\\n{{ technical_assessment.scoring_breakdown | tojson(indent=2) }}\\n```\\n**Justification:**  \\n{{ technical_assessment.justification }}\\n\\n---\\n\\n## 4. Behavioral Assessment  \\n**Score:** {{ behavioral_assessment.score }}  \\n**Comments:**  \\n{{ behavioral_assessment.comments }}\\n\\n**Scoring Breakdown:**\\n```json\\n{{ behavioral_assessment.scoring_breakdown | tojson(indent=2) }}\\n```\\n**Justification:**  \\n{{ behavioral_assessment.justification }}\\n\\n---\\n\\n## 5. Strengths\\n{% for s in strengths -%}\\n- {{ s }}\\n{% endfor %}\\n\\n## 6. Weaknesses\\n{% for w in weaknesses -%}\\n- {{ w }}\\n{% endfor %}\\n\\n---\\n\\n## 7. Final Recommendation  \\n{{ final_recommendation }}\\n\\n---\\n\\n## 8. Overall Score  \\n{{ overall_score }}\\n\\n## 9. Scoring Breakdown  \\n```json\\n{{ scoring_breakdown | tojson(indent=2) }}\\n```\\n\\\"\\\"\\\"\\n\\n    def __init__(self):\\n        # Setup Jinja with a safe tojson filter that accepts indent\\n        self.jinja_env = Environment(loader=BaseLoader(), trim_blocks=True, lstrip_blocks=True)\\n        def _tojson(obj, indent=2):\\n            return json.dumps(obj, indent=indent, default=str)\\n        self.jinja_env.filters['tojson'] = _tojson\\n\\n    def generate_dict(self, data: ReportData) -> Dict[str, Any]:\\n        try:\\n            return data.to_dict()\\n        except Exception as e:\\n            logger.error(f\\\"Failed to generate report dict: {e}\\\")\\n            raise\\n\\n    def generate_json(self, data: ReportData) -> str:\\n        try:\\n            return data.to_json()\\n        except Exception as e:\\n            logger.error(f\\\"Failed to generate report JSON: {e}\\\")\\n            raise\\n\\n    def generate_markdown(self, data: ReportData) -> str:\\n        try:\\n            # Flatten data into context\\n            context = data.to_dict()\\n            template = self.jinja_env.from_string(self.MARKDOWN_TEMPLATE)\\n            return template.render(**context)\\n        except Exception as e:\\n            logger.error(f\\\"Failed to generate report Markdown: {e}\\\")\\n            raise\\n\\n    def save_to_file(self, content: str, filename: str) -> None:\\n        try:\\n            with open(filename, \\\"w\\\", encoding=\\\"utf-8\\\") as f:\\n                f.write(content)\\n            logger.info(f\\\"Report saved to {filename}\\\")\\n        except Exception as e:\\n            logger.error(f\\\"Failed to save report to file {filename}: {e}\\\")\\n            raise\\n\\n# ----------------------------\\n# Example Usage\\n# ----------------------------\\n\\nif __name__ == \\\"__main__\\\":\\n    # Populate ReportData (dummy or real)...\\n    report_data = ReportData(\\n        candidate_name=\\\"John Doe\\\",\\n        job_title=\\\"Software Engineer\\\",\\n        resume_job_match=ResumeJobMatchData(\\n            score=0.92,\\n            highlights=[\\\"Python expert\\\", \\\"Built 3 full-stack apps\\\"],\\n            details=\\\"Strong fit, slight AWS gap.\\\",\\n            job_skills=[\\\"Python\\\", \\\"JavaScript\\\", \\\"SQL\\\"],\\n            resume_skills=[\\\"Python\\\", \\\"JavaScript\\\"]\\n        ),\\n        interview_summary=InterviewSummaryData(\\n            summary_text=\\\"Demonstrated solid technical knowledge and communication.\\\",\\n            questions_and_answers=[\\n                {\\\"question\\\": \\\"Explain quicksort.\\\", \\\"answer\\\": \\\"Pivot partitioning...\\\"},\\n                {\\\"question\\\": \\\"CI/CD practices?\\\", \\\"answer\\\": \\\"Use Jenkins pipelines.\\\"}\\n            ]\\n        ),\\n        technical_assessment=AssessmentData(\\n            score=0.88,\\n            comments=\\\"Understands algorithms well.\\\",\\n            scoring_breakdown={\\\"algorithms\\\": 0.9, \\\"architecture\\\": 0.85},\\n            justification=\\\"Clear explanation of sorting.\\\"\\n        ),\\n        behavioral_assessment=AssessmentData(\\n            score=0.93,\\n            comments=\\\"Great team player.\\\",\\n            scoring_breakdown={\\\"communication\\\": 0.95, \\\"adaptability\\\": 0.9},\\n            justification=\\\"Provided real-world examples.\\\"\\n        ),\\n        strengths=[\\\"Algorithms\\\", \\\"System Design\\\", \\\"Teamwork\\\"],\\n        weaknesses=[\\\"AWS experience\\\"],\\n        final_recommendation=\\\"Strong Hire\\\",\\n        overall_score=0.905,\\n        scoring_breakdown={\\n            \\\"technical\\\": 0.88,\\n            \\\"behavioral\\\": 0.93,\\n            \\\"problem_solving\\\": 0.90,\\n            \\\"communication\\\": 0.92\\n        },\\n        job_id=1,\\n        candidate_id=101,\\n        session_id=201\\n    )\\n\\n    generator = FinalReportGenerator()\\n\\n    # JSON output\\n    report_json = generator.generate_json(report_data)\\n    print(report_json)\\n    generator.save_to_file(report_json, \\\"candidate_report.json\\\")\\n\\n    # Markdown output\\n    report_md = generator.generate_markdown(report_data)\\n    print(report_md)\\n    generator.save_to_file(report_md, \\\"candidate_report.md\\\")\\n```\",\n  \"timestamp\": \"2026-05-26T15:57:38.485760\"\n}"}
