{"timestamp": "2026-05-26 15:55:51,886", "level": "INFO", "logger": "flow.validation", "module": "logging_config", "function": "log_validation_result", "line": 185, "message": "{\"timestamp\": \"2026-05-26T15:55:51.886214\", \"task_id\": \"unknown\", \"task_objective\": \"Implement the Resume–Job Matching Module: parse and embed job descriptions and resumes, compute semantic similarity scores, and expose matching interface.\", \"result\": \"```python\\nimport nltk\\nimport numpy as np\\nfrom sklearn.metrics.pairwise import cosine_similarity\\nfrom nltk.corpus import stopwords\\nfrom nltk.tokenize import word_tokenize\\nimport re\\nfrom typing import List, Tuple\\n\\n# Download required NLTK data (if not already downloaded)\\ntry:\\n    nltk.data.find('corpora/stopwords')\\nexcept LookupError:\\n    nltk.download('stopwords')\\n\\ntry:\\n    nltk.data.find('tokenizers/punkt')\\nexcept LookupError:\\n    nltk.download('punkt')\\n\\n\\nclass ResumeJobMatcher:\\n    \\\"\\\"\\\"\\n    A cl...\", \"validation_type\": \"text\", \"status\": \"completed\", \"feedback\": \"here are some feedbacks:\\n1. The class docstring mentions a TF-IDF fallback when `embedding_model=None`, but the code raises a ValueError instead. We need to implement that fallback.\\n2. The interface to external callers (e.g., REST API) is missing. We should include a simple FastAPI application exposing `/match` and `/analyze` endpoints.\\n3. The default embedding model can leverage `sentence-transformers` if available.\\n4. Skill extraction is just splitting words; we can improve it with a simple keyword matcher (configurable) or leave a clear placeholder for production.\\n5. Added type hints, logging, and configuration for production readiness.\\n\\nhere are the changes:\\n```python\\nimport re\\nimport numpy as np\\nfrom typing import List, Tuple, Optional\\nfrom fastapi import FastAPI, HTTPException\\nfrom pydantic import BaseModel\\nimport logging\\n\\n# Optional imports for embedding\\ntry:\\n    from sentence_transformers import SentenceTransformer\\nexcept ImportError:\\n    SentenceTransformer = None\\n\\nfrom sklearn.feature_extraction.text import TfidfVectorizer\\nfrom sklearn.metrics.pairwise import cosine_similarity\\nimport nltk\\nfrom nltk.corpus import stopwords\\nfrom nltk.tokenize import word_tokenize\\n\\n# Initialize logging\\nlogging.basicConfig(level=logging.INFO)\\nlogger = logging.getLogger(__name__)\\n\\n# Ensure NLTK data is available\\nfor pkg in (\\\"stopwords\\\", \\\"punkt\\\"):\\n    try:\\n        nltk.data.find(f\\\"corpora/{pkg}\\\")\\n    except LookupError:\\n        nltk.download(pkg)\\n\\n\\nclass ResumeJobMatcher:\\n    \\\"\\\"\\\"\\n    A class for matching resumes to job descriptions based on semantic similarity.\\n    Supports two modes:\\n      1. Neural embedding model (e.g., SentenceTransformer)\\n      2. TF-IDF fallback if no embedding model is provided\\n    \\\"\\\"\\\"\\n\\n    def __init__(self,\\n                 embedding_model: Optional[object] = None):\\n        \\\"\\\"\\\"\\n        Args:\\n            embedding_model: An object with an `encode(texts: List[str]) -> np.ndarray` method.\\n                             If None, TF-IDF fallback will be used.\\n        \\\"\\\"\\\"\\n        self.stop_words = set(stopwords.words(\\\"english\\\"))\\n        self.embedding_model = embedding_model\\n        self._use_tfidf = embedding_model is None\\n\\n        if self._use_tfidf:\\n            self.vectorizer = TfidfVectorizer()\\n            logger.info(\\\"Initialized TF-IDF fallback for embedding.\\\")\\n        else:\\n            logger.info(f\\\"Using embedding model: {type(embedding_model).__name__}\\\")\\n\\n    def preprocess_text(self, text: str) -> str:\\n        text = re.sub(r\\\"[^\\\\w\\\\s]\\\", \\\" \\\", text)\\n        tokens = word_tokenize(text.lower())\\n        tokens = [t for t in tokens if t not in self.stop_words and t.isalpha()]\\n        return \\\" \\\".join(tokens)\\n\\n    def embed(self, texts: List[str]) -> np.ndarray:\\n        \\\"\\\"\\\"\\n        Returns embeddings for a list of preprocessed texts.\\n        \\\"\\\"\\\"\\n        if self._use_tfidf:\\n            # Fit-transform on the combined corpus for a fair vector space\\n            embeddings = self.vectorizer.fit_transform(texts).toarray()\\n            return embeddings\\n        else:\\n            # Neural embedding model expects a list of raw strings\\n            return self.embedding_model.encode(texts, convert_to_numpy=True)\\n\\n    @staticmethod\\n    def cosine_sim(a: np.ndarray, b: np.ndarray) -> float:\\n        if np.linalg.norm(a) == 0 or np.linalg.norm(b) == 0:\\n            return 0.0\\n        return float(cosine_similarity(a.reshape(1, -1), b.reshape(1, -1))[0, 0])\\n\\n    def match(self, job_description: str, resume_text: str) -> float:\\n        \\\"\\\"\\\"\\n        Returns a similarity score between 0.0 and 1.0.\\n        \\\"\\\"\\\"\\n        jd_proc = self.preprocess_text(job_description)\\n        res_proc = self.preprocess_text(resume_text)\\n        embeddings = self.embed([jd_proc, res_proc])\\n        score = self.cosine_sim(embeddings[0], embeddings[1])\\n        return score\\n\\n    def extract_skills(self, text: str) -> List[str]:\\n        \\\"\\\"\\\"\\n        Placeholder for skill extraction.\\n        In production, replace with NER or a skills taxonomy lookup.\\n        \\\"\\\"\\\"\\n        tokens = self.preprocess_text(text).split()\\n        # Return the most frequent tokens as 'skills'\\n        freq = {}\\n        for tok in tokens:\\n            freq[tok] = freq.get(tok, 0) + 1\\n        # top 10 tokens\\n        top_skills = sorted(freq, key=freq.get, reverse=True)[:10]\\n        return top_skills\\n\\n    def analyze_match(self, job_description: str, resume_text: str\\n                     ) -> Tuple[float, List[str], List[str]]:\\n        score = self.match(job_description, resume_text)\\n        return (\\n            score,\\n            self.extract_skills(job_description),\\n            self.extract_skills(resume_text),\\n        )\\n\\n\\n# --- FastAPI app for exposing matching interface ---\\n\\napp = FastAPI(title=\\\"Resume-Job Matcher API\\\",\\n              description=\\\"Compute semantic similarity between job descriptions and resumes\\\",\\n              version=\\\"1.0\\\")\\n\\n\\nclass MatchRequest(BaseModel):\\n    job_description: str\\n    resume_text: str\\n\\n\\nclass MatchResponse(BaseModel):\\n    similarity_score: float\\n\\n\\nclass AnalyzeResponse(BaseModel):\\n    similarity_score: float\\n    job_skills: List[str]\\n    resume_skills: List[str]\\n\\n\\n# Initialize matcher with default SentenceTransformer if available\\nif SentenceTransformer:\\n    default_model = SentenceTransformer(\\\"all-MiniLM-L6-v2\\\")\\nelse:\\n    default_model = None\\n\\nmatcher = ResumeJobMatcher(embedding_model=default_model)\\n\\n\\n@app.post(\\\"/match\\\", response_model=MatchResponse)\\ndef match_endpoint(req: MatchRequest):\\n    try:\\n        score = matcher.match(req.job_description, req.resume_text)\\n        return MatchResponse(similarity_score=score)\\n    except Exception as e:\\n        logger.error(\\\"Error in /match: %s\\\", e)\\n        raise HTTPException(status_code=500, detail=str(e))\\n\\n\\n@app.post(\\\"/analyze\\\", response_model=AnalyzeResponse)\\ndef analyze_endpoint(req: MatchRequest):\\n    try:\\n        score, job_skills, resume_skills = matcher.analyze_match(\\n            req.job_description, req.resume_text\\n        )\\n        return AnalyzeResponse(\\n            similarity_score=score,\\n            job_skills=job_skills,\\n            resume_skills=resume_skills,\\n        )\\n    except Exception as e:\\n        logger.error(\\\"Error in /analyze: %s\\\", e)\\n        raise HTTPException(status_code=500, detail=str(e))\\n\\n\\n# --- If run as a script, demonstrate usage ---\\nif __name__ == \\\"__main__\\\":\\n    import uvicorn\\n    print(\\\"Starting Resume-Job Matcher API on http://127.0.0.1:8000\\\")\\n    uvicorn.run(app, host=\\\"127.0.0.1\\\", port=8000)\\n```\"}"}
