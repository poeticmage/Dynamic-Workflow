: Resume retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  resume_id:\\n                    type: string\\n                    description: Unique identifier for the resume\\n                  candidate_name:\\n                    type: string\\n                    description: Name of the candidate\\n                  resume_text:\\n                    type: string\\n                    description: Text content of the resume\\n                  email:\\n                    type: string\\n                    format: email\\n                    description: Candidate's email address\\n                  skills:\\n                    type: array\\n                    items:\\n                      type: string\\n                    description: List of skills extracted from the resume\\n                example:\\n                  resume_id: resume456\\n                  candidate_name: John Doe\\n                  resume_text: Experienced software engineer with Python and Javascript skills.\\n                  email: john.doe@example.com\\n                  skills: [Python, Javascript, SQL]\\n        '404':\\n          description: Resume not found\\n\\n  /interviews:\\n    post:\\n      summary: Start a new interview session\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                job_id:\\n                  type: string\\n                  description: ID of the job for the interview\\n                resume_id:\\n                  type: string\\n                  description: ID of the candidate's resume\\n              example:\\n                job_id: job123\\n                resume_id: resume456\\n      responses:\\n        '201':\\n          description: Interview session started successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  interview_id:\\n                    type: string\\n                    description: Unique identifier for the interview session\\n                  first_question:\\n                    type: string\\n                    description: The first question to ask the candidate\\n                example:\\n                  interview_id: interview789\\n                  first_question: \\\"Tell me about your experience with Python.\\\"\\n        '400':\\n          description: Invalid request\\n        '404':\\n          description: Job or Resume not found\\n\\n  /interviews/{interview_id}/questions:\\n    get:\\n      summary: Get the current or next question in the interview\\n      parameters:\\n        - in: path\\n          name: interview_id\\n          required: true\\n          schema:\\n            type: string\\n          description: Unique identifier for the interview session\\n      responses:\\n        '200':\\n          description: Question retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  question:\\n                    type: string\\n                    description: The question to ask the candidate\\n                example:\\n                  question: \\\"Explain the difference between '==' and '===' in Javascript.\\\"\\n        '404':\\n          description: Interview not found\\n\\n  /interviews/{interview_id}/responses:\\n    post:\\n      summary: Submit a candidate's response to a question\\n      parameters:\\n        - in: path\\n          name: interview_id\\n          required: true\\n          schema:\\n            type: string\\n          description: Unique identifier for the interview session\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                question:\\n                  type: string\\n                  description: The question being answered.\\n                response:\\n                  type: string\\n                  description: The candidate's answer to the question\\n              example:\\n                question: \\\"Explain the difference between '==' and '===' in Javascript.\\\"\\n                response: \\\"'==' compares values, while '===' compares values and types.\\\"\\n      responses:\\n        '200':\\n          description: Response submitted successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  next_question:\\n                    type: string\\n                    nullable: true\\n                    description: The next question to ask, or null if the interview is complete\\n                  evaluation:\\n                    type: object\\n                    description: Evaluation of the response\\n                    properties:\\n                      relevance:\\n                        type: number\\n                        format: float\\n                        description: Relevance score (0-1)\\n                      depth:\\n                        type: number\\n                        format: float\\n                        description: Depth score (0-1)\\n                      confidence:\\n                        type: number\\n                        format: float\\n                        description: Confidence score (0-1)\\n                      technical_accuracy:\\n                        type: number\\n                        format: float\\n                        description: Technical accuracy score (0-1)\\n                    example:\\n                      relevance: 0.9\\n                      depth: 0.8\\n                      confidence: 0.7\\n                      technical_accuracy: 0.95\\n                example:\\n                  next_question: \\\"How would you optimize a slow SQL query?\\\"\\n                  evaluation:\\n                    relevance: 0.9\\n                    depth: 0.8\\n                    confidence: 0.7\\n                    technical_accuracy: 0.95\\n        '400':\\n          description: Invalid request\\n        '404':\\n          description: Interview not found\\n\\n  /interviews/{interview_id}/scores:\\n    get:\\n      summary: Retrieve the candidate's scores for the interview\\n      parameters:\\n        - in: path\\n          name: interview_id\\n          required: true\\n          schema:\\n            type: string\\n          description: Unique identifier for the interview session\\n      responses:\\n        '200':\\n          description: Scores retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  technical_score:\\n                    type: number\\n                    format: float\\n                    description: Overall technical score\\n                  behavioral_score:\\n                    type: number\\n                    format: float\\n                    description: Overall behavioral score\\n                  overall_score:\\n                    type: number\\n                    format: float\\n                    description: Overall score\\n                  category_scores:\\n                    type: object\\n                    description: Scores for individual categories\\n                    properties:\\n                      problem_solving:\\n                        type: number\\n                        format: float\\n                        description: Problem-solving score\\n                      communication:\\n                        type: number\\n                        format: float\\n                        description: Communication score\\n                    example:\\n                      problem_solving: 0.85\\n                      communication: 0.9\\n                example:\\n                  technical_score: 0.8\\n                  behavioral_score: 0.9\\n                  overall_score: 0.85\\n                  category_scores:\\n                    problem_solving: 0.85\\n                    communication: 0.9\\n        '404':\\n          description: Interview not found\\n\\n  /emails/invite:\\n    post:\\n      summary: Generate and send an interview invitation email\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                candidate_email:\\n                  type: string\\n                  format: email\\n                  description: Candidate's email address\\n                job_title:\\n                  type: string\\n                  description: Job title\\n                interview_date:\\n                  type: string\\n                  format: date-time\\n                  description: Date and time of the interview\\n                interviewer_name:\\n                  type: string\\n                  description: Name of the interviewer\\n              example:\\n                candidate_email: john.doe@example.com\\n                job_title: Software Engineer\\n                interview_date: \\\"2024-01-20T10:00:00Z\\\"\\n                interviewer_name: Jane Smith\\n      responses:\\n        '200':\\n          description: Email sent successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  message:\\n                    type: string\\n                    description: Confirmation message\\n                example:\\n                  message: \\\"Interview invitation email sent to john.doe@example.com\\\"\\n        '400':\\n          description: Invalid request\\n        '500':\\n          description: Email sending failed\\n\\n  /emails/followup:\\n    post:\\n      summary: Generate and send a follow-up email to the candidate\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              properties:\\n                candidate_email:\\n                  type: string\\n                  format: email\\n                  description: Candidate's email address\\n                interview_id:\\n                  type: string\\n                  description: Interview ID\\n              example:\\n                candidate_email: john.doe@example.com\\n                interview_id: interview789\\n      responses:\\n        '200':\\n          description: Email sent successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  message:\\n                    type: string\\n                    description: Confirmation message\\n                example:\\n                  message: \\\"Follow-up email sent to john.doe@example.com\\\"\\n        '400':\\n          description: Invalid request\\n        '500':\\n          description: Email sending failed\\n\\n  /reports/{interview_id}:\\n    get:\\n      summary: Retrieve the final candidate evaluation report\\n      parameters:\\n        - in: path\\n          name: interview_id\\n          required: true\\n          schema:\\n            type: string\\n          description: Unique identifier for the interview session\\n      responses:\\n        '200':\\n          description: Report retrieved successfully\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  resume_job_match_analysis:\\n                    type: string\\n                    description: Analysis of how well the resume matches the job description\\n                  interview_summary:\\n                    type: string\\n                    description: Summary of the interview\\n                  technical_assessment:\\n                    type: string\\n                    description: Assessment of the candidate's technical skills\\n                  behavioral_assessment:\\n                    type: string\\n                    description: Assessment of the candidate's behavioral traits\\n                  strengths:\\n                    type: array\\n                    items:\\n                      type: string\\n                    description: List of the candidate's strengths\\n                  weaknesses:\\n                    type: array\\n                    items:\\n                      type: string\\n                    description: List of the candidate's weaknesses\\n                  final_recommendation:\\n                    type: string\\n                    description: Final recommendation (Hire/No Hire/Maybe)\\n                  scoring_breakdown:\\n                    type: object\\n                    description: Detailed breakdown of the candidate's scores\\n                    properties:\\n                      technical_score:\\n                        type: number\\n                        format: float\\n                        description: Overall technical score\\n                      behavioral_score:\\n                        type: number\\n                        format: float\\n                        description: Overall behavioral score\\n                      overall_score:\\n                        type: number\\n                        format: float\\n                        description: Overall score\\n                    example:\\n                      technical_score: 0.8\\n                      behavioral_score: 0.9\\n                      overall_score: 0.85\\n                example:\\n                  resume_job_match_analysis: \\\"The candidate's resume closely matches the job description, with strong skills in Python and Javascript.\\\"\\n                  interview_summary: \\\"The candidate performed well in the interview, demonstrating strong technical knowledge and communication skills.\\\"\\n                  technical_assessment: \\\"The candidate has a solid understanding of software engineering principles and is proficient in Python and Javascript.\\\"\\n                  behavioral_assessment: \\\"The candidate is a good communicator and works well in a team environment.\\\"\\n                  strengths: [\\\"Technical Skills\\\", \\\"Communication\\\", \\\"Problem Solving\\\"]\\n                  weaknesses: [\\\"Lack of experience with AWS\\\"]\\n                  final_recommendation: \\\"Hire\\\"\\n                  scoring_breakdown:\\n                    technical_score: 0.8\\n                    behavioral_score: 0.9\\n                    overall_score: 0.85\\n        '404':\\n          description: Report not found\\ncomponents:\\n  schemas:\\n    Error:\\n      type: object\\n      properties:\\n        message:\\n          type: string\\n          description: Error message\\n      example:\\n        message: \\\"An error occurred\\\"\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task6:\\n  Objective: Implement the Final Report Generation Module: assemble resume-job match data, interview summaries, technical and behavioral assessments, strengths/weaknesses, and recommendations into a structured report.\\n\\n---\\n# **Current Task Requirements**\\nDevelop the Candidate Evaluation & Scoring Logic: analyze candidate responses for relevance, depth, confidence, and technical accuracy; compute composite scores across defined categories.\\n\\n---\\n\\n# **Required Output Format**\\nPython code (module)\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport math\\n\\ndef calculate_relevance_score(response, expected_answer, job_description):\\n    \\\"\\\"\\\"\\n    Calculates a relevance score based on the presence of keywords\\n    from the expected answer and job description in the candidate's response.\\n\\n    Args:\\n        response (str): The candidate's response.\\n        expected_answer (str): The expected answer to the question.\\n        job_description (str): The job description.\\n\\n    Returns:\\n        float: The relevance score (0.0 to 1.0).\\n    \\\"\\\"\\\"\\n    response_keywords = set(response.lower().split())\\n    expected_keywords = set(expected_answer.lower().split())\\n    job_keywords = set(job_description.lower().split())\\n\\n    relevant_keywords = expected_keywords.union(job_keywords)\\n\\n    common_keywords = response_keywords.intersection(relevant_keywords)\\n\\n    relevance_score = len(common_keywords) / max(1, len(relevant_keywords))\\n    return relevance_score\\n\\n\\ndef calculate_depth_score(response, expected_answer):\\n    \\\"\\\"\\\"\\n    Calculates a depth score based on the length and complexity\\n    of the candidate's response compared to the expected answer.\\n\\n    Args:\\n        response (str): The candidate's response.\\n        expected_answer (str): The expected answer to the question.\\n\\n    Returns:\\n        float: The depth score (0.0 to 1.0).\\n    \\\"\\\"\\\"\\n    response_length = len(response.split())\\n    expected_length = len(expected_answer.split())\\n\\n    # Normalize the response length by the expected length\\n    depth_score = min(1.0, response_length / max(1, expected_length))\\n\\n    # Apply a sigmoid function to moderate the score\\n    depth_score = 1 / (1 + math.exp(-5 * (depth_score - 0.5)))\\n\\n    return depth_score\\n\\n\\ndef calculate_confidence_score(response):\\n    \\\"\\\"\\\"\\n    Calculates a confidence score based on the presence of confident language\\n    and the absence of hesitant language in the candidate's response.\\n\\n    Args:\\n        response (str): The candidate's response.\\n\\n    Returns:\\n        float: The confidence score (0.0 to 1.0).\\n    \\\"\\\"\\\"\\n    confident_keywords = [\\\"I am confident\\\", \\\"I know\\\", \\\"I have experience\\\", \\\"definitely\\\", \\\"certainly\\\"]\\n    hesitant_keywords = [\\\"I think\\\", \\\"I believe\\\", \\\"I'm not sure\\\", \\\"maybe\\\", \\\"possibly\\\"]\\n\\n    confident_score = sum([1 for keyword in confident_keywords if keyword.lower() in response.lower()])\\n    hesitant_score = sum([1 for keyword in hesitant_keywords if keyword.lower() in response.lower()])\\n\\n    confidence_score = (confident_score + 1) / (confident_score + hesitant_score + 2)  # Add small constant to avoid division by zero\\n\\n    return confidence_score\\n\\n\\ndef calculate_technical_accuracy_score(response, expected_answer):\\n    \\\"\\\"\\\"\\n    Calculates a technical accuracy score based on the correctness\\n    of the candidate's response compared to the expected answer.\\n    This is a simplified example and would ideally use a more sophisticated\\n    method such as semantic similarity analysis.\\n\\n    Args:\\n        response (str): The candidate's response.\\n        expected_answer (str): The expected answer to the question.\\n\\n    Returns:\\n        float: The technical accuracy score (0.0 to 1.0).\\n    \\\"\\\"\\\"\\n    response_keywords = set(response.lower().split())\\n    expected_keywords = set(expected_answer.lower().split())\\n\\n    correct_keywords = response_keywords.intersection(expected_keywords)\\n\\n    accuracy_score = len(correct_keywords) / max(1, len(expected_keywords))\\n\\n    return accuracy_score\\n\\n\\ndef compute_composite_scores(relevance, depth, confidence, technical_accuracy):\\n    \\\"\\\"\\\"\\n    Computes composite scores for different categories based on the\\n    individual scores.\\n\\n    Args:\\n        relevance (float): The relevance score.\\n        depth (float): The depth score.\\n        confidence (float): The confidence score.\\n        technical_accuracy (float): The technical accuracy score.\\n\\n    Returns:\\n        dict: A dictionary containing the composite scores for technical skills,\\n              communication skills, problem-solving, and an overall score.\\n    \\\"\\\"\\\"\\n    technical_skills = (depth + technical_accuracy) / 2.0\\n    communication_skills = (relevance + confidence) / 2.0\\n    problem_solving = (relevance + depth + technical_accuracy) / 3.0\\n    overall_score = (technical_skills + communication_skills + problem_solving) / 3.0\\n\\n    return {\\n        \\\"technical_skills\\\": technical_skills,\\n        \\\"communication_skills\\\": communication_skills,\\n        \\\"problem_solving\\\": problem_solving,\\n        \\\"overall_score\\\": overall_score\\n    }\\n\\n\\ndef evaluate_candidate_response(response, question, expected_answer, job_description):\\n    \\\"\\\"\\\"\\n    Evaluates a candidate's response based on relevance, depth,\\n    confidence, and technical accuracy, and computes composite scores.\\n\\n    Args:\\n        response (str): The candidate's response.\\n        question (str): The question asked.\\n        expected_answer (str): The expected answer to the question.\\n        job_description (str): The job description.\\n\\n    Returns:\\n        dict: A dictionary containing the individual scores and composite scores.\\n    \\\"\\\"\\\"\\n    relevance = calculate_relevance_score(response, expected_answer, job_description)\\n    depth = calculate_depth_score(response, expected_answer)\\n    confidence = calculate_confidence_score(response)\\n    technical_accuracy = calculate_technical_accuracy_score(response, expected_answer)\\n\\n    composite_scores = compute_composite_scores(relevance, depth, confidence, technical_accuracy)\\n\\n    return {\\n        \\\"relevance\\\": relevance,\\n        \\\"depth\\\": depth,\\n        \\\"confidence\\\": confidence,\\n        \\\"technical_accuracy\\\": technical_accuracy,\\n        **composite_scores\\n    }\\n\\nif __name__ == '__main__':\\n    # Example Usage\\n    response = \\\"I have experience with Python and Javascript and I am confident in my ability to develop and maintain software applications. I think I know SQL.\\\"\\n    question = \\\"Tell me about your experience with Python and Javascript.\\\"\\n    expected_answer = \\\"Experience with Python and Javascript is required.\\\"\\n    job_description = \\\"Software Engineer: Develop and maintain software applications. Experience with Python and Javascript required.\\\"\\n\\n    evaluation_results = evaluate_candidate_response(response, question, expected_answer, job_description)\\n    print(evaluation_results)\\n```\\n\",\n  \"timestamp\": \"2026-05-26T15:55:41.137498\"\n}"}
