n period.\\n3. The `draw_next_tetromino` uses `get_blocks()` without coordinates, and translating block positions via integer division leads to incorrect placement.\\n4. We should pause tetromino dropping and input handling while the clear animation runs.\\n5. After animation completes, cleared lines should be reset.\\n\\nhere are the changes:\\n```python\\nimport pygame\\nimport random\\nfrom enum import Enum\\nfrom task0 import (\\n    GRID_WIDTH,\\n    GRID_HEIGHT,\\n    CellState,\\n    Cell,\\n    Grid,\\n    BASE_SHAPES,\\n    Tetromino\\n)\\n\\n# Pygame Constants\\nSCREEN_WIDTH = GRID_WIDTH * 30 + 200  # extra space for preview & score\\nSCREEN_HEIGHT = GRID_HEIGHT * 30\\nGRID_LINE_COLOR = (50, 50, 50)\\nEMPTY_COLOR = (30, 30, 30)\\nBLOCK_SIZE = 30\\nSPAWN_X = GRID_WIDTH // 2 - 2\\nSPAWN_Y = 0\\nPREVIEW_POS = (GRID_WIDTH * BLOCK_SIZE + 20, 50)\\n\\nclass GameState(Enum):\\n    ACTIVE = 0\\n    PAUSED = 1\\n    GAME_OVER = 2\\n\\nclass TetrisJeweled:\\n    def __init__(self):\\n        pygame.init()\\n        self.screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\\n        pygame.display.set_caption(\\\"Tetris Jeweled\\\")\\n        self.clock = pygame.time.Clock()\\n        self.grid = Grid()\\n        self.current_tetromino = self.new_tetromino()\\n        self.next_tetromino = self.new_tetromino()\\n        self.tetromino_x = SPAWN_X\\n        self.tetromino_y = SPAWN_Y\\n        self.game_state = GameState.ACTIVE\\n        self.score = 0\\n        self.drop_speed = 500  # milliseconds per drop\\n        self.last_drop_time = pygame.time.get_ticks()\\n        # Animation for line clear\\n        self.animation_frames = 15  # number of frames to flash\\n        self.animation_timer = 0\\n        self.cleared_lines = []\\n\\n    def new_tetromino(self):\\n        shape = random.choice(list(BASE_SHAPES.keys()))\\n        return Tetromino(shape)\\n\\n    def run(self):\\n        running = True\\n        while running:\\n            dt = self.clock.tick(60)\\n            for event in pygame.event.get():\\n                if event.type == pygame.QUIT:\\n                    running = False\\n                elif event.type == pygame.KEYDOWN:\\n                    if event.key == pygame.K_p and self.game_state == GameState.ACTIVE:\\n                        self.game_state = GameState.PAUSED\\n                    elif event.key == pygame.K_p and self.game_state == GameState.PAUSED:\\n                        self.game_state = GameState.ACTIVE\\n                    # only handle move/rotate/drop when active and not animating\\n                    elif (self.game_state == GameState.ACTIVE and self.animation_timer == 0):\\n                        if event.key == pygame.K_LEFT:\\n                            self.move_tetromino(-1, 0)\\n                        elif event.key == pygame.K_RIGHT:\\n                            self.move_tetromino(1, 0)\\n                        elif event.key == pygame.K_DOWN:\\n                            self.move_tetromino(0, 1)\\n                        elif event.key == pygame.K_UP:\\n                            self.rotate_tetromino()\\n                        elif event.key == pygame.K_SPACE:\\n                            self.drop_tetromino()\\n\\n            if self.game_state == GameState.ACTIVE:\\n                self.update(dt)\\n\\n            self.render()\\n            pygame.display.flip()\\n\\n        pygame.quit()\\n\\n    def update(self, dt):\\n        # if animating clear, just count down\\n        if self.animation_timer > 0:\\n            self.animation_timer -= 1\\n            if self.animation_timer == 0:\\n                # after animation, clear record\\n                self.cleared_lines.clear()\\n            return\\n\\n        # normal gravity drop\\n        now = pygame.time.get_ticks()\\n        if now - self.last_drop_time >= self.drop_speed:\\n            self.move_tetromino(0, 1)\\n            self.last_drop_time = now\\n\\n    def move_tetromino(self, dx, dy):\\n        new_x = self.tetromino_x + dx\\n        new_y = self.tetromino_y + dy\\n        if self.is_valid_position(new_x, new_y, self.current_tetromino):\\n            self.tetromino_x = new_x\\n            self.tetromino_y = new_y\\n        elif dy != 0:\\n            # hit bottom / landed\\n            self.lock_tetromino()\\n\\n    def rotate_tetromino(self):\\n        old_index = self.current_tetromino.rotation_index\\n        self.current_tetromino.rotate()\\n        if not self.is_valid_position(self.tetromino_x, self.tetromino_y, self.current_tetromino):\\n            # revert\\n            self.current_tetromino.rotation_index = old_index\\n            self.current_tetromino.blocks = list(self.current_tetromino.rotations[old_index])\\n\\n    def drop_tetromino(self):\\n        while self.is_valid_position(self.tetromino_x, self.tetromino_y + 1, self.current_tetromino):\\n            self.tetromino_y += 1\\n        self.lock_tetromino()\\n\\n    def is_valid_position(self, x, y, tetromino):\\n        for bx, by in tetromino.get_blocks(x, y):\\n            if not self.grid.is_inside(bx, by):\\n                return False\\n            if self.grid.get_cell(bx, by).state == CellState.FILLED:\\n                return False\\n        return True\\n\\n    def lock_tetromino(self):\\n        for bx, by in self.current_tetromino.get_blocks(self.tetromino_x, self.tetromino_y):\\n            self.grid.set_cell(bx, by, CellState.FILLED, self.current_tetromino.color)\\n        self.clear_lines()\\n        # spawn next\\n        self.current_tetromino = self.next_tetromino\\n        self.next_tetromino = self.new_tetromino()\\n        self.tetromino_x = SPAWN_X\\n        self.tetromino_y = SPAWN_Y\\n        if not self.is_valid_position(self.tetromino_x, self.tetromino_y, self.current_tetromino):\\n            self.game_state = GameState.GAME_OVER\\n\\n    def clear_lines(self):\\n        lines = []\\n        # find full rows\\n        for y in range(self.grid.height):\\n            if all(self.grid.get_cell(x, y).state == CellState.FILLED for x in range(self.grid.width)):\\n                lines.append(y)\\n        if not lines:\\n            return\\n\\n        # record for animation highlight\\n        self.cleared_lines = lines.copy()\\n        # remove lines top-down to keep indexes consistent\\n        for y in sorted(lines):\\n            for x in range(self.grid.width):\\n                self.grid.set_cell(x, y, CellState.EMPTY, None)\\n            # move rows above down\\n            for yy in range(y - 1, -1, -1):\\n                for x in range(self.grid.width):\\n                    cell = self.grid.get_cell(x, yy)\\n                    self.grid.set_cell(x, yy + 1, cell.state, cell.color)\\n                    self.grid.set_cell(x, yy, CellState.EMPTY, None)\\n\\n        self.score += self.calculate_score(len(lines))\\n        self.animation_timer = self.animation_frames\\n\\n    def calculate_score(self, n):\\n        return {1:100, 2:300, 3:500, 4:800}.get(n, n*200)\\n\\n    def render(self):\\n        self.screen.fill((0, 0, 0))\\n        self.draw_grid()\\n        if self.current_tetromino and self.game_state != GameState.GAME_OVER:\\n            self.draw_tetromino()\\n        self.draw_next_tetromino()\\n        self.draw_score()\\n        if self.game_state == GameState.PAUSED:\\n            self.draw_overlay(\\\"Paused\\\")\\n        elif self.game_state == GameState.GAME_OVER:\\n            self.draw_overlay(\\\"Game Over\\\", final=True)\\n\\n    def draw_grid(self):\\n        for x in range(self.grid.width):\\n            for y in range(self.grid.height):\\n                cell = self.grid.get_cell(x, y)\\n                rect = pygame.Rect(x * BLOCK_SIZE, y * BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE)\\n                # if animating this line, flash white\\n                if self.animation_timer > 0 and y in self.cleared_lines:\\n                    color = (255, 255, 255) if (self.animation_timer % 2 == 0) else EMPTY_COLOR\\n                else:\\n                    color = cell.color if cell.state == CellState.FILLED else EMPTY_COLOR\\n                pygame.draw.rect(self.screen, color, rect)\\n                pygame.draw.rect(self.screen, GRID_LINE_COLOR, rect, 1)\\n\\n    def draw_tetromino(self):\\n        for bx, by in self.current_tetromino.get_blocks(self.tetromino_x, self.tetromino_y):\\n            rect = pygame.Rect(bx * BLOCK_SIZE, by * BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE)\\n            pygame.draw.rect(self.screen, self.current_tetromino.color, rect)\\n            pygame.draw.rect(self.screen, GRID_LINE_COLOR, rect, 1)\\n\\n    def draw_next_tetromino(self):\\n        font = pygame.font.Font(None, 30)\\n        label = font.render(\\\"Next Piece:\\\", True, (255, 255, 255))\\n        self.screen.blit(label, (PREVIEW_POS[0], PREVIEW_POS[1] - 30))\\n        # draw at (0,0) of preview space\\n        for bx, by in self.next_tetromino.get_blocks(0, 0):\\n            px = PREVIEW_POS[0] + bx * BLOCK_SIZE\\n            py = PREVIEW_POS[1] + by * BLOCK_SIZE\\n            rect = pygame.Rect(px, py, BLOCK_SIZE, BLOCK_SIZE)\\n            pygame.draw.rect(self.screen, self.next_tetromino.color, rect)\\n            pygame.draw.rect(self.screen, GRID_LINE_COLOR, rect, 1)\\n\\n    def draw_score(self):\\n        font = pygame.font.Font(None, 36)\\n        text = font.render(f\\\"Score: {self.score}\\\", True, (255, 255, 255))\\n        # position below preview\\n        self.screen.blit(text, (PREVIEW_POS[0], PREVIEW_POS[1] + 150))\\n\\n    def draw_overlay(self, text, final=False):\\n        overlay = pygame.Surface((SCREEN_WIDTH, SCREEN_HEIGHT), pygame.SRCALPHA)\\n        overlay.fill((0, 0, 0, 180))\\n        self.screen.blit(overlay, (0, 0))\\n        font_size = 72 if not final else 72\\n        font = pygame.font.Font(None, font_size)\\n        label = font.render(text, True, (255, 255, 255))\\n        rect = label.get_rect(center=(SCREEN_WIDTH // 2, SCREEN_HEIGHT // 2 - (0 if final else 0)))\\n        self.screen.blit(label, rect)\\n        if final:\\n            sub = pygame.font.Font(None, 48).render(f\\\"Final Score: {self.score}\\\", True, (255,255,255))\\n            sub_rect = sub.get_rect(center=(SCREEN_WIDTH//2, SCREEN_HEIGHT//2 + 60))\\n            self.screen.blit(sub, sub_rect)\\n\\nif __name__ == '__main__':\\n    game = TetrisJeweled()\\n    game.run()\\n```\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"# **The Overall Goal**\\nDevelop a game that fuses Tetris and Bejeweled mechanics. \\nThis game needs to add keyboard control function.\\nFalling tetrominoes should lock into a grid and transform into colored gems. \\nThe game must support both Tetris line-clearing and Bejeweled match-3 clearing, triggering chain reactions and bonus points. \\nInclude a GUI (using a framework like Pygame) that displays the game grid, current score, and next tetromino preview, along with smooth animations. \\nNo sound effects are needed.\\n\\nOutput Format: python\\n\\n---\\n# **Context from Upstream Tasks**\\nTask task0:\\n  Objective: Implement core data structures: grid representation, cell states, and tetromino shape definitions with rotation matrices.\\n  Result: import enum\\n\\nGRID_WIDTH = 10\\nGRID_HEIGHT = 20\\n\\nclass CellState(enum.Enum):\\n    EMPTY = 0\\n    FILLED = 1\\n\\nclass Cell:\\n    __slots__ = (\\\"state\\\", \\\"color\\\")\\n    def __init__(self, state=CellState.EMPTY, color=None):\\n        self.state = state\\n        self.color = color\\n\\nclass Grid:\\n    def __init__(self, width=GRID_WIDTH, height=GRID_HEIGHT):\\n        self.width = width\\n        self.height = height\\n        self.cells = [[Cell() for _ in range(width)] for _ in range(height)]\\n    def is_inside(self, x, y):\\n        return 0 <= x < self.width and 0 <= y < self.height\\n    def get_cell(self, x, y):\\n        return self.cells[y][x]\\n    def set_cell(self, x, y, state, color=None):\\n        cell = self.cells[y][x]\\n        cell.state = state\\n        cell.color = color\\n\\n# Rotation matrices\\nROT_90  = ((0, -1), (1, 0))\\nROT_180 = ((-1, 0), (0, -1))\\nROT_270 = ((0, 1), (-1, 0))\\n\\ndef rotate_point(px, py, matrix):\\n    return px * matrix[0][0] + py * matrix[0][1], px * matrix[1][0] + py * matrix[1][1]\\n\\ndef generate_rotations(shape_coords):\\n    rotations = []\\n    current = shape_coords\\n    for matrix in (ROT_90, ROT_180, ROT_270):\\n        rotated = [rotate_point(x, y, matrix) for x, y in current]\\n        # normalize so min x,y is zero-based\\n        min_x = min(p[0] for p in rotated)\\n        min_y = min(p[1] for p in rotated)\\n        normalized = [(x - min_x, y - min_y) for x, y in rotated]\\n        rotations.append(normalized)\\n        current = rotated\\n    return rotations\\n\\n# Tetromino base shapes in spawn orientation with origin at (0,0)\\nBASE_SHAPES = {\\n    'I': [(0,1),(1,1),(2,1),(3,1)],\\n    'J': [(0,0),(0,1),(1,1),(2,1)],\\n    'L': [(2,0),(0,1),(1,1),(2,1)],\\n    'O': [(0,0),(1,0),(0,1),(1,1)],\\n    'S': [(1,0),(2,0),(0,1),(1,1)],\\n    'T': [(1,0),(0,1),(1,1),(2,1)],\\n    'Z': [(0,0),(1,0),(1,1),(2,1)],\\n}\\n\\nTETROMINO_COLORS = {\\n    'I': (0, 240, 240),\\n    'J': (0, 0, 240),\\n    'L': (240, 160, 0),\\n    'O': (240, 240, 0),\\n    'S': (0, 240, 0),\\n    'T': (160, 0, 240),\\n    'Z': (240, 0, 0),\\n}\\n\\nclass Tetromino:\\n    def __init__(self, shape_key):\\n        self.key = shape_key\\n        self.color = TETROMINO_COLORS[shape_key]\\n        base = BASE_SHAPES[shape_key]\\n        self.rotations = [base] + generate_rotations(base)\\n        self.rotation_index = 0\\n        self.blocks = list(self.rotations[self.rotation_index])\\n    def rotate(self, direction=1):\\n        self.rotation_index = (self.rotation_index + direction) % len(self.rotations)\\n        self.blocks = list(self.rotations[self.rotation_index])\\n    def get_blocks(self, offset_x=0, offset_y=0):\\n        return [(x + offset_x, y + offset_y) for x, y in self.blocks]\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task6:\\n  Objective: Integrate game state, input handler, and GUI renderer into a cohesive main loop with smooth animations and real-time updates.\\n\\n---\\n# **Current Task Requirements**\\nImplement the GUI renderer using Pygame: draw grid, current score, next piece preview, and manage animation frames.\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport pygame\\nimport random\\nfrom enum import Enum\\nfrom task0 import (\\n    GRID_WIDTH, GRID_HEIGHT,\\n    CellState, Grid,\\n    BASE_SHAPES, Tetromino\\n)\\n\\n# Pygame Constants\\nBLOCK_SIZE = 30\\nSCREEN_WIDTH = GRID_WIDTH * BLOCK_SIZE + 200\\nSCREEN_HEIGHT = GRID_HEIGHT * BLOCK_SIZE\\nGRID_LINE_COLOR = (50, 50, 50)\\nEMPTY_COLOR = (30, 30, 30)\\nSPAWN_X = GRID_WIDTH // 2 - 2\\nSPAWN_Y = 0\\nPREVIEW_POS = (GRID_WIDTH * BLOCK_SIZE + 20, 50)\\n\\nLINE_ANIM_FRAMES = 30\\nMATCH_ANIM_FRAMES = 20\\n\\nclass GameState(Enum):\\n    ACTIVE = 0\\n    PAUSED = 1\\n    GAME_OVER = 2\\n\\nclass TetrisJeweled:\\n    def __init__(self):\\n        pygame.init()\\n        self.screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\\n        pygame.display.set_caption(\\\"Tetris Jeweled\\\")\\n        self.clock = pygame.time.Clock()\\n        self.grid = Grid()\\n        self.current = self.new_tetromino()\\n        self.next_piece = self.new_tetromino()\\n        self.x = SPAWN_X\\n        self.y = SPAWN_Y\\n        self.state = GameState.ACTIVE\\n        self.score = 0\\n        self.drop_speed = 500\\n        self.last_drop = pygame.time.get_ticks()\\n        # animation & clearing\\n        self.animation_timer = 0\\n        self.animation_type = None  # 'line' or 'match'\\n        self.cleared_lines = []\\n        self.match_positions = set()\\n        self.chain = 1\\n        self.spawn_pending = False\\n\\n    def new_tetromino(self):\\n        return Tetromino(random.choice(list(BASE_SHAPES.keys())))\\n\\n    def run(self):\\n        running = True\\n        while running:\\n            dt = self.clock.tick(60)\\n            for evt in pygame.event.get():\\n                if evt.type == pygame.QUIT:\\n                    running = False\\n                elif evt.type == pygame.KEYDOWN:\\n                    if evt.key == pygame.K_p:\\n                        if self.state == GameState.ACTIVE:\\n                            self.state = GameState.PAUSED\\n                        elif self.state == GameState.PAUSED:\\n                            self.state = GameState.ACTIVE\\n                    elif (self.state == GameState.ACTIVE and self.animation_timer == 0):\\n                        if evt.key == pygame.K_LEFT:\\n                            self.move(-1,0)\\n                        elif evt.key == pygame.K_RIGHT:\\n                            self.move(1,0)\\n                        elif evt.key == pygame.K_DOWN:\\n                            self.move(0,1)\\n                        elif evt.key == pygame.K_UP:\\n                            self.rotate()\\n                        elif evt.key == pygame.K_SPACE:\\n                            self.hard_drop()\\n            if self.state == GameState.ACTIVE:\\n                self.update(dt)\\n            self.render()\\n            pygame.display.flip()\\n        pygame.quit()\\n\\n    def update(self, dt):\\n        if self.animation_timer > 0:\\n            self.animation_timer -= 1\\n            if self.animation_timer == 0:\\n                if self.animation_type == 'line':\\n                    # after line, look for matches\\n                    matches = self.detect_matches()\\n                    if matches:\\n                        self.match_positions = matches\\n                        self.animation_type = 'match'\\n                        self.animation_timer = MATCH_ANIM_FRAMES\\n                        return\\n                elif self.animation_type == 'match':\\n                    # clear matched gems\\n                    self.clear_matches()\\n                    # collapse and score done in clear_matches\\n                    # look for next matches\\n                    matches = self.detect_matches()\\n                    if matches:\\n                        self.chain += 1\\n                        self.match_positions = matches\\n                        self.animation_type = 'match'\\n                        self.animation_timer = MATCH_ANIM_FRAMES\\n                        return\\n                # end of all clears or no clears\\n                self.animation_type = None\\n                self.cleared_lines.clear()\\n                self.match_positions.clear()\\n                self.chain = 1\\n                if self.spawn_pending:\\n                    self.finish_spawn()\\n            return\\n\\n        now = pygame.time.get_ticks()\\n        if now - self.last_drop >= self.drop_speed:\\n            self.move(0,1)\\n            self.last_drop = now\\n\\n    def move(self, dx, dy):\\n        nx, ny = self.x+dx, self.y+dy\\n        if self.is_valid(nx,ny,self.current):\\n            self.x, self.y = nx, ny\\n        elif dy != 0:\\n            self.lock()\\n\\n    def rotate(self):\\n        old = self.current.rotation_index\\n        self.current.rotate()\\n        if not self.is_valid(self.x,self.y,self.current):\\n            # revert\\n            self.current.rotation_index = old\\n            self.current.blocks = list(self.current.rotations[old])\\n\\n    def hard_drop(self):\\n        while self.is_valid(self.x,self.y+1,self.current):\\n            self.y += 1\\n        self.lock()\\n\\n    def is_valid(self, x, y, tet):\\n        for bx,by in tet.get_blocks(x,y):\\n            if not self.grid.is_inside(bx,by):\\n                return False\\n            if self.grid.get_cell(bx,by).state == CellState.FILLED:\\n                return False\\n        return True\\n\\n    def lock(self):\\n        for bx,by in self.current.get_blocks(self.x,self.y):\\n            self.grid.set_cell(bx,by,CellState.FILLED,self.current.color)\\n        self.spawn_pending = True\\n        # try line clear\\n        lines = [y for y in range(self.grid.height)\\n                 if all(self.grid.get_cell(x,y).state==CellState.FILLED\\n                        for x in range(self.grid.width))]\\n        if lines:\\n            self.cleared_lines = lines\\n            # remove lines\\n            for y in sorted(lines):\\n                for x in range(self.grid.width):\\n                    self.grid.set_cell(x,y,CellState.EMPTY,None)\\n                for yy in range(y-1,-1,-1):\\n                    for x in range(self.grid.width):\\n                        c = self.grid.get_cell(x,yy)\\n                        self.grid.set_cell(x,yy+1,c.state,c.color)\\n                        self.grid.set_cell(x,yy,CellState.EMPTY,None)\\n            self.score += {1:100,2:300,3:500,4:800}.get(len(lines),len(lines)*100)\\n            self.animation_type = 'line'\\n            self.animation_timer = LINE_ANIM_FRAMES\\n        else:\\n            # no line, try match\\n            matches = self.detect_matches()\\n            if matches:\\n                self.match_positions = matches\\n                self.animation_type = 'match'\\n                self.animation_timer = MATCH_ANIM_FRAMES\\n            else:\\n                self.finish_spawn()\\n\\n    def finish_spawn(self):\\n        self.current = self.next_piece\\n        self.next_piece = self.new_tetromino()\\n        self.x, self.y = SPAWN_X, SPAWN_Y\\n        self.spawn_pending = False\\n        if not self.is_valid(self.x,self.y,self.current):\\n            self.state = GameState.GAME_OVER\\n\\n    def detect_matches(self):\\n        visited = [[False]*self.grid.width for _ in range(self.grid.height)]\\n        matches = set()\\n        for y in range(self.grid.height):\\n            for x in range(self.grid.width):\\n                cell = self.grid.get_cell(x,y)\\n                if cell.state==CellState.FILLED and not visited[y][x]:\\n                    color = cell.color\\n                    stack = [(x,y)]\\n                    comp = []\\n                    visited[y][x] = True\\n                    while stack:\\n                        cx,cy = stack.pop()\\n                        comp.append((cx,cy))\\n                        for dx,dy in ((1,0),(-1,0),(0,1),(0,-1)):\\n                            nx,ny = cx+dx, cy+dy\\n                            if (0<=nx<self.grid.width and 0<=ny<self.grid.height\\n                                and not visited[ny][nx]):\\n                                nc = self.grid.get_cell(nx,ny)\\n                                if nc.state==CellState.FILLED and nc.color==color:\\n                                    visited[ny][nx]=True\\n                                    stack.append((nx,ny))\\n                    if len(comp)>=3:\\n                        matches.update(comp)\\n        return matches\\n\\n    def clear_matches(self):\\n        # remove matched cells\\n        for x,y in self.match_positions:\\n            self.grid.set_cell(x,y,CellState.EMPTY,None)\\n        # collapse each column\\n        for x in range(self.grid.width):\\n            stack = []\\n            for y in range(self.grid.height):\\n                c = self.grid.get_cell(x,y)\\n                if c.state==CellState.FILLED:\\n                    stack.append(c.color)\\n            for y in range(self.grid.height-1,-1,-1):\\n                if stack:\\n                    color = stack.pop()\\n                    self.grid.set_cell(x,y,CellState.FILLED,color)\\n                else:\\n                    self.grid.set_cell(x,y,CellState.EMPTY,None)\\n        # score\\n        self.score += len(self.match_positions) * 50 * self.chain\\n\\n    def render(self):\\n        self.screen.fill((0,0,0))\\n        self.draw_grid()\\n        if self.state!=GameState.GAME_OVER and self.animation_timer==0:\\n            self.draw_tetromino()\\n        self.draw_next()\\n        self.draw_score()\\n        if self.state==GameState.PAUSED:\\n            self.draw_overlay(\\\"Paused\\\")\\n        elif self.state==GameState.GAME_OVER:\\n            self.draw_overlay(\\\"Game Over\\\", final=True)\\n\\n    def draw_grid(self):\\n        for y in range(self.grid.height):\\n            for x in range(self.grid.width):\\n                cell = self.grid.get_cell(x,y)\\n                rect = pygame.Rect(x*BLOCK_SIZE, y*BLOCK_SIZE,\\n                                   BLOCK_SIZE, BLOCK_SIZE)\\n                color = EMPTY_COLOR\\n                if self.animation_timer>0:\\n                    if self.animation_type=='line' and y in self.cleared_lines:\\n                        color = (255,255,255) if (self.animation_timer%2==0) else EMPTY_COLOR\\n                    elif self.animation_type=='match' and (x,y) in self.match_positions:\\n                        color = (255,255,255) if (self.animation_timer%2==0) else EMPTY_COLOR\\n                    else:\\n                        if cell.state==CellState.FILLED:\\n                            color = cell.color\\n                else:\\n                    if cell.state==CellState.FILLED:\\n                        color = cell.color\\n                pygame.draw.rect(self.screen, color, rect)\\n                pygame.draw.rect(self.screen, GRID_LINE_COLOR, rect, 1)\\n\\n    def draw_tetromino(self):\\n        for bx,by in self.current.get_blocks(self.x,self.y):\\n            rect = pygame.Rect(bx*BLOCK_SIZE, by*BLOCK_SIZE,\\n                               BLOCK_SIZE, BLOCK_SIZE)\\n            pygame.draw.rect(self.screen, self.current.color, rect)\\n            pygame.draw.rect(self.screen, GRID_LINE_COLOR, rect, 1)\\n\\n    def draw_next(self):\\n        font = pygame.font.Font(None,30)\\n        label = font.render(\\\"Next:\\\", True, (255,255,255))\\n        self.screen.blit(label, (PREVIEW_POS[0], PREVIEW_POS[1]-30))\\n        for bx,by in self.next_piece.get_blocks(0,0):\\n            px = PREVIEW_POS[0] + bx*BLOCK_SIZE\\n            py = PREVIEW_POS[1] + by*BLOCK_SIZE\\n            rect = pygame.Rect(px,py,BLOCK_SIZE,BLOCK_SIZE)\\n            pygame.draw.rect(self.screen, self.next_piece.color, rect)\\n            pygame.draw.rect(self.screen, GRID_LINE_COLOR, rect,1)\\n\\n    def draw_score(self):\\n        font = pygame.font.Font(None,36)\\n        text = font.render(f\\\"Score: {self.score}\\\", True, (255,255,255))\\n        self.screen.blit(text, (PREVIEW_POS[0], PREVIEW_POS[1]+150))\\n\\n    def draw_overlay(self, text, final=False):\\n        ov = pygame.Surface((SCREEN_WIDTH,SCREEN_HEIGHT), pygame.SRCALPHA)\\n        ov.fill((0,0,0,180))\\n        self.screen.blit(ov,(0,0))\\n        font = pygame.font.Font(None,72)\\n        lbl = font.render(text, True, (255,255,255))\\n        rect = lbl.get_rect(center=(SCREEN_WIDTH//2,SCREEN_HEIGHT//2- (60 if final else 0)))\\n        self.screen.blit(lbl,rect)\\n        if final:\\n            sub = pygame.font.Font(None,48).render(f\\\"Final Score: {self.score}\\\", True, (255,255,255))\\n            r2 = sub.get_rect(center=(SCREEN_WIDTH//2,SCREEN_HEIGHT//2+60))\\n            self.screen.blit(sub,r2)\\n\\nif __name__ == '__main__':\\n    game = TetrisJeweled()\\n    game.run()\\n```\",\n  \"timestamp\": \"2026-05-22T11:34:15.102822\"\n}"}
