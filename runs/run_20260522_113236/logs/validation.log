f.tetromino.rotate(direction)\\n        if not self.is_valid_position(self.x, self.y):\\n            # Revert rotation if it leads to an invalid position\\n            self.tetromino.rotation_index = original_rotation_index\\n            self.tetromino.blocks = list(self.tetromino.rotations[self.tetromino.rotation_index])\\n\\n    def is_valid_position(self, x, y):\\n        blocks = self.tetromino.get_blocks(x, y)\\n        for block_x, block_y in blocks:\\n            if not self.grid.is_inside(block_x, block_y):\\n                return False\\n            if block_y >= 0 and self.grid.get_cell(block_x, block_y).state == CellState.FILLED:\\n                return False\\n        return True\\n\\n    def lock(self):\\n        blocks = self.tetromino.get_blocks(self.x, self.y)\\n        for block_x, block_y in blocks:\\n            self.grid.set_cell(block_x, block_y, CellState.FILLED, self.tetromino.color)\\n\\ndef get_new_tetromino():\\n    shape_key = random.choice(list(BASE_SHAPES.keys()))\\n    return Tetromino(shape_key)\\n```\",\n  \"timestamp\": \"2026-05-22T11:33:11.099600\"\n}"}
