__init__(self, width, height):\\n        self.width = width\\n        self.height = height\\n        self.cells = [[Cell() for _ in range(height)] for _ in range(width)]\\n\\n    def is_inside(self, x, y):\\n        return 0 <= x < self.width and y < self.height\\n\\n    def get_cell(self, x, y):\\n        if 0 <= x < self.width and 0 <= y < self.height:\\n            return self.cells[x][y]\\n        return None\\n\\n    def set_cell(self, x, y, state, color=None):\\n        if 0 <= x < self.width and 0 <= y < self.height:\\n            cell = self.cells[x][y]\\n            cell.state = state\\n            cell.color = color\\n\\n# -- Tetromino Definitions --\\n\\n# Base shapes: each list of rotations is a list of (x,y) offsets\\nBASE_SHAPES = {\\n    'I': [\\n        [(0,1), (1,1), (2,1), (3,1)],\\n        [(2,0), (2,1), (2,2), (2,3)],\\n    ],\\n    'O': [\\n        [(1,0), (2,0), (1,1), (2,1)],\\n    ],\\n    'T': [\\n        [(1,0), (0,1), (1,1), (2,1)],\\n        [(1,0), (1,1), (2,1), (1,2)],\\n        [(0,1), (1,1), (2,1), (1,2)],\\n        [(1,0), (0,1), (1,1), (1,2)],\\n    ],\\n    # Add S, Z, J, L similarly...\\n}\\n\\nCOLOR_MAP = {\\n    'I': (0, 255, 255),\\n    'O': (255, 255, 0),\\n    'T': (128, 0, 128),\\n    # etc...\\n}\\n\\nclass Tetromino:\\n    def __init__(self, shape_key):\\n        self.shape_key = shape_key\\n        self.rotations = BASE_SHAPES[shape_key]\\n        self.rotation_index = 0\\n        self.blocks = list(self.rotations[self.rotation_index])\\n        self.color = COLOR_MAP[shape_key]\\n\\n    def rotate(self, direction):\\n        # direction +1 = cw, -1 = ccw\\n        n = len(self.rotations)\\n        self.rotation_index = (self.rotation_index + direction) % n\\n        self.blocks = list(self.rotations[self.rotation_index])\\n\\n    def get_blocks(self, origin_x, origin_y):\\n        # Returns absolute coords of blocks\\n        return [(origin_x + bx, origin_y + by) for bx, by in self.blocks]\\n\\n# -- Falling Piece Logic --\\n\\nclass FallingPiece:\\n    def __init__(self, tetromino, grid):\\n        self.tetromino = tetromino\\n        self.grid = grid\\n        self.x = grid.width // 2 - 2  # spawn near top center\\n        self.y = -2  # start above the visible grid\\n\\n    def is_valid_position(self, x, y):\\n        for bx, by in self.tetromino.get_blocks(x, y):\\n            if by < 0:\\n                continue  # above the grid is okay\\n            if not self.grid.is_inside(bx, by):\\n                return False\\n            cell = self.grid.get_cell(bx, by)\\n            if cell.state == CellState.FILLED:\\n                return False\\n        return True\\n\\n    def move(self, dx, dy):\\n        new_x, new_y = self.x + dx, self.y + dy\\n        if self.is_valid_position(new_x, new_y):\\n            self.x, self.y = new_x, new_y\\n            return True\\n        return False\\n\\n    def rotate(self, direction):\\n        old_index = self.tetromino.rotation_index\\n        self.tetromino.rotate(direction)\\n        if not self.is_valid_position(self.x, self.y):\\n            # revert\\n            self.tetromino.rotation_index = old_index\\n            self.tetromino.blocks = list(self.tetromino.rotations[old_index])\\n\\n    def lock(self):\\n        # Convert each block into a colored gem in the grid\\n        for bx, by in self.tetromino.get_blocks(self.x, self.y):\\n            if by >= 0:\\n                self.grid.set_cell(bx, by, CellState.FILLED, self.tetromino.color)\\n\\n# -- Factory Function --\\n\\ndef get_new_tetromino(grid):\\n    shape = random.choice(list(BASE_SHAPES.keys()))\\n    return FallingPiece(Tetromino(shape), grid)\\n\\n# -- Example of a simple tick/update function --\\n\\ndef update_game(grid, current_piece):\\n    # Try to move down; if blocked, lock and spawn new piece\\n    if not current_piece.move(0, 1):\\n        current_piece.lock()\\n        return get_new_tetromino(grid)\\n    return current_piece\\n\\n# -- Usage Example --\\n\