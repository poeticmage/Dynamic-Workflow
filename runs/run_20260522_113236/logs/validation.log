n  Objective: Create the game state manager to sequence tetromino drops, gem/line clears, chain reactions, and bonus point updates.\\n  Result: ```python\\nimport pygame\\nfrom constants import DROP_INTERVAL\\nfrom tetromino import get_new_tetromino, FallingPiece\\nfrom logic import GameLogic\\n\\nclass GameState:\\n    # Game states\\n    STATE_SPAWN    = 'spawn'\\n    STATE_FALL     = 'fall'\\n    STATE_LOCK     = 'lock'\\n    STATE_CLEAR    = 'clear'\\n    STATE_GAMEOVER = 'gameover'\\n\\n    # Scoring constants\\n    LINE_CLEAR_POINTS = 100\\n    GEM_CLEAR_POINTS  = 20\\n    CHAIN_BONUS_RATE  = 0.5\\n\\n    def __init__(self, grid):\\n        self.grid           = grid\\n        self.game_logic     = GameLogic(self.grid)\\n        self.score          = 0\\n        self.chain_count    = 0\\n\\n        self.current_piece  = None\\n        self.next_tetromino = get_new_tetromino()\\n\\n        self.state          = self.STATE_SPAWN\\n        self.drop_interval  = DROP_INTERVAL  # milliseconds\\n        self.last_drop_time = pygame.time.get_ticks()\\n\\n    # --- Getters for rendering\\n    def get_grid(self):\\n        return self.grid\\n\\n    def get_current_piece(self):\\n        return self.current_piece\\n\\n    def get_next_tetromino(self):\\n        return self.next_tetromino\\n\\n    def is_game_over(self):\\n        return self.state == self.STATE_GAMEOVER\\n\\n    # --- Input handling\\n    def handle_event(self, event):\\n        if self.state != self.STATE_FALL or not self.current_piece:\\n            return\\n        if event.type == pygame.KEYDOWN:\\n            if event.key == pygame.K_LEFT:\\n                self.current_piece.move(-1, 0)\\n            elif event.key == pygame.K_RIGHT:\\n                self.current_piece.move(1, 0)\\n            elif event.key == pygame.K_UP:\\n                self.current_piece.rotate(1)\\n            elif event.key == pygame.K_DOWN:\\n                # soft drop\\n                if not self.current_piece.move(0, 1):\\n                    self.state = self.STATE_LOCK\\n            elif event.key == pygame.K_SPACE:\\n                # hard drop\\n                self.current_piece.hard_drop()\\n                self.state = self.STATE_LOCK\\n\\n    # --- Core mechanics\\n    def spawn_new_piece(self):\\n        self.current_piece   = FallingPiece(self.next_tetromino, self.grid)\\n        self.next_tetromino  = get_new_tetromino()\\n        self.chain_count     = 0\\n        self.last_drop_time  = pygame.time.get_ticks()\\n\\n        if not self.current_piece.is_valid_position(\\n                self.current_piece.x, self.current_piece.y):\\n            self.state = self.STATE_GAMEOVER\\n            return False\\n\\n        self.state = self.STATE_FALL\\n        return True\\n\\n    def lock_piece(self):\\n        self.current_piece.lock()\\n        self.current_piece = None\\n        self.state         = self.STATE_CLEAR\\n\\n    def process_clears(self):\\n        while True:\\n            line_matches = self.game_logic.find_line_matches()  # e.g. list of row indices\\n            gem_matches  = self.game_logic.find_gem_matches()   # e.g. list of lists of (x,y)\\n\\n            if not line_matches and not gem_matches:\\n                break\\n\\n            # Clear lines first\\n            lines_cleared = self.game_logic.clear_line_matches(line_matches)\\n            self.game_logic.collapse_lines()\\n\\n            # Clear gem matches\\n            gems_cleared = self.game_logic.clear_gem_matches(gem_matches)\\n            self.game_logic.collapse_gems()\\n\\n            # Calculate points\\n            base_points = (lines_cleared * self.LINE_CLEAR_POINTS +\\n                           gems_cleared  * self.GEM_CLEAR_POINTS)\\n            chain_bonus = int(base_points * self.CHAIN_BONUS_RATE * self.chain_count)\\n            gain        = base_points + chain_bonus\\n\\n            self.score += gain\\n            self.chain_count += 1\\n\\n        # after all chains\\n        self.state = self.STATE_SPAWN\\n\\n    def update(self):\\n        now = pygame.time.get_ticks()\\n\\n        if self.state == self.STATE_SPAWN:\\n            if not self.spawn_new_piece():\\n                self.state = self.STATE_GAMEOVER\\n\\n        elif self.state == self.STATE_FALL:\\n            if now - self.last_drop_time >= self.drop_interval:\\n                if not self.current_piece.move(0, 1):\\n                    self.state = self.STATE_LOCK\\n                self.last_drop_time = now\\n\\n        elif self.state == self.STATE_LOCK:\\n            self.lock_piece()\\n\\n        elif self.state == self.STATE_CLEAR:\\n            self.process_clears()\\n\\n        # STATE_GAMEOVER → external loop handles termination\\n```\\nTask task4:\\n  Objective: Develop the keyboard input handler for moving, rotating, and dropping tetrominoes.\\n  Result: ```python\\nimport pygame\\n\\nclass InputHandler:\\n    def __init__(self, game):\\n        self.game = game\\n\\n    def handle_input(self):\\n        for event in pygame.event.get():\\n            if event.type == pygame.QUIT:\\n                self.game.running = False\\n            if event.type == pygame.KEYDOWN:\\n                if event.key == pygame.K_LEFT:\\n                    self.game.move_tetromino_sideways(-1)\\n                if event.key == pygame.K_RIGHT:\\n                    self.game.move_tetromino_sideways(1)\\n                if event.key == pygame.K_DOWN:\\n                    self.game.move_tetromino_down()\\n                if event.key == pygame.K_UP:\\n                    self.game.rotate_tetromino()\\n                if event.key == pygame.K_SPACE:\\n                    self.game.drop_tetromino()\\n```\\nTask task5:\\n  Objective: Implement the GUI renderer using Pygame: draw grid, current score, next piece preview, and manage animation frames.\\n  Result: ```python\\nimport pygame\\nimport random\\nfrom enum import Enum\\nfrom task0 import (\\n    GRID_WIDTH, GRID_HEIGHT,\\n    CellState, Grid,\\n    BASE_SHAPES, Tetromino\\n)\\n\\n# Pygame Constants\\nBLOCK_SIZE = 30\\nSCREEN_WIDTH = GRID_WIDTH * BLOCK_SIZE + 200\\nSCREEN_HEIGHT = GRID_HEIGHT * BLOCK_SIZE\\nGRID_LINE_COLOR = (50, 50, 50)\\nEMPTY_COLOR = (30, 30, 30)\\nSPAWN_X = GRID_WIDTH // 2 - 2\\nSPAWN_Y = 0\\nPREVIEW_POS = (GRID_WIDTH * BLOCK_SIZE + 20, 50)\\n\\nLINE_ANIM_FRAMES = 30\\nMATCH_ANIM_FRAMES = 20\\n\\nclass GameState(Enum):\\n    ACTIVE = 0\\n    PAUSED = 1\\n    GAME_OVER = 2\\n\\nclass TetrisJeweled:\\n    def __init__(self):\\n        pygame.init()\\n        self.screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\\n        pygame.display.set_caption(\\\"Tetris Jeweled\\\")\\n        self.clock = pygame.time.Clock()\\n        self.grid = Grid()\\n        self.current = self.new_tetromino()\\n        self.next_piece = self.new_tetromino()\\n        self.x = SPAWN_X\\n        self.y = SPAWN_Y\\n        self.state = GameState.ACTIVE\\n        self.score = 0\\n        self.drop_speed = 500\\n        self.last_drop = pygame.time.get_ticks()\\n        # animation & clearing\\n        self.animation_timer = 0\\n        self.animation_type = None  # 'line' or 'match'\\n        self.cleared_lines = []\\n        self.match_positions = set()\\n        self.chain = 1\\n        self.spawn_pending = False\\n\\n    def new_tetromino(self):\\n        return Tetromino(random.choice(list(BASE_SHAPES.keys())))\\n\\n    def run(self):\\n        running = True\\n        while running:\\n            dt = self.clock.tick(60)\\n            for evt in pygame.event.get():\\n                if evt.type == pygame.QUIT:\\n                    running = False\\n                elif evt.type == pygame.KEYDOWN:\\n                    if evt.key == pygame.K_p:\\n                        if self.state == GameState.ACTIVE:\\n                            self.state = GameState.PAUSED\\n                        elif self.state == GameState.PAUSED:\\n                            self.state = GameState.ACTIVE\\n                    elif (self.state == GameState.ACTIVE and self.animation_timer == 0):\\n                        if evt.key == pygame.K_LEFT:\\n                            self.move(-1,0)\\n                        elif evt.key == pygame.K_RIGHT:\\n                            self.move(1,0)\\n                        elif evt.key == pygame.K_DOWN:\\n                            self.move(0,1)\\n                        elif evt.key == pygame.K_UP:\\n                            self.rotate()\\n                        elif evt.key == pygame.K_SPACE:\\n                            self.hard_drop()\\n            if self.state == GameState.ACTIVE:\\n                self.update(dt)\\n            self.render()\\n            pygame.display.flip()\\n        pygame.quit()\\n\\n    def update(self, dt):\\n        if self.animation_timer > 0:\\n            self.animation_timer -= 1\\n            if self.animation_timer == 0:\\n                if self.animation_type == 'line':\\n                    # after line, look for matches\\n                    matches = self.detect_matches()\\n                    if matches:\\n                        self.match_positions = matches\\n                        self.animation_type = 'match'\\n                        self.animation_timer = MATCH_ANIM_FRAMES\\n                        return\\n                elif self.animation_type == 'match':\\n                    # clear matched gems\\n                    self.clear_matches()\\n                    # collapse and score done in clear_matches\\n                    # look for next matches\\n                    matches = self.detect_matches()\\n                    if matches:\\n                        self.chain += 1\\n                        self.match_positions = matches\\n                        self.animation_type = 'match'\\n                        self.animation_timer = MATCH_ANIM_FRAMES\\n                        return\\n                # end of all clears or no clears\\n                self.animation_type = None\\n                self.cleared_lines.clear()\\n                self.match_positions.clear()\\n                self.chain = 1\\n                if self.spawn_pending:\\n                    self.finish_spawn()\\n            return\\n\\n        now = pygame.time.get_ticks()\\n        if now - self.last_drop >= self.drop_speed:\\n            self.move(0,1)\\n            self.last_drop = now\\n\\n    def move(self, dx, dy):\\n        nx, ny = self.x+dx, self.y+dy\\n        if self.is_valid(nx,ny,self.current):\\n            self.x, self.y = nx, ny\\n        elif dy != 0:\\n            self.lock()\\n\\n    def rotate(self):\\n        old = self.current.rotation_index\\n        self.current.rotate()\\n        if not self.is_valid(self.x,self.y,self.current):\\n            # revert\\n            self.current.rotation_index = old\\n            self.current.blocks = list(self.current.rotations[old])\\n\\n    def hard_drop(self):\\n        while self.is_valid(self.x,self.y+1,self.current):\\n            self.y += 1\\n        self.lock()\\n\\n    def is_valid(self, x, y, tet):\\n        for bx,by in tet.get_blocks(x,y):\\n            if not self.grid.is_inside(bx,by):\\n                return False\\n            if self.grid.get_cell(bx,by).state == CellState.FILLED:\\n                return False\\n        return True\\n\\n    def lock(self):\\n        for bx,by in self.current.get_blocks(self.x,self.y):\\n            self.grid.set_cell(bx,by,CellState.FILLED,self.current.color)\\n        self.spawn_pending = True\\n        # try line clear\\n        lines = [y for y in range(self.grid.height)\\n                 if all(self.grid.get_cell(x,y).state==CellState.FILLED\\n                        for x in range(self.grid.width))]\\n        if lines:\\n            self.cleared_lines = lines\\n            # remove lines\\n            for y in sorted(lines):\\n                for x in range(self.grid.width):\\n                    self.grid.set_cell(x,y,CellState.EMPTY,None)\\n                for yy in range(y-1,-1,-1):\\n                    for x in range(self.grid.width):\\n                        c = self.grid.get_cell(x,yy)\\n                        self.grid.set_cell(x,yy+1,c.state,c.color)\\n                        self.grid.set_cell(x,yy,CellState.EMPTY,None)\\n            self.score += {1:100,2:300,3:500,4:800}.get(len(lines),len(lines)*100)\\n            self.animation_type = 'line'\\n            self.animation_timer = LINE_ANIM_FRAMES\\n        else:\\n            # no line, try match\\n            matches = self.detect_matches()\\n            if matches:\\n                self.match_positions = matches\\n                self.animation_type = 'match'\\n                self.animation_timer = MATCH_ANIM_FRAMES\\n            else:\\n                self.finish_spawn()\\n\\n    def finish_spawn(self):\\n        self.current = self.next_piece\\n        self.next_piece = self.new_tetromino()\\n        self.x, self.y = SPAWN_X, SPAWN_Y\\n        self.spawn_pending = False\\n        if not self.is_valid(self.x,self.y,self.current):\\n            self.state = GameState.GAME_OVER\\n\\n    def detect_matches(self):\\n        visited = [[False]*self.grid.width for _ in range(self.grid.height)]\\n        matches = set()\\n        for y in range(self.grid.height):\\n            for x in range(self.grid.width):\\n                cell = self.grid.get_cell(x,y)\\n                if cell.state==CellState.FILLED and not visited[y][x]:\\n                    color = cell.color\\n                    stack = [(x,y)]\\n                    comp = []\\n                    visited[y][x] = True\\n                    while stack:\\n                        cx,cy = stack.pop()\\n                        comp.append((cx,cy))\\n                        for dx,dy in ((1,0),(-1,0),(0,1),(0,-1)):\\n                            nx,ny = cx+dx, cy+dy\\n                            if (0<=nx<self.grid.width and 0<=ny<self.grid.height\\n                                and not visited[ny][nx]):\\n                                nc = self.grid.get_cell(nx,ny)\\n                                if nc.state==CellState.FILLED and nc.color==color:\\n                                    visited[ny][nx]=True\\n                                    stack.append((nx,ny))\\n                    if len(comp)>=3:\\n                        matches.update(comp)\\n        return matches\\n\\n    def clear_matches(self):\\n        # remove matched cells\\n        for x,y in self.match_positions:\\n            self.grid.set_cell(x,y,CellState.EMPTY,None)\\n        # collapse each column\\n        for x in range(self.grid.width):\\n            stack = []\\n            for y in range(self.grid.height):\\n                c = self.grid.get_cell(x,y)\\n                if c.state==CellState.FILLED:\\n                    stack.append(c.color)\\n            for y in range(self.grid.height-1,-1,-1):\\n                if stack:\\n                    color = stack.pop()\\n                    self.grid.set_cell(x,y,CellState.FILLED,color)\\n                else:\\n                    self.grid.set_cell(x,y,CellState.EMPTY,None)\\n        # score\\n        self.score += len(self.match_positions) * 50 * self.chain\\n\\n    def render(self):\\n        self.screen.fill((0,0,0))\\n        self.draw_grid()\\n        if self.state!=GameState.GAME_OVER and self.animation_timer==0:\\n            self.draw_tetromino()\\n        self.draw_next()\\n        self.draw_score()\\n        if self.state==GameState.PAUSED:\\n            self.draw_overlay(\\\"Paused\\\")\\n        elif self.state==GameState.GAME_OVER:\\n            self.draw_overlay(\\\"Game Over\\\", final=True)\\n\\n    def draw_grid(self):\\n        for y in range(self.grid.height):\\n            for x in range(self.grid.width):\\n                cell = self.grid.get_cell(x,y)\\n                rect = pygame.Rect(x*BLOCK_SIZE, y*BLOCK_SIZE,\\n                                   BLOCK_SIZE, BLOCK_SIZE)\\n                color = EMPTY_COLOR\\n                if self.animation_timer>0:\\n                    if self.animation_type=='line' and y in self.cleared_lines:\\n                        color = (255,255,255) if (self.animation_timer%2==0) else EMPTY_COLOR\\n                    elif self.animation_type=='match' and (x,y) in self.match_positions:\\n                        color = (255,255,255) if (self.animation_timer%2==0) else EMPTY_COLOR\\n                    else:\\n                        if cell.state==CellState.FILLED:\\n                            color = cell.color\\n                else:\\n                    if cell.state==CellState.FILLED:\\n                        color = cell.color\\n                pygame.draw.rect(self.screen, color, rect)\\n                pygame.draw.rect(self.screen, GRID_LINE_COLOR, rect, 1)\\n\\n    def draw_tetromino(self):\\n        for bx,by in self.current.get_blocks(self.x,self.y):\\n            rect = pygame.Rect(bx*BLOCK_SIZE, by*BLOCK_SIZE,\\n                               BLOCK_SIZE, BLOCK_SIZE)\\n            pygame.draw.rect(self.screen, self.current.color, rect)\\n            pygame.draw.rect(self.screen, GRID_LINE_COLOR, rect, 1)\\n\\n    def draw_next(self):\\n        font = pygame.font.Font(None,30)\\n        label = font.render(\\\"Next:\\\", True, (255,255,255))\\n        self.screen.blit(label, (PREVIEW_POS[0], PREVIEW_POS[1]-30))\\n        for bx,by in self.next_piece.get_blocks(0,0):\\n            px = PREVIEW_POS[0] + bx*BLOCK_SIZE\\n            py = PREVIEW_POS[1] + by*BLOCK_SIZE\\n            rect = pygame.Rect(px,py,BLOCK_SIZE,BLOCK_SIZE)\\n            pygame.draw.rect(self.screen, self.next_piece.color, rect)\\n            pygame.draw.rect(self.screen, GRID_LINE_COLOR, rect,1)\\n\\n    def draw_score(self):\\n        font = pygame.font.Font(None,36)\\n        text = font.render(f\\\"Score: {self.score}\\\", True, (255,255,255))\\n        self.screen.blit(text, (PREVIEW_POS[0], PREVIEW_POS[1]+150))\\n\\n    def draw_overlay(self, text, final=False):\\n        ov = pygame.Surface((SCREEN_WIDTH,SCREEN_HEIGHT), pygame.SRCALPHA)\\n        ov.fill((0,0,0,180))\\n        self.screen.blit(ov,(0,0))\\n        font = pygame.font.Font(None,72)\\n        lbl = font.render(text, True, (255,255,255))\\n        rect = lbl.get_rect(center=(SCREEN_WIDTH//2,SCREEN_HEIGHT//2- (60 if final else 0)))\\n        self.screen.blit(lbl,rect)\\n        if final:\\n            sub = pygame.font.Font(None,48).render(f\\\"Final Score: {self.score}\\\", True, (255,255,255))\\n            r2 = sub.get_rect(center=(SCREEN_WIDTH//2,SCREEN_HEIGHT//2+60))\\n            self.screen.blit(sub,r2)\\n\\nif __name__ == '__main__':\\n    game = TetrisJeweled()\\n    game.run()\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nNo downstream objectives available.\\n\\n---\\n# **Current Task Requirements**\\nIntegrate game state, input handler, and GUI renderer into a cohesive main loop with smooth animations and real-time updates.\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport pygame\\nimport random\\nfrom enum import Enum\\n\\n# Constants\\nGRID_WIDTH = 10\\nGRID_HEIGHT = 20\\nBLOCK_SIZE = 30\\nSCREEN_WIDTH = GRID_WIDTH * BLOCK_SIZE + 200\\nSCREEN_HEIGHT = GRID_HEIGHT * BLOCK_SIZE\\nGRID_LINE_COLOR = (50, 50, 50)\\nEMPTY_COLOR = (30, 30, 30)\\nSPAWN_X = GRID_WIDTH // 2 - 2\\nSPAWN_Y = 0\\nPREVIEW_POS = (GRID_WIDTH * BLOCK_SIZE + 20, 50)\\nLINE_ANIM_FRAMES = 30\\nMATCH_ANIM_FRAMES = 20\\nDROP_INTERVAL = 500\\n\\n# Cell States\\nclass CellState(Enum):\\n    EMPTY = 0\\n    FILLED = 1\\n\\n# Tetromino Shapes and Colors\\nBASE_SHAPES = {\\n    \\\"I\\\": [[(0, 0), (1, 0), (2, 0), (3, 0)], [(0, 0), (0, 1), (0, 2), (0, 3)]],\\n    \\\"J\\\": [[(0, 1), (0, 0), (1, 0), (2, 0)], [(0, 0), (1, 0), (0, 1), (0, 2)],\\n          [(0, 2), (1, 2), (2, 2), (2, 1)], [(1, 0), (1, 1), (1, 2), (0, 2)]],\\n    \\\"L\\\": [[(0, 0), (1, 0), (2, 0), (2, 1)], [(0, 0), (0, 1), (0, 2), (1, 0)],\\n          [(0, 2), (0, 1), (1, 2), (2, 2)], [(0, 2), (1, 2), (1, 1), (1, 0)]],\\n    \\\"O\\\": [[(0, 0), (1, 0), (0, 1), (1, 1)]],\\n    \\\"S\\\": [[(1, 0), (2, 0), (0, 1), (1, 1)], [(0, 0), (0, 1), (1, 1), (1, 2)]],\\n    \\\"T\\\": [[(0, 0), (1, 0), (2, 0), (1, 1)], [(0, 0), (0, 1), (0, 2), (1, 1)],\\n          [(1, 1), (0, 2), (1, 2), (2, 2)], [(1, 0), (0, 1), (1, 1), (1, 2)]],\\n    \\\"Z\\\": [[(0, 0), (1, 0), (1, 1), (2, 1)], [(1, 0), (0, 1), (1, 1), (0, 2)]]\\n}\\n\\nSHAPE_COLORS = {\\n    \\\"I\\\": (0, 255, 255),  # Cyan\\n    \\\"J\\\": (0, 0, 255),    # Blue\\n    \\\"L\\\": (255, 165, 0),  # Orange\\n    \\\"O\\\": (255, 255, 0),  # Yellow\\n    \\\"S\\\": (0, 255, 0),    # Green\\n    \\\"T\\\": (128, 0, 128),  # Purple\\n    \\\"Z\\\": (255, 0, 0)     # Red\\n}\\n\\nclass Cell:\\n    def __init__(self):\\n        self.state = CellState.EMPTY\\n        self.color = None\\n\\nclass Grid:\\n    def __init__(self, width=GRID_WIDTH, height=GRID_HEIGHT):\\n        self.width = width\\n        self.height = height\\n        self.grid = [[Cell() for _ in range(width)] for _ in range(height)]\\n\\n    def is_inside(self, x, y):\\n        return 0 <= x < self.width and 0 <= y < self.height\\n\\n    def get_cell(self, x, y):\\n        return self.grid[y][x]\\n\\n    def set_cell(self, x, y, state, color):\\n        self.grid[y][x].state = state\\n        self.grid[y][x].color = color\\n\\nclass Tetromino:\\n    def __init__(self, shape):\\n        self.shape = shape\\n        self.rotations = BASE_SHAPES[shape]\\n        self.rotation_index = 0\\n        self.blocks = list(self.rotations[self.rotation_index])\\n        self.color = SHAPE_COLORS[shape]\\n\\n    def rotate(self):\\n        self.rotation_index = (self.rotation_index + 1) % len(self.rotations)\\n        self.blocks = list(self.rotations[self.rotation_index])\\n\\n    def get_blocks(self, x, y):\\n        return [(x + bx, y + by) for bx, by in self.blocks]\\n\\nclass GameState(Enum):\\n    ACTIVE = 0\\n    PAUSED = 1\\n    GAME_OVER = 2\\n\\nclass TetrisJeweled:\\n    def __init__(self):\\n        pygame.init()\\n        self.screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\\n        pygame.display.set_caption(\\\"Tetris Jeweled\\\")\\n        self.clock = pygame.time.Clock()\\n        self.grid = Grid()\\n        self.current = self.new_tetromino()\\n        self.next_piece = self.new_tetromino()\\n        self.x = SPAWN_X\\n        self.y = SPAWN_Y\\n        self.state = GameState.ACTIVE\\n        self.score = 0\\n        self.drop_speed = DROP_INTERVAL\\n        self.last_drop = pygame.time.get_ticks()\\n        self.animation_timer = 0\\n        self.animation_type = None\\n        self.cleared_lines = []\\n        self.match_positions = set()\\n        self.chain = 1\\n        self.spawn_pending = False\\n\\n    def new_tetromino(self):\\n        return Tetromino(random.choice(list(BASE_SHAPES.keys())))\\n\\n    def run(self):\\n        running = True\\n        while running:\\n            dt = self.clock.tick(60)\\n            for evt in pygame.event.get():\\n                if evt.type == pygame.QUIT:\\n                    running = False\\n                elif evt.type == pygame.KEYDOWN:\\n                    if evt.key == pygame.K_p:\\n                        if self.state == GameState.ACTIVE:\\n                            self.state = GameState.PAUSED\\n                        elif self.state == GameState.PAUSED:\\n                            self.state = GameState.ACTIVE\\n                    elif (self.state == GameState.ACTIVE and self.animation_timer == 0):\\n                        if evt.key == pygame.K_LEFT:\\n                            self.move(-1,0)\\n                        elif evt.key == pygame.K_RIGHT:\\n                            self.move(1,0)\\n                        elif evt.key == pygame.K_DOWN:\\n                            self.move(0,1)\\n                        elif evt.key == pygame.K_UP:\\n                            self.rotate()\\n                        elif evt.key == pygame.K_SPACE:\\n                            self.hard_drop()\\n            if self.state == GameState.ACTIVE:\\n                self.update(dt)\\n            self.render()\\n            pygame.display.flip()\\n        pygame.quit()\\n\\n    def update(self, dt):\\n        if self.animation_timer > 0:\\n            self.animation_timer -= 1\\n            if self.animation_timer == 0:\\n                if self.animation_type == 'line':\\n                    matches = self.detect_matches()\\n                    if matches:\\n                        self.match_positions = matches\\n                        self.animation_type = 'match'\\n                        self.animation_timer = MATCH_ANIM_FRAMES\\n                        return\\n                elif self.animation_type == 'match':\\n                    self.clear_matches()\\n                    matches = self.detect_matches()\\n                    if matches:\\n                        self.chain += 1\\n                        self.match_positions = matches\\n                        self.animation_type = 'match'\\n                        self.animation_timer = MATCH_ANIM_FRAMES\\n                        return\\n                self.animation_type = None\\n                self.cleared_lines.clear()\\n                self.match_positions.clear()\\n                self.chain = 1\\n                if self.spawn_pending:\\n                    self.finish_spawn()\\n            return\\n\\n        now = pygame.time.get_ticks()\\n        if now - self.last_drop >= self.drop_speed:\\n            self.move(0,1)\\n            self.last_drop = now\\n\\n    def move(self, dx, dy):\\n        nx, ny = self.x+dx, self.y+dy\\n        if self.is_valid(nx,ny,self.current):\\n            self.x, self.y = nx, ny\\n        elif dy != 0:\\n            self.lock()\\n\\n    def rotate(self):\\n        old = self.current.rotation_index\\n        self.current.rotate()\\n        if not self.is_valid(self.x,self.y,self.current):\\n            self.current.rotation_index = old\\n            self.current.blocks = list(self.current.rotations[old])\\n\\n    def hard_drop(self):\\n        while self.is_valid(self.x,self.y+1,self.current):\\n            self.y += 1\\n        self.lock()\\n\\n    def is_valid(self, x, y, tet):\\n        for bx,by in tet.get_blocks(x,y):\\n            if not self.grid.is_inside(bx,by):\\n                return False\\n            if self.grid.get_cell(bx,by).state == CellState.FILLED:\\n                return False\\n        return True\\n\\n    def lock(self):\\n        for bx,by in self.current.get_blocks(self.x,self.y):\\n            self.grid.set_cell(bx,by,CellState.FILLED,self.current.color)\\n        self.spawn_pending = True\\n        lines = [y for y in range(self.grid.height)\\n                 if all(self.grid.get_cell(x,y).state==CellState.FILLED\\n                        for x in range(self.grid.width))]\\n        if lines:\\n            self.cleared_lines = lines\\n            for y in sorted(lines):\\n                for x in range(self.grid.width):\\n                    self.grid.set_cell(x,y,CellState.EMPTY,None)\\n                for yy in range(y-1,-1,-1):\\n                    for x in range(self.grid.width):\\n                        c = self.grid.get_cell(x,yy)\\n                        self.grid.set_cell(x,yy+1,c.state,c.color)\\n                        self.grid.set_cell(x,yy,CellState.EMPTY,None)\\n            self.score += {1:100,2:300,3:500,4:800}.get(len(lines),len(lines)*100)\\n            self.animation_type = 'line'\\n            self.animation_timer = LINE_ANIM_FRAMES\\n        else:\\n            matches = self.detect_matches()\\n            if matches:\\n                self.match_positions = matches\\n                self.animation_type = 'match'\\n                self.animation_timer = MATCH_ANIM_FRAMES\\n            else:\\n                self.finish_spawn()\\n\\n    def finish_spawn(self):\\n        self.current = self.next_piece\\n        self.next_piece = self.new_tetromino()\\n        self.x, self.y = SPAWN_X, SPAWN_Y\\n        self.spawn_pending = False\\n        if not self.is_valid(self.x,self.y,self.current):\\n            self.state = GameState.GAME_OVER\\n\\n    def detect_matches(self):\\n        visited = [[False]*self.grid.width for _ in range(self.grid.height)]\\n        matches = set()\\n        for y in range(self.grid.height):\\n            for x in range(self.grid.width):\\n                cell = self.grid.get_cell(x,y)\\n                if cell.state==CellState.FILLED and not visited[y][x]:\\n                    color = cell.color\\n                    stack = [(x,y)]\\n                    comp = []\\n                    visited[y][x] = True\\n                    while stack:\\n                        cx,cy = stack.pop()\\n                        comp.append((cx,cy))\\n                        for dx,dy in ((1,0),(-1,0),(0,1),(0,-1)):\\n                            nx,ny = cx+dx, cy+dy\\n                            if (0<=nx<self.grid.width and 0<=ny<self.grid.height\\n                                and not visited[ny][nx]):\\n                                nc = self.grid.get_cell(nx,ny)\\n                                if nc.state==CellState.FILLED and nc.color==color:\\n                                    visited[ny][nx]=True\\n                                    stack.append((nx,ny))\\n                    if len(comp)>=3:\\n                        matches.update(comp)\\n        return matches\\n\\n    def clear_matches(self):\\n        for x,y in self.match_positions:\\n            self.grid.set_cell(x,y,CellState.EMPTY,None)\\n        for x in range(self.grid.width):\\n            stack = []\\n            for y in range(self.grid.height):\\n                c = self.grid.get_cell(x,y)\\n                if c.state==CellState.FILLED:\\n                    stack.append(c.color)\\n            for y in range(self.grid.height-1,-1,-1):\\n                if stack:\\n                    color = stack.pop()\\n                    self.grid.set_cell(x,y,CellState.FILLED,color)\\n                else:\\n                    self.grid.set_cell(x,y,CellState.EMPTY,None)\\n        self.score += len(self.match_positions) * 50 * self.chain\\n\\n    def render(self):\\n        self.screen.fill((0,0,0))\\n        self.draw_grid()\\n        if self.state!=GameState.GAME_OVER and self.animation_timer==0:\\n            self.draw_tetromino()\\n        self.draw_next()\\n        self.draw_score()\\n        if self.state==GameState.PAUSED:\\n            self.draw_overlay(\\\"Paused\\\")\\n        elif self.state==GameState.GAME_OVER:\\n            self.draw_overlay(\\\"Game Over\\\", final=True)\\n\\n    def draw_grid(self):\\n        for y in range(self.grid.height):\\n            for x in range(self.grid.width):\\n                cell = self.grid.get_cell(x,y)\\n                rect = pygame.Rect(x*BLOCK_SIZE, y*BLOCK_SIZE,\\n                                   BLOCK_SIZE, BLOCK_SIZE)\\n                color = EMPTY_COLOR\\n                if self.animation_timer>0:\\n                    if self.animation_type=='line' and y in self.cleared_lines:\\n                        color = (255,255,255) if (self.animation_timer%2==0) else EMPTY_COLOR\\n                    elif self.animation_type=='match' and (x,y) in self.match_positions:\\n                        color = (255,255,255) if (self.animation_timer%2==0) else EMPTY_COLOR\\n                    else:\\n                        if cell.state==CellState.FILLED:\\n                            color = cell.color\\n                else:\\n                    if cell.state==CellState.FILLED:\\n                        color = cell.color\\n                pygame.draw.rect(self.screen, color, rect)\\n                pygame.draw.rect(self.screen, GRID_LINE_COLOR, rect, 1)\\n\\n    def draw_tetromino(self):\\n        for bx,by in self.current.get_blocks(self.x,self.y):\\n            rect = pygame.Rect(bx*BLOCK_SIZE, by*BLOCK_SIZE,\\n                               BLOCK_SIZE, BLOCK_SIZE)\\n            pygame.draw.rect(self.screen, self.current.color, rect)\\n            pygame.draw.rect(self.screen, GRID_LINE_COLOR, rect, 1)\\n\\n    def draw_next(self):\\n        font = pygame.font.Font(None,30)\\n        label = font.render(\\\"Next:\\\", True, (255,255,255))\\n        self.screen.blit(label, (PREVIEW_POS[0], PREVIEW_POS[1]-30))\\n        for bx,by in self.next_piece.get_blocks(0,0):\\n            px = PREVIEW_POS[0] + bx*BLOCK_SIZE\\n            py = PREVIEW_POS[1] + by*BLOCK_SIZE\\n            rect = pygame.Rect(px,py,BLOCK_SIZE,BLOCK_SIZE)\\n            pygame.draw.rect(self.screen, self.next_piece.color, rect)\\n            pygame.draw.rect(self.screen, GRID_LINE_COLOR, rect,1)\\n\\n    def draw_score(self):\\n        font = pygame.font.Font(None,36)\\n        text = font.render(f\\\"Score: {self.score}\\\", True, (255,255,255))\\n        self.screen.blit(text, (PREVIEW_POS[0], PREVIEW_POS[1]+150))\\n\\n    def draw_overlay(self, text, final=False):\\n        ov = pygame.Surface((SCREEN_WIDTH,SCREEN_HEIGHT), pygame.SRCALPHA)\\n        ov.fill((0,0,0,180))\\n        self.screen.blit(ov,(0,0))\\n        font = pygame.font.Font(None,72)\\n        lbl = font.render(text, True, (255,255,255))\\n        rect = lbl.get_rect(center=(SCREEN_WIDTH//2,SCREEN_HEIGHT//2- (60 if final else 0)))\\n        self.screen.blit(lbl,rect)\\n        if final:\\n            sub = pygame.font.Font(None,48).render(f\\\"Final Score: {self.score}\\\", True, (255,255,255))\\n            r2 = sub.get_rect(center=(SCREEN_WIDTH//2,SCREEN_HEIGHT//2+60))\\n            self.screen.blit(sub,r2)\\n\\nclass InputHandler:\\n    def __init__(self, game):\\n        self.game = game\\n\\n    def handle_input(self):\\n        for event in pygame.event.get():\\n            if event.type == pygame.QUIT:\\n                self.game.running = False\\n            if event.type == pygame.KEYDOWN:\\n                if event.key == pygame.K_LEFT:\\n                    self.game.move_tetromino_sideways(-1)\\n                if event.key == pygame.K_RIGHT:\\n                    self.game.move_tetromino_sideways(1)\\n                if event.key == pygame.K_DOWN:\\n                    self.game.move_tetromino_down()\\n                if event.key == pygame.K_UP:\\n                    self.game.rotate_tetromino()\\n                if event.key == pygame.K_SPACE:\\n                    self.game.drop_tetromino()\\n\\nclass GameStateNew:\\n    # Game states\\n    STATE_SPAWN    = 'spawn'\\n    STATE_FALL     = 'fall'\\n    STATE_LOCK     = 'lock'\\n    STATE_CLEAR    = 'clear'\\n    STATE_GAMEOVER = 'gameover'\\n\\n    # Scoring constants\\n    LINE_CLEAR_POINTS = 100\\n    GEM_CLEAR_POINTS  = 20\\n    CHAIN_BONUS_RATE  = 0.5\\n\\n    def __init__(self, grid):\\n        self.grid           = grid\\n        self.game_logic     = GameLogic(self.grid)\\n        self.score          = 0\\n        self.chain_count    = 0\\n\\n        self.current_piece  = None\\n        self.next_tetromino = self.get_new_tetromino()\\n\\n        self.state          = self.STATE_SPAWN\\n        self.drop_interval  = DROP_INTERVAL  # milliseconds\\n        self.last_drop_time = pygame.time.get_ticks()\\n\\n    # --- Getters for rendering\\n    def get_grid(self):\\n        return self.grid\\n\\n    def get_current_piece(self):\\n        return self.current_piece\\n\\n    def get_next_tetromino(self):\\n        return self.next_tetromino\\n\\n    def is_game_over(self):\\n        return self.state == self.STATE_GAMEOVER\\n\\n    def get_new_tetromino(self):\\n        return Tetromino(random.choice(list(BASE_SHAPES.keys())))\\n\\n\\n    # --- Input handling\\n    def handle_event(self, event):\\n        if self.state != self.STATE_FALL or not self.current_piece:\\n            return\\n        if event.type == pygame.KEYDOWN:\\n            if event.key == pygame.K_LEFT:\\n                self.current_piece.move(-1, 0)\\n            elif event.key == pygame.K_RIGHT:\\n                self.current_piece.move(1, 0)\\n            elif event.key == pygame.K_UP:\\n                self.current_piece.rotate(1)\\n            elif event.key == pygame.K_DOWN:\\n                # soft drop\\n                if not self.current_piece.move(0, 1):\\n                    self.state = self.STATE_LOCK\\n            elif event.key == pygame.K_SPACE:\\n                # hard drop\\n                self.current_piece.hard_drop()\\n                self.state = self.STATE_LOCK\\n\\n    # --- Core mechanics\\n    def spawn_new_piece(self):\\n        self.current_piece   = FallingPiece(self.next_tetromino, self.grid)\\n        self.next_tetromino  = self.get_new_tetromino()\\n        self.chain_count     = 0\\n        self.last_drop_time  = pygame.time.get_ticks()\\n\\n        if not self.current_piece.is_valid_position(\\n                self.current_piece.x, self.current_piece.y):\\n            self.state = self.STATE_GAMEOVER\\n            return False\\n\\n        self.state = self.STATE_FALL\\n        return True\\n\\n    def lock_piece(self):\\n        self.current_piece.lock()\\n        self.current_piece = None\\n        self.state         = self.STATE_CLEAR\\n\\n    def process_clears(self):\\n        while True:\\n            line_matches = self.game_logic.find_line_matches()  # e.g. list of row indices\\n            gem_matches  = self.game_logic.find_gem_matches()   # e.g. list of lists of (x,y)\\n\\n            if not line_matches and not gem_matches:\\n                break\\n\\n            # Clear lines first\\n            lines_cleared = self.game_logic.clear_line_matches(line_matches)\\n            self.game_logic.collapse_lines()\\n\\n            # Clear gem matches\\n            gems_cleared = self.game_logic.clear_gem_matches(gem_matches)\\n            self.game_logic.collapse_gems()\\n\\n            # Calculate points\\n            base_points = (lines_cleared * self.LINE_CLEAR_POINTS +\\n                           gems_cleared  * self.GEM_CLEAR_POINTS)\\n            chain_bonus = int(base_points * self.CHAIN_BONUS_RATE * self.chain_count)\\n            gain        = base_points + chain_bonus\\n\\n            self.score += gain\\n            self.chain_count += 1\\n\\n        # after all chains\\n        self.state = self.STATE_SPAWN\\n\\n    def update(self):\\n        now = pygame.time.get_ticks()\\n\\n        if self.state == self.STATE_SPAWN:\\n            if not self.spawn_new_piece():\\n                self.state = self.STATE_GAMEOVER\\n\\n        elif self.state == self.STATE_FALL:\\n            if now - self.last_drop_time >= self.drop_interval:\\n                if not self.current_piece.move(0, 1):\\n                    self.state = self.STATE_LOCK\\n                self.last_drop_time = now\\n\\n        elif self.state == self.STATE_LOCK:\\n            self.lock_piece()\\n\\n        elif self.state == self.STATE_CLEAR:\\n            self.process_clears()\\n\\n        # STATE_GAMEOVER → external loop handles termination\\n\\nclass FallingPiece:\\n    def __init__(self, tetromino, grid):\\n        self.tetromino = tetromino\\n        self.grid = grid\\n        self.x = SPAWN_X\\n        self.y = SPAWN_Y\\n\\n    def move(self, dx, dy):\\n        new_x = self.x + dx\\n        new_y = self.y + dy\\n        if self.is_valid_position(new_x, new_y):\\n            self.x = new_x\\n            self.y = new_y\\n            return True\\n        return False\\n\\n    def rotate(self, direction):\\n        original_rotation = self.tetromino.rotation_index\\n        self.tetromino.rotate()\\n        if not self.is_valid_position(self.x, self.y):\\n            # Revert rotation if invalid\\n            self.tetromino.rotation_index = original_rotation\\n            self.tetromino.blocks = list(self.tetromino.rotations[original_rotation])\\n\\n    def hard_drop(self):\\n        while self.move(0, 1):\\n            pass\\n\\n    def lock(self):\\n         # Lock the tetromino into the grid\\n        for bx, by in self.tetromino.get_blocks(self.x, self.y):\\n            self.grid.set_cell(bx, by, CellState.FILLED, self.tetromino.color)\\n\\n    def is_valid_position(self, x, y):\\n        for bx, by in self.tetromino.get_blocks(x, y):\\n            if not self.grid.is_inside(bx, by) or self.grid.get_cell(bx, by).state == CellState.FILLED:\\n                return False\\n        return True\\n\\nclass GameLogic:\\n    def __init__(self, grid):\\n        self.grid = grid\\n\\n    def find_line_matches(self):\\n        lines = [y for y in range(self.grid.height)\\n                 if all(self.grid.get_cell(x, y).state == CellState.FILLED\\n                        for x in range(self.grid.width))]\\n        return lines\\n\\n    def clear_line_matches(self, lines):\\n        num_lines = len(lines)\\n        for y in sorted(lines):\\n            for x in range(self.grid.width):\\n                self.grid.set_cell(x, y, CellState.EMPTY, None)\\n        return num_lines\\n\\n    def collapse_lines(self):\\n        for y in sorted(self.find_line_matches()):\\n            for yy in range(y - 1, -1, -1):\\n                for x in range(self.grid.width):\\n                    c = self.grid.get_cell(x, yy)\\n                    self.grid.set_cell(x, yy + 1, c.state, c.color)\\n                    self.grid.set_cell(x, yy, CellState.EMPTY, None)\\n\\n    def find_gem_matches(self):\\n        visited = [[False] * self.grid.width for _ in range(self.grid.height)]\\n        matches = []\\n\\n        for y in range(self.grid.height):\\n            for x in range(self.grid.width):\\n                cell = self.grid.get_cell(x, y)\\n                if cell.state == CellState.FILLED and not visited[y][x]:\\n                    color = cell.color\\n                    stack = [(x, y)]\\n                    component = []\\n                    visited[y][x] = True\\n\\n                    while stack:\\n                        cx, cy = stack.pop()\\n                        component.append((cx, cy))\\n                        for dx, dy in ((1, 0), (-1, 0), (0, 1), (0, -1)):\\n                            nx, ny = cx + dx, cy + dy\\n                            if 0 <= nx < self.grid.width and 0 <= ny < self.grid.height and not visited[ny][nx]:\\n                                neighbor_cell = self.grid.get_cell(nx, ny)\\n                                if neighbor_cell.state == CellState.FILLED and neighbor_cell.color == color:\\n                                    visited[ny][nx] = True\\n                                    stack.append((nx, ny))\\n\\n                    if len(component) >= 3:\\n                        matches.append(component)\\n        return matches\\n\\n    def clear_gem_matches(self, matches):\\n        num_gems = 0\\n        for match in matches:\\n            num_gems += len(match)\\n            for x, y in match:\\n                self.grid.set_cell(x, y, CellState.EMPTY, None)\\n        return num_gems\\n\\n    def collapse_gems(self):\\n        for x in range(self.grid.width):\\n            stack = []\\n            for y in range(self.grid.height):\\n                cell = self.grid.get_cell(x, y)\\n                if cell.state == CellState.FILLED:\\n                    stack.append(cell.color)\\n            for y in range(self.grid.height - 1, -1, -1):\\n                if stack:\\n                    color = stack.pop()\\n                    self.grid.set_cell(x, y, CellState.FILLED, color)\\n                else:\\n                    self.grid.set_cell(x, y, CellState.EMPTY, None)\\n\\nif __name__ == '__main__':\\n    game = TetrisJeweled()\\n    game.run()\\n```\",\n  \"timestamp\": \"2026-05-22T11:36:10.014827\"\n}"}
