 = 'spawn'\\n    STATE_FALL     = 'fall'\\n    STATE_LOCK     = 'lock'\\n    STATE_CLEAR    = 'clear'\\n    STATE_GAMEOVER = 'gameover'\\n\\n    def __init__(self, grid):\\n        self.grid           = grid\\n        self.game_logic     = GameLogic(self.grid)\\n        self.score          = 0\\n        self.chain_count    = 0\\n\\n        self.current_piece  = None\\n        self.next_tetromino = get_new_tetromino()\\n\\n        self.state          = self.STATE_SPAWN\\n        self.drop_interval  = DROP_INTERVAL  # milliseconds\\n        self.last_drop_time = pygame.time.get_ticks()\\n\\n    # --- Public getters for rendering:\\n    def get_grid(self):\\n        return self.grid\\n\\n    def get_current_piece(self):\\n        return self.current_piece\\n\\n    def get_next_tetromino(self):\\n        return self.next_tetromino\\n\\n    def is_game_over(self):\\n        return self.state == self.STATE_GAMEOVER\\n\\n    # --- Input handling:\\n    def handle_event(self, event):\\n        if self.state != self.STATE_FALL or not self.current_piece:\\n            return\\n        if event.type == pygame.KEYDOWN:\\n            if event.key == pygame.K_LEFT:\\n                self.current_piece.move(-1, 0)\\n            elif event.key == pygame.K_RIGHT:\\n                self.current_piece.move(1, 0)\\n            elif event.key == pygame.K_UP:\\n                self.current_piece.rotate(1)\\n            elif event.key == pygame.K_DOWN:\\n                # soft drop\\n                if not self.current_piece.move(0, 1):\\n                    self.state = self.STATE_LOCK\\n            elif event.key == pygame.K_SPACE:\\n                # hard drop\\n                self.current_piece.hard_drop()\\n                self.state = self.STATE_LOCK\\n\\n    # --- Core mechanics:\\n    def spawn_new_piece(self):\\n        \\\"\\\"\\\"Spawn the next tetromino, reset chain, reset drop timer.\\\"\\\"\\\"\\n        self.current_piece  = FallingPiece(self.next_tetromino, self.grid)\\n        self.next_tetromino = get_new_tetromino()\\n        self.chain_count    = 0\\n        self.last_drop_time = pygame.time.get_ticks()\\n\\n        if not self.current_piece.is_valid_position(\\n                self.current_piece.x, self.current_piece.y):\\n            self.state = self.STATE_GAMEOVER\\n            return False\\n\\n        self.state = self.STATE_FALL\\n        return True\\n\\n    def lock_piece(self):\\n        \\\"\\\"\\\"Lock piece into the grid and move to clear phase.\\\"\\\"\\\"\\n        self.current_piece.lock()\\n        self.current_piece = None\\n        self.state         = self.STATE_CLEAR\\n\\n    def process_clears(self):\\n        \\\"\\\"\\\"\\n        1) Detect line clears\\n        2) Detect gem matches\\n        3) Clear both, collapse, award points, repeat for chains\\n        \\\"\\\"\\\"\\n        while True:\\n            # 1) Line clears\\n            line_matches = self.game_logic.find_line_matches()  # returns list of row indices\\n            # 2) Gem (Bejeweled) matches\\n            gem_matches  = self.game_logic.find_gem_matches()   # returns list of lists of (x,y)\\n\\n            if not line_matches and not gem_matches:\\n                break\\n\\n            # Clear them\\n            lines_cleared = len(line_matches)\\n            cells_from_gems = self.game_logic.clear_gem_matches(gem_matches)\\n            cells_from_lines = self.game_logic.clear_line_matches(line_matches)\\n\\n            # Base points: e.g., 100 per line, 10 per gem\\n            base_points = lines_cleared * 100 + cells_from_gems * 10\\n\\n            # Chain bonus: +50% per chain\\n            chain_bonus = int(base_points * 0.5 * self.chain_count)\\n            total_gain  = base_points + chain_bonus\\n            self.score += total_gain\\n\\n            self.chain_count += 1\\n            self.game_logic.collapse_gems()\\n            self.game_logic.collapse_lines()\\n\\n        # After all chains finish, spawn next piece\\n        self.state = self.STATE_SPAWN\\n\\n    def update(self):\\n        now = pygame.time.get_ticks()\\n\\n        if self.state == self.STATE_SPAWN:\\n            if not self.spawn_new_piece():\\n                # cannot spawn → game over\\n                self.state = self.STATE_GAMEOVER\\n\\n        elif self.state == self.STATE_FALL:\\n            # automatic drop by interval\\n            if now - self.last_drop_time >= self.drop_interval:\\n                if not self.current_piece.move(0, 1):\\n                    self.state = self.STATE_LOCK\\n                self.last_drop_time = now\\n\\n        elif self.state == self.STATE_LOCK:\\n            self.lock_piece()\\n\\n        elif self.state == self.STATE_CLEAR:\\n            self.process_clears()\\n\\n        # STATE_GAMEOVER: do nothing (external loop can detect)\\n\\n```\"}"}
