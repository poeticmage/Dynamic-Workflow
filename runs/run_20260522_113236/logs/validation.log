n  Objective: Implement core data structures: grid representation, cell states, and tetromino shape definitions with rotation matrices.\\n  Result: import enum\\n\\nGRID_WIDTH = 10\\nGRID_HEIGHT = 20\\n\\nclass CellState(enum.Enum):\\n    EMPTY = 0\\n    FILLED = 1\\n\\nclass Cell:\\n    __slots__ = (\\\"state\\\", \\\"color\\\")\\n    def __init__(self, state=CellState.EMPTY, color=None):\\n        self.state = state\\n        self.color = color\\n\\nclass Grid:\\n    def __init__(self, width=GRID_WIDTH, height=GRID_HEIGHT):\\n        self.width = width\\n        self.height = height\\n        self.cells = [[Cell() for _ in range(width)] for _ in range(height)]\\n    def is_inside(self, x, y):\\n        return 0 <= x < self.width and 0 <= y < self.height\\n    def get_cell(self, x, y):\\n        return self.cells[y][x]\\n    def set_cell(self, x, y, state, color=None):\\n        cell = self.cells[y][x]\\n        cell.state = state\\n        cell.color = color\\n\\n# Rotation matrices\\nROT_90  = ((0, -1), (1, 0))\\nROT_180 = ((-1, 0), (0, -1))\\nROT_270 = ((0, 1), (-1, 0))\\n\\ndef rotate_point(px, py, matrix):\\n    return px * matrix[0][0] + py * matrix[0][1], px * matrix[1][0] + py * matrix[1][1]\\n\\ndef generate_rotations(shape_coords):\\n    rotations = []\\n    current = shape_coords\\n    for matrix in (ROT_90, ROT_180, ROT_270):\\n        rotated = [rotate_point(x, y, matrix) for x, y in current]\\n        # normalize so min x,y is zero-based\\n        min_x = min(p[0] for p in rotated)\\n        min_y = min(p[1] for p in rotated)\\n        normalized = [(x - min_x, y - min_y) for x, y in rotated]\\n        rotations.append(normalized)\\n        current = rotated\\n    return rotations\\n\\n# Tetromino base shapes in spawn orientation with origin at (0,0)\\nBASE_SHAPES = {\\n    'I': [(0,1),(1,1),(2,1),(3,1)],\\n    'J': [(0,0),(0,1),(1,1),(2,1)],\\n    'L': [(2,0),(0,1),(1,1),(2,1)],\\n    'O': [(0,0),(1,0),(0,1),(1,1)],\\n    'S': [(1,0),(2,0),(0,1),(1,1)],\\n    'T': [(1,0),(0,1),(1,1),(2,1)],\\n    'Z': [(0,0),(1,0),(1,1),(2,1)],\\n}\\n\\nTETROMINO_COLORS = {\\n    'I': (0, 240, 240),\\n    'J': (0, 0, 240),\\n    'L': (240, 160, 0),\\n    'O': (240, 240, 0),\\n    'S': (0, 240, 0),\\n    'T': (160, 0, 240),\\n    'Z': (240, 0, 0),\\n}\\n\\nclass Tetromino:\\n    def __init__(self, shape_key):\\n        self.key = shape_key\\n        self.color = TETROMINO_COLORS[shape_key]\\n        base = BASE_SHAPES[shape_key]\\n        self.rotations = [base] + generate_rotations(base)\\n        self.rotation_index = 0\\n        self.blocks = list(self.rotations[self.rotation_index])\\n    def rotate(self, direction=1):\\n        self.rotation_index = (self.rotation_index + direction) % len(self.rotations)\\n        self.blocks = list(self.rotations[self.rotation_index])\\n    def get_blocks(self, offset_x=0, offset_y=0):\\n        return [(x + offset_x, y + offset_y) for x, y in self.blocks]\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task6:\\n  Objective: Integrate game state, input handler, and GUI renderer into a cohesive main loop with smooth animations and real-time updates.\\n\\n---\\n# **Current Task Requirements**\\nImplement the GUI renderer using Pygame: draw grid, current score, next piece preview, and manage animation frames.\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport pygame\\nimport random\\nfrom enum import Enum\\nfrom task0 import GRID_WIDTH, GRID_HEIGHT, CellState, Cell, Grid, ROT_90, ROT_180, ROT_270, rotate_point, generate_rotations, BASE_SHAPES, TETROMINO_COLORS, Tetromino\\n\\n# Pygame Constants\\nSCREEN_WIDTH = 600\\nSCREEN_HEIGHT = 800\\nGRID_LINE_COLOR = (50, 50, 50)\\nEMPTY_COLOR = (30, 30, 30)\\nBLOCK_SIZE = 30\\nSPAWN_X = GRID_WIDTH // 2 - 2\\nSPAWN_Y = 0\\nPREVIEW_SIZE = 4\\nPREVIEW_POS = (450, 100)\\n\\nclass GameState(Enum):\\n    ACTIVE = 0\\n    PAUSED = 1\\n    GAME_OVER = 2\\n\\nclass TetrisJeweled:\\n    def __init__(self):\\n        pygame.init()\\n        self.screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\\n        pygame.display.set_caption(\\\"Tetris Jeweled\\\")\\n        self.clock = pygame.time.Clock()\\n        self.grid = Grid()\\n        self.current_tetromino = self.new_tetromino()\\n        self.next_tetromino = self.new_tetromino()\\n        self.tetromino_x = SPAWN_X\\n        self.tetromino_y = SPAWN_Y\\n        self.game_state = GameState.ACTIVE\\n        self.score = 0\\n        self.drop_speed = 500 # milliseconds\\n        self.last_drop_time = pygame.time.get_ticks()\\n        self.animation_frames = 6\\n        self.animation_timer = 0\\n\\n    def new_tetromino(self):\\n        return Tetromino(random.choice(list(BASE_SHAPES.keys())))\\n\\n    def run(self):\\n        running = True\\n        while running:\\n            delta_time = self.clock.tick(60) / 1000.0\\n            for event in pygame.event.get():\\n                if event.type == pygame.QUIT:\\n                    running = False\\n                if event.type == pygame.KEYDOWN:\\n                    if event.key == pygame.K_LEFT and self.game_state == GameState.ACTIVE:\\n                        self.move_tetromino(-1, 0)\\n                    if event.key == pygame.K_RIGHT and self.game_state == GameState.ACTIVE:\\n                        self.move_tetromino(1, 0)\\n                    if event.key == pygame.K_DOWN and self.game_state == GameState.ACTIVE:\\n                        self.move_tetromino(0, 1)\\n                    if event.key == pygame.K_UP and self.game_state == GameState.ACTIVE:\\n                        self.rotate_tetromino()\\n                    if event.key == pygame.K_SPACE and self.game_state == GameState.ACTIVE:\\n                        self.drop_tetromino()\\n                    if event.key == pygame.K_p:\\n                        if self.game_state == GameState.ACTIVE:\\n                            self.game_state = GameState.PAUSED\\n                        elif self.game_state == GameState.PAUSED:\\n                            self.game_state = GameState.ACTIVE\\n\\n            if self.game_state == GameState.ACTIVE:\\n                self.update(delta_time)\\n            self.render()\\n            pygame.display.flip()\\n\\n        pygame.quit()\\n\\n    def update(self, delta_time):\\n        time_now = pygame.time.get_ticks()\\n        if time_now - self.last_drop_time > self.drop_speed:\\n            self.move_tetromino(0, 1)\\n            self.last_drop_time = time_now\\n\\n        if self.animation_timer > 0:\\n            self.animation_timer -= 1\\n\\n    def move_tetromino(self, dx, dy):\\n        new_x = self.tetromino_x + dx\\n        new_y = self.tetromino_y + dy\\n        if self.is_valid_position(new_x, new_y, self.current_tetromino):\\n            self.tetromino_x = new_x\\n            self.tetromino_y = new_y\\n        elif dy != 0:  # Attempting to move down and collision occurred\\n            self.lock_tetromino()\\n\\n    def rotate_tetromino(self):\\n        original_rotation_index = self.current_tetromino.rotation_index\\n        self.current_tetromino.rotate()\\n        if not self.is_valid_position(self.tetromino_x, self.tetromino_y, self.current_tetromino):\\n            # Revert rotation if the new position is invalid\\n            self.current_tetromino.rotation_index = original_rotation_index\\n            self.current_tetromino.blocks = list(self.current_tetromino.rotations[original_rotation_index])\\n\\n    def drop_tetromino(self):\\n        while self.is_valid_position(self.tetromino_x, self.tetromino_y + 1, self.current_tetromino):\\n            self.tetromino_y += 1\\n        self.lock_tetromino()\\n\\n    def is_valid_position(self, x, y, tetromino):\\n        for block_x, block_y in tetromino.get_blocks(x, y):\\n            if not self.grid.is_inside(block_x, block_y) or self.grid.get_cell(block_x, block_y).state == CellState.FILLED:\\n                return False\\n        return True\\n\\n    def lock_tetromino(self):\\n        for block_x, block_y in self.current_tetromino.get_blocks(self.tetromino_x, self.tetromino_y):\\n            self.grid.set_cell(block_x, block_y, CellState.FILLED, self.current_tetromino.color)\\n        self.clear_lines()\\n        self.current_tetromino = self.next_tetromino\\n        self.next_tetromino = self.new_tetromino()\\n        self.tetromino_x = SPAWN_X\\n        self.tetromino_y = SPAWN_Y\\n        if not self.is_valid_position(self.tetromino_x, self.tetromino_y, self.current_tetromino):\\n            self.game_state = GameState.GAME_OVER\\n\\n    def clear_lines(self):\\n          lines_cleared = 0\\n          y = self.grid.height - 1\\n          while y >= 0:\\n              if all(self.grid.get_cell(x, y).state == CellState.FILLED for x in range(self.grid.width)):\\n                  # Clear the line\\n                  for x in range(self.grid.width):\\n                      self.grid.set_cell(x, y, CellState.EMPTY, None)\\n                  # Move all lines above down by one\\n                  for yy in range(y - 1, -1, -1):\\n                      for x in range(self.grid.width):\\n                          cell = self.grid.get_cell(x, yy)\\n                          self.grid.set_cell(x, yy + 1, cell.state, cell.color)\\n                          self.grid.set_cell(x, yy, CellState.EMPTY, None)\\n                  lines_cleared += 1\\n              else:\\n                  y -= 1\\n\\n          if lines_cleared > 0:\\n              self.score += self.calculate_score(lines_cleared)\\n              self.animation_timer = self.animation_frames\\n\\n    def calculate_score(self, lines_cleared):\\n        if lines_cleared == 1:\\n            return 100\\n        elif lines_cleared == 2:\\n            return 300\\n        elif lines_cleared == 3:\\n            return 500\\n        elif lines_cleared == 4:\\n            return 800\\n        return 0\\n\\n    def render(self):\\n        self.screen.fill((0, 0, 0))\\n        self.draw_grid()\\n        self.draw_tetromino()\\n        self.draw_next_tetromino()\\n        self.draw_score()\\n        if self.game_state == GameState.PAUSED:\\n            self.draw_pause_screen()\\n        if self.game_state == GameState.GAME_OVER:\\n            self.draw_game_over_screen()\\n\\n    def draw_grid(self):\\n        for x in range(self.grid.width):\\n            for y in range(self.grid.height):\\n                cell = self.grid.get_cell(x, y)\\n                rect = pygame.Rect(x * BLOCK_SIZE, y * BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE)\\n                if cell.state == CellState.FILLED:\\n                    pygame.draw.rect(self.screen, cell.color, rect)\\n                    pygame.draw.rect(self.screen, GRID_LINE_COLOR, rect, 1)\\n                else:\\n                    pygame.draw.rect(self.screen, EMPTY_COLOR, rect)\\n                    pygame.draw.rect(self.screen, GRID_LINE_COLOR, rect, 1)\\n\\n    def draw_tetromino(self):\\n        for block_x, block_y in self.current_tetromino.get_blocks(self.tetromino_x, self.tetromino_y):\\n            rect = pygame.Rect(block_x * BLOCK_SIZE, block_y * BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE)\\n            pygame.draw.rect(self.screen, self.current_tetromino.color, rect)\\n            pygame.draw.rect(self.screen, GRID_LINE_COLOR, rect, 1)\\n\\n    def draw_next_tetromino(self):\\n        font = pygame.font.Font(None, 30)\\n        text = font.render(\\\"Next Piece:\\\", True, (255, 255, 255))\\n        self.screen.blit(text, (PREVIEW_POS[0], PREVIEW_POS[1] - 30))\\n\\n        for block_x, block_y in self.next_tetromino.get_blocks():\\n            x = block_x + PREVIEW_POS[0] // BLOCK_SIZE\\n            y = block_y + (PREVIEW_POS[1] + 30) // BLOCK_SIZE\\n            rect = pygame.Rect(x * BLOCK_SIZE, y * BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE)\\n            pygame.draw.rect(self.screen, self.next_tetromino.color, rect)\\n            pygame.draw.rect(self.screen, GRID_LINE_COLOR, rect, 1)\\n\\n    def draw_score(self):\\n        font = pygame.font.Font(None, 36)\\n        text = font.render(f\\\"Score: {self.score}\\\", True, (255, 255, 255))\\n        self.screen.blit(text, (420, 300))\\n\\n    def draw_pause_screen(self):\\n        overlay = pygame.Surface((SCREEN_WIDTH, SCREEN_HEIGHT), pygame.SRCALPHA)\\n        overlay.fill((0, 0, 0, 128))\\n        self.screen.blit(overlay, (0, 0))\\n\\n        font = pygame.font.Font(None, 72)\\n        text = font.render(\\\"Paused\\\", True, (255, 255, 255))\\n        text_rect = text.get_rect(center=(SCREEN_WIDTH // 2, SCREEN_HEIGHT // 2))\\n        self.screen.blit(text, text_rect)\\n\\n    def draw_game_over_screen(self):\\n        overlay = pygame.Surface((SCREEN_WIDTH, SCREEN_HEIGHT), pygame.SRCALPHA)\\n        overlay.fill((0, 0, 0, 128))\\n        self.screen.blit(overlay, (0, 0))\\n\\n        font = pygame.font.Font(None, 72)\\n        text = font.render(\\\"Game Over\\\", True, (255, 255, 255))\\n        text_rect = text.get_rect(center=(SCREEN_WIDTH // 2, SCREEN_HEIGHT // 2))\\n        self.screen.blit(text, text_rect)\\n\\n        score_text = pygame.font.Font(None, 48).render(f\\\"Final Score: {self.score}\\\", True, (255, 255, 255))\\n        score_rect = score_text.get_rect(center=(SCREEN_WIDTH // 2, SCREEN_HEIGHT // 2 + 60))\\n        self.screen.blit(score_text, score_rect)\\n\\nif __name__ == '__main__':\\n    game = TetrisJeweled()\\n    game.run()\\n```\",\n  \"timestamp\": \"2026-05-22T11:33:25.649447\"\n}"}
