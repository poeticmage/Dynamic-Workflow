{"timestamp": "2026-05-28 12:33:36,274", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task3: ```python\nimport smtplib\nfrom email.mime.text import MIMEText\nimport json\nfrom datetime import datetime\n\nclass InterviewAutomation:\n    def __init__(self, interview_module_json, sender_email, sender_password):\n        \"\"\"\n        Initializes the InterviewAutomation class.\n\n        Args:\n            interview_module_json (str): JSON string containing interview details.\n            sender_email (str): Email address of the sender.\n            sender_password (str): Password of the sender email account.\n        \"\"\"\n        self.interview_module = json.loads(interview_module_json)\n        self.sender_email = sender_email\n        self.sender_password = sender_password\n\n    def send_email(self, recipient_email, subject, body):\n        \"\"\"\n        Sends an email to the specified recipient.\n\n        Args:\n            recipient_email (str): Email address of the recipient.\n            subject (str): Subject of the email.\n            body (str): Body of the email.\n\n        Returns:\n            bool: True if the email was sent successfully, False otherwise.\n        \"\"\"\n        try:\n            msg = MIMEText(body)\n            msg['Subject'] = subject\n            msg['From'] = self.sender_email\n            msg['To'] = recipient_email\n\n            with smtplib.SMTP_SSL('smtp.gmail.com', 465) as smtp_server:\n                smtp_server.login(self.sender_email, self.sender_password)\n                smtp_server.sendmail(self.sender_email, recipient_email, msg.as_string())\n            return True\n        except Exception as e:\n            print(f\"Email sending failed: {e}\")\n            return False\n\n    def process_emails(self):\n        \"\"\"\n        Processes the emails in the interview module, sending invites and follow-ups.\n        \"\"\"\n        candidate_email = self.interview_module['interviewModule']['candidateResume']['candidate_details']['email']\n        emails = self.interview_module['interviewModule']['emails']\n\n        for email in emails:\n            if email['status'] == 'pending':\n                if email['type'] == 'invite':\n                    success = self.send_email(candidate_email, email['subject'], email['body'])\n                    if success:\n                        email['status'] = 'sent'\n                        email['timestamp'] = datetime.now().isoformat()\n                        print(f\"Interview invite sent to {candidate_email}\")\n                    else:\n                        print(f\"Failed to send interview invite to {candidate_email}\")\n                elif email['type'] == 'follow_up':\n                    success = self.send_email(candidate_email, email['subject'], email['body'])\n                    if success:\n                        email['status'] = 'sent'\n                        email['timestamp'] = datetime.now().isoformat()\n                        print(f\"Interview follow-up sent to {candidate_email}\")\n                    else:\n                        print(f\"Failed to send interview follow-up to {candidate_email}\")\n        return self.interview_module\n\n    def update_interview_module_json(self):\n        \"\"\"\n        Updates the interview module JSON with the new email statuses and timestamps.\n        Returns:\n            str: Updated JSON string.\n        \"\"\"\n        return json.dumps(self.process_emails(), indent=2)\n\n\n# Example Usage (replace with actual credentials and JSON data)\nif __name__ == '__main__':\n    interview_module_json = \"\"\"\n    {\n      \"interviewModule\": {\n        \"jobDescription\": {\n          \"job_title\": \"Data Scientist\",\n          \"seniority_level\": \"Mid\",\n          \"department\": \"Research\",\n          \"employment_type\": \"Full-time\",\n          \"location\": \"New York\",\n          \"remote_policy\": \"Hybrid\",\n          \"required_skills\": [\n            \"Python\",\n            \"Machine Learning\",\n            \"Data Analysis\",\n            \"SQL\"\n          ],\n          \"preferred_skills\": [\n            \"Deep Learning\",\n            \"Cloud Computing (AWS)\"\n          ],\n          \"required_experience_years\": 3,\n          \"educational_requirements\": \"Master's Degree in Data Science or related field\",\n          \"key_responsibilities\": [\n            \"Develop and deploy machine learning models\",\n            \"Conduct data analysis and statistical modeling\",\n            \"Collaborate with cross-functional teams\",\n            \"Build data pipelines\"\n          ],\n          \"compensation_range\": \"$120k-$150k\",\n          \"flags\": []\n        },\n        \"candidateResume\": {\n          \"candidate_details\": {\n            \"personal_details\": {\n              \"full_name\": \"Jane Smith\",\n              \"email\": \"jane.smith@email.com\",\n              \"phone\": \"+1-555-123-4567\",\n              \"linkedin\": \"linkedin.com/in/janesmith\"\n            },\n            \"summary\": \"Highly motivated data scientist with 3+ years of experience in machine learning, data analysis, and statistical modeling. Proven ability to develop and implement effective solutions to complex business problems.\",\n            \"skills\": [\n              {\n                \"name\": \"Python\",\n                \"level\": \"Expert\"\n              },\n              {\n                \"name\": \"Machine Learning\",\n                \"level\": \"Expert\"\n              },\n              {\n                \"name\": \"Data Analysis\",\n                \"level\": \"Proficient\"\n              },\n              {\n                \"name\": \"SQL\",\n                \"level\": \"Proficient\"\n              },\n              {\n                \"name\": \"Deep Learning\",\n                \"level\": \"Intermediate\"\n              },\n              {\n                \"name\": \"Cloud Computing (AWS)\",\n                \"level\": \"Intermediate\"\n              }\n            ],\n            \"experience\": [\n              {\n                \"position\": \"Data Scientist\",\n                \"company\": \"Acme Corp\",\n                \"start_date\": \"2020-06-01\",\n                \"end_date\": \"2023-08-15\",\n                \"responsibilities\": [\n                  \"Developed and deployed machine learning models for fraud detection, resulting in a 20% reduction in fraudulent transactions.\",\n                  \"Conducted data analysis to identify key business insights and trends.\",\n                  \"Collaborated with cross-functional teams to implement data-driven solutions.\",\n                  \"Built data pipelines for efficient data processing and storage.\"\n                ]\n              },\n              {\n                \"position\": \"Data Analyst\",\n                \"company\": \"Beta Inc.\",\n                \"start_date\": \"2019-01-02\",\n                \"end_date\": \"2020-05-31\",\n                \"responsibilities\": [\n                  \"Performed data analysis to support business decision-making.\",\n                  \"Created dashboards and reports to visualize key performance indicators.\",\n                  \"Assisted in the development of machine learning models.\"\n                ]\n              }\n            ],\n            \"education\": [\n              {\n                \"degree\": \"M.Sc. Data Science\",\n                \"institution\": \"University of California, Berkeley\",\n                \"start_year\": 2017,\n                \"end_year\": 2018,\n                \"grade\": \"3.9/4.0\"\n              },\n              {\n                \"degree\": \"B.Sc. Statistics\",\n                \"institution\": \"University of Michigan\",\n                \"start_year\": 2013,\n                \"end_year\": \"2016\",\n                \"grade\": \"3.7/4.0\"\n              }\n            ],\n            \"projects\": [\n              {\n                \"name\": \"Customer Churn Prediction\",\n                \"description\": \"Developed a machine learning model to predict customer churn with 85% accuracy.\",\n                \"skills\": [\"Python\", \"Machine Learning\", \"Data Analysis\"]\n              }\n            ],\n            \"certifications\": [\n              {\n                \"name\": \"AWS Certified Machine Learning Specialist\",\n                \"issuing_organization\": \"Amazon Web Services\",\n                \"issue_date\": \"2022-12-01\"\n              }\n            ]\n          }\n        },\n        \"questions\": [\n          {\n            \"questionId\": \"Q1\",\n            \"skill\": \"Python\",\n            \"level\": \"Expert\",\n            \"type\": \"theoretical\",\n            \"prompt\": \"Explain the difference between lists and tuples in Python. When would you use one over the other?\",\n            \"expectedAnswer\": \"Lists are mutable, while tuples are immutable. Use tuples when you want to ensure data integrity or use them as keys in dictionaries.\",\n            \"candidateResponse\": null,\n            \"timeTakenSeconds\": null,\n            \"score\": null,\n            \"feedback\": null\n          },\n          {\n            \"questionId\": \"Q2\",\n            \"skill\": \"Machine Learning\",\n            \"level\": \"Expert\",\n            \"type\": \"practical\",\n            \"prompt\": \"Describe the steps involved in building and evaluating a machine learning model. Provide an example of a model you have built and evaluated.\",\n            \"expectedAnswer\": \"Data collection, preprocessing, feature engineering, model selection, training, evaluation, and deployment. For example, a fraud detection model using logistic regression.\",\n            \"candidateResponse\": null,\n            \"timeTakenSeconds\": null,\n            \"score\": null,\n            \"feedback\": null\n          },\n          {\n            \"questionId\": \"Q3\",\n            \"skill\": \"Data Analysis\",\n            \"level\": \"Proficient\",\n            \"type\": \"problem-solving\",\n            \"prompt\": \"Given a dataset with missing values, what are the different approaches you can take to handle them? Explain the pros and cons of each approach.\",\n            \"expectedAnswer\": \"Imputation (mean, median, mode), deletion (listwise, pairwise), or using algorithms that handle missing data natively. Pros and cons depend on the specific dataset and missingness pattern.\",\n            \"candidateResponse\": null,\n            \"timeTakenSeconds\": null,\n            \"score\": null,\n            \"feedback\": null\n          },\n          {\n            \"questionId\": \"Q4\",\n            \"skill\": \"SQL\",\n            \"level\": \"Proficient\",\n            \"type\": \"practical\",\n            \"prompt\": \"Write a SQL query to retrieve the top 10 customers with the highest total purchase amount.\",\n            \"expectedAnswer\": \"SELECT customer_id, SUM(purchase_amount) AS total_purchase FROM purchases GROUP BY customer_id ORDER BY total_purchase DESC LIMIT 10;\",\n            \"candidateResponse\": null,\n            \"timeTakenSeconds\": null,\n            \"score\": null,\n            \"feedback\": null\n          },\n          {\n            \"questionId\": \"Q5\",\n            \"skill\": \"Cloud Computing (AWS)\",\n            \"level\": \"Intermediate\",\n            \"type\": \"theoretical\",\n            \"prompt\": \"Explain the differences between EC2, S3, and Lambda in AWS. When would you use each of these services?\",\n            \"expectedAnswer\": \"EC2 is a virtual server, S3 is object storage, and Lambda is a serverless compute service. Use EC2 for general-purpose computing, S3 for storing files, and Lambda for event-driven applications.\",\n            \"candidateResponse\": null,\n            \"timeTakenSeconds\": null,\n            \"score\": null,\n            \"feedback\": null\n          }\n        ],\n        \"metadata\": {\n          \"scheduledAt\": null,\n          \"conductedAt\": null,\n          \"interviewer\": \"Jane Doe\",\n          \"jobDescriptionId\": \"JOB123\",\n          \"candidateId\": \"CAND456\"\n        },\n         \"emails\": [\n          {\n            \"type\": \"invite\",\n            \"timestamp\": null,\n            \"subject\": \"Interview Invitation\",\n            \"body\": \"Dear Jane Smith, You are invited to an interview...\",\n            \"status\": \"pending\"\n          },\n          {\n            \"type\": \"follow_up\",\n            \"timestamp\": null,\n            \"subject\": \"Interview Follow-up\",\n            \"body\": \"Dear Jane Smith, Thank you for your time...\",\n            \"status\": \"pending\"\n          }\n        ],\n        \"evaluationReport\": {\n          \"overallScore\": null,\n          \"summary\": null,\n          \"strengths\": [],\n          \"weaknesses\": [],\n          \"recommendation\": null\n        }\n      }\n    }\n    \"\"\"\n    sender_email = \"your_email@gmail.com\"  # Replace with your email\n    sender_password = \"your_password\"  # Replace with your password\n\n    automation = InterviewAutomation(interview_module_json, sender_email, sender_password)\n    updated_json = automation.update_interview_module_json()\n\n    print(updated_json)\n\n    # Save the updated JSON to a file\n    with open(\"updated_interview_module.json\", \"w\") as f:\n        f.write(updated_json)\n```\n```text\n1.  The `InterviewAutomation` class is initialized with the interview module data, the sender's email, and the sender's password.\n2.  The `send_email` method sends an email using the provided SMTP server details. It takes the recipient's email, subject, and body as input. It returns `True` if the email is sent successfully, and `False` otherwise.\n3.  The `process_emails` method iterates through the emails in the interview module. If an email's status is 'pending', it sends the email (either invite or follow-up) and updates the email's status to 'sent' along with a timestamp.\n4.  The `update_interview_module_json` method calls `process_emails` and returns an updated JSON string.\n5.  The main block demonstrates how to use the `InterviewAutomation` class with sample data. It initializes the class, processes the emails, and prints the updated JSON.  It saves the updated JSON to `updated_interview_module.json`.\n\nDependencies:\n- `smtplib`: For sending emails.\n- `email.mime.text`:  For constructing email messages.\n- `json`: For handling JSON data.\n- `datetime`:  For timestamping emails.\n\nTo use this code:\n\n1.  Replace `\"your_email@gmail.com\"` and `\"your_password\"` with your actual Gmail credentials.  Note that you might need to enable \"less secure app access\" in your Gmail settings or use an App Password if you have 2-Factor Authentication enabled.\n2.  Replace the sample `interview_module_json` with your actual JSON data.\n3.  Run the script. It will print the updated JSON to the console and save it to `updated_interview_module.json`.\n```"}
