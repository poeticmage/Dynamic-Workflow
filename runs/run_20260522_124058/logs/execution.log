{"timestamp": "2026-05-22 12:47:35,552", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task0: from enum import Enum\nfrom dataclasses import dataclass\nfrom typing import List, Tuple, Optional, Dict\n\nclass Color(Enum):\n    CYAN = (0, 255, 255)\n    BLUE = (0, 0, 255)\n    ORANGE = (255, 165, 0)\n    YELLOW = (255, 255, 0)\n    GREEN = (0, 255, 0)\n    PURPLE = (128, 0, 128)\n    RED = (255, 0, 0)\n\n@dataclass\nclass GemCell:\n    color: Color\n\n@dataclass\nclass Tetromino:\n    shape_id: str\n    rotations: List[List[Tuple[int, int]]]\n    color: Color\n\nTETROMINO_SHAPES: Dict[str, Tetromino] = {\n    'I': Tetromino(\n        shape_id='I',\n        color=Color.CYAN,\n        rotations=[\n            [(0,1),(1,1),(2,1),(3,1)],\n            [(2,0),(2,1),(2,2),(2,3)],\n            [(0,2),(1,2),(2,2),(3,2)],\n            [(1,0),(1,1),(1,2),(1,3)]\n        ]\n    ),\n    'O': Tetromino(\n        shape_id='O',\n        color=Color.YELLOW,\n        rotations=[\n            [(1,0),(2,0),(1,1),(2,1)]\n        ]\n    ),\n    'T': Tetromino(\n        shape_id='T',\n        color=Color.PURPLE,\n        rotations=[\n            [(1,0),(0,1),(1,1),(2,1)],\n            [(1,0),(1,1),(2,1),(1,2)],\n            [(0,1),(1,1),(2,1),(1,2)],\n            [(1,0),(0,1),(1,1),(1,2)]\n        ]\n    ),\n    'S': Tetromino(\n        shape_id='S',\n        color=Color.GREEN,\n        rotations=[\n            [(1,0),(2,0),(0,1),(1,1)],\n            [(1,0),(1,1),(2,1),(2,2)]\n        ]\n    ),\n    'Z': Tetromino(\n        shape_id='Z',\n        color=Color.RED,\n        rotations=[\n            [(0,0),(1,0),(1,1),(2,1)],\n            [(2,0),(1,1),(2,1),(1,2)]\n        ]\n    ),\n    'J': Tetromino(\n        shape_id='J',\n        color=Color.BLUE,\n        rotations=[\n            [(0,0),(0,1),(1,1),(2,1)],\n            [(1,0),(2,0),(1,1),(1,2)],\n            [(0,1),(1,1),(2,1),(2,2)],\n            [(1,0),(1,1),(0,2),(1,2)]\n        ]\n    ),\n    'L': Tetromino(\n        shape_id='L',\n        color=Color.ORANGE,\n        rotations=[\n            [(2,0),(0,1),(1,1),(2,1)],\n            [(1,0),(1,1),(1,2),(2,2)],\n            [(0,1),(1,1),(2,1),(0,2)],\n            [(0,0),(1,0),(1,1),(1,2)]\n        ]\n    )\n}\n\nclass Grid:\n    def __init__(self, width: int = 10, height: int = 20):\n        self.width = width\n        self.height = height\n        self.cells: List[List[Optional[GemCell]]] = [\n            [None for _ in range(self.width)] for _ in range(self.height)\n        ]\n\n    def is_inside(self, x: int, y: int) -> bool:\n        return 0 <= x < self.width and 0 <= y < self.height\n\n    def get_cell(self, x: int, y: int) -> Optional[GemCell]:\n        if not self.is_inside(x, y):\n            return None\n        return self.cells[y][x]\n\n    def set_cell(self, x: int, y: int, gem: GemCell) -> None:\n        if self.is_inside(x, y):\n            self.cells[y][x] = gem\n\n    def clear_cell(self, x: int, y: int) -> None:\n        if self.is_inside(x, y):\n            self.cells[y][x] = None\n\n    def reset(self) -> None:\n        for y in range(self.height):\n            for x in range(self.width):\n                self.cells[y][x] = None"}
{"timestamp": "2026-05-22 12:47:35,552", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task1: ```python\nimport random\nfrom typing import Optional, List, Tuple  # Added List and Tuple imports\n\nfrom task0 import Color, GemCell, Tetromino, TETROMINO_SHAPES, Grid\n\n\nclass TetrominoManager:\n    def __init__(self, grid: Grid):\n        self.grid = grid\n        self.current_tetromino: Optional[Tetromino] = None\n        self.current_rotation: int = 0\n        self.x: int = 0\n        self.y: int = 0\n        self.new_tetromino()\n\n    def new_tetromino(self) -> None:\n        \"\"\"Generates a new tetromino at the top of the grid.\"\"\"\n        self.current_tetromino = random.choice(list(TETROMINO_SHAPES.values()))\n        self.current_rotation = 0\n        self.x = self.grid.width // 2 - 2  # Center the tetromino\n        self.y = 0\n\n        if self.check_collision(self.x, self.y, self.current_rotation):\n            self.grid.reset()  # Game over if new tetromino can't fit\n            self.current_tetromino = None  # Indicate game over\n\n    def rotate(self) -> None:\n        \"\"\"Rotates the current tetromino clockwise.\"\"\"\n        if self.current_tetromino is None:\n            return\n        new_rotation = (self.current_rotation + 1) % len(self.current_tetromino.rotations)\n        if not self.check_collision(self.x, self.y, new_rotation):\n            self.current_rotation = new_rotation\n\n    def move(self, dx: int) -> None:\n        \"\"\"Moves the current tetromino horizontally.\"\"\"\n        if self.current_tetromino is None:\n            return\n        if not self.check_collision(self.x + dx, self.y, self.current_rotation):\n            self.x += dx\n\n    def move_down(self) -> bool:\n        \"\"\"Moves the current tetromino down. Returns True if it locked.\"\"\"\n        if self.current_tetromino is None:\n            return False\n\n        if not self.check_collision(self.x, self.y + 1, self.current_rotation):\n            self.y += 1\n            return False\n        else:\n            self.lock_tetromino()\n            return True\n\n    def check_collision(self, x: int, y: int, rotation: int) -> bool:\n        \"\"\"Checks for collisions with the grid boundaries and existing gems.\"\"\"\n        if self.current_tetromino is None:\n            return True\n\n        for cell_x, cell_y in self.current_tetromino.rotations[rotation]:\n            grid_x = x + cell_x\n            grid_y = y + cell_y\n\n            if not self.grid.is_inside(grid_x, grid_y):\n                return True  # Out of bounds\n\n            if grid_y >= 0 and self.grid.get_cell(grid_x, grid_y) is not None:\n                return True  # Collision with existing gem\n\n        return False\n\n    def lock_tetromino(self) -> None:\n        \"\"\"Locks the current tetromino into the grid and converts it to gems.\"\"\"\n        if self.current_tetromino is None:\n            return\n\n        for cell_x, cell_y in self.current_tetromino.rotations[self.current_rotation]:\n            grid_x = self.x + cell_x\n            grid_y = self.y + cell_y\n            if self.grid.is_inside(grid_x, grid_y):\n                self.grid.set_cell(grid_x, grid_y, GemCell(self.current_tetromino.color))\n        self.new_tetromino()\n\n    def get_tetromino_cells(self) -> Optional[List[Tuple[int, int, Color]]]:\n        \"\"\"Returns the cell positions and colors of the current tetromino.\"\"\"\n        if self.current_tetromino is None:\n            return None\n\n        cells: List[Tuple[int, int, Color]] = []\n        for cell_x, cell_y in self.current_tetromino.rotations[self.current_rotation]:\n            grid_x = self.x + cell_x\n            grid_y = self.y + cell_y\n            if self.grid.is_inside(grid_x, grid_y) and grid_y >= 0:\n                cells.append((grid_x, grid_y, self.current_tetromino.color))\n        return cells\n```"}
{"timestamp": "2026-05-22 12:47:35,552", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task2: ```python\nimport random\nfrom typing import List, Tuple, Optional\n\nfrom task0 import Grid, GemCell, Color\n\n\n# Standard Tetris line clear scoring\nTETRIS_SCORES = {\n    1: 100,\n    2: 300,\n    3: 500,\n    4: 800,\n}\n\n\nclass ClearingManager:\n    def __init__(self, grid: Grid):\n        self.grid = grid\n        self.score = 0\n\n    def clear_lines(self) -> int:\n        \"\"\"Detects and removes all full rows, returns number of lines cleared.\"\"\"\n        full_rows = [y for y in range(self.grid.height)\n                     if all(self.grid.get_cell(x, y) is not None for x in range(self.grid.width))]\n        if not full_rows:\n            return 0\n\n        # Rebuild each column by filtering out cleared rows\n        for x in range(self.grid.width):\n            column_cells = [self.grid.get_cell(x, y) for y in range(self.grid.height)\n                             if y not in full_rows]\n            # Pad top with None\n            new_col = [None] * len(full_rows) + column_cells\n            for y, cell in enumerate(new_col):\n                self.grid.set_cell(x, y, cell)\n        return len(full_rows)\n\n    def find_matches(self) -> List[Tuple[int, int]]:\n        \"\"\"Finds all match-3+ runs and returns unique gem coordinates.\"\"\"\n        matches = set()\n\n        # Horizontal runs\n        for y in range(self.grid.height):\n            x = 0\n            while x < self.grid.width - 2:\n                cell = self.grid.get_cell(x, y)\n                if cell is None:\n                    x += 1\n                    continue\n                run_color = cell.color\n                run_length = 1\n                while x + run_length < self.grid.width and \\\n                      self.grid.get_cell(x + run_length, y) and \\\n                      self.grid.get_cell(x + run_length, y).color == run_color:\n                    run_length += 1\n                if run_length >= 3:\n                    for rx in range(x, x + run_length):\n                        matches.add((rx, y))\n                x += run_length\n        # Vertical runs\n        for x in range(self.grid.width):\n            y = 0\n            while y < self.grid.height - 2:\n                cell = self.grid.get_cell(x, y)\n                if cell is None:\n                    y += 1\n                    continue\n                run_color = cell.color\n                run_length = 1\n                while y + run_length < self.grid.height and \\\n                      self.grid.get_cell(x, y + run_length) and \\\n                      self.grid.get_cell(x, y + run_length).color == run_color:\n                    run_length += 1\n                if run_length >= 3:\n                    for ry in range(y, y + run_length):\n                        matches.add((x, ry))\n                y += run_length\n        return list(matches)\n\n    def clear_matches(self) -> int:\n        \"\"\"Clears all matched gems, drops floating gems, returns count cleared.\"\"\"\n        matches = self.find_matches()\n        if not matches:\n            return 0\n        for x, y in matches:\n            self.grid.set_cell(x, y, None)\n        self.drop_floating_gems()\n        return len(matches)\n\n    def drop_floating_gems(self) -> None:\n        \"\"\"Gravity: drop gems down into empty spaces.\"\"\"\n        for x in range(self.grid.width):\n            stack = [self.grid.get_cell(x, y) for y in range(self.grid.height)\n                     if self.grid.get_cell(x, y) is not None]\n            # pad with None at top\n            new_col = [None] * (self.grid.height - len(stack)) + stack\n            for y, cell in enumerate(new_col):\n                self.grid.set_cell(x, y, cell)\n\n    def resolve_chains(self) -> int:\n        \"\"\"\n        Repeatedly clears lines and matches until stable.\n        Applies chain multipliers and returns total score gained.\n        \"\"\"\n        total_gain = 0\n        chain_level = 0\n\n        while True:\n            chain_level += 1\n            multiplier = 1.0 + 0.5 * (chain_level - 1)\n\n            # 1) Clear Tetris lines\n            lines = self.clear_lines()\n            if lines > 0:\n                line_base = TETRIS_SCORES.get(lines, lines * 200)\n                gain = int(line_base * multiplier)\n                self.score += gain\n                total_gain += gain\n\n            # 2) Clear Bejeweled matches\n            gems = self.clear_matches()\n            if gems > 0:\n                match_base = gems * 10\n                gain = int(match_base * multiplier)\n                self.score += gain\n                total_gain += gain\n\n            # Stop if nothing cleared this chain level\n            if lines == 0 and gems == 0:\n                break\n\n        return total_gain\n```"}
{"timestamp": "2026-05-22 12:47:35,552", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task3: ```python\nimport random\nfrom typing import List, Optional\nfrom task0 import Tetromino, TETROMINO_SHAPES\n\nclass TetrominoGenerator:\n    \"\"\"\n    Implements a 7-bag tetromino randomizer with a preview queue.\n\n    Attributes:\n        preview_size (int): Number of upcoming pieces to maintain.\n        _bag (List[str]): Current bag of shape IDs to draw from.\n        _queue (List[Tetromino]): Queue of next Tetromino instances.\n    \"\"\"\n\n    def __init__(self, preview_size: int = 5):\n        self.preview_size: int = preview_size\n        self._bag: List[str] = []\n        self._queue: List[Tetromino] = []\n        self._fill_bag()\n        self._fill_queue()\n\n    def _fill_bag(self) -> None:\n        \"\"\"Refill and shuffle the 7-bag of tetromino shape IDs.\"\"\"\n        self._bag = list(TETROMINO_SHAPES.keys())\n        random.shuffle(self._bag)\n\n    def _generate_tetromino(self) -> Tetromino:\n        \"\"\"\n        Pop one shape ID from the bag, refill if empty,\n        and return a new Tetromino instance.\n        \"\"\"\n        if not self._bag:\n            self._fill_bag()\n        shape_id = self._bag.pop()\n        return Tetromino(shape_id=shape_id, rotations=TETROMINO_SHAPES[shape_id].rotations, color=TETROMINO_SHAPES[shape_id].color)\n\n    def _fill_queue(self) -> None:\n        \"\"\"Populate the preview queue up to preview_size.\"\"\"\n        while len(self._queue) < self.preview_size:\n            self._queue.append(self._generate_tetromino())\n\n    def get_next_tetromino(self) -> Tetromino:\n        \"\"\"\n        Retrieve and remove the next tetromino from the queue,\n        then enqueue a new random tetromino from the bag.\n        \"\"\"\n        if not self._queue:\n            # Should never happen, but safeguard\n            self._fill_queue()\n        next_piece = self._queue.pop(0)\n        self._queue.append(self._generate_tetromino())\n        return next_piece\n\n    def peek_next_tetromino(self, index: int = 0) -> Optional[Tetromino]:\n        \"\"\"\n        Return the tetromino at position `index` in the preview queue\n        without removing it. Returns None if index is out of range.\n        \"\"\"\n        if 0 <= index < len(self._queue):\n            return self._queue[index]\n        return None\n\n    def get_preview_queue(self) -> List[Tetromino]:\n        \"\"\"\n        Return a copy of the full preview queue for display purposes.\n        \"\"\"\n        return list(self._queue)\n```"}
{"timestamp": "2026-05-22 12:47:35,552", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task4: ```python\nimport pygame\n\nfrom task0 import Color, GemCell, Tetromino, TETROMINO_SHAPES, Grid\nfrom task1 import TetrominoManager\n\n\nclass TetrisBejeweled:\n    def __init__(self, width: int, height: int, cell_size: int = 30):\n        pygame.init()\n        self.width = width\n        self.height = height\n        self.cell_size = cell_size\n        self.grid = Grid(width, height)\n        self.tetromino_manager = TetrominoManager(self.grid)\n        self.screen = pygame.display.set_mode((width * cell_size, height * cell_size))\n        pygame.display.set_caption(\"Tetris Bejeweled\")\n        self.clock = pygame.time.Clock()\n        self.score = 0\n        self.game_over = False\n        self.drop_timer = 0\n        self.drop_speed = 500  # Milliseconds\n\n    def handle_input(self) -> None:\n        \"\"\"Handles keyboard input for controlling the tetromino.\"\"\"\n        for event in pygame.event.get():\n            if event.type == pygame.QUIT:\n                self.game_over = True\n            if event.type == pygame.KEYDOWN:\n                if event.key == pygame.K_LEFT:\n                    self.tetromino_manager.move(-1)\n                if event.key == pygame.K_RIGHT:\n                    self.tetromino_manager.move(1)\n                if event.key == pygame.K_UP:\n                    self.tetromino_manager.rotate()\n                if event.key == pygame.K_DOWN:\n                    self.drop_speed = 50 # increase drop speed\n                if event.key == pygame.K_SPACE:\n                    while not self.tetromino_manager.move_down():  # Hard drop\n                        pass\n        keys = pygame.key.get_pressed()\n        if not keys[pygame.K_DOWN]:\n            self.drop_speed = 500 # reset drop speed\n\n    def update(self) -> None:\n        \"\"\"Updates the game state.\"\"\"\n        if self.tetromino_manager.current_tetromino is None:\n            self.game_over = True\n            return\n\n        self.drop_timer += self.clock.get_rawtime()\n        self.clock.tick()\n\n        if self.drop_timer > self.drop_speed:\n            self.drop_timer = 0\n            if self.tetromino_manager.move_down():\n                self.clear_lines()\n                self.clear_matches()\n\n    def clear_lines(self) -> None:\n        \"\"\"Clears full lines in the grid.\"\"\"\n        lines_to_clear = []\n        for y in range(self.height):\n            if all(self.grid.get_cell(x, y) is not None for x in range(self.width)):\n                lines_to_clear.append(y)\n\n        for line in lines_to_clear:\n            self.grid.clear_line(line)\n            self.score += 100  # Award points for clearing lines\n\n    def clear_matches(self) -> None:\n        \"\"\"Clears gem matches in the grid.\"\"\"\n        matches = self.find_matches()\n        if matches:\n            self.remove_matches(matches)\n            self.score += len(matches) * 50  # Award points for clearing matches\n            self.drop_gems()\n            self.clear_matches()  # Chain reaction\n\n    def find_matches(self) -> list[list[tuple[int, int]]]:\n        \"\"\"Finds gem matches (3 or more in a row) in the grid.\"\"\"\n        matches: list[list[tuple[int, int]]] = []\n\n        # Horizontal matches\n        for y in range(self.height):\n            for x in range(self.width - 2):\n                gem1 = self.grid.get_cell(x, y)\n                gem2 = self.grid.get_cell(x + 1, y)\n                gem3 = self.grid.get_cell(x + 2, y)\n                if gem1 and gem2 and gem3 and gem1.color == gem2.color == gem3.color:\n                    match = [(x, y), (x + 1, y), (x + 2, y)]\n                    x_temp = x + 3\n                    while x_temp < self.width and self.grid.get_cell(x_temp, y) and self.grid.get_cell(x_temp, y).color == gem1.color:\n                        match.append((x_temp, y))\n                        x_temp += 1\n                    matches.append(match)\n\n        # Vertical matches\n        for x in range(self.width):\n            for y in range(self.height - 2):\n                gem1 = self.grid.get_cell(x, y)\n                gem2 = self.grid.get_cell(x, y + 1)\n                gem3 = self.grid.get_cell(x, y + 2)\n                if gem1 and gem2 and gem3 and gem1.color == gem2.color == gem3.color:\n                    match = [(x, y), (x, y + 1), (x, y + 2)]\n                    y_temp = y + 3\n                    while y_temp < self.height and self.grid.get_cell(x, y_temp) and self.grid.get_cell(x, y_temp).color == gem1.color:\n                        match.append((x, y_temp))\n                        y_temp += 1\n                    matches.append(match)\n        \n        # Remove duplicate matches\n        unique_matches: list[list[tuple[int, int]]] = []\n        for match in matches:\n            if match not in unique_matches:\n                unique_matches.append(match)\n        return unique_matches\n\n    def remove_matches(self, matches: list[list[tuple[int, int]]]) -> None:\n        \"\"\"Removes matched gems from the grid.\"\"\"\n        for match in matches:\n            for x, y in match:\n                self.grid.set_cell(x, y, None)\n\n    def drop_gems(self) -> None:\n        \"\"\"Drops gems down to fill empty spaces.\"\"\"\n        for x in range(self.width):\n            empty_space = -1\n            for y in range(self.height - 1, -1, -1):\n                if self.grid.get_cell(x,y) is None:\n                    empty_space = y\n                    break\n            if empty_space == -1:\n                continue\n\n            for y in range(empty_space - 1, -1, -1):\n                if self.grid.get_cell(x,y) is not None:\n                    self.grid.set_cell(x, empty_space, self.grid.get_cell(x,y))\n                    self.grid.set_cell(x, y, None)\n                    empty_space -= 1\n\n    def draw(self) -> None:\n        \"\"\"Draws the game grid, tetromino, and score on the screen.\"\"\"\n        self.screen.fill((0, 0, 0))  # Black background\n\n        # Draw the grid\n        for x in range(self.width):\n            for y in range(self.height):\n                cell = self.grid.get_cell(x, y)\n                if cell:\n                    pygame.draw.rect(\n                        self.screen,\n                        cell.color.value,\n                        (x * self.cell_size, y * self.cell_size, self.cell_size, self.cell_size),\n                    )\n                    pygame.draw.rect(\n                        self.screen,\n                        (50, 50, 50),\n                        (x * self.cell_size, y * self.cell_size, self.cell_size, self.cell_size),\n                        1,\n                    )\n\n        # Draw the current tetromino\n        tetromino_cells = self.tetromino_manager.get_tetromino_cells()\n        if tetromino_cells:\n            for x, y, color in tetromino_cells:\n                pygame.draw.rect(\n                    self.screen,\n                    color.value,\n                    (x * self.cell_size, y * self.cell_size, self.cell_size, self.cell_size),\n                )\n                pygame.draw.rect(\n                    self.screen,\n                    (50, 50, 50),\n                    (x * self.cell_size, y * self.cell_size, self.cell_size, self.cell_size),\n                    1,\n                )\n\n        # Display the score\n        font = pygame.font.Font(None, 36)\n        text = font.render(f\"Score: {self.score}\", True, (255, 255, 255))\n        self.screen.blit(text, (10, 10))\n\n        pygame.display.flip()\n\n    def run(self) -> None:\n        \"\"\"Main game loop.\"\"\"\n        while not self.game_over:\n            self.handle_input()\n            self.update()\n            self.draw()\n\n        print(f\"Game Over! Final Score: {self.score}\")\n        pygame.quit()\n\n\nif __name__ == \"__main__\":\n    game = TetrisBejeweled(10, 20)\n    game.run()\n```"}
{"timestamp": "2026-05-22 12:47:35,553", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task5: ```python\nimport pygame\nfrom task0 import Grid, GemCell, Tetromino, Color\nfrom task3 import TetrominoGenerator\nfrom typing import List, Tuple, Optional\n\nclass GUIRenderer:\n    def __init__(\n        self,\n        grid: Grid,\n        tetromino_generator: TetrominoGenerator,\n        cell_size: int = 30,\n        grid_x_offset: int = 50,\n        grid_y_offset: int = 50,\n        preview_x_offset: int = 350,\n        preview_y_offset: int = 50\n    ):\n        \"\"\"\n        Initializes the GUI renderer.\n\n        Args:\n            grid: The game grid.\n            tetromino_generator: The tetromino generator.\n            cell_size: Size of each cell in pixels.\n            grid_x_offset: X offset of grid.\n            grid_y_offset: Y offset of grid.\n            preview_x_offset: X offset of next-piece preview.\n            preview_y_offset: Y offset of next-piece preview.\n        \"\"\"\n        self.grid = grid\n        self.tetromino_generator = tetromino_generator\n        self.cell_size = cell_size\n        self.grid_x_offset = grid_x_offset\n        self.grid_y_offset = grid_y_offset\n        self.preview_x_offset = preview_x_offset\n        self.preview_y_offset = preview_y_offset\n\n        self.screen: Optional[pygame.Surface] = None\n        self.font: Optional[pygame.font.Font] = None\n\n    def initialize_screen(self, width: int, height: int):\n        \"\"\"Initializes the Pygame screen and font.\"\"\"\n        pygame.init()\n        self.screen = pygame.display.set_mode((width, height))\n        pygame.display.set_caption(\"Tetris Bejeweled\")\n        self.font = pygame.font.Font(None, 36)\n\n    def draw_grid(self):\n        \"\"\"Draws the game grid and its colored gems.\"\"\"\n        for y in range(self.grid.height):\n            for x in range(self.grid.width):\n                cell = self.grid.get_cell(x, y)\n                rect = pygame.Rect(\n                    self.grid_x_offset + x * self.cell_size,\n                    self.grid_y_offset + y * self.cell_size,\n                    self.cell_size,\n                    self.cell_size\n                )\n                if cell:\n                    # Draw filled gem\n                    pygame.draw.rect(self.screen, cell.color.value, rect)\n                    pygame.draw.rect(self.screen, (50, 50, 50), rect, 1)\n                else:\n                    # Empty cell border\n                    pygame.draw.rect(self.screen, (128, 128, 128), rect, 1)\n\n    def draw_tetromino(self, tetromino: Tetromino, rotation_index: int, x_grid: int, y_grid: int):\n        \"\"\"Draws the active tetromino at grid position (x_grid, y_grid).\"\"\"\n        shape = tetromino.rotations[rotation_index]\n        for dx, dy in shape:\n            gx, gy = x_grid + dx, y_grid + dy\n            if self.grid.is_inside(gx, gy):\n                rect = pygame.Rect(\n                    self.grid_x_offset + gx * self.cell_size,\n                    self.grid_y_offset + gy * self.cell_size,\n                    self.cell_size,\n                    self.cell_size\n                )\n                pygame.draw.rect(self.screen, tetromino.color.value, rect)\n                pygame.draw.rect(self.screen, (50, 50, 50), rect, 1)\n\n    def draw_next_piece_preview(self):\n        \"\"\"Draws the upcoming tetromino preview queue.\"\"\"\n        preview_queue = self.tetromino_generator.get_preview_queue()\n        for i, tetromino in enumerate(preview_queue):\n            shape = tetromino.rotations[0]  # fixed orientation for preview\n            base_x = self.preview_x_offset\n            base_y = self.preview_y_offset + i * 3 * self.cell_size\n            for dx, dy in shape:\n                rect = pygame.Rect(\n                    base_x + dx * self.cell_size,\n                    base_y + dy * self.cell_size,\n                    self.cell_size,\n                    self.cell_size\n                )\n                pygame.draw.rect(self.screen, tetromino.color.value, rect)\n                pygame.draw.rect(self.screen, (50, 50, 50), rect, 1)\n\n    def draw_score(self, score: int):\n        \"\"\"Renders the current score.\"\"\"\n        text = f\"Score: {score}\"\n        text_surf = self.font.render(text, True, (255, 255, 255))\n        self.screen.blit(text_surf, (self.preview_x_offset, self.preview_y_offset + 4 * self.cell_size))\n\n    def render(\n        self,\n        active_tetromino: Tetromino,\n        active_x: int,\n        active_y: int,\n        active_rotation: int,\n        score: int\n    ):\n        \"\"\"Full-screen render: grid, active piece, preview, and score.\"\"\"\n        self.screen.fill((0, 0, 0))\n        self.draw_grid()\n        self.draw_tetromino(active_tetromino, active_rotation, active_x, active_y)\n        self.draw_next_piece_preview()\n        self.draw_score(score)\n        pygame.display.flip()\n\n    def handle_animations(\n        self,\n        clear_lines: List[int],\n        matched_cells: Optional[List[Tuple[int, int]]] = None\n    ):\n        \"\"\"\n        Animates both line clears and gem matches with a simple flash.\n\n        Args:\n            clear_lines: Row indices that were cleared (Tetris).\n            matched_cells: List of (x, y) gem positions cleared by match-3.\n        \"\"\"\n        matched_cells = matched_cells or []\n        flash_color = (255, 255, 255)\n        for _ in range(3):  # flash 3 times\n            self.screen.fill((0, 0, 0))\n            self.draw_grid()\n            # Line-clear flash\n            for row in clear_lines:\n                for x in range(self.grid.width):\n                    rect = pygame.Rect(\n                        self.grid_x_offset + x * self.cell_size,\n                        self.grid_y_offset + row * self.cell_size,\n                        self.cell_size,\n                        self.cell_size\n                    )\n                    pygame.draw.rect(self.screen, flash_color, rect)\n            # Gem-match flash\n            for gx, gy in matched_cells:\n                rect = pygame.Rect(\n                    self.grid_x_offset + gx * self.cell_size,\n                    self.grid_y_offset + gy * self.cell_size,\n                    self.cell_size,\n                    self.cell_size\n                )\n                pygame.draw.rect(self.screen, flash_color, rect)\n            pygame.display.flip()\n            pygame.time.delay(100)\n```"}
{"timestamp": "2026-05-22 12:47:35,553", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task6: ```python\nimport pygame\n\nfrom task0 import Grid\nfrom task1 import TetrominoManager\nfrom task2 import ClearingManager\nfrom task3 import TetrominoGenerator\nfrom task5 import GUIRenderer\n\n\nclass TetrisBejeweledGame:\n    def __init__(\n        self,\n        width: int = 10,\n        height: int = 20,\n        cell_size: int = 30,\n        drop_speed: int = 500,\n        fps: int = 60,\n    ):\n        # Initialize pygame\n        pygame.init()\n        self.width = width\n        self.height = height\n        self.cell_size = cell_size\n\n        # Core components\n        self.grid = Grid(width, height)\n        self.tetromino_generator = TetrominoGenerator()\n        self.tetromino_manager = TetrominoManager(self.grid, self.tetromino_generator)\n        self.clearing_manager = ClearingManager(self.grid)\n        self.gui_renderer = GUIRenderer(self.grid, self.tetromino_generator, cell_size=cell_size)\n\n        # Window setup (grid + side panel for next‐piece & score)\n        side_panel = 200\n        self.screen_width = width * cell_size + side_panel\n        self.screen_height = height * cell_size\n        self.gui_renderer.initialize_screen(self.screen_width, self.screen_height)\n        pygame.display.set_caption(\"Tetris Bejeweled\")\n\n        # Timing & game state\n        self.clock = pygame.time.Clock()\n        self.fps = fps\n        self.drop_speed = drop_speed\n        self.drop_timer = 0\n        self.score = 0\n        self.game_over = False\n\n        # Spawn the first tetromino\n        self.tetromino_manager.spawn_tetromino()\n        self._sync_active()\n\n    def _sync_active(self):\n        \"\"\"Update local references to the current piece.\"\"\"\n        self.active = self.tetromino_manager.current_tetromino\n        self.active_x = self.tetromino_manager.x\n        self.active_y = self.tetromino_manager.y\n        self.active_rot = self.tetromino_manager.rotation_index\n\n    def handle_input(self):\n        \"\"\"Process user key events.\"\"\"\n        for ev in pygame.event.get():\n            if ev.type == pygame.QUIT:\n                self.game_over = True\n            elif ev.type == pygame.KEYDOWN:\n                if ev.key == pygame.K_LEFT:\n                    self.tetromino_manager.move(-1)\n                    self._sync_active()\n                elif ev.key == pygame.K_RIGHT:\n                    self.tetromino_manager.move(1)\n                    self._sync_active()\n                elif ev.key == pygame.K_UP:\n                    self.tetromino_manager.rotate()\n                    self._sync_active()\n                elif ev.key == pygame.K_DOWN:\n                    # soft drop\n                    self.drop_speed = 50\n                elif ev.key == pygame.K_SPACE:\n                    # hard drop\n                    while self.tetromino_manager.move_down():\n                        pass\n                    self.lock_tetromino()\n        # reset soft-drop when DOWN is released\n        keys = pygame.key.get_pressed()\n        if not keys[pygame.K_DOWN]:\n            self.drop_speed = 500\n\n    def update(self, dt: int):\n        \"\"\"Advance gravity and handle automatic locking/spawning.\"\"\"\n        if self.game_over:\n            return\n\n        # spawn if there's no active piece\n        if self.tetromino_manager.current_tetromino is None:\n            self.tetromino_manager.spawn_tetromino()\n            self._sync_active()\n\n        # accumulate gravity timer\n        self.drop_timer += dt\n        if self.drop_timer >= self.drop_speed:\n            self.drop_timer -= self.drop_speed\n            if not self.tetromino_manager.move_down():\n                self.lock_tetromino()\n            self._sync_active()\n\n    def lock_tetromino(self):\n        \"\"\"Lock piece into grid, clear lines/matches, resolve chains, update score.\"\"\"\n        self.tetromino_manager.lock_tetromino()\n\n        cleared = self.clearing_manager.clear_lines()      # List[int]\n        matched = self.clearing_manager.find_matches()     # List[(x,y)]\n        if cleared or matched:\n            self.gui_renderer.handle_animations(\n                clear_lines=cleared,\n                matched_cells=matched\n            )\n\n        gained = self.clearing_manager.resolve_chains()\n        self.score += gained\n\n        if self.tetromino_manager.check_game_over():\n            self.game_over = True\n        else:\n            # spawn next piece\n            self.tetromino_manager.spawn_tetromino()\n            self._sync_active()\n\n    def draw(self):\n        \"\"\"Render grid, active piece, preview, score, and any ongoing animations.\"\"\"\n        next_piece = self.tetromino_generator.peek()\n        self.gui_renderer.render(\n            active_tetromino=self.active,\n            active_x=self.active_x,\n            active_y=self.active_y,\n            active_rotation=self.active_rot,\n            next_tetromino=next_piece,\n            score=self.score\n        )\n\n    def run(self):\n        \"\"\"Main loop with FPS cap and display flip.\"\"\"\n        while not self.game_over:\n            self.handle_input()\n            dt = self.clock.tick(self.fps)\n            self.update(dt)\n            self.draw()\n            pygame.display.flip()\n\n        print(f\"Game Over! Final Score: {self.score}\")\n        pygame.quit()\n\nif __name__ == \"__main__\":\n    game = TetrisBejeweledGame()\n    game.run()\n```"}
