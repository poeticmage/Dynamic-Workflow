(0,1),(1,1),(1,2)]\\n        ]\\n    ),\\n    'S': Tetromino(\\n        shape_id='S',\\n        color=Color.GREEN,\\n        rotations=[\\n            [(1,0),(2,0),(0,1),(1,1)],\\n            [(1,0),(1,1),(2,1),(2,2)]\\n        ]\\n    ),\\n    'Z': Tetromino(\\n        shape_id='Z',\\n        color=Color.RED,\\n        rotations=[\\n            [(0,0),(1,0),(1,1),(2,1)],\\n            [(2,0),(1,1),(2,1),(1,2)]\\n        ]\\n    ),\\n    'J': Tetromino(\\n        shape_id='J',\\n        color=Color.BLUE,\\n        rotations=[\\n            [(0,0),(0,1),(1,1),(2,1)],\\n            [(1,0),(2,0),(1,1),(1,2)],\\n            [(0,1),(1,1),(2,1),(2,2)],\\n            [(1,0),(1,1),(0,2),(1,2)]\\n        ]\\n    ),\\n    'L': Tetromino(\\n        shape_id='L',\\n        color=Color.ORANGE,\\n        rotations=[\\n            [(2,0),(0,1),(1,1),(2,1)],\\n            [(1,0),(1,1),(1,2),(2,2)],\\n            [(0,1),(1,1),(2,1),(0,2)],\\n            [(0,0),(1,0),(1,1),(1,2)]\\n        ]\\n    )\\n}\\n\\nclass Grid:\\n    def __init__(self, width: int = 10, height: int = 20):\\n        self.width = width\\n        self.height = height\\n        self.cells: List[List[Optional[GemCell]]] = [\\n            [None for _ in range(self.width)] for _ in range(self.height)\\n        ]\\n\\n    def is_inside(self, x: int, y: int) -> bool:\\n        return 0 <= x < self.width and 0 <= y < self.height\\n\\n    def get_cell(self, x: int, y: int) -> Optional[GemCell]:\\n        if not self.is_inside(x, y):\\n            return None\\n        return self.cells[y][x]\\n\\n    def set_cell(self, x: int, y: int, gem: GemCell) -> None:\\n        if self.is_inside(x, y):\\n            self.cells[y][x] = gem\\n\\n    def clear_cell(self, x: int, y: int) -> None:\\n        if self.is_inside(x, y):\\n            self.cells[y][x] = None\\n\\n    def reset(self) -> None:\\n        for y in range(self.height):\\n            for x in range(self.width):\\n                self.cells[y][x] = None\",\n  \"time