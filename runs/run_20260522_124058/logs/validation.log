g(self) -> None:\\n        self._bag = self._types[:]\\n        random.shuffle(self._bag)\\n\\n    def get_next_tetromino(self) -> Tetromino:\\n        \\\"\\\"\\\"\\n        Pops one type from the bag, refilling when empty,\\n        and returns a fresh Tetromino instance.\\n        \\\"\\\"\\\"\\n        if not self._bag:\\n            self._refill_bag()\\n        tet_type = self._bag.pop()\\n        shape = TETROMINO_SHAPES[tet_type]\\n        return Tetromino(tetromino_type=tet_type, shape=shape)\\n\\nclass NextTetrominoPreview:\\n    \\\"\\\"\\\"\\n    Maintains a preview queue of upcoming tetrominoes.\\n    Use pop_next() to consume the next piece and refill the queue.\\n    \\\"\\\"\\\"\\n    def __init__(self, generator: TetrominoGenerator, preview_size: int = 4):\\n        self._gen = generator\\n        self._size = preview_size\\n        # initialize the preview queue\\n        self._queue: List[Tetromino] = [self._gen.get_next_tetromino()\\n                                        for _ in range(self._size)]\\n\\n    def get_preview_queue(self) -> List[Tetromino]:\\n        \\\"\\\"\\\"\\n        Returns a copy of the current preview queue (list of Tetromino).\\n        \\\"\\\"\\\"\\n        return list(self._queue)\\n\\n    def pop_next(self) -> Tetromino:\\n        \\\"\\\"\\\"\\n        Removes and returns the next tetromino to spawn,\\n        then refills the queue by adding one more from the generator.\\n        \\\"\\\"\\\"\\n        next_piece = self._queue.pop(0)\\n        self._queue.append(self._gen.get_next_tetromino())\\n        return next_piece\\n\\n# Example usage:\\nif __name__ == \\\"__main__\\\":\\n    gen = TetrominoGenerator()\\n    preview = NextTetrominoPreview(gen, preview_size=4)\\n\\n    # Show initial preview\\n    upcoming = preview.get_preview_queue()\\n    print(\\\"Upcoming:\\\", [t.tetromino_type for t in upcoming])\\n\\n    # Spawn next piece\\n    current = preview.pop_next()\\n    print(\\\"Spawned:\\\", current.tetromino_type)\\n\\n    # Show updated preview\\n    upcoming = preview.get_preview_queue()\\n    print(\\\"Upcoming now:\\\", [t.tetromino_type for t in upcoming])\\n```\"}"}
