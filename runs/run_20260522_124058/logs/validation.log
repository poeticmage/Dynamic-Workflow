= list(TETROMINO_SHAPES.keys())\\n        self._bag: List[str] = []\\n        self._refill_bag()\\n\\n    def _refill_bag(self) -> None:\\n        \\\"\\\"\\\"Refills the bag with all tetromino types and shuffles it.\\\"\\\"\\\"\\n        self._bag = self._types[:]\\n        random.shuffle(self._bag)\\n\\n    def get_next_tetromino(self) -> Tetromino:\\n        \\\"\\\"\\\"\\n        Pops one type from the bag (refilling when empty),\\n        and returns a new Tetromino instance with its type and shape.\\n        \\\"\\\"\\\"\\n        if not self._bag:\\n            self._refill_bag()\\n        tet_type = self._bag.pop()\\n        return TETROMINO_SHAPES[tet_type]\\n\\n\\nclass NextTetrominoPreview:\\n    \\\"\\\"\\\"\\n    Maintains a preview queue of upcoming Tetromino instances.\\n    Use pop_next() to consume the next piece and automatically refill the queue.\\n    \\\"\\\"\\\"\\n    def __init__(self, generator: TetrominoGenerator, preview_size: int = 4):\\n        \\\"\\\"\\\"\\n        Initializes the preview with a generator and a specified preview size.\\n\\n        Args:\\n            generator: The TetrominoGenerator instance to use for generating pieces.\\n            preview_size: The number of tetrominoes to keep in the preview queue.\\n        \\\"\\\"\\\"\\n        self._gen = generator\\n        self._size = preview_size\\n        self._queue: List[Tetromino] = [\\n            self._gen.get_next_tetromino() for _ in range(self._size)\\n        ]\\n\\n    def get_preview_queue(self) -> List[Tetromino]:\\n        \\\"\\\"\\\"\\n        Returns a shallow copy of the current preview queue.\\n        \\\"\\\"\\\"\\n        return list(self._queue)\\n\\n    def pop_next(self) -> Tetromino:\\n        \\\"\\\"\\\"\\n        Removes and returns the next Tetromino to spawn,\\n        then refills the queue by appending one more from the generator.\\n        \\\"\\\"\\\"\\n        next_piece = self._queue.pop(0)\\n        self._queue.append(self._gen.get_next_tetromino())\\n        return next_piece\\n\\nif __name__ == \\\"__main__\\\":\\n    from task0 import Color, Tetromino, TETROMINO_SHAPES\\n\\n    gen = TetrominoGenerator()\\n    preview = NextTetrominoPreview(gen, preview_size=4)\\n\\n    print(\\\"Upcoming:\\\", [t.shape_id for t in preview.get_preview_queue()])\\n    spawned = preview.pop_next()\\n    print(\\\"Spawned:\\\", spawned.shape_id)\\n    print(\\\"Upcoming now:\\\", [t.shape_id for t in preview.get_preview_queue()])\\n```\",\n  \"timestamp\": \"2026-05-22T12:42:07.987622\"\n}"}
