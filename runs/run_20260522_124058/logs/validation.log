\n        self,\\n        width: int = 10,\\n        height: int = 20,\\n        cell_size: int = 30,\\n        drop_speed: int = 500,\\n        fps: int = 60,\\n    ):\\n        # Initialize pygame\\n        pygame.init()\\n        self.width = width\\n        self.height = height\\n        self.cell_size = cell_size\\n\\n        # Core components\\n        self.grid = Grid(width, height)\\n        self.tetromino_generator = TetrominoGenerator()\\n        self.tetromino_manager = TetrominoManager(self.grid, self.tetromino_generator)\\n        self.clearing_manager = ClearingManager(self.grid)\\n        self.gui_renderer = GUIRenderer(self.grid, self.tetromino_generator, cell_size=cell_size)\\n\\n        # Window setup (grid + side panel for next‐piece & score)\\n        side_panel = 200\\n        self.screen_width = width * cell_size + side_panel\\n        self.screen_height = height * cell_size\\n        self.gui_renderer.initialize_screen(self.screen_width, self.screen_height)\\n        pygame.display.set_caption(\\\"Tetris Bejeweled\\\")\\n\\n        # Timing & game state\\n        self.clock = pygame.time.Clock()\\n        self.fps = fps\\n        self.drop_speed = drop_speed\\n        self.drop_timer = 0\\n        self.score = 0\\n        self.game_over = False\\n\\n        # Spawn the first tetromino\\n        self.tetromino_manager.spawn_tetromino()\\n        self._sync_active()\\n\\n    def _sync_active(self):\\n        \\\"\\\"\\\"Update local references to the current piece.\\\"\\\"\\\"\\n        self.active = self.tetromino_manager.current_tetromino\\n        self.active_x = self.tetromino_manager.x\\n        self.active_y = self.tetromino_manager.y\\n        self.active_rot = self.tetromino_manager.rotation_index\\n\\n    def handle_input(self):\\n        \\\"\\\"\\\"Process user key events.\\\"\\\"\\\"\\n        for ev in pygame.event.get():\\n            if ev.type == pygame.QUIT:\\n                self.game_over = True\\n            elif ev.type == pygame.KEYDOWN:\\n                if ev.key == pygame.K_LEFT:\\n                    self.tetromino_manager.move(-1)\\n                    self._sync_active()\\n                elif ev.key == pygame.K_RIGHT:\\n                    self.tetromino_manager.move(1)\\n                    self._sync_active()\\n                elif ev.key == pygame.K_UP:\\n                    self.tetromino_manager.rotate()\\n                    self._sync_active()\\n                elif ev.key == pygame.K_DOWN:\\n                    # soft drop\\n                    self.drop_speed = 50\\n                elif ev.key == pygame.K_SPACE:\\n                    # hard drop\\n                    while self.tetromino_manager.move_down():\\n                        pass\\n                    self.lock_tetromino()\\n        # reset soft-drop when DOWN is released\\n        keys = pygame.key.get_pressed()\\n        if not keys[pygame.K_DOWN]:\\n            self.drop_speed = drop_speed = 500\\n\\n    def update(self, dt: int):\\n        \\\"\\\"\\\"Advance gravity and handle automatic locking/spawning.\\\"\\\"\\\"\\n        if self.game_over:\\n            return\\n\\n        # spawn if there's no active piece\\n        if self.tetromino_manager.current_tetromino is None:\\n            self.tetromino_manager.spawn_tetromino()\\n            self._sync_active()\\n\\n        # accumulate gravity timer\\n        self.drop_timer += dt\\n        if self.drop_timer >= self.drop_speed:\\n            self.drop_timer -= self.drop_speed\\n            if not self.tetromino_manager.move_down():\\n                self.lock_tetromino()\\n            self._sync_active()\\n\\n    def lock_tetromino(self):\\n        \\\"\\\"\\\"Lock piece into grid, clear lines/matches, resolve chains, update score.\\\"\\\"\\\"\\n        self.tetromino_manager.lock_tetromino()\\n\\n        cleared = self.clearing_manager.clear_lines()      # List[int]\\n        matched = self.clearing_manager.find_matches()     # List[(x,y)]\\n        if cleared or matched:\\n            self.gui_renderer.handle_animations(\\n                clear_lines=cleared,\\n                matched_cells=matched\\n            )\\n\\n        gained = self.clearing_manager.resolve_chains()\\n        self.score += gained\\n\\n        if self.tetromino_manager.check_game_over():\\n            self.game_over = True\\n        else:\\n            # spawn next piece\\n            self.tetromino_manager.spawn_tetromino()\\n            self._sync_active()\\n\\n    def draw(self):\\n        \\\"\\\"\\\"Render grid, active piece, preview, score, and any ongoing animations.\\\"\\\"\\\"\\n        next_piece = self.tetromino_generator.peek()\\n        self.gui_renderer.render(\\n            active_tetromino=self.active,\\n            active_x=self.active_x,\\n            active_y=self.active_y,\\n            active_rotation=self.active_rot,\\n            next_tetromino=next_piece,\\n            score=self.score\\n        )\\n\\n    def run(self):\\n        \\\"\\\"\\\"Main loop with FPS cap and display flip.\\\"\\\"\\\"\\n        while not self.game_over:\\n            self.handle_input()\\n            dt = self.clock.tick(self.fps)\\n            self.update(dt)\\n            self.draw()\\n            pygame.display.flip()\\n\\n        print(f\\\"Game Over! Final Score: {self.score}\\\")\\n        pygame.quit()\\n\\nif __name__ == \\\"__main__\\\":\\n    game = TetrisBejeweledGame()\\n    game.run()\\n```\"}"}
