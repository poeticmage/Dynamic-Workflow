N = (0, 255, 255)\\n    BLUE = (0, 0, 255)\\n    ORANGE = (255, 165, 0)\\n    YELLOW = (255, 255, 0)\\n    GREEN = (0, 255, 0)\\n    PURPLE = (128, 0, 128)\\n    RED = (255, 0, 0)\\n\\n@dataclass\\nclass GemCell:\\n    color: Color\\n\\n@dataclass\\nclass Tetromino:\\n    shape_id: str\\n    rotations: List[List[Tuple[int, int]]]\\n    color: Color\\n\\nTETROMINO_SHAPES: Dict[str, Tetromino] = {\\n    'I': Tetromino(\\n        shape_id='I',\\n        color=Color.CYAN,\\n        rotations=[\\n            [(0,1),(1,1),(2,1),(3,1)],\\n            [(2,0),(2,1),(2,2),(2,3)],\\n            [(0,2),(1,2),(2,2),(3,2)],\\n            [(1,0),(1,1),(1,2),(1,3)]\\n        ]\\n    ),\\n    'O': Tetromino(\\n        shape_id='O',\\n        color=Color.YELLOW,\\n        rotations=[\\n            [(1,0),(2,0),(1,1),(2,1)]\\n        ]\\n    ),\\n    'T': Tetromino(\\n        shape_id='T',\\n        color=Color.PURPLE,\\n        rotations=[\\n            [(1,0),(0,1),(1,1),(2,1)],\\n            [(1,0),(1,1),(2,1),(1,2)],\\n            [(0,1),(1,1),(2,1),(1,2)],\\n            [(1,0),(0,1),(1,1),(1,2)]\\n        ]\\n    ),\\n    'S': Tetromino(\\n        shape_id='S',\\n        color=Color.GREEN,\\n        rotations=[\\n            [(1,0),(2,0),(0,1),(1,1)],\\n            [(1,0),(1,1),(2,1),(2,2)]\\n        ]\\n    ),\\n    'Z': Tetromino(\\n        shape_id='Z',\\n        color=Color.RED,\\n        rotations=[\\n            [(0,0),(1,0),(1,1),(2,1)],\\n            [(2,0),(1,1),(2,1),(1,2)]\\n        ]\\n    ),\\n    'J': Tetromino(\\n        shape_id='J',\\n        color=Color.BLUE,\\n        rotations=[\\n            [(0,0),(0,1),(1,1),(2,1)],\\n            [(1,0),(2,0),(1,1),(1,2)],\\n            [(0,1),(1,1),(2,1),(2,2)],\\n            [(1,0),(1,1),(0,2),(1,2)]\\n        ]\\n    ),\\n    'L': Tetromino(\\n        shape_id='L',\\n        color=Color.ORANGE,\\n        rotations=[\\n            [(2,0),(0,1),(1,1),(2,1)],\\n            [(1,0),(1,1),(1,2),(2,2)],\\n            [(0,1),(1,