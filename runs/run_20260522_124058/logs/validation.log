): Queue of next Tetromino instances.\\n    \\\"\\\"\\\"\\n\\n    def __init__(self, preview_size: int = 5):\\n        self.preview_size: int = preview_size\\n        self._bag: List[str] = []\\n        self._queue: List[Tetromino] = []\\n        self._fill_bag()\\n        self._fill_queue()\\n\\n    def _fill_bag(self) -> None:\\n        \\\"\\\"\\\"Refill and shuffle the 7-bag of tetromino shape IDs.\\\"\\\"\\\"\\n        self._bag = list(TETROMINO_SHAPES.keys())\\n        random.shuffle(self._bag)\\n\\n    def _generate_tetromino(self) -> Tetromino:\\n        \\\"\\\"\\\"\\n        Pop one shape ID from the bag, refill if empty,\\n        and return a new Tetromino instance.\\n        \\\"\\\"\\\"\\n        if not self._bag:\\n            self._fill_bag()\\n        shape_id = self._bag.pop()\\n        return Tetromino(shape_id=shape_id, rotations=TETROMINO_SHAPES[shape_id].rotations, color=TETROMINO_SHAPES[shape_id].color)\\n\\n    def _fill_queue(self) -> None:\\n        \\\"\\\"\\\"Populate the preview queue up to preview_size.\\\"\\\"\\\"\\n        while len(self._queue) < self.preview_size:\\n            self._queue.append(self._generate_tetromino())\\n\\n    def get_next_tetromino(self) -> Tetromino:\\n        \\\"\\\"\\\"\\n        Retrieve and remove the next tetromino from the queue,\\n        then enqueue a new random tetromino from the bag.\\n        \\\"\\\"\\\"\\n        if not self._queue:\\n            # Should never happen, but safeguard\\n            self._fill_queue()\\n        next_piece = self._queue.pop(0)\\n        self._queue.append(self._generate_tetromino())\\n        return next_piece\\n\\n    def peek_next_tetromino(self, index: int = 0) -> Optional[Tetromino]:\\n        \\\"\\\"\\\"\\n        Return the tetromino at position `index` in the preview queue\\n        without removing it. Returns None if index is out of range.\\n        \\\"\\\"\\\"\\n        if 0 <= index < len(self._queue):\\n            return self._queue[index]\\n       