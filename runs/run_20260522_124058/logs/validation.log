self, width: int = 10, height: int = 20, cell_size: int = 30):\\n        pygame.init()\\n        self.width: int = width\\n        self.height: int = height\\n        self.cell_size: int = cell_size\\n        self.grid: Grid = Grid(width, height)\\n        self.tetromino_generator: TetrominoGenerator = TetrominoGenerator()\\n        self.tetromino_manager: TetrominoManager = TetrominoManager(self.grid, self.tetromino_generator)\\n        self.clearing_manager: ClearingManager = ClearingManager(self.grid)\\n        self.gui_renderer: GUIRenderer = GUIRenderer(self.grid, self.tetromino_generator)\\n\\n        self.screen_width: int = width * cell_size + 400  # Adjusted screen width\\n        self.screen_height: int = height * cell_size + 100 # Adjusted screen height\\n        self.gui_renderer.initialize_screen(self.screen_width, self.screen_height)\\n\\n        pygame.display.set_caption(\\\"Tetris Bejeweled\\\")\\n        self.clock: pygame.time.Clock = pygame.time.Clock()\\n        self.score: int = 0\\n        self.game_over: bool = False\\n        self.drop_timer: int = 0\\n        self.drop_speed: int = 500  # Milliseconds\\n        self.active_tetromino: Optional[Tetromino] = self.tetromino_manager.current_tetromino\\n        self.active_x: int = self.tetromino_manager.x\\n        self.active_y: int = self.tetromino_manager.y\\n        self.active_rotation: int = self.tetromino_manager.rotation_index\\n\\n    def handle_input(self) -> None:\\n        \\\"\\\"\\\"Handles keyboard input for controlling the tetromino.\\\"\\\"\\\"\\n        for event in pygame.event.get():\\n            if event.type == pygame.QUIT:\\n                self.game_over = True\\n            if event.type == pygame.KEYDOWN:\\n                if event.key == pygame.K_LEFT:\\n                    self.tetromino_manager.move(-1)\\n                if event.key == pygame.K_RIGHT:\\n                    self.tetromino_manager.move(1)\\n                if event.key == pygame.K_UP:\\n             