ialized in initialize_screen\\n        self.font = None  # Pygame font, initialized in initialize_screen\\n\\n    def initialize_screen(self, width: int, height: int):\\n        \\\"\\\"\\\"Initializes the Pygame screen and font.\\\"\\\"\\\"\\n        pygame.init()\\n        self.screen = pygame.display.set_mode((width, height))\\n        pygame.display.set_caption(\\\"Tetris Bejeweled\\\")\\n        self.font = pygame.font.Font(None, 36)\\n\\n    def draw_grid(self):\\n        \\\"\\\"\\\"Draws the game grid and its contents.\\\"\\\"\\\"\\n        for y in range(self.grid.height):\\n            for x in range(self.grid.width):\\n                cell = self.grid.get_cell(x, y)\\n                rect = pygame.Rect(\\n                    self.grid_x_offset + x * self.cell_size,\\n                    self.grid_y_offset + y * self.cell_size,\\n                    self.cell_size,\\n                    self.cell_size\\n                )\\n                if cell:\\n                    pygame.draw.rect(self.screen, cell.color.value, rect)\\n                    pygame.draw.rect(self.screen, (50, 50, 50), rect, 1)  # Dark gray border\\n                else:\\n                    pygame.draw.rect(self.screen, (128, 128, 128), rect, 1)  # Light gray border\\n\\n    def draw_tetromino(self, tetromino: Tetromino, offset_x: int, offset_y: int, rotation_index: int, x_grid: int, y_grid: int):\\n        \\\"\\\"\\\"Draws the active tetromino.\\\"\\\"\\\"\\n        shape = tetromino.rotations[rotation_index]\\n        for x, y in shape:\\n            grid_x = x_grid + x\\n            grid_y = y_grid + y\\n            if self.grid.is_inside(grid_x, grid_y):\\n                rect = pygame.Rect(\\n                    self.grid_x_offset + grid_x * self.cell_size,\\n                    self.grid_y_offset + grid_y * self.cell_size,\\n                    self.cell_size,\\n                    self.cell_size\\n                )\\n                pygame.draw.rect(self.screen, tetromino.color.value, rect)\\n                pygame.draw.rect(self.screen, (50, 50, 50), rect, 1)  # Dark gray border\\n\\n    def draw_next_piece_preview(self):\\n        \\\"\\\"\\\"Draws the next piece preview.\\\"\\\"\\\"\\n        preview_queue = self.tetromino_generator.get_preview_queue()\\n        for i, tetromino in enumerate(preview_queue):\\n            shape = tetromino.rotations[0]  # Use the first rotation for preview\\n            for x, y in shape:\\n                rect = pygame.Rect(\\n                    self.preview_x_offset + x * self.cell_size + 50,\\n                    self.preview_y_offset + y * self.cell_size + i * 3 * self.cell_size,\\n                    self.cell_size,\\n                    self.cell_size\\n                )\\n                pygame.draw.rect(self.screen, tetromino.color.value, rect)\\n                pygame.draw.rect(self.screen, (50, 50, 50), rect, 1)  # Dark gray border\\n\\n    def draw_score(self, score: int):\\n        \\\"\\\"\\\"Draws the score on the screen.\\\"\\\"\\\"\\n        text_surface = self.font.render(f\\\"Score: {score}\\\", True, (255, 255, 255))\\n        self.screen.blit(text_surface, (self.preview_x_offset, 300))\\n\\n    def render(self, active_tetromino: Tetromino, active_tetromino_x: int, active_tetromino_y: int, active_rotation_index: int, score: int):\\n        \\\"\\\"\\\"Renders the entire game screen.\\\"\\\"\\\"\\n        self.screen.fill((0, 0, 0))  # Black background\\n        self.draw_grid()\\n        self.draw_tetromino(active_tetromino, self.grid_x_offset, self.grid_y_offset, active_rotation_index, active_tetromino_x, active_tetromino_y)\\n        self.draw_next_piece_preview()\\n        self.draw_score(score)\\n        pygame.display.flip()\\n\\n    def handle_animations(self, clear_lines: List[int]):\\n        \\\"\\\"\\\"Handles animations for clearing lines (example animation).\\\"\\\"\\\"\\n        # Simple flash animation for cleared lines\\n        for i in range(3):  # Flash three times\\n            self.screen.fill((0, 0, 0))\\n            self.draw_grid()  # Redraw the grid\\n            # Highlight cleared lines\\n            for line in clear_lines:\\n                for x in range(self.grid.width):\\n                    rect = pygame.Rect(\\n                        self.grid_x_offset + x * self.cell_size,\\n                        self.grid_y_offset + line * self.cell_size,\\n                        self.cell_size,\\n                        self.cell_size\\n                    )\\n                    pygame.draw.rect(self.screen, (255, 255, 255), rect)  # White flash\\n            pygame.display.flip()\\n            pygame.time.delay(100)  # Short delay\\n```\",\n  \"timestamp\": \"2026-05-22T12:43:54.788862\"\n}"}
