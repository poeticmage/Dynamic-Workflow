{"timestamp": "2026-05-23 11:08:46,287", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task0: ```python\nimport pygame\nimport random\n\n# Constants\nGRID_WIDTH = 10\nGRID_HEIGHT = 20\nBLOCK_SIZE = 30\nSCREEN_WIDTH = 600\nSCREEN_HEIGHT = 800\n\n# Colors (RGB tuples)\nCOLORS = {\n    \"red\":    (255, 0, 0),\n    \"green\":  (0, 255, 0),\n    \"blue\":   (0, 0, 255),\n    \"yellow\": (255, 255, 0),\n    \"magenta\":(255, 0, 255),\n    \"cyan\":   (0, 255, 255),\n}\n\n# Fixed mapping from tetromino shapes to gem colors\nSHAPE_COLORS = {\n    \"I\": COLORS[\"cyan\"],\n    \"J\": COLORS[\"blue\"],\n    \"L\": COLORS[\"yellow\"],\n    \"O\": COLORS[\"yellow\"],\n    \"S\": COLORS[\"green\"],\n    \"T\": COLORS[\"magenta\"],\n    \"Z\": COLORS[\"red\"],\n}\n\n# Tetromino shapes and their rotation states\nTETROMINOES = {\n    \"I\": [\n        [(0,0), (1,0), (2,0), (3,0)],\n        [(1,0), (1,1), (1,2), (1,3)]\n    ],\n    \"J\": [\n        [(0,0), (1,0), (2,0), (2,1)],\n        [(1,0), (1,1), (1,2), (0,2)],\n        [(0,0), (0,1), (1,1), (2,1)],\n        [(1,0), (1,1), (1,2), (2,2)]\n    ],\n    \"L\": [\n        [(0,0), (1,0), (2,0), (0,1)],\n        [(0,0), (0,1), (0,2), (1,2)],\n        [(2,0), (0,1), (1,1), (2,1)],\n        [(0,0), (1,0), (1,1), (1,2)]\n    ],\n    \"O\": [\n        [(0,0), (1,0), (0,1), (1,1)]\n    ],\n    \"S\": [\n        [(1,0), (2,0), (0,1), (1,1)],\n        [(0,0), (0,1), (1,1), (1,2)]\n    ],\n    \"T\": [\n        [(0,0), (1,0), (2,0), (1,1)],\n        [(1,0), (0,1), (1,1), (1,2)],\n        [(1,0), (0,1), (1,1), (2,1)],\n        [(0,0), (0,1), (1,1), (0,2)]\n    ],\n    \"Z\": [\n        [(0,0), (1,0), (1,1), (2,1)],\n        [(1,0), (0,1), (1,1), (0,2)]\n    ],\n}\n\n# Game grid: 2D array; each cell is None or an RGB color tuple.\ngrid = [[None for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]\n\nclass Tetromino:\n    def __init__(self, shape: str):\n        assert shape in TETROMINOES, f\"Unknown shape '{shape}'\"\n        self.shape = shape\n        self.color = SHAPE_COLORS[shape]\n        # Spawn near top-center\n        self.x = GRID_WIDTH // 2 - 2\n        self.y = 0\n        self.rotation = 0\n\n    def current_blocks(self):\n        \"\"\"Return list of (x, y) for each block in current rotation.\"\"\"\n        coords = TETROMINOES[self.shape][self.rotation % len(TETROMINOES[self.shape])]\n        return [(self.x + dx, self.y + dy) for dx, dy in coords]\n\ndef lock_tetromino(grid, tetromino):\n    \"\"\"Lock tetromino blocks into the grid as gem colors.\"\"\"\n    for x, y in tetromino.current_blocks():\n        if 0 <= x < GRID_WIDTH and 0 <= y < GRID_HEIGHT:\n            grid[y][x] = tetromino.color\n\n# Example usage:\nif __name__ == \"__main__\":\n    pygame.init()\n    screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\n    pygame.display.set_caption(\"Tetris Bejeweled\")\n    \n    # Create a new random tetromino\n    shape = random.choice(list(TETROMINOES.keys()))\n    current = Tetromino(shape)\n    # Lock it (after collision check in real game)\n    #lock_tetromino(grid, current) # commented out for now as it locks immediately at the start\n\n    running = True\n    while running:\n        for event in pygame.event.get():\n            if event.type == pygame.QUIT:\n                running = False\n            if event.type == pygame.KEYDOWN:\n                if event.key == pygame.K_LEFT:\n                    current.x -= 1\n                if event.key == pygame.K_RIGHT:\n                    current.x += 1\n                if event.key == pygame.K_DOWN:\n                    current.y += 1\n                if event.key == pygame.K_UP:\n                    current.rotation += 1  # Rotate the tetromino\n\n        # Basic grid rendering (replace with proper GUI later)\n        screen.fill((0, 0, 0))  # Clear the screen\n\n        # Draw the Tetromino\n        for x, y in current.current_blocks():\n            if 0 <= x < GRID_WIDTH and 0 <= y < GRID_HEIGHT:\n                pygame.draw.rect(screen, current.color, (x * BLOCK_SIZE, y * BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE))\n\n        # Draw the Grid\n        for row_index, row in enumerate(grid):\n            for col_index, cell in enumerate(row):\n                if cell:  # If the cell is not None (empty)\n                    pygame.draw.rect(screen, cell, (col_index * BLOCK_SIZE, row_index * BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE))\n\n\n        pygame.display.flip()\n\n    pygame.quit()\n```"}
{"timestamp": "2026-05-23 11:08:46,287", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task1: ```python\nimport pygame\nimport random\n\n# Constants\nGRID_WIDTH = 10\nGRID_HEIGHT = 20\nBLOCK_SIZE = 30\nSCREEN_WIDTH = GRID_WIDTH * BLOCK_SIZE\nSCREEN_HEIGHT = GRID_HEIGHT * BLOCK_SIZE\nLATERAL_SPEED = 10    # Moves per second\nDROP_SPEED = 1        # Moves per second\nSOFT_DROP_SPEED = 20  # Moves per second\n\n# Colors (RGB tuples)\nCOLORS = {\n    \"red\":     (255, 0, 0),\n    \"green\":   (0, 255, 0),\n    \"blue\":    (0, 0, 255),\n    \"yellow\":  (255, 255, 0),\n    \"magenta\": (255, 0, 255),\n    \"cyan\":    (0, 255, 255),\n}\n\n# Fixed mapping from tetromino shapes to gem colors\nSHAPE_COLORS = {\n    \"I\": COLORS[\"cyan\"],\n    \"J\": COLORS[\"blue\"],\n    \"L\": COLORS[\"yellow\"],\n    \"O\": COLORS[\"yellow\"],\n    \"S\": COLORS[\"green\"],\n    \"T\": COLORS[\"magenta\"],\n    \"Z\": COLORS[\"red\"],\n}\n\n# Tetromino definitions\nTETROMINOES = {\n    \"I\": [\n        [(0,0), (1,0), (2,0), (3,0)],\n        [(1,0), (1,1), (1,2), (1,3)]\n    ],\n    \"J\": [\n        [(0,0), (1,0), (2,0), (2,1)],\n        [(1,0), (1,1), (1,2), (0,2)],\n        [(0,0), (0,1), (1,1), (2,1)],\n        [(1,0), (1,1), (1,2), (2,0)]\n    ],\n    \"L\": [\n        [(0,0), (1,0), (2,0), (0,1)],\n        [(0,0), (0,1), (0,2), (1,2)],\n        [(2,0), (0,1), (1,1), (2,1)],\n        [(0,0), (1,0), (1,1), (1,2)]\n    ],\n    \"O\": [[(0,0), (1,0), (0,1), (1,1)]],\n    \"S\": [\n        [(1,0), (2,0), (0,1), (1,1)],\n        [(0,0), (0,1), (1,1), (1,2)]\n    ],\n    \"T\": [\n        [(0,0), (1,0), (2,0), (1,1)],\n        [(1,0), (0,1), (1,1), (1,2)],\n        [(1,0), (0,1), (1,1), (2,1)],\n        [(0,0), (0,1), (1,1), (0,2)]\n    ],\n    \"Z\": [\n        [(0,0), (1,0), (1,1), (2,1)],\n        [(1,0), (0,1), (1,1), (0,2)]\n    ],\n}\n\n# Game grid: None or an RGB tuple\ngrid = [[None for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]\n\nclass Tetromino:\n    def __init__(self, shape: str):\n        assert shape in TETROMINOES, f\"Unknown shape '{shape}'\"\n        self.shape = shape\n        self.color = SHAPE_COLORS[shape]\n        self.x = GRID_WIDTH // 2 - 2\n        self.y = 0\n        self.rotation = 0\n\n    def current_blocks(self):\n        \"\"\"Return list of (x, y) for each block in current rotation.\"\"\"\n        coords = TETROMINOES[self.shape][self.rotation % len(TETROMINOES[self.shape])]\n        return [(self.x + dx, self.y + dy) for dx, dy in coords]\n\n    def move(self, dx, dy):\n        \"\"\"Attempt to move; return True if successful.\"\"\"\n        new_x, new_y = self.x + dx, self.y + dy\n        if self.is_valid_position(new_x, new_y, self.rotation):\n            self.x, self.y = new_x, new_y\n            return True\n        return False\n\n    def rotate(self):\n        \"\"\"Attempt to rotate; return True if successful.\"\"\"\n        new_rot = (self.rotation + 1) % len(TETROMINOES[self.shape])\n        if self.is_valid_position(self.x, self.y, new_rot):\n            self.rotation = new_rot\n            return True\n        return False\n\n    def hard_drop(self):\n        \"\"\"Instantly drop to the lowest valid position.\"\"\"\n        while self.move(0, 1):\n            pass\n\n    def is_valid_position(self, x, y, rotation):\n        \"\"\"Check bounds and collisions.\"\"\"\n        for dx, dy in TETROMINOES[self.shape][rotation % len(TETROMINOES[self.shape])]:\n            gx, gy = x + dx, y + dy\n            if gx < 0 or gx >= GRID_WIDTH or gy >= GRID_HEIGHT:\n                return False\n            if gy >= 0 and grid[gy][gx] is not None:\n                return False\n        return True\n\ndef lock_tetromino(grid, tetromino):\n    \"\"\"Lock the tetromino into the grid.\"\"\"\n    for x, y in tetromino.current_blocks():\n        if 0 <= x < GRID_WIDTH and 0 <= y < GRID_HEIGHT:\n            grid[y][x] = tetromino.color\n\ndef new_tetromino():\n    return Tetromino(random.choice(list(TETROMINOES.keys())))\n\nif __name__ == \"__main__\":\n    pygame.init()\n    screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\n    pygame.display.set_caption(\"Tetris-Bejeweled Fusion\")\n\n    clock = pygame.time.Clock()\n    fall_time = 0\n    fall_speed = DROP_SPEED\n    lateral_time = 0\n\n    current = new_tetromino()\n    next_piece = new_tetromino()\n    game_over = False\n\n    key_left = key_right = key_down = False\n\n    running = True\n    while running:\n        dt = clock.tick(60) / 1000.0  # seconds\n        for event in pygame.event.get():\n            if event.type == pygame.QUIT:\n                running = False\n\n            elif event.type == pygame.KEYDOWN:\n                if event.key == pygame.K_LEFT:\n                    key_left = True\n                elif event.key == pygame.K_RIGHT:\n                    key_right = True\n                elif event.key == pygame.K_DOWN:\n                    key_down = True\n                    fall_speed = SOFT_DROP_SPEED\n                elif event.key == pygame.K_UP:\n                    current.rotate()\n                elif event.key == pygame.K_SPACE:\n                    # Hard drop: lock immediately\n                    current.hard_drop()\n                    lock_tetromino(grid, current)\n                    current = next_piece\n                    next_piece = new_tetromino()\n                    current.x = GRID_WIDTH//2 - 2\n                    current.y = 0\n                    fall_time = 0\n                    if not current.is_valid_position(current.x, current.y, current.rotation):\n                        game_over = True\n                        running = False\n\n            elif event.type == pygame.KEYUP:\n                if event.key == pygame.K_LEFT:\n                    key_left = False\n                elif event.key == pygame.K_RIGHT:\n                    key_right = False\n                elif event.key == pygame.K_DOWN:\n                    key_down = False\n                    fall_speed = DROP_SPEED\n\n        # Lateral move timing\n        lateral_time += dt\n        if lateral_time >= 1.0 / LATERAL_SPEED:\n            if key_left:\n                current.move(-1, 0)\n            elif key_right:\n                current.move(1, 0)\n            lateral_time = 0\n\n        # Gravity\n        fall_time += dt\n        if fall_time >= 1.0 / fall_speed:\n            if not current.move(0, 1):\n                # Lock on collision\n                lock_tetromino(grid, current)\n                current = next_piece\n                next_piece = new_tetromino()\n                current.x = GRID_WIDTH//2 - 2\n                current.y = 0\n                if not current.is_valid_position(current.x, current.y, current.rotation):\n                    game_over = True\n                    running = False\n            fall_time = 0\n\n        # Render\n        screen.fill((0,0,0))\n        # Draw grid blocks\n        for y in range(GRID_HEIGHT):\n            for x in range(GRID_WIDTH):\n                if grid[y][x] is not None:\n                    pygame.draw.rect(screen, grid[y][x],\n                                     (x*BLOCK_SIZE, y*BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE))\n        # Draw current tetromino\n        for x, y in current.current_blocks():\n            if 0 <= x < GRID_WIDTH and 0 <= y < GRID_HEIGHT:\n                pygame.draw.rect(screen, current.color,\n                                 (x*BLOCK_SIZE, y*BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE))\n\n        pygame.display.flip()\n\n    pygame.quit()\n```"}
{"timestamp": "2026-05-23 11:08:46,287", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task2: ```python\nimport pygame\nimport random\n\n# Constants\nGRID_WIDTH = 10\nGRID_HEIGHT = 20\nBLOCK_SIZE = 30\nSCREEN_WIDTH = GRID_WIDTH * BLOCK_SIZE\nSCREEN_HEIGHT = GRID_HEIGHT * BLOCK_SIZE\n\n# Colors (RGB tuples)\nCOLORS = {\n    \"red\":     (255, 0, 0),\n    \"green\":   (0, 255, 0),\n    \"blue\":    (0, 0, 255),\n    \"yellow\":  (255, 255, 0),\n    \"magenta\": (255, 0, 255),\n    \"cyan\":    (0, 255, 255),\n}\n\n# Fixed mapping from tetromino shapes to gem colors\nSHAPE_COLORS = {\n    \"I\": COLORS[\"cyan\"],\n    \"J\": COLORS[\"blue\"],\n    \"L\": COLORS[\"yellow\"],\n    \"O\": COLORS[\"yellow\"],\n    \"S\": COLORS[\"green\"],\n    \"T\": COLORS[\"magenta\"],\n    \"Z\": COLORS[\"red\"],\n}\n\n# Tetromino shapes and their rotation states\nTETROMINOES = {\n    \"I\": [\n        [(0,0),(1,0),(2,0),(3,0)],\n        [(1,0),(1,1),(1,2),(1,3)],\n    ],\n    \"J\": [\n        [(0,0),(1,0),(2,0),(2,1)],\n        [(1,0),(1,1),(1,2),(0,2)],\n        [(0,0),(0,1),(1,1),(2,1)],\n        [(1,0),(1,1),(1,2),(2,2)],\n    ],\n    \"L\": [\n        [(0,0),(1,0),(2,0),(0,1)],\n        [(0,0),(0,1),(0,2),(1,2)],\n        [(2,0),(0,1),(1,1),(2,1)],\n        [(0,0),(1,0),(1,1),(1,2)],\n    ],\n    \"O\": [\n        [(0,0),(1,0),(0,1),(1,1)],\n    ],\n    \"S\": [\n        [(1,0),(2,0),(0,1),(1,1)],\n        [(0,0),(0,1),(1,1),(1,2)],\n    ],\n    \"T\": [\n        [(0,0),(1,0),(2,0),(1,1)],\n        [(1,0),(0,1),(1,1),(1,2)],\n        [(1,0),(0,1),(1,1),(2,1)],\n        [(0,0),(0,1),(1,1),(0,2)],\n    ],\n    \"Z\": [\n        [(0,0),(1,0),(1,1),(2,1)],\n        [(1,0),(0,1),(1,1),(0,2)],\n    ],\n}\n\n# Game grid: 2D array; each cell is None or an RGB color tuple.\ngrid = [[None for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]\n\nclass Tetromino:\n    def __init__(self, shape: str):\n        assert shape in TETROMINOES, f\"Unknown shape '{shape}'\"\n        self.shape = shape\n        self.color = SHAPE_COLORS[shape]\n        # Spawn near top-center\n        self.x = GRID_WIDTH // 2 - 2\n        self.y = 0\n        self.rotation = 0\n\n    def current_blocks(self):\n        \"\"\"Return list of (x, y) for each block in current rotation.\"\"\"\n        coords = TETROMINOES[self.shape][self.rotation % len(TETROMINOES[self.shape])]\n        return [(self.x + dx, self.y + dy) for dx, dy in coords]\n\ndef lock_tetromino(grid, tetromino):\n    \"\"\"Lock tetromino blocks into the grid as gem colors.\"\"\"\n    for x, y in tetromino.current_blocks():\n        if 0 <= x < GRID_WIDTH and 0 <= y < GRID_HEIGHT:\n            grid[y][x] = tetromino.color\n\ndef apply_gravity(grid):\n    \"\"\"Let gems fall down to fill empty spaces after clears.\"\"\"\n    for x in range(GRID_WIDTH):\n        stack = [grid[y][x] for y in range(GRID_HEIGHT) if grid[y][x] is not None]\n        # Fill from bottom\n        for y in range(GRID_HEIGHT-1, -1, -1):\n            if stack:\n                grid[y][x] = stack.pop()\n            else:\n                grid[y][x] = None\n\ndef find_matches(grid):\n    \"\"\"Find all horizontal/vertical match-3+ groups; return set of coords.\"\"\"\n    matched = set()\n    for y in range(GRID_HEIGHT):\n        for x in range(GRID_WIDTH):\n            color = grid[y][x]\n            if color is None:\n                continue\n            # horizontal\n            run = [(x, y)]\n            i = x+1\n            while i < GRID_WIDTH and grid[y][i] == color:\n                run.append((i, y)); i += 1\n            i = x-1\n            while i >= 0 and grid[y][i] == color:\n                run.append((i, y)); i -= 1\n            if len(run) >= 3:\n                matched.update(run)\n            # vertical\n            run = [(x, y)]\n            j = y+1\n            while j < GRID_HEIGHT and grid[j][x] == color:\n                run.append((x, j)); j += 1\n            j = y-1\n            while j >= 0 and grid[j][x] == color:\n                run.append((x, j)); j -= 1\n            if len(run) >= 3:\n                matched.update(run)\n    return matched\n\ndef clear_cells(grid, cells):\n    \"\"\"Clear the given list of cells (set them to None).\"\"\"\n    for x, y in cells:\n        grid[y][x] = None\n\ndef find_full_lines(grid):\n    \"\"\"Return list of row indices that are completely filled.\"\"\"\n    return [y for y in range(GRID_HEIGHT) if all(grid[y][x] is not None for x in range(GRID_WIDTH))]\n\ndef clear_full_lines(grid, lines):\n    \"\"\"Remove full lines and insert empty ones at the top.\"\"\"\n    for line in sorted(lines, reverse=True):\n        del grid[line]\n        grid.insert(0, [None]*GRID_WIDTH)\n\ndef handle_clearing(grid):\n    \"\"\"\n    Handle chain reactions of match-3 and line clears.\n    Returns total score earned in this lock cycle.\n    \"\"\"\n    total_score = 0\n    chain = 1\n\n    while True:\n        # 1) Check and clear gem matches\n        matches = find_matches(grid)\n        if matches:\n            clear_cells(grid, matches)\n            apply_gravity(grid)\n            # Scoring: 10 points per gem\n            pts = len(matches) * 10 * chain\n            total_score += pts\n            chain += 1\n            continue\n\n        # 2) If no gem matches, check line clears\n        full_lines = find_full_lines(grid)\n        if full_lines:\n            clear_full_lines(grid, full_lines)\n            # line clear automatically shifts rows; gravity not needed\n            pts = len(full_lines) * 100 * chain\n            total_score += pts\n            chain += 1\n            continue\n\n        # No more clears\n        break\n\n    return total_score\n\n# Example usage and test:\nif __name__ == \"__main__\":\n    # Fill grid with a test scenario\n    for y in range(GRID_HEIGHT):\n        for x in range(GRID_WIDTH):\n            grid[y][x] = None\n\n    # Create sample match-3 in row 0\n    grid[0][0] = grid[0][1] = grid[0][2] = COLORS[\"red\"]\n    # Create full line at row 1\n    grid[1] = [COLORS[\"blue\"]]*GRID_WIDTH\n    # Create a vertical match-3 at column 0\n    grid[2][0] = grid[3][0] = grid[4][0] = COLORS[\"green\"]\n\n    score = handle_clearing(grid)\n    print(f\"Total score from clears: {score}\")\n\n    # Basic Pygame loop to visualize (optional)\n    pygame.init()\n    screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\n    pygame.display.set_caption(\"Tetris-Bejeweled Clearing Demo\")\n\n    running = True\n    while running:\n        for ev in pygame.event.get():\n            if ev.type == pygame.QUIT:\n                running = False\n\n        screen.fill((0, 0, 0))\n        # Draw the grid\n        for y in range(GRID_HEIGHT):\n            for x in range(GRID_WIDTH):\n                cell = grid[y][x]\n                if cell:\n                    pygame.draw.rect(screen, cell,\n                                     (x*BLOCK_SIZE, y*BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE))\n        pygame.display.flip()\n\n    pygame.quit()\n```"}
{"timestamp": "2026-05-23 11:08:46,287", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task3: ```python\nimport pygame\nimport random\n\n# Constants\nGRID_WIDTH = 10\nGRID_HEIGHT = 20\nBLOCK_SIZE = 30\nSCREEN_WIDTH = 600\nSCREEN_HEIGHT = 800\nGRID_OFFSET_X = 150\nGRID_OFFSET_Y = 50\nSCORE_AREA_HEIGHT = 100\nPREVIEW_AREA_WIDTH = 150\nPREVIEW_AREA_HEIGHT = 150\nSCORE_X = 10\nSCORE_Y = 10\nPREVIEW_X = SCREEN_WIDTH - PREVIEW_AREA_WIDTH - 10\nPREVIEW_Y = 10\n\nFALL_SPEED = 500      # ms per cell\nCLEAR_FLASH_SPEED = 200  # ms per flash toggle\nCLEAR_DURATION = 600     # total ms of flashing\n\n# Colors\nCOLORS = {\n    \"red\":     (255, 0, 0),\n    \"green\":   (0, 255, 0),\n    \"blue\":    (0, 0, 255),\n    \"yellow\":  (255, 255, 0),\n    \"magenta\": (255, 0, 255),\n    \"cyan\":    (0, 255, 255),\n    \"white\":   (255, 255, 255),\n    \"gray\":    (128, 128, 128),\n    \"black\":   (0, 0, 0)\n}\n\n# Map tetromino shapes to gem colors\nSHAPE_COLORS = {\n    \"I\": COLORS[\"cyan\"],\n    \"J\": COLORS[\"blue\"],\n    \"L\": COLORS[\"yellow\"],\n    \"O\": COLORS[\"yellow\"],\n    \"S\": COLORS[\"green\"],\n    \"T\": COLORS[\"magenta\"],\n    \"Z\": COLORS[\"red\"],\n}\n\n# Tetromino definitions\nTETROMINOES = {\n    \"I\": [\n        [(0,0),(1,0),(2,0),(3,0)],\n        [(1,0),(1,1),(1,2),(1,3)]\n    ],\n    \"J\": [\n        [(0,0),(1,0),(2,0),(2,1)],\n        [(1,0),(1,1),(1,2),(0,2)],\n        [(0,1),(1,1),(2,1),(0,0)],\n        [(1,0),(1,1),(1,2),(2,0)]\n    ],\n    \"L\": [\n        [(0,0),(1,0),(2,0),(0,1)],\n        [(0,2),(1,2),(1,1),(1,0)],\n        [(2,1),(1,1),(0,1),(2,0)],\n        [(1,0),(1,1),(1,2),(2,2)]\n    ],\n    \"O\": [\n        [(0,0),(1,0),(0,1),(1,1)]\n    ],\n    \"S\": [\n        [(1,0),(2,0),(0,1),(1,1)],\n        [(0,0),(0,1),(1,1),(1,2)]\n    ],\n    \"T\": [\n        [(0,0),(1,0),(2,0),(1,1)],\n        [(1,0),(0,1),(1,1),(1,2)],\n        [(1,1),(0,1),(2,1),(1,0)],\n        [(0,0),(0,1),(0,2),(1,1)]\n    ],\n    \"Z\": [\n        [(0,0),(1,0),(1,1),(2,1)],\n        [(1,0),(1,1),(0,1),(0,2)]\n    ]\n}\n\nclass Tetromino:\n    def __init__(self, shape, x=None, y=None, rotation=None):\n        self.shape = shape\n        self.color = SHAPE_COLORS[shape]\n        self.rotation = rotation if rotation is not None else 0\n        self.x = x if x is not None else GRID_WIDTH//2 - 2\n        self.y = y if y is not None else 0\n\n    def current_blocks(self):\n        coords = TETROMINOES[self.shape][self.rotation % len(TETROMINOES[self.shape])]\n        return [(self.x+dx, self.y+dy) for dx, dy in coords]\n\n    def copy(self):\n        return Tetromino(self.shape, self.x, self.y, self.rotation)\n\ndef check_collision(grid, tetromino):\n    for x,y in tetromino.current_blocks():\n        if x<0 or x>=GRID_WIDTH or y>=GRID_HEIGHT or (y>=0 and grid[y][x] is not None):\n            return True\n    return False\n\ndef lock_tetromino(grid, tetromino):\n    for x,y in tetromino.current_blocks():\n        if 0<=x<GRID_WIDTH and 0<=y<GRID_HEIGHT:\n            grid[y][x] = tetromino.color\n\ndef clear_full_lines(grid):\n    removed = 0\n    new_grid = []\n    for row in grid:\n        if all(cell is not None for cell in row):\n            removed += 1\n        else:\n            new_grid.append(row)\n    for _ in range(removed):\n        new_grid.insert(0, [None]*GRID_WIDTH)\n    return new_grid, removed\n\ndef find_matches(grid):\n    matches = set()\n    # horizontal\n    for y in range(GRID_HEIGHT):\n        x=0\n        while x<GRID_WIDTH-2:\n            c=grid[y][x]\n            if c and grid[y][x+1]==c and grid[y][x+2]==c:\n                span=3\n                while x+span<GRID_WIDTH and grid[y][x+span]==c:\n                    span+=1\n                for i in range(span):\n                    matches.add((x+i,y))\n                x+=span\n            else:\n                x+=1\n    # vertical\n    for x in range(GRID_WIDTH):\n        y=0\n        while y<GRID_HEIGHT-2:\n            c=grid[y][x]\n            if c and grid[y+1][x]==c and grid[y+2][x]==c:\n                span=3\n                while y+span<GRID_HEIGHT and grid[y+span][x]==c:\n                    span+=1\n                for i in range(span):\n                    matches.add((x,y+i))\n                y+=span\n            else:\n                y+=1\n    return matches\n\ndef apply_gravity(grid):\n    for x in range(GRID_WIDTH):\n        col = [grid[y][x] for y in range(GRID_HEIGHT) if grid[y][x] is not None]\n        for y in range(GRID_HEIGHT-1, -1, -1):\n            grid[y][x] = col.pop() if col else None\n\ndef draw_grid(screen, grid):\n    for y,row in enumerate(grid):\n        for x,cell in enumerate(row):\n            rect = pygame.Rect(GRID_OFFSET_X + x*BLOCK_SIZE,\n                               GRID_OFFSET_Y + y*BLOCK_SIZE,\n                               BLOCK_SIZE, BLOCK_SIZE)\n            if cell:\n                pygame.draw.rect(screen, cell, rect)\n            pygame.draw.rect(screen, COLORS[\"gray\"], rect, 1)\n\ndef draw_tetromino(screen, tetromino, fall_offset):\n    for x,y in tetromino.current_blocks():\n        if 0<=x<GRID_WIDTH and y>=-4 and y<GRID_HEIGHT:\n            px = GRID_OFFSET_X + x*BLOCK_SIZE\n            py = GRID_OFFSET_Y + y*BLOCK_SIZE + fall_offset\n            pygame.draw.rect(screen, tetromino.color, (px,py,BLOCK_SIZE,BLOCK_SIZE))\n\ndef draw_score(screen, score, font):\n    text = font.render(f\"Score: {score}\", True, COLORS[\"white\"])\n    screen.blit(text, (SCORE_X, SCORE_Y))\n\ndef draw_next(screen, preview, font):\n    pygame.draw.rect(screen, COLORS[\"gray\"], (PREVIEW_X,PREVIEW_Y,PREVIEW_AREA_WIDTH,PREVIEW_AREA_HEIGHT),2)\n    center_x = PREVIEW_X + PREVIEW_AREA_WIDTH//2\n    center_y = PREVIEW_Y + PREVIEW_AREA_HEIGHT//2\n    shape = TETROMINOES[preview.shape][0]\n    max_w = max(x for x,y in shape)+1\n    max_h = max(y for x,y in shape)+1\n    scale = min(PREVIEW_AREA_WIDTH/(max_w*BLOCK_SIZE),\n                PREVIEW_AREA_HEIGHT/(max_h*BLOCK_SIZE))\n    for dx,dy in shape:\n        px = center_x + (dx - max_w/2)*BLOCK_SIZE*scale\n        py = center_y + (dy - max_h/2)*BLOCK_SIZE*scale\n        rect = pygame.Rect(px,py,BLOCK_SIZE*scale,BLOCK_SIZE*scale)\n        pygame.draw.rect(screen, preview.color, rect)\n\ndef game_over_screen(screen, font):\n    text = font.render(\"Game Over! Press any key.\", True, COLORS[\"red\"])\n    rect = text.get_rect(center=(SCREEN_WIDTH//2, SCREEN_HEIGHT//2))\n    screen.blit(text, rect)\n    pygame.display.flip()\n    while True:\n        for e in pygame.event.get():\n            if e.type==pygame.QUIT:\n                return False\n            if e.type==pygame.KEYDOWN:\n                return True\n\ndef spawn_tetromino(next_tet):\n    cur = next_tet\n    cur.x = GRID_WIDTH//2 - 2\n    cur.y = 0\n    cur.rotation = 0\n    nxt = Tetromino(random.choice(list(TETROMINOES.keys())))\n    return cur, nxt\n\ndef main():\n    pygame.init()\n    screen = pygame.display.set_mode((SCREEN_WIDTH,SCREEN_HEIGHT))\n    pygame.display.set_caption(\"Tetris-Bejeweled\")\n    clock = pygame.time.Clock()\n    font = pygame.font.Font(None, 36)\n\n    grid = [[None]*GRID_WIDTH for _ in range(GRID_HEIGHT)]\n    score = 0\n\n    next_tet = Tetromino(random.choice(list(TETROMINOES.keys())))\n    current_tet, next_tet = spawn_tetromino(next_tet)\n    fall_offset = 0.0\n    fall_timer = 0\n    clearing = False\n    clear_timer = 0\n    flash_state = False\n    matches = set()\n    running = True\n    game_active = True\n\n    while running:\n        dt = clock.tick(60)\n        for event in pygame.event.get():\n            if event.type==pygame.QUIT:\n                running=False\n            if event.type==pygame.KEYDOWN and game_active and not clearing:\n                temp = current_tet.copy()\n                if event.key==pygame.K_LEFT:\n                    temp.x-=1\n                elif event.key==pygame.K_RIGHT:\n                    temp.x+=1\n                elif event.key==pygame.K_DOWN:\n                    temp.y+=1\n                elif event.key==pygame.K_UP:\n                    temp.rotation=(temp.rotation+1)%len(TETROMINOES[current_tet.shape])\n                if not check_collision(grid,temp):\n                    current_tet = temp\n\n        if game_active:\n            if not clearing:\n                # update fall offset\n                fall_timer += dt\n                fall_offset = (fall_timer / FALL_SPEED) * BLOCK_SIZE\n                if fall_timer >= FALL_SPEED:\n                    # try moving down one\n                    temp = current_tet.copy()\n                    temp.y += 1\n                    if not check_collision(grid,temp):\n                        current_tet = temp\n                        fall_timer -= FALL_SPEED\n                        fall_offset = 0.0\n                    else:\n                        # lock\n                        lock_tetromino(grid, current_tet)\n                        # clear lines\n                        grid, lines = clear_full_lines(grid)\n                        if lines:\n                            score += 100 * (lines**2)\n                        # find matches\n                        matches = find_matches(grid)\n                        if matches:\n                            clearing = True\n                            clear_timer = 0\n                            flash_state = False\n                        else:\n                            # spawn next\n                            current_tet, next_tet = spawn_tetromino(next_tet)\n                            fall_timer = 0\n                            fall_offset = 0.0\n                            if check_collision(grid, current_tet):\n                                game_active=False\n            else:\n                # handle flashing animation\n                clear_timer += dt\n                if clear_timer//CLEAR_FLASH_SPEED % 2 == 1:\n                    flash_state = True\n                else:\n                    flash_state = False\n                if clear_timer >= CLEAR_DURATION:\n                    # actually clear matches\n                    for x,y in matches:\n                        grid[y][x] = None\n                    apply_gravity(grid)\n                    score += 5 * len(matches)\n                    matches.clear()\n                    clearing = False\n                    # spawn next\n                    current_tet, next_tet = spawn_tetromino(next_tet)\n                    fall_timer = 0\n                    fall_offset = 0.0\n                    if check_collision(grid, current_tet):\n                        game_active=False\n\n        # draw\n        screen.fill(COLORS[\"black\"])\n        draw_grid(screen, grid)\n        if game_active:\n            if not clearing:\n                draw_tetromino(screen, current_tet, fall_offset)\n            else:\n                # draw flashing overlay for matches\n                draw_tetromino(screen, current_tet, 0)\n                for x,y in matches:\n                    if flash_state:\n                        px = GRID_OFFSET_X + x*BLOCK_SIZE\n                        py = GRID_OFFSET_Y + y*BLOCK_SIZE\n                        pygame.draw.rect(screen, COLORS[\"white\"], (px,py,BLOCK_SIZE,BLOCK_SIZE))\n        draw_score(screen, score, font)\n        draw_next(screen, next_tet, font)\n\n        if not game_active:\n            if not game_over_screen(screen, font):\n                running=False\n            else:\n                # reset game\n                grid = [[None]*GRID_WIDTH for _ in range(GRID_HEIGHT)]\n                score = 0\n                next_tet = Tetromino(random.choice(list(TETROMINOES.keys())))\n                current_tet, next_tet = spawn_tetromino(next_tet)\n                fall_timer = fall_offset = 0.0\n                game_active = True\n                clearing = False\n                matches.clear()\n\n        pygame.display.flip()\n\n    pygame.quit()\n\nif __name__==\"__main__\":\n    main()\n```"}
{"timestamp": "2026-05-23 11:08:46,288", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task4: ```python\nimport pygame\nimport random\n\n# Constants\nGRID_WIDTH = 10\nGRID_HEIGHT = 20\nBLOCK_SIZE = 30\nSCREEN_WIDTH = 600\nSCREEN_HEIGHT = 800\nGRID_OFFSET_X = 150\nGRID_OFFSET_Y = 50\nSCORE_AREA_HEIGHT = 100\nPREVIEW_AREA_WIDTH = 150\nPREVIEW_AREA_HEIGHT = 150\nSCORE_X = 10\nSCORE_Y = 10\nPREVIEW_X = SCREEN_WIDTH - PREVIEW_AREA_WIDTH - 10\nPREVIEW_Y = 10\nLATERAL_SPEED = 10    # Moves per second\nDROP_SPEED = 1        # Moves per second\nSOFT_DROP_SPEED = 20  # Moves per second\nFALL_SPEED = 500      # ms per cell\nCLEAR_FLASH_SPEED = 200  # ms per flash toggle\nCLEAR_DURATION = 600     # total ms of flashing\n\n# Colors\nCOLORS = {\n    \"red\":     (255, 0, 0),\n    \"green\":   (0, 255, 0),\n    \"blue\":    (0, 0, 255),\n    \"yellow\":  (255, 255, 0),\n    \"magenta\": (255, 0, 255),\n    \"cyan\":    (0, 255, 255),\n    \"white\":   (255, 255, 255),\n    \"gray\":    (128, 128, 128),\n    \"black\":   (0, 0, 0)\n}\n\n# Map tetromino shapes to gem colors\nSHAPE_COLORS = {\n    \"I\": COLORS[\"cyan\"],\n    \"J\": COLORS[\"blue\"],\n    \"L\": COLORS[\"yellow\"],\n    \"O\": COLORS[\"yellow\"],\n    \"S\": COLORS[\"green\"],\n    \"T\": COLORS[\"magenta\"],\n    \"Z\": COLORS[\"red\"],\n}\n\n# Tetromino definitions\nTETROMINOES = {\n    \"I\": [\n        [(0, 0), (1, 0), (2, 0), (3, 0)],\n        [(1, 0), (1, 1), (1, 2), (1, 3)]\n    ],\n    \"J\": [\n        [(0, 0), (1, 0), (2, 0), (2, 1)],\n        [(1, 0), (1, 1), (1, 2), (0, 2)],\n        [(0, 1), (1, 1), (2, 1), (0, 0)],\n        [(1, 0), (1, 1), (1, 2), (2, 0)]\n    ],\n    \"L\": [\n        [(0, 0), (1, 0), (2, 0), (0, 1)],\n        [(0, 0), (0, 1), (0, 2), (1, 2)],\n        [(2, 0), (0, 1), (1, 1), (2, 1)],\n        [(0, 0), (1, 0), (1, 1), (1, 2)]\n    ],\n    \"O\": [\n        [(0, 0), (1, 0), (0, 1), (1, 1)]\n    ],\n    \"S\": [\n        [(1, 0), (2, 0), (0, 1), (1, 1)],\n        [(0, 0), (0, 1), (1, 1), (1, 2)]\n    ],\n    \"T\": [\n        [(0, 0), (1, 0), (2, 0), (1, 1)],\n        [(1, 0), (0, 1), (1, 1), (1, 2)],\n        [(1, 0), (0, 1), (1, 1), (2, 1)],\n        [(0, 0), (0, 1), (1, 1), (0, 2)]\n    ],\n    \"Z\": [\n        [(0, 0), (1, 0), (1, 1), (2, 1)],\n        [(1, 0), (0, 1), (1, 1), (0, 2)]\n    ]\n}\n\n\nclass Tetromino:\n    def __init__(self, shape: str):\n        assert shape in TETROMINOES, f\"Unknown shape '{shape}'\"\n        self.shape = shape\n        self.color = SHAPE_COLORS[shape]\n        self.x = GRID_WIDTH // 2 - 2\n        self.y = 0\n        self.rotation = 0\n\n    def current_blocks(self):\n        \"\"\"Return list of (x, y) for each block in current rotation.\"\"\"\n        coords = TETROMINOES[self.shape][self.rotation % len(TETROMINOES[self.shape])]\n        return [(self.x + dx, self.y + dy) for dx, dy in coords]\n\n    def move(self, dx, dy):\n        \"\"\"Attempt to move; return True if successful.\"\"\"\n        new_x, new_y = self.x + dx, self.y + dy\n        if self.is_valid_position(new_x, new_y, self.rotation):\n            self.x, self.y = new_x, new_y\n            return True\n        return False\n\n    def rotate(self):\n        \"\"\"Attempt to rotate; return True if successful.\"\"\"\n        new_rot = (self.rotation + 1) % len(TETROMINOES[self.shape])\n        if self.is_valid_position(self.x, self.y, new_rot):\n            self.rotation = new_rot\n            return True\n        return False\n\n    def hard_drop(self):\n        \"\"\"Instantly drop to the lowest valid position.\"\"\"\n        while self.move(0, 1):\n            pass\n\n    def is_valid_position(self, x, y, rotation):\n        \"\"\"Check bounds and collisions.\"\"\"\n        for dx, dy in TETROMINOES[self.shape][rotation % len(TETROMINOES[self.shape])]:\n            gx, gy = x + dx, y + dy\n            if gx < 0 or gx >= GRID_WIDTH or gy >= GRID_HEIGHT:\n                return False\n            if gy >= 0 and grid[gy][gx] is not None:\n                return False\n        return True\n    \n    def copy(self):\n        return Tetromino(self.shape)\n    \n    def __copy__(self):\n        return Tetromino(self.shape)\n\n\ndef lock_tetromino(grid, tetromino):\n    \"\"\"Lock the tetromino into the grid.\"\"\"\n    for x, y in tetromino.current_blocks():\n        if 0 <= x < GRID_WIDTH and 0 <= y < GRID_HEIGHT:\n            grid[y][x] = tetromino.color\n\n\ndef new_tetromino():\n    return Tetromino(random.choice(list(TETROMINOES.keys())))\n\n\ndef find_matches(grid):\n    \"\"\"Find all horizontal/vertical match-3+ groups; return set of coords.\"\"\"\n    matched = set()\n    for y in range(GRID_HEIGHT):\n        for x in range(GRID_WIDTH):\n            color = grid[y][x]\n            if color is None:\n                continue\n            # horizontal\n            run = [(x, y)]\n            i = x + 1\n            while i < GRID_WIDTH and grid[y][i] == color:\n                run.append((i, y))\n                i += 1\n            i = x - 1\n            while i >= 0 and grid[y][i] == color:\n                run.append((i, y))\n                i -= 1\n            if len(run) >= 3:\n                matched.update(run)\n            # vertical\n            run = [(x, y)]\n            j = y + 1\n            while j < GRID_HEIGHT and grid[j][x] == color:\n                run.append((x, j))\n                j += 1\n            j = y - 1\n            while j >= 0 and grid[j][x] == color:\n                run.append((x, j))\n                j -= 1\n            if len(run) >= 3:\n                matched.update(run)\n    return matched\n\n\ndef clear_cells(grid, cells):\n    \"\"\"Clear the given list of cells (set them to None).\"\"\"\n    for x, y in cells:\n        grid[y][x] = None\n\n\ndef find_full_lines(grid):\n    \"\"\"Return list of row indices that are completely filled.\"\"\"\n    return [y for y in range(GRID_HEIGHT) if all(grid[y][x] is not None for x in range(GRID_WIDTH))]\n\n\ndef clear_full_lines(grid, lines):\n    \"\"\"Remove full lines and insert empty ones at the top.\"\"\"\n    for line in sorted(lines, reverse=True):\n        del grid[line]\n        grid.insert(0, [None] * GRID_WIDTH)\n\n\ndef apply_gravity(grid):\n    \"\"\"Let gems fall down to fill empty spaces after clears.\"\"\"\n    for x in range(GRID_WIDTH):\n        stack = [grid[y][x] for y in range(GRID_HEIGHT) if grid[y][x] is not None]\n        # Fill from bottom\n        for y in range(GRID_HEIGHT - 1, -1, -1):\n            if stack:\n                grid[y][x] = stack.pop()\n            else:\n                grid[y][x] = None\n\n\ndef handle_clearing(grid):\n    \"\"\"\n    Handle chain reactions of match-3 and line clears.\n    Returns total score earned in this lock cycle.\n    \"\"\"\n    total_score = 0\n    chain = 1\n\n    while True:\n        # 1) Check and clear gem matches\n        matches = find_matches(grid)\n        if matches:\n            clear_cells(grid, matches)\n            apply_gravity(grid)\n            # Scoring: 10 points per gem\n            pts = len(matches) * 10 * chain\n            total_score += pts\n            chain += 1\n            continue\n\n        # 2) If no gem matches, check line clears\n        full_lines = find_full_lines(grid)\n        if full_lines:\n            clear_full_lines(grid, full_lines)\n            # line clear automatically shifts rows; gravity not needed\n            pts = len(full_lines) * 100 * chain\n            total_score += pts\n            chain += 1\n            continue\n\n        # No more clears\n        break\n\n    return total_score\n\n\ndef draw_grid(screen, grid):\n    for y, row in enumerate(grid):\n        for x, cell in enumerate(row):\n            rect = pygame.Rect(GRID_OFFSET_X + x * BLOCK_SIZE,\n                               GRID_OFFSET_Y + y * BLOCK_SIZE,\n                               BLOCK_SIZE, BLOCK_SIZE)\n            if cell:\n                pygame.draw.rect(screen, cell, rect)\n            pygame.draw.rect(screen, COLORS[\"gray\"], rect, 1)\n\n\ndef draw_tetromino(screen, tetromino):\n    for x, y in tetromino.current_blocks():\n        if 0 <= x < GRID_WIDTH and 0 <= y < GRID_HEIGHT:\n            px = GRID_OFFSET_X + x * BLOCK_SIZE\n            py = GRID_OFFSET_Y + y * BLOCK_SIZE\n            pygame.draw.rect(screen, tetromino.color, (px, py, BLOCK_SIZE, BLOCK_SIZE))\n\n\ndef draw_score(screen, score, font):\n    text = font.render(f\"Score: {score}\", True, COLORS[\"white\"])\n    screen.blit(text, (SCORE_X, SCORE_Y))\n\n\ndef draw_next(screen, next_piece, font):\n    pygame.draw.rect(screen, COLORS[\"gray\"], (PREVIEW_X, PREVIEW_Y, PREVIEW_AREA_WIDTH, PREVIEW_AREA_HEIGHT), 2)\n    font_small = pygame.font.Font(None, 24)  # Smaller font for the \"Next\" label\n    next_text = font_small.render(\"Next:\", True, COLORS[\"white\"])\n    screen.blit(next_text, (PREVIEW_X, PREVIEW_Y - 25))\n\n    # Calculate the center of the preview area\n    center_x = PREVIEW_X + PREVIEW_AREA_WIDTH // 2\n    center_y = PREVIEW_Y + PREVIEW_AREA_HEIGHT // 2\n\n    # Get the shape of the next piece (using the first rotation)\n    shape = TETROMINOES[next_piece.shape][0]\n\n    # Calculate the maximum width and height of the shape\n    max_w = max(x for x, y in shape) + 1\n    max_h = max(y for x, y in shape) + 1\n\n    # Calculate the scaling factor to fit the shape within the preview area\n    scale = min(PREVIEW_AREA_WIDTH / (max_w * BLOCK_SIZE),\n                PREVIEW_AREA_HEIGHT / (max_h * BLOCK_SIZE))\n\n    # Draw each block of the next piece, centered in the preview area\n    for dx, dy in shape:\n        px = center_x + (dx - max_w / 2) * BLOCK_SIZE * scale\n        py = center_y + (dy - max_h / 2) * BLOCK_SIZE * scale\n        rect = pygame.Rect(px - BLOCK_SIZE*scale/2, py - BLOCK_SIZE*scale/2, BLOCK_SIZE * scale, BLOCK_SIZE * scale)  # Adjusted centering\n        pygame.draw.rect(screen, next_piece.color, rect)\n\n\ndef game_over_screen(screen, font):\n    text = font.render(\"Game Over! Press any key to restart.\", True, COLORS[\"red\"])\n    rect = text.get_rect(center=(SCREEN_WIDTH // 2, SCREEN_HEIGHT // 2))\n    screen.blit(text, rect)\n    pygame.display.flip()\n\n    waiting = True\n    while waiting:\n        for event in pygame.event.get():\n            if event.type == pygame.QUIT:\n                return False  # Exit game\n            if event.type == pygame.KEYDOWN:\n                return True   # Restart game\n\n\nif __name__ == \"__main__\":\n    pygame.init()\n    screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\n    pygame.display.set_caption(\"Tetris-Bejeweled Fusion\")\n    clock = pygame.time.Clock()\n    font = pygame.font.Font(None, 36)\n\n    grid = [[None for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]\n    score = 0\n\n    current = new_tetromino()\n    next_piece = new_tetromino()\n    game_over = False\n\n    key_left = key_right = key_down = False\n    fall_time = 0\n    fall_speed = DROP_SPEED\n    lateral_time = 0\n    clearing = False\n    clear_timer = 0\n    flash_state = False\n    matches = set()\n\n    running = True\n    while running:\n        dt = clock.tick(60) / 1000.0  # seconds\n        for event in pygame.event.get():\n            if event.type == pygame.QUIT:\n                running = False\n\n            elif event.type == pygame.KEYDOWN:\n                if event.key == pygame.K_LEFT:\n                    key_left = True\n                elif event.key == pygame.K_RIGHT:\n                    key_right = True\n                elif event.key == pygame.K_DOWN:\n                    key_down = True\n                    fall_speed = SOFT_DROP_SPEED\n                elif event.key == pygame.K_UP:\n                    current.rotate()\n                elif event.key == pygame.K_SPACE:\n                    # Hard drop: lock immediately\n                    current.hard_drop()\n                    lock_tetromino(grid, current)\n                    score += handle_clearing(grid)  # Apply clearing logic and update score\n                    current = next_piece\n                    next_piece = new_tetromino()\n                    current.x = GRID_WIDTH // 2 - 2\n                    current.y = 0\n                    fall_time = 0\n                    if not current.is_valid_position(current.x, current.y, current.rotation):\n                        game_over = True\n                        running = False\n\n            elif event.type == pygame.KEYUP:\n                if event.key == pygame.K_LEFT:\n                    key_left = False\n                elif event.key == pygame.K_RIGHT:\n                    key_right = False\n                elif event.key == pygame.K_DOWN:\n                    key_down = False\n                    fall_speed = DROP_SPEED\n\n        # Lateral move timing\n        lateral_time += dt\n        if lateral_time >= 1.0 / LATERAL_SPEED:\n            if key_left:\n                current.move(-1, 0)\n            elif key_right:\n                current.move(1, 0)\n            lateral_time = 0\n\n        # Gravity\n        fall_time += dt\n        if fall_time >= 1.0 / fall_speed:\n            if not current.move(0, 1):\n                # Lock on collision\n                lock_tetromino(grid, current)\n                score += handle_clearing(grid)  # Apply clearing logic and update score\n                current = next_piece\n                next_piece = new_tetromino()\n                current.x = GRID_WIDTH // 2 - 2\n                current.y = 0\n                fall_time = 0\n                if not current.is_valid_position(current.x, current.y, current.rotation):\n                    game_over = True\n                    running = False\n            fall_time = 0\n\n        # Render\n        screen.fill((0, 0, 0))\n        draw_grid(screen, grid)\n        draw_tetromino(screen, current)\n        draw_score(screen, score, font)\n        draw_next(screen, next_piece, font)\n\n        if game_over:\n            if game_over_screen(screen, font):\n                # Reset game state\n                grid = [[None for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]\n                score = 0\n                current = new_tetromino()\n                next_piece = new_tetromino()\n                game_over = False\n            else:\n                running = False\n\n        pygame.display.flip()\n\n    pygame.quit()\n```"}
