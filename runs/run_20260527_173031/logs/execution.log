{"timestamp": "2026-05-27 17:34:29,841", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task0: ```python\nimport re\n\nclass JobDescriptionParser:\n    def __init__(self, job_description):\n        self.job_description = job_description\n        self.required_skills = []\n        self.competencies = []\n        self.evaluation_criteria = []\n\n    def extract_skills(self):\n        \"\"\"\n        Extracts required skills from the job description using regex.\n        This is a basic implementation and can be improved with more sophisticated NLP techniques.\n        \"\"\"\n        # Keywords indicating skills (can be expanded)\n        skill_keywords = [\"skills\", \"skill\", \"experience\", \"knowledge\", \"proficiency\", \"familiarity\"]\n\n        # Regex to find sections related to skills\n        skill_regex = r\"(?i)(?P<header>(?:\" + \"|\".join(skill_keywords) + r\")[\\s\\w]*?:)\\s*(?P<skills>.*?)(?=\\n\\w+[\\s:]|$)\"\n\n        matches = re.finditer(skill_regex, self.job_description, re.DOTALL)\n\n        for match in matches:\n            skills_text = match.group(\"skills\")\n            # Split the skills text into individual skills (can be improved)\n            skills = re.split(r\"[,;\\n]+\", skills_text)\n            # Clean up the skills (remove extra spaces, etc.)\n            cleaned_skills = [skill.strip() for skill in skills if skill.strip()]\n            self.required_skills.extend(cleaned_skills)\n\n    def extract_competencies(self):\n         \"\"\"\n         Extracts competencies from the job description using regex.\n         Competencies are behavioral or personal attributes.\n         \"\"\"\n         competency_keywords = [\"competencies\", \"competency\", \"abilities\", \"ability\", \"attributes\", \"attribute\"]\n\n         competency_regex = r\"(?i)(?P<header>(?:\" + \"|\".join(competency_keywords) + r\")[\\s\\w]*?:)\\s*(?P<competencies>.*?)(?=\\n\\w+[\\s:]|$)\"\n\n         matches = re.finditer(competency_regex, self.job_description, re.DOTALL)\n\n         for match in matches:\n            competencies_text = match.group(\"competencies\")\n            competencies = re.split(r\"[,;\\n]+\", competencies_text)\n            cleaned_competencies = [competency.strip() for competency in competencies if competency.strip()]\n            self.competencies.extend(cleaned_competencies)\n\n\n    def extract_evaluation_criteria(self):\n        \"\"\"\n        Extracts evaluation criteria from the job description using regex.\n        Evaluation criteria are the standards used to assess candidates.\n        \"\"\"\n        criteria_keywords = [\"evaluation criteria\", \"evaluation\", \"criteria\", \"performance indicators\", \"performance\", \"indicators\", \"assessment\"]\n\n        criteria_regex = r\"(?i)(?P<header>(?:\" + \"|\".join(criteria_keywords) + r\")[\\s\\w]*?:)\\s*(?P<criteria>.*?)(?=\\n\\w+[\\s:]|$)\"\n\n        matches = re.finditer(criteria_regex, self.job_description, re.DOTALL)\n\n        for match in matches:\n            criteria_text = match.group(\"criteria\")\n            criteria = re.split(r\"[,;\\n]+\", criteria_text)\n            cleaned_criteria = [criterion.strip() for criterion in criteria if criterion.strip()]\n            self.evaluation_criteria.extend(cleaned_criteria)\n\n\n    def parse(self):\n        \"\"\"\n        Parses the job description and extracts skills, competencies, and evaluation criteria.\n        \"\"\"\n        self.extract_skills()\n        self.extract_competencies()\n        self.extract_evaluation_criteria()\n\n\n    def get_required_skills(self):\n        \"\"\"\n        Returns the list of required skills.\n        \"\"\"\n        return self.required_skills\n\n    def get_competencies(self):\n        \"\"\"\n        Returns the list of competencies.\n        \"\"\"\n        return self.competencies\n\n    def get_evaluation_criteria(self):\n        \"\"\"\n        Returns the list of evaluation criteria.\n        \"\"\"\n        return self.evaluation_criteria\n\n\nif __name__ == '__main__':\n    # Example usage:\n    job_description_text = \"\"\"\n    Job Title: Software Engineer\n\n    Responsibilities:\n    - Develop and maintain software applications\n    - Write clean and efficient code\n    - Collaborate with cross-functional teams\n\n    Required Skills:\n    - Python, Java, SQL\n    - Experience with Agile methodologies\n    - Knowledge of data structures and algorithms\n\n    Competencies:\n    - Problem-solving\n    - Communication\n    - Teamwork\n\n    Evaluation Criteria:\n    - Code quality\n    - Problem-solving skills\n    - Teamwork and collaboration\n    \"\"\"\n\n    parser = JobDescriptionParser(job_description_text)\n    parser.parse()\n\n    print(\"Required Skills:\", parser.get_required_skills())\n    print(\"Competencies:\", parser.get_competencies())\n    print(\"Evaluation Criteria:\", parser.get_evaluation_criteria())\n```\n"}
{"timestamp": "2026-05-27 17:34:29,841", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task1: ```python\nimport re\nimport pdfplumber\nimport docx\n\nclass ResumeParser:\n    def __init__(self, resume_path):\n        self.resume_path = resume_path\n        self.text = self.load_text()\n\n    def load_text(self):\n        \"\"\"Loads text from the resume based on the file type.\"\"\"\n        if self.resume_path.endswith('.pdf'):\n            return self.load_text_from_pdf()\n        elif self.resume_path.endswith('.docx'):\n            return self.load_text_from_docx()\n        elif self.resume_path.endswith('.txt'):\n            return self.load_text_from_txt()\n        else:\n            raise ValueError(\"Unsupported file format.  Only .pdf, .docx, and .txt files are supported.\")\n\n    def load_text_from_pdf(self):\n        \"\"\"Extracts text from a PDF file.\"\"\"\n        text = \"\"\n        try:\n            with pdfplumber.open(self.resume_path) as pdf:\n                for page in pdf.pages:\n                    text += page.extract_text() + \"\\n\"\n        except Exception as e:\n            print(f\"Error reading PDF: {e}\")\n            return \"\"\n        return text\n\n    def load_text_from_docx(self):\n        \"\"\"Extracts text from a DOCX file.\"\"\"\n        text = \"\"\n        try:\n            doc = docx.Document(self.resume_path)\n            for paragraph in doc.paragraphs:\n                text += paragraph.text + \"\\n\"\n        except Exception as e:\n            print(f\"Error reading DOCX: {e}\")\n            return \"\"\n        return text\n\n    def load_text_from_txt(self):\n        \"\"\"Extracts text from a TXT file.\"\"\"\n        try:\n            with open(self.resume_path, 'r', encoding='utf-8') as file:\n                text = file.read()\n            return text\n        except Exception as e:\n            print(f\"Error reading TXT file: {e}\")\n            return \"\"\n\n    def extract_skills(self, skills_list):\n        \"\"\"Extracts skills from the resume based on a provided list of skills.\"\"\"\n        extracted_skills = []\n        for skill in skills_list:\n            if re.search(r'\\b' + re.escape(skill) + r'\\b', self.text, re.IGNORECASE):\n                extracted_skills.append(skill)\n        return extracted_skills\n\n    def extract_experience(self):\n        \"\"\"Extracts experience details from the resume.\"\"\"\n        experience = []\n        # This is a basic example and may need refinement based on resume format\n        experience_matches = re.findall(r\"(?:(?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)\\s+\\d{4})\\s*[-–—]\\s*(?:(?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)\\s+\\d{4}|Present).*\\n(?:(?!\\n).*\\n)*\", self.text) # Adjusted regex\n\n        for match in experience_matches:\n            experience.append(match.strip())\n        return experience\n\n    def extract_projects(self):\n         \"\"\"Extracts project details from the resume.\"\"\"\n         projects = []\n         # This is a basic example and may need refinement based on resume format\n         project_matches = re.findall(r\"(Project|PROJECT)\\s*[:\\s]\\s*(.*?)(?:\\n|$)\", self.text, re.IGNORECASE | re.DOTALL)\n\n         for match in project_matches:\n             projects.append(match[1].strip())\n         return projects\n\n    def parse_resume(self, skills_list):\n        \"\"\"Parses the resume and returns a dictionary of extracted information.\"\"\"\n        skills = self.extract_skills(skills_list)\n        experience = self.extract_experience()\n        projects = self.extract_projects()\n\n        return {\n            \"skills\": skills,\n            \"experience\": experience,\n            \"projects\": projects\n        }\n\nif __name__ == '__main__':\n    # Example Usage (replace with your actual resume path and skills list)\n    resume_path = 'example_resume.pdf'  # Replace with your resume file\n    skills_list = ['Python', 'Java', 'Data Analysis', 'Machine Learning', 'SQL', 'Communication', 'Project Management'] # Replace with skills relevant to the job\n\n    try:\n        parser = ResumeParser(resume_path)\n        parsed_data = parser.parse_resume(skills_list)\n\n        print(\"Extracted Skills:\", parsed_data['skills'])\n        print(\"\\nExtracted Experience:\", parsed_data['experience'])\n        print(\"\\nExtracted Projects:\", parsed_data['projects'])\n\n    except FileNotFoundError:\n        print(f\"Error: Resume file not found at {resume_path}\")\n    except ValueError as e:\n        print(f\"Error: {e}\")\n    except Exception as e:\n        print(f\"An unexpected error occurred: {e}\")\n```"}
{"timestamp": "2026-05-27 17:34:29,841", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task2: ```python\nimport json\n\nclass InterviewQuestionGenerator:\n    def __init__(self, job_description_data, resume_data):\n        \"\"\"\n        Initializes the InterviewQuestionGenerator with job description data and resume data.\n\n        Args:\n            job_description_data (dict): A dictionary containing extracted information from the job description,\n                                         including required skills, competencies, and evaluation criteria.\n            resume_data (dict): A dictionary containing extracted information from the candidate's resume,\n                                 including skills, experience, and projects.\n        \"\"\"\n        self.job_description_data = job_description_data\n        self.resume_data = resume_data\n        self.questions = []\n\n    def generate_questions(self):\n        \"\"\"\n        Generates a list of tailored technical interview questions based on the job description and resume.\n        \"\"\"\n        self.questions = []\n        required_skills = self.job_description_data.get(\"required_skills\", [])\n        candidate_skills = self.resume_data.get(\"skills\", [])\n        candidate_experience = self.resume_data.get(\"experience\", [])\n        candidate_projects = self.resume_data.get(\"projects\", [])\n        competencies = self.job_description_data.get(\"competencies\", [])\n\n        # 1. Questions based on Required Skills from Job Description\n        for skill in required_skills:\n            question = f\"Can you describe your experience with {skill}?  Please provide specific examples.\"\n            self.questions.append(question)\n\n            # If the candidate claims the skill, ask a follow-up question\n            if skill in candidate_skills:\n                follow_up = f\"You mentioned experience with {skill} on your resume. Can you elaborate on a challenging project where you utilized {skill}?\"\n                self.questions.append(follow_up)\n            else:\n                 follow_up = f\"The job description requires {skill}.  If you don't have direct experience with it, how would you approach learning and applying it to this role?\"\n                 self.questions.append(follow_up)\n\n\n        # 2. Questions based on Candidate's Experience\n        if candidate_experience:\n            self.questions.append(\"Walk me through your previous roles and responsibilities, highlighting experiences relevant to this position.\")\n            for exp in candidate_experience:\n                question = f\"Tell me more about your experience at {exp[:50]}... What were your key accomplishments and challenges?\"  # Limit the length of experience string\n                self.questions.append(question)\n\n        # 3. Questions based on Candidate's Projects\n        if candidate_projects:\n            self.questions.append(\"Tell me about some of the projects you've worked on.\")\n            for project in candidate_projects:\n                question = f\"Describe your role and contributions to the project: {project[:50]}...\" # Limit the length of project string\n                self.questions.append(question)\n                question = f\"What were the key technologies used in {project[:50]}...?\" # Limit the length of project string\n                self.questions.append(question)\n                question = f\"What challenges did you face during {project[:50]}... and how did you overcome them?\" # Limit the length of project string\n                self.questions.append(question)\n\n        # 4. Questions based on Competencies\n        for competency in competencies:\n            question = f\"Describe a situation where you had to demonstrate {competency}. What was the outcome?\"\n            self.questions.append(question)\n\n        # 5. General Technical Questions (Example - can be expanded)\n        self.questions.append(\"Explain the difference between a stack and a queue.  Provide examples of when you would use each.\")\n        self.questions.append(\"What are the benefits of using version control systems like Git?\")\n        self.questions.append(\"Describe your approach to debugging code.\")\n\n\n    def get_questions(self):\n        \"\"\"\n        Returns the generated list of interview questions.\n\n        Returns:\n            list: A list of strings, where each string is an interview question.\n        \"\"\"\n        return self.questions\n\n    def save_questions_to_json(self, filename=\"interview_questions.json\"):\n        \"\"\"Saves the generated questions to a JSON file.\"\"\"\n        with open(filename, 'w') as f:\n            json.dump(self.questions, f, indent=4)\n        print(f\"Interview questions saved to {filename}\")\n\n\nif __name__ == '__main__':\n    # Example Usage (replace with your actual data)\n    job_description_data = {\n        \"required_skills\": [\"Python\", \"Java\", \"SQL\", \"Data Analysis\"],\n        \"competencies\": [\"Problem-solving\", \"Communication\", \"Teamwork\"],\n        \"evaluation_criteria\": [\"Code quality\", \"Problem-solving skills\", \"Teamwork and collaboration\"]\n    }\n\n    resume_data = {\n        \"skills\": [\"Python\", \"SQL\", \"Communication\", \"Project Management\"],\n        \"experience\": [\"Software Engineer at Example Corp (2020-Present)\", \"Data Analyst Intern at Another Corp (2019)\"],\n        \"projects\": [\"Data Analysis Project using Python\", \"Web Application Development using Java\"]\n    }\n\n    generator = InterviewQuestionGenerator(job_description_data, resume_data)\n    generator.generate_questions()\n    questions = generator.get_questions()\n\n    for i, question in enumerate(questions):\n        print(f\"Question {i+1}: {question}\")\n\n    generator.save_questions_to_json()\n```\n"}
{"timestamp": "2026-05-27 17:34:29,841", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task3: ```python\nimport smtplib\nfrom email.mime.multipart import MIMEMultipart\nfrom email.mime.text import MIMEText\nimport threading\nimport datetime\nimport time\n\nclass EmailAutomation:\n    def __init__(self, smtp_server, port, sender_email, sender_password):\n        \"\"\"\n        Initializes the EmailAutomation component.\n        \"\"\"\n        self.smtp_server = smtp_server\n        self.port = port\n        self.sender_email = sender_email\n        self.sender_password = sender_password\n        self.email_templates = {}\n        self.timers = []  # keep references to threading.Timer\n\n    def load_templates(self, template_name, subject, body):\n        \"\"\"\n        Loads an email template into memory.\n        \"\"\"\n        self.email_templates[template_name] = {\"subject\": subject, \"body\": body}\n\n    def create_email(self, template_name, recipient_email, replacements=None):\n        \"\"\"\n        Builds an email message from a named template.\n        \"\"\"\n        template = self.email_templates.get(template_name)\n        if not template:\n            raise ValueError(f\"Template '{template_name}' not found.\")\n\n        subject = template[\"subject\"]\n        body = template[\"body\"]\n        if replacements:\n            for key, val in replacements.items():\n                placeholder = \"{\" + key + \"}\"\n                subject = subject.replace(placeholder, str(val))\n                body = body.replace(placeholder, str(val))\n\n        msg = MIMEMultipart()\n        msg[\"From\"] = self.sender_email\n        msg[\"To\"] = recipient_email\n        msg[\"Subject\"] = subject\n        msg.attach(MIMEText(body, \"plain\"))\n        return msg\n\n    def send_email(self, message, recipient_email):\n        \"\"\"\n        Connects to SMTP server and sends a MIMEMultipart message.\n        \"\"\"\n        try:\n            server = smtplib.SMTP(self.smtp_server, self.port)\n            server.starttls()\n            server.login(self.sender_email, self.sender_password)\n            server.sendmail(self.sender_email, recipient_email, message.as_string())\n            server.quit()\n            print(f\"[{datetime.datetime.now()}] Email sent to {recipient_email} | Subject: {message['Subject']}\")\n        except Exception as e:\n            print(f\"Error sending email to {recipient_email}: {e}\")\n            raise\n\n    def schedule_one_off_email(self, template_name, recipient_email, send_datetime, replacements=None):\n        \"\"\"\n        Schedules a single‐send email at an exact datetime.\n\n        Args:\n            send_datetime (datetime.datetime): when to send\n        \"\"\"\n        now = datetime.datetime.now()\n        delay = (send_datetime - now).total_seconds()\n        if delay <= 0:\n            # send immediately if time is in the past\n            print(f\"Scheduled time {send_datetime} already passed; sending now.\")\n            msg = self.create_email(template_name, recipient_email, replacements)\n            self.send_email(msg, recipient_email)\n            return\n\n        def job():\n            msg = self.create_email(template_name, recipient_email, replacements)\n            self.send_email(msg, recipient_email)\n\n        timer = threading.Timer(delay, job)\n        timer.daemon = True\n        timer.start()\n        self.timers.append(timer)\n        print(f\"Email '{template_name}' scheduled to {recipient_email} at {send_datetime}\")\n\n    def cancel_all(self):\n        \"\"\"\n        Cancels all pending scheduled emails.\n        \"\"\"\n        for t in self.timers:\n            t.cancel()\n        self.timers.clear()\n        print(\"All scheduled emails have been canceled.\")\n\n# Example Usage\nif __name__ == \"__main__\":\n    # SMTP configuration (fill in your real credentials)\n    smtp_server = \"smtp.example.com\"\n    port = 587\n    sender_email = \"no-reply@example.com\"\n    sender_password = \"your_password\"\n\n    email_auto = EmailAutomation(smtp_server, port, sender_email, sender_password)\n\n    # Define templates\n    email_auto.load_templates(\n        \"interview_invite\",\n        \"Interview Invitation for {candidate_name}\",\n        \"Hello {candidate_name},\\n\\n\"\n        \"You are invited to interview on {date} at {time}.\\n\"\n        \"Please confirm your availability.\\n\\n\"\n        \"Best,\\nRecruitment Team\"\n    )\n    email_auto.load_templates(\n        \"interview_reminder\",\n        \"Reminder: Interview Today at {time}\",\n        \"Hi {candidate_name},\\n\\n\"\n        \"This is a reminder that your interview is today at {time}.\\n\\n\"\n        \"Cheers,\\nRecruitment Team\"\n    )\n    email_auto.load_templates(\n        \"thank_you\",\n        \"Thank You for Interviewing\",\n        \"Dear {candidate_name},\\n\\n\"\n        \"Thank you for your time today. We will be in touch soon.\\n\\n\"\n        \"Regards,\\nRecruitment Team\"\n    )\n\n    email_auto.load_templates(\n        \"rejection_email\",\n        \"Regarding your application\",\n        \"Dear {candidate_name},\\n\\n\"\n        \"Thank you for applying for {job_title} at our company. After careful consideration, we have decided to move forward with other candidates whose qualifications and experience more closely align with the requirements of this position.\\n\\n\"\n        \"We appreciate your interest in our company and wish you the best of luck in your job search.\\n\\n\"\n        \"Sincerely,\\nRecruitment Team\"\n    )\n\n    # Candidate details\n    candidate_name = \"John Doe\"\n    candidate_email = \"john.doe@example.com\"\n    interview_date = datetime.date.today() + datetime.timedelta(days=2)\n    interview_time = \"10:00\"\n    job_title = \"Software Engineer\"\n\n    # Schedule invite 2 days before at 09:00\n    send_dt_invite = datetime.datetime.combine(\n        interview_date - datetime.timedelta(days=2),\n        datetime.time(hour=9, minute=0)\n    )\n    email_auto.schedule_one_off_email(\n        \"interview_invite\",\n        candidate_email,\n        send_dt_invite,\n        {\"candidate_name\": candidate_name, \"date\": interview_date, \"time\": interview_time}\n    )\n\n    # Schedule reminder on interview day at 08:00\n    send_dt_reminder = datetime.datetime.combine(\n        interview_date,\n        datetime.time(hour=8, minute=0)\n    )\n    email_auto.schedule_one_off_email(\n        \"interview_reminder\",\n        candidate_email,\n        send_dt_reminder,\n        {\"candidate_name\": candidate_name, \"time\": interview_time}\n    )\n\n    # Schedule thank-you after interview at 14:00 on interview day\n    send_dt_thanks = datetime.datetime.combine(\n        interview_date,\n        datetime.time(hour=14, minute=0)\n    )\n    email_auto.schedule_one_off_email(\n        \"thank_you\",\n        candidate_email,\n        send_dt_thanks,\n        {\"candidate_name\": candidate_name}\n    )\n\n     # Schedule rejection email (example)\n    send_dt_rejection = datetime.datetime.combine(\n        interview_date + datetime.timedelta(days=7),  # Send a week after the interview\n        datetime.time(hour=16, minute=0) #4:00 PM\n    )\n    email_auto.schedule_one_off_email(\n        \"rejection_email\",\n        candidate_email,\n        send_dt_rejection,\n        {\"candidate_name\": candidate_name, \"job_title\": job_title}\n    )\n\n\n    # Keep the main thread alive while timers run\n    try:\n        while True:\n            time.sleep(1)\n    except KeyboardInterrupt:\n        email_auto.cancel_all()\n        print(\"Shutting down.\")\n```"}
{"timestamp": "2026-05-27 17:34:29,842", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task4: ```python\nimport json\nimport datetime\n\nclass InterviewEngine:\n    def __init__(self, question_generator, email_automation, scoring_algorithm=None):\n        \"\"\"\n        Initializes the InterviewEngine.\n\n        Args:\n            question_generator: An instance of InterviewQuestionGenerator.\n            email_automation: An instance of EmailAutomation.\n            scoring_algorithm: A scoring algorithm to evaluate candidate responses (optional).\n        \"\"\"\n        self.question_generator = question_generator\n        self.email_automation = email_automation\n        self.scoring_algorithm = scoring_algorithm\n        self.candidate_responses = {}\n        self.questions = [] # List to store the generated questions\n        self.candidate_name = None\n        self.candidate_email = None\n        self.job_title = None\n\n    def load_candidate_info(self, candidate_name, candidate_email, job_title):\n        \"\"\"\n        Loads candidate information.\n        \"\"\"\n        self.candidate_name = candidate_name\n        self.candidate_email = candidate_email\n        self.job_title = job_title\n\n    def generate_interview_questions(self):\n        \"\"\"\n        Generates interview questions using the question generator.\n        \"\"\"\n        self.question_generator.generate_questions()\n        self.questions = self.question_generator.get_questions()\n\n    def conduct_interview(self):\n        \"\"\"\n        Conducts the interactive technical interview.\n        Presents questions to the candidate and records their responses.\n        \"\"\"\n        if not self.questions:\n            print(\"No questions generated. Please call generate_interview_questions() first.\")\n            return\n\n        print(f\"Starting interview for {self.candidate_name} ({self.candidate_email})\")\n        self.candidate_responses[self.candidate_name] = {}  # Initialize responses\n\n        for i, question in enumerate(self.questions):\n            print(f\"\\nQuestion {i+1}: {question}\")\n            response = input(\"Your Answer: \")\n            self.candidate_responses[self.candidate_name][question] = response\n\n    def score_responses(self):\n         \"\"\"\n         Scores the candidate's responses if a scoring algorithm is provided.\n         \"\"\"\n         if self.scoring_algorithm:\n             print(\"Scoring responses...\")\n             scores = self.scoring_algorithm.evaluate_responses(self.candidate_responses[self.candidate_name])  # Assuming the scoring algorithm takes responses as input.  Modify as needed\n             print(f\"Scores for {self.candidate_name}: {scores}\")\n             return scores\n         else:\n             print(\"No scoring algorithm provided.\")\n             return None\n\n\n    def generate_evaluation_report(self, scores=None):\n        \"\"\"\n        Generates a final evaluation report based on the interview and scoring (if available).\n        \"\"\"\n        report = f\"Interview Evaluation Report for {self.candidate_name}\\n\"\n        report += f\"Candidate Email: {self.candidate_email}\\n\"\n        report += f\"Job Title: {self.job_title}\\n\\n\"\n        report += \"Candidate Responses:\\n\"\n        for question, response in self.candidate_responses[self.candidate_name].items():\n            report += f\"Question: {question}\\n\"\n            report += f\"Response: {response}\\n\\n\"\n\n        if scores:\n            report += \"\\nScoring Results:\\n\"\n            for criterion, score in scores.items(): # Assuming 'scores' is a dictionary with criterion and score. Modify as needed\n                report += f\"{criterion}: {score}\\n\"\n\n        report += \"\\nOverall Evaluation: [To be completed manually]\\n\"  # Add a placeholder for manual overall evaluation.\n\n        filename = f\"{self.candidate_name.replace(' ', '_')}_evaluation_report.txt\"\n        with open(filename, \"w\") as f:\n            f.write(report)\n        print(f\"Evaluation report saved to {filename}\")\n\n    def send_email_notification(self, template_name, replacements=None):\n        \"\"\"\n        Sends an email notification to the candidate using the email automation component.\n        \"\"\"\n        if not self.candidate_email:\n            print(\"Candidate email not loaded. Please call load_candidate_info() first.\")\n            return\n\n        try:\n            self.email_automation.schedule_one_off_email(\n                template_name,\n                self.candidate_email,\n                datetime.datetime.now() + datetime.timedelta(minutes=5), #send after 5 minutes\n                replacements\n            )\n            print(f\"Email '{template_name}' scheduled for {self.candidate_name} ({self.candidate_email})\")\n        except ValueError as e:\n            print(f\"Error sending email: {e}\")\n\n\nif __name__ == '__main__':\n    # Mock Question Generator (replace with your actual InterviewQuestionGenerator)\n    class MockQuestionGenerator:\n        def __init__(self, job_description_data, resume_data):\n            pass\n        def generate_questions(self):\n            self.questions = [\"What is your experience with Python?\", \"Explain the concept of inheritance.\"]\n        def get_questions(self):\n            return self.questions\n\n    # Mock Email Automation (replace with your actual EmailAutomation)\n    class MockEmailAutomation:\n        def __init__(self, smtp_server, port, sender_email, sender_password):\n            pass\n        def load_templates(self, template_name, subject, body):\n            pass\n        def schedule_one_off_email(self, template_name, recipient_email, send_datetime, replacements=None):\n            print(f\"Mock Email sent to {recipient_email} using template {template_name}\")\n\n    # Mock Scoring Algorithm\n    class MockScoringAlgorithm:\n        def evaluate_responses(self, responses):\n            scores = {}\n            for question, answer in responses.items():\n                if \"Python\" in question and \"Python\" in answer:\n                    scores[\"Python Experience\"] = 5\n                else:\n                    scores[\"Python Experience\"] = 3\n            return scores\n\n\n    # Instantiate the mock classes\n    question_generator = MockQuestionGenerator({}, {})\n    email_automation = MockEmailAutomation(\"\",\"\", \"\", \"\")\n    scoring_algorithm = MockScoringAlgorithm()\n\n    # Instantiate the InterviewEngine\n    interview_engine = InterviewEngine(question_generator, email_automation, scoring_algorithm)\n\n    # Load candidate information\n    interview_engine.load_candidate_info(\"Jane Smith\", \"jane.smith@example.com\", \"Software Engineer\")\n\n    # Generate interview questions\n    interview_engine.generate_interview_questions()\n\n    # Conduct the interview\n    interview_engine.conduct_interview()\n\n    #Score responses\n    scores = interview_engine.score_responses()\n\n    # Generate the evaluation report\n    interview_engine.generate_evaluation_report(scores)\n\n    # Send email notification (e.g., thank you email)\n    email_automation.load_templates(\n        \"thank_you\",\n        \"Thank You for Interviewing\",\n        \"Dear {candidate_name},\\n\\n\"\n        \"Thank you for your time today. We will be in touch soon.\\n\\n\"\n        \"Regards,\\nRecruitment Team\"\n    )\n\n    interview_engine.send_email_notification(\"thank_you\", {\"candidate_name\": \"Jane Smith\"})\n```"}
{"timestamp": "2026-05-27 17:34:29,842", "level": "INFO", "logger": "flow.execution", "module": "flow", "function": "run_async", "line": 205, "message": " - task5: ```python\nimport re\nfrom typing import Dict, Any, List\n\nclass ScoringAlgorithm:\n    def __init__(self, job_description_data: Dict[str, Any]):\n        \"\"\"\n        Initializes with a config format:\n        {\n          \"evaluation_criteria\": {\n            \"Code quality\": {\n              \"keywords\": {\"comments\":1.0, \"error handling\":1.0, \"tests\":0.5},\n              \"max_score\":5\n            },\n            ...\n          }\n        }\n        \"\"\"\n        self.criteria_config = job_description_data.get(\"evaluation_criteria\", {})\n\n    def evaluate_responses(self, candidate_responses: Dict[str, str]) -> Dict[str, Any]:\n        \"\"\"\n        Returns a dict:\n        {\n          \"Code quality\": {\"raw_score\": 2.5, \"normalized_score\": 3},\n          ...\n        }\n        \"\"\"\n        results = {}\n        for criterion, config in self.criteria_config.items():\n            raw = self._compute_raw_score(config, candidate_responses)\n            norm = self._normalize_score(raw, config)\n            results[criterion] = {\n                \"raw_score\": round(raw, 2),\n                \"normalized_score\": min(max(round(norm), 0), config.get(\"max_score\", 5))\n            }\n        return results\n\n    def _compute_raw_score(self, config: Dict[str, Any], responses: Dict[str, str]) -> float:\n        keywords: Dict[str, float] = config.get(\"keywords\", {})\n        total = 0.0\n        for answer in responses.values():\n            text = answer.lower()\n            for kw, weight in keywords.items():\n                # count whole-word occurrences\n                count = len(re.findall(r'\\b' + re.escape(kw.lower()) + r'\\b', text))\n                total += count * weight\n        return total\n\n    def _normalize_score(self, raw: float, config: Dict[str, Any]) -> float:\n        max_score = config.get(\"max_score\", 5)\n        keywords: Dict[str, float] = config.get(\"keywords\", {})\n        # assume one mention per keyword is the max\n        max_raw = sum(keywords.values())\n        if max_raw <= 0:\n            return 0.0\n        return (raw / max_raw) * max_score\n\n\nclass WorkflowPlanner:\n    def __init__(self,\n                 job_description_data: Dict[str, Any],\n                 resume_data: Dict[str, Any],\n                 email_automation,\n                 question_generator,\n                 scoring_algorithm: ScoringAlgorithm):\n        self.job_description_data = job_description_data\n        self.resume_data = resume_data\n        self.email_automation = email_automation\n        self.question_generator = question_generator\n        self.scoring_algorithm = scoring_algorithm\n\n    def execute_workflow(self, candidate_name: str, candidate_email: str, job_title: str) -> List[str]:\n        steps = []\n\n        # 1. Analyze Job Description and Resume\n        steps.append(\"Step 1: Analyzing the job description and candidate resume.\")\n\n        # 2. Generate Interview Questions\n        steps.append(\"Step 2: Generating tailored technical interview questions.\")\n        self.question_generator.generate_questions()\n        questions = self.question_generator.get_questions()\n        steps.append(f\"Generated questions: {questions}\")\n\n        # 3. Conduct Technical Interview\n        steps.append(\"Step 3: Conducting the technical interview.\")\n        class MockInterviewEngine:\n            def __init__(self, questions):\n                self.questions = questions\n                self.candidate_responses = {}\n\n            def conduct_interview(self):\n                for q in self.questions:\n                    # In real scenario, collect live input\n                    if \"Python\" in q:\n                        ans = \"I have extensive experience with Python and wrote unit tests.\"\n                    else:\n                        ans = \"I use a structured approach: analysis, steps, edge case consideration.\"\n                    self.candidate_responses[q] = ans\n\n            def get_responses(self):\n                return self.candidate_responses\n\n        interview_engine = MockInterviewEngine(questions)\n        interview_engine.conduct_interview()\n        candidate_responses = interview_engine.get_responses()\n        steps.append(f\"Candidate responses: {candidate_responses}\")\n\n        # 4. Score Candidate Responses\n        steps.append(\"Step 4: Scoring candidate responses.\")\n        scores = self.scoring_algorithm.evaluate_responses(candidate_responses)\n        steps.append(f\"Candidate scores: {scores}\")\n\n        # 5. Generate Evaluation Report\n        steps.append(\"Step 5: Generating the final evaluation report.\")\n        report = self.generate_evaluation_report(candidate_name, candidate_email,\n                                                 job_title, candidate_responses, scores)\n        steps.append(f\"Evaluation report:\\n{report}\")\n        self.save_report_to_file(candidate_name, report)\n\n        # 6. Send Email Notifications\n        steps.append(\"Step 6: Sending email notifications.\")\n        self.send_email_notification(candidate_email, \"thank_you_email\")\n\n        return steps\n\n    def generate_evaluation_report(self, name, email, title, responses, scores) -> str:\n        report = f\"Interview Evaluation Report for {name}\\n\"\n        report += f\"Candidate Email: {email}\\nJob Title: {title}\\n\\n\"\n        report += \"Responses:\\n\"\n        for q, a in responses.items():\n            report += f\"- Q: {q}\\n  A: {a}\\n\"\n        report += \"\\nScores:\\n\"\n        for crit, vals in scores.items():\n            report += f\"- {crit}: raw={vals['raw_score']} norm={vals['normalized_score']}\\n\"\n        report += \"\\nOverall Evaluation: [To be completed]\\n\"\n        return report\n\n    def save_report_to_file(self, name: str, report: str):\n        fn = f\"{name.replace(' ', '_')}_evaluation_report.txt\"\n        with open(fn, \"w\") as f:\n            f.write(report)\n\n    def send_email_notification(self, recipient: str, template: str):\n        self.email_automation.send_email(recipient, f\"Subject: {template}\", \"Thank you for your time.\")\n\n\nif __name__ == '__main__':\n    # Example config with criteria\n    job_description_data = {\n        \"evaluation_criteria\": {\n            \"Code quality\": {\n                \"keywords\": {\"comments\":1.0, \"error handling\":1.0, \"tests\":0.5},\n                \"max_score\": 5\n            },\n            \"Problem-solving\": {\n                \"keywords\": {\"analysis\":1.0, \"steps\":1.0, \"edge case\":0.5},\n                \"max_score\": 5\n            },\n            \"Teamwork\": {\n                \"keywords\": {\"communication\":1.0, \"conflict resolution\":1.0, \"peer review\":0.5},\n                \"max_score\": 5\n            }\n        }\n    }\n    resume_data = {\"skills\": [\"Python\", \"SQL\"]}\n    \n    class MockEmailAutomation:\n        def send_email(self, recipient, subject, body):\n            print(f\"Email to {recipient}: {subject}\\n{body}\")\n\n    class MockQuestionGenerator:\n        def __init__(self, jd, res):\n            self.questions = []\n        def generate_questions(self):\n            self.questions = [\"What is your experience with Python?\",\n                              \"How do you handle error handling in your code?\",\n                              \"Describe your approach to solving a challenging problem.\"]\n        def get_questions(self):\n            return self.questions\n\n    email_automation = MockEmailAutomation()\n    question_generator = MockQuestionGenerator(job_description_data, resume_data)\n    scoring_algorithm = ScoringAlgorithm(job_description_data)\n    planner = WorkflowPlanner(job_description_data, resume_data,\n                              email_automation, question_generator, scoring_algorithm)\n\n    steps = planner.execute_workflow(\"John Doe\", \"john.doe@example.com\", \"Software Engineer\")\n    with open(\"workflow_steps.txt\", \"w\") as f:\n        for s in steps:\n            f.write(s + \"\\n\")\n    print(\"Workflow steps and report generated.\")\n```"}
