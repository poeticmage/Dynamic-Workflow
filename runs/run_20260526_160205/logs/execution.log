ation reports.\"\n    ]\n  },\n  \"skills\": {\n    \"technical\": [\n      \"AI Interview Platforms\",\n      \"Resume Parsing\",\n      \"Data Analysis\"\n    ],\n    \"soft\": [\n      \"Communication\",\n      \"Analytical Skills\",\n      \"Evaluation\",\n      \"Report Writing\"\n    ]\n  },\n  \"experience\": {\n    \"minimum_years\": 2,\n    \"relevant_fields\": [\n      \"Recruiting\",\n      \"Human Resources\",\n      \"Artificial Intelligence\"\n    ]\n  },\n  \"education\": {\n    \"degree\": [\n      \"Bachelor’s\"\n    ],\n    \"major\": [\n      \"Human Resources\",\n      \"Computer Science\",\n      \"Related Field\"\n    ]\n  },\n  \"certifications\": [],\n  \"industry_experience\": [\n    \"Recruiting\",\n    \"Artificial Intelligence\"\n  ],\n  \"travel_requirements\": {\n    \"required\": false,\n    \"frequency\": \"\"\n  },\n  \"relocation_assistance\": false,\n  \"benefits\": [],\n  \"perks\": [],\n  \"contact_information\": {\n    \"recruiter_name\": \"\",\n    \"email\": \"\",\n    \"phone\": \"\"\n  }\n}\n```"}
