    \\\"phone\\\": \\\"\\\",\\n      \\\"linkedin\\\": \\\"\\\",\\n      \\\"location\\\": \\\"\\\"\\n    },\\n    \\\"summary\\\": \\\"\\\",\\n    \\\"skills\\\": [],\\n    \\\"experience\\\": [],\\n    \\\"education\\\": [],\\n    \\\"projects\\\": [],\\n    \\\"certifications\\\": [],\\n    \\\"awards\\\": [],\\n    \\\"volunteer_experience\\\": [],\\n    \\\"publications\\\": [],\\n    \\\"languages\\\": [],\\n    \\\"interests\\\": [],\\n    \\\"references\\\": []\\n  }\\n}\\n```\\nTask task6:\\n  Objective: Develop email template generator for interview invitations and follow-up communications\\n  Result: ```python\\ndef generate_interview_invitation_email(candidate_name, interview_date, interview_time, interviewer_name, meeting_link, job_title, company_name):\\n    \\\"\\\"\\\"\\n    Generates an email invitation for an interview.\\n\\n    Args:\\n        candidate_name (str): The name of the candidate.\\n        interview_date (str): The date of the interview (e.g., \\\"October 26, 2023\\\").\\n        interview_time (str): The time of the interview (e.g., \\\"10:00 AM PST\\\").\\n        interviewer_name (str): The name of the interviewer.\\n        meeting_link (str): The link to the online meeting.\\n        job_title (str): The title of the job the candidate is interviewing for.\\n        company_name (str): The name of the company.\\n\\n    Returns:\\n        str: The generated email invitation.\\n    \\\"\\\"\\\"\\n\\n    subject = f\\\"Interview Invitation: {job_title} at {company_name}\\\"\\n    body = f\\\"\\\"\\\"\\nDear {candidate_name},\\n\\nWe are pleased to invite you to interview for the {job_title} position at {company_name}.\\n\\nYour interview is scheduled for:\\n\\nDate: {interview_date}\\nTime: {interview_time}\\nInterviewer: {interviewer_name}\\nMeeting Link: {meeting_link}\\n\\nPlease join the meeting at the scheduled time by clicking on the link above.\\n\\nWe look forward to speaking with you!\\n\\nSincerely,\\n\\nThe {company_name} Recruiting Team\\n\\\"\\\"\\\"\\n    return subject, body\\n\\n\\ndef generate_interview_followup_email(candidate_name, interviewer_name, job_title, company_name):\\n    \\\"\\\"\\\"\\n    Generates a follow-up email after an interview.\\n\\n    Args:\\n        candidate_name (str): The name of the candidate.\\n        interviewer_name (str): The name of the interviewer.\\n        job_title (str): The title of the job the candidate interviewed for.\\n        company_name (str): The name of the company.\\n\\n    Returns:\\n        str: The generated follow-up email.\\n    \\\"\\\"\\\"\\n\\n    subject = f\\\"Thank you for interviewing with {company_name}\\\"\\n    body = f\\\"\\\"\\\"\\nDear {candidate_name},\\n\\nThank you for taking the time to interview with {interviewer_name} for the {job_title} position at {company_name}.\\n\\nWe appreciate you sharing your experience and qualifications with us.\\n\\nWe are currently reviewing all candidates and will be in touch with you regarding the next steps in the hiring process.\\n\\nThank you again for your interest in {company_name}.\\n\\nSincerely,\\n\\nThe {company_name} Recruiting Team\\n\\\"\\\"\\\"\\n    return subject, body\\n\\n\\ndef generate_rejection_email(candidate_name, job_title, company_name):\\n    \\\"\\\"\\\"\\n    Generates a rejection email after an interview.\\n\\n    Args:\\n        candidate_name (str): The name of the candidate.\\n        job_title (str): The title of the job the candidate interviewed for.\\n        company_name (str): The name of the company.\\n\\n    Returns:\\n        str: The generated rejection email.\\n    \\\"\\\"\\\"\\n\\n    subject = f\\\"Update on your application for {job_title} at {company_name}\\\"\\n    body = f\\\"\\\"\\\"\\nDear {candidate_name},\\n\\nThank you for your interest in the {job_title} position at {company_name}. We appreciate you taking the time to interview with our team.\\n\\nAfter careful consideration, we have decided to move forward with other candidates whose qualifications and experience more closely align with the requirements of this role.\\n\\nThis was a difficult decision, as we were impressed with many aspects of your background. We encourage you to apply for other positions at {company_name} that may be a good fit for your skills and experience.\\n\\nWe wish you the best of luck in your job search.\\n\\nSincerely,\\n\\nThe {company_name} Recruiting Team\\n\\\"\\\"\\\"\\n    return subject, body\\n\\n\\ndef generate_offer_email(candidate_name, job_title, company_name, salary, start_date, benefits_summary):\\n    \\\"\\\"\\\"\\n    Generates an offer email for a candidate.\\n\\n    Args:\\n        candidate_name (str): The name of the candidate.\\n        job_title (str): The title of the job being offered.\\n        company_name (str): The name of the company.\\n        salary (str): The salary being offered (e.g., \\\"$100,000 per year\\\").\\n        start_date (str): The start date of the job (e.g., \\\"November 1, 2023\\\").\\n        benefits_summary (str): A brief summary of the benefits offered.\\n\\n    Returns:\\n        str: The generated offer email.\\n    \\\"\\\"\\\"\\n\\n    subject = f\\\"Job Offer: {job_title} at {company_name}\\\"\\n    body = f\\\"\\\"\\\"\\nDear {candidate_name},\\n\\nWe are delighted to offer you the position of {job_title} at {company_name}!\\n\\nWe were very impressed with your qualifications and experience during the interview process, and we believe you would be a valuable asset to our team.\\n\\nHere are the details of our offer:\\n\\nJob Title: {job_title}\\nSalary: {salary}\\nStart Date: {start_date}\\nBenefits: {benefits_summary}\\n\\nWe have attached a formal offer letter with more details about the position and benefits. Please review it carefully and let us know if you have any questions.\\n\\nWe are excited about the possibility of you joining our team! Please let us know your decision by [Date].\\n\\nSincerely,\\n\\nThe {company_name} Recruiting Team\\n\\\"\\\"\\\"\\n    return subject, body\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task4:\\n  Objective: Build answer evaluation module to assess relevance, depth, confidence, and technical accuracy of responses\\n\\n---\\n# **Current Task Requirements**\\nImplement AI-based dynamic interview engine that generates technical and behavioral questions and follow-ups\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport json\\nimport random\\n\\nclass InterviewEngine:\\n    def __init__(self, job_description_json, candidate_profile_json):\\n        \\\"\\\"\\\"\\n        Initializes the InterviewEngine with job description and candidate profile.\\n\\n        Args:\\n            job_description_json (dict): Parsed job description in JSON format.\\n            candidate_profile_json (dict): Parsed candidate resume in JSON format.\\n        \\\"\\\"\\\"\\n        self.job_description = job_description_json\\n        self.candidate_profile = candidate_profile_json\\n        self.technical_questions = self.load_questions(\\\"technical\\\")\\n        self.behavioral_questions = self.load_questions(\\\"behavioral\\\")\\n        self.follow_up_questions = self.load_questions(\\\"follow_up\\\") # Load follow-up questions\\n\\n    def load_questions(self, question_type=\\\"technical\\\"):\\n          \\\"\\\"\\\"\\n          Loads questions from JSON files based on question type.\\n\\n          Args:\\n              question_type (str): Type of questions to load (\\\"technical\\\", \\\"behavioral\\\", \\\"follow_up\\\").\\n\\n          Returns:\\n              list: A list of dictionaries, each representing a question.\\n          \\\"\\\"\\\"\\n          try:\\n              with open(f\\\"questions_{question_type}.json\\\", \\\"r\\\") as f:\\n                  questions = json.load(f)\\n              return questions\\n          except FileNotFoundError:\\n              print(f\\\"Error: questions_{question_type}.json not found.  Returning empty list.\\\")\\n              return []\\n\\n    def generate_initial_question(self, question_type=\\\"technical\\\"):\\n        \\\"\\\"\\\"\\n        Generates an initial technical or behavioral question.\\n\\n        Args:\\n            question_type (str): \\\"technical\\\" or \\\"behavioral\\\".\\n\\n        Returns:\\n            dict: A question dictionary.\\n        \\\"\\\"\\\"\\n        if question_type == \\\"technical\\\":\\n            questions = self.technical_questions\\n        elif question_type == \\\"behavioral\\\":\\n            questions = self.behavioral_questions\\n        else:\\n            raise ValueError(\\\"Invalid question type.  Must be 'technical' or 'behavioral'.\\\")\\n\\n        if not questions:\\n            return {\\\"question\\\": \\\"No questions available for this type.\\\"}\\n\\n        return random.choice(questions)\\n\\n    def generate_follow_up_question(self, candidate_answer):\\n        \\\"\\\"\\\"\\n        Generates a follow-up question based on the candidate's answer.  This is a simplified\\n        implementation that randomly selects a follow-up question.  A more sophisticated\\n        implementation would analyze the candidate's answer and select a follow-up question\\n        that is relevant to the answer.\\n\\n        Args:\\n            candidate_answer (str): The candidate's answer to the previous question.\\n\\n        Returns:\\n            dict: A follow-up question dictionary.\\n        \\\"\\\"\\\"\\n        if not self.follow_up_questions:\\n            return {\\\"question\\\": \\\"No follow-up questions available.\\\"}\\n\\n        return random.choice(self.follow_up_questions)\\n\\n    def conduct_interview(self, num_technical_questions=3, num_behavioral_questions=2):\\n        \\\"\\\"\\\"\\n        Conducts a dynamic interview with technical and behavioral questions.\\n\\n        Args:\\n            num_technical_questions (int): Number of technical questions to ask.\\n            num_behavioral_questions (int): Number of behavioral questions to ask.\\n\\n        Returns:\\n            list: A list of dictionaries, each containing a question, the candidate's answer, and any follow-up questions/answers.\\n        \\\"\\\"\\\"\\n        interview_transcript = []\\n\\n        # Technical Questions\\n        for _ in range(num_technical_questions):\\n            question_data = self.generate_initial_question(question_type=\\\"technical\\\")\\n            question = question_data[\\\"question\\\"]\\n            print(f\\\"Technical Question: {question}\\\")\\n            candidate_answer = input(\\\"Your Answer: \\\")  # Simulate candidate answering\\n            interview_transcript.append({\\\"question\\\": question, \\\"answer\\\": candidate_answer, \\\"follow_ups\\\": []})\\n\\n            # Generate and ask a follow-up question\\n            follow_up_data = self.generate_follow_up_question(candidate_answer)\\n            follow_up_question = follow_up_data[\\\"question\\\"]\\n            print(f\\\"Follow-up: {follow_up_question}\\\")\\n            follow_up_answer = input(\\\"Your Answer: \\\") # Simulate candidate answering\\n            interview_transcript[-1][\\\"follow_ups\\\"].append({\\\"question\\\": follow_up_question, \\\"answer\\\": follow_up_answer})\\n\\n\\n        # Behavioral Questions\\n        for _ in range(num_behavioral_questions):\\n            question_data = self.generate_initial_question(question_type=\\\"behavioral\\\")\\n            question = question_data[\\\"question\\\"]\\n            print(f\\\"Behavioral Question: {question}\\\")\\n            candidate_answer = input(\\\"Your Answer: \\\")  # Simulate candidate answering\\n            interview_transcript.append({\\\"question\\\": question, \\\"answer\\\": candidate_answer, \\\"follow_ups\\\": []})\\n\\n            # Generate and ask a follow-up question\\n            follow_up_data = self.generate_follow_up_question(candidate_answer)\\n            follow_up_question = follow_up_data[\\\"question\\\"]\\n            print(f\\\"Follow-up: {follow_up_question}\\\")\\n            follow_up_answer = input(\\\"Your Answer: \\\") # Simulate candidate answering\\n            interview_transcript[-1][\\\"follow_ups\\\"].append({\\\"question\\\": follow_up_question, \\\"answer\\\": follow_up_answer})\\n\\n\\n        return interview_transcript\\n\\nif __name__ == '__main__':\\n    # Sample Usage (replace with actual JSON data)\\n    job_description_data = {\\n      \\\"job_title\\\": \\\"Software Engineer\\\",\\n      \\\"skills\\\": {\\n        \\\"technical\\\": [\\\"Python\\\", \\\"Data Analysis\\\"]\\n      }\\n    }\\n    candidate_profile_data = {\\n      \\\"candidate_profile\\\": {\\n        \\\"skills\\\": [\\\"Python\\\", \\\"Machine Learning\\\"]\\n      }\\n    }\\n\\n    # Create dummy question files\\n    with open(\\\"questions_technical.json\\\", \\\"w\\\") as f:\\n        json.dump([{\\\"question\\\": \\\"Explain the difference between lists and tuples in Python.\\\"}, {\\\"question\\\": \\\"What is the time complexity of a dictionary lookup?\\\"}], f)\\n    with open(\\\"questions_behavioral.json\\\", \\\"w\\\") as f:\\n        json.dump([{\\\"question\\\": \\\"Tell me about a time you failed.\\\"}, {\\\"question\\\": \\\"Describe a time you had to work with a difficult team member.\\\"}], f)\\n    with open(\\\"questions_follow_up.json\\\", \\\"w\\\") as f:\\n        json.dump([{\\\"question\\\": \\\"Can you elaborate on that?\\\"}, {\\\"question\\\": \\\"What were the key takeaways?\\\"}], f)\\n\\n\\n\\n    engine = InterviewEngine(job_description_data, candidate_profile_data)\\n    interview_transcript = engine.conduct_interview()\\n\\n    print(\\\"\\\\nInterview Transcript:\\\")\\n    print(json.dumps(interview_transcript, indent=4))\\n```\",\n  \"timestamp\": \"2026-05-26T16:03:41.094569\"\n}"}
