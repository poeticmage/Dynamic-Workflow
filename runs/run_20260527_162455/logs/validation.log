 words = text.split()\\n        return words\\n\\n    def score_response(self, response):\\n        \\\"\\\"\\\"\\n        Scores a candidate's response against expected keywords.\\n\\n        Args:\\n            response (str): The candidate's response.\\n\\n        Returns:\\n            int: The score for the response (0-10).\\n        \\\"\\\"\\\"\\n        words = self.preprocess(response)\\n        word_counts = Counter(words)\\n\\n        # Sum up weights for matched keywords\\n        raw_score = 0\\n        for kw in self.expected_keywords:\\n            if word_counts.get(kw, 0) > 0:\\n                raw_score += self.keyword_weights.get(kw, 1)\\n\\n        # Normalize: maximum possible raw score is the sum of all weights\\n        max_raw = sum(self.keyword_weights.values()) or 1\\n        normalized = (raw_score / max_raw) * 10\\n\\n        # Cap and round\\n        final_score = min(10, round(normalized))\\n        return final_score\\n\\nif __name__ == '__main__':\\n    # Example Usage\\n    expected_keywords = [\\\"mutable\\\", \\\"immutable\\\", \\\"faster\\\", \\\"list\\\", \\\"tuple\\\"]\\n    weights = {\\\"mutable\\\": 2, \\\"immutable\\\": 2, \\\"faster\\\": 1, \\\"list\\\": 1, \\\"tuple\\\": 1}\\n\\n    scorer = ScoringAlgorithm(expected_keywords=expected_keywords,\\n                              keyword_weights=weights)\\n\\n    response1 = \\\"Lists are mutable, while tuples are immutable. Tuples are also faster.\\\"\\n    print(\\\"Score1:\\\", scorer.score_response(response1))  # Should be 10\\n\\n    response2 = \\\"Lists are mutable but I don't know about speed differences.\\\"\\n    print(\\\"Score2:\\\", scorer.score_response(response2))  # Partial score\\n\\n    response3 = \\\"Tuples are immutable.\\\"\\n    print(\\\"Score3:\\\", scorer.score_response(response3))  # Lower score\\n```\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"# **The Overall Goal**\\nYou are a workflow planning agent.\\nYour task is to:\\n-\\\