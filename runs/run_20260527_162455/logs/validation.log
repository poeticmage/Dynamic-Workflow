lls_and_experience(resume_text):\\n    \\\"\\\"\\\"\\n    Extracts skills and experience from a resume text.\\n\\n    Args:\\n        resume_text: The text content of the resume.\\n\\n    Returns:\\n        A dictionary containing lists of skills and experience entries.\\n    \\\"\\\"\\\"\\n\\n    skills = extract_skills(resume_text)\\n    experience = extract_experience(resume_text)\\n\\n    return {\\n        \\\"skills\\\": skills,\\n        \\\"experience\\\": experience\\n    }\\n\\ndef extract_skills(resume_text):\\n    \\\"\\\"\\\"\\n    Extracts skills from the resume text using regex.\\n\\n    Args:\\n        resume_text: The text content of the resume.\\n\\n    Returns:\\n        A list of skills.\\n    \\\"\\\"\\\"\\n\\n    # Define common skill keywords and patterns\\n    skill_patterns = [\\n        r\\\"(Python|Java|C++|JavaScript|SQL|HTML|CSS|React|Angular|Node\\\\.js)\\\",\\n        r\\\"(Data Science|Machine Learning|Deep Learning|Natural Language Processing)\\\",\\n        r\\\"(Cloud Computing|AWS|Azure|GCP)\\\",\\n        r\\\"(Project Management|Agile|Scrum)\\\",\\n        r\\\"(Communication|Leadership|Teamwork)\\\"\\n    ]\\n\\n    skills = []\\n    for pattern in skill_patterns:\\n        matches = re.findall(pattern, resume_text, re.IGNORECASE)\\n        skills.extend(matches)\\n    \\n    # Remove duplicates while preserving order\\n    unique_skills = []\\n    [unique_skills.append(x) for x in skills if x not in unique_skills]\\n\\n    return unique_skills\\n\\ndef extract_experience(resume_text):\\n    \\\"\\\"\\\"\\n    Extracts experience entries from the resume text using regex.\\n\\n    Args:\\n        resume_text: The text content of the resume.\\n\\n    Returns:\\n        A list of experience entries.\\n    \\\"\\\"\\\"\\n    # Define pattern for experience sections\\n    experience_pattern = r\\\"(?i)(?:Experience|Employment History)([\\\\s\\\\S]*?)(?:Education|Skills|References|$)\\\"\\n\\n    match = re.search(experience_pattern, resume_text)\\n    if match:\\n      experience_section = match.group(1)\\n\\n      #Split experience section into individual entries based on common separators like dates or job titles\\n      experience_entries = re.split(r\\\"\\\\d{4}[-–—]\\\\d{4}|\\\\d{4}\\\\s*-\\\\s*(Present|Current)|\\\\b(?:[A-Z][a-z]+\\\\s)+[A-Z][a-z]+(?:,\\\\s(?:[A-Z][a-z]+))?\\\\b\\\", experience_section)\\n      \\n      #Clean up the entries by removing whitespace and empty strings\\n      experience_entries = [entry.strip() for entry in experience_entries if entry.strip()]\\n\\n      return experience_entries\\n\\n    return []\\n\\n\\n\\nif __name__ == '__main__':\\n    # Example usage:\\n    resume_text = \\\"\\\"\\\"\\n    John Doe\\n    john.doe@example.com\\n    (123) 456-7890\\n\\n    Summary\\n    A highly motivated and experienced software engineer with a passion for developing innovative solutions.\\n\\n    Experience\\n    Software Engineer, Acme Corp, 2018-2022\\n    - Developed and maintained web applications using Python, JavaScript, and React.\\n    - Designed and implemented REST APIs using Node.js.\\n    - Worked with databases such as SQL and MongoDB.\\n\\n    Senior Software Engineer, Beta Inc, 2022-Present\\n    - Led a team of engineers in the development of a new mobile application.\\n    - Utilized cloud computing platforms such as AWS and Azure.\\n    - Implemented machine learning algorithms for data analysis.\\n\\n    Education\\n    Bachelor of Science in Computer Science, University of Example, 2018\\n\\n    Skills\\n    Python, Java, JavaScript, SQL, HTML, CSS, React, Node.js, Data Science, Machine Learning, Cloud Computing, AWS, Azure, Project Management, Agile, Scrum, Communication, Leadership, Teamwork\\n\\n    References\\n    Available upon request.\\n    \\\"\\\"\\\"\\n\\n    extracted_data = extract_skills_and_experience(resume_text)\\n    print(\\\"Extracted Skills:\\\", extracted_data['skills'])\\n    print(\\\"Extracted Experience:\\\", extracted_data['experience'])\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task6:\\n  Objective: Generate the final evaluation report in Python by aggregating candidate profile and interview scores\\n\\n---\\n# **Current Task Requirements**\\nImplement Python code to match extracted resume data against job requirements and build a candidate profile\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\ndef create_candidate_profile(job_description, resume_data):\\n    \\\"\\\"\\\"\\n    Matches extracted resume data against job requirements and builds a candidate profile.\\n\\n    Args:\\n        job_description: A string containing the job description.\\n        resume_data: A dictionary containing extracted resume data (skills and experience).\\n\\n    Returns:\\n        A dictionary representing the candidate profile, including:\\n            - skills_match: A list of skills from the resume that match the job description.\\n            - experience_match: A list of experience entries from the resume that align with the job description.\\n            - overall_fit: A score (0-100) indicating the overall fit of the candidate for the job.\\n    \\\"\\\"\\\"\\n\\n    skills_match = find_matching_skills(job_description, resume_data['skills'])\\n    experience_match = find_matching_experience(job_description, resume_data['experience'])\\n    overall_fit = calculate_overall_fit(job_description, resume_data)\\n\\n    candidate_profile = {\\n        \\\"skills_match\\\": skills_match,\\n        \\\"experience_match\\\": experience_match,\\n        \\\"overall_fit\\\": overall_fit\\n    }\\n\\n    return candidate_profile\\n\\ndef find_matching_skills(job_description, resume_skills):\\n    \\\"\\\"\\\"\\n    Identifies skills from the resume that match the job description.\\n\\n    Args:\\n        job_description: A string containing the job description.\\n        resume_skills: A list of skills extracted from the resume.\\n\\n    Returns:\\n        A list of skills from the resume that are present in the job description.\\n    \\\"\\\"\\\"\\n\\n    matching_skills = [skill for skill in resume_skills if skill.lower() in job_description.lower()]\\n    return matching_skills\\n\\ndef find_matching_experience(job_description, resume_experience):\\n    \\\"\\\"\\\"\\n    Identifies experience entries from the resume that align with the job description.\\n\\n    Args:\\n        job_description: A string containing the job description.\\n        resume_experience: A list of experience entries extracted from the resume.\\n\\n    Returns:\\n        A list of experience entries from the resume that are relevant to the job description.\\n    \\\"\\\"\\\"\\n\\n    matching_experience = [exp for exp in resume_experience if exp.lower() in job_description.lower()]\\n    return matching_experience\\n\\ndef calculate_overall_fit(job_description, resume_data):\\n    \\\"\\\"\\\"\\n    Calculates an overall fit score for the candidate based on skills and experience.\\n\\n    Args:\\n        job_description: A string containing the job description.\\n        resume_data: A dictionary containing extracted resume data (skills and experience).\\n\\n    Returns:\\n        An integer representing the overall fit score (0-100).\\n    \\\"\\\"\\\"\\n\\n    # Placeholder logic for calculating overall fit.  This can be refined with more sophisticated methods.\\n    skills_match = find_matching_skills(job_description, resume_data['skills'])\\n    experience_match = find_matching_experience(job_description, resume_data['experience'])\\n\\n    skill_points = len(skills_match) * 15  #Weight each skill match as 15 points\\n    experience_points = len(experience_match) * 20 #Weight each experience match as 20 points\\n\\n    overall_fit = skill_points + experience_points\\n\\n    # Cap the score at 100\\n    overall_fit = min(overall_fit, 100)\\n\\n    return overall_fit\\n\\nif __name__ == '__main__':\\n    # Example usage:\\n    job_description = \\\"\\\"\\\"\\n    We are looking for a skilled Software Engineer with experience in Python, JavaScript, and React.\\n    The ideal candidate should have experience with cloud computing platforms such as AWS and Azure.\\n    Experience with data science and machine learning is a plus.\\n    \\\"\\\"\\\"\\n\\n    resume_data = {\\n        \\\"skills\\\": [\\\"Python\\\", \\\"JavaScript\\\", \\\"React\\\", \\\"AWS\\\", \\\"Azure\\\", \\\"Data Science\\\", \\\"SQL\\\"],\\n        \\\"experience\\\": [\\n            \\\"Developed web applications using Python, JavaScript, and React.\\\",\\n            \\\"Worked with cloud computing platforms such as AWS and Azure.\\\",\\n            \\\"Implemented machine learning algorithms for data analysis.\\\"\\n        ]\\n    }\\n\\n    candidate_profile = create_candidate_profile(job_description, resume_data)\\n    print(\\\"Candidate Profile:\\\", candidate_profile)\\n```\",\n  \"timestamp\": \"2026-05-27T16:26:18.888299\"\n}"}
