ef extract_skills_responsibilities(job_description):\\n    \\\"\\\"\\\"\\n    Extracts skills and responsibilities from a job description.\\n\\n    Args:\\n        job_description (str): The job description text.\\n\\n    Returns:\\n        dict: A dictionary containing lists of skills and responsibilities.\\n              Returns None if extraction fails.\\n    \\\"\\\"\\\"\\n\\n    if not isinstance(job_description, str) or not job_description:\\n        print(\\\"Error: Job description must be a non-empty string.\\\")\\n        return None\\n\\n    skills = []\\n    responsibilities = []\\n\\n    # Skill extraction (using regex, customize as needed)\\n    skill_patterns = [\\n        r\\\"(?i)\\\\b(?:proficient in|experience with|knowledge of|familiar with|expertise in|skilled in)\\\\s+(?:[a-zA-Z#]+(?:,\\\\s*[a-zA-Z#]+)*(?:and\\\\s*[a-zA-Z#]+)?)\\\",\\n        r\\\"(?i)\\\\b[A-Z][a-zA-Z]+(?:\\\\s+[A-Z][a-zA-Z]+)*(?:\\\\s+skills?)\\\\b\\\", # e.g., Python skills, Java skills\\n        r\\\"(?i)\\\\b(?:skills:)\\\\s*(.+)\\\",  # skills: python, java\\n        r\\\"(?i)\\\\b(?:skillset:)\\\\s*(.+)\\\" # skillset: python, java\\n    ]\\n\\n    for pattern in skill_patterns:\\n        matches = re.findall(pattern, job_description)\\n        for match in matches:\\n            # Clean up matches (remove prefixes, split into individual skills)\\n            cleaned_match = re.sub(r\\\"(?i)(?:proficient in|experience with|knowledge of|familiar with|expertise in|skilled in|skills:|skillset:)\\\\s*\\\", \\\"\\\", match).strip()\\n            individual_skills = re.split(r\\\",\\\\s*|and\\\\s*\\\", cleaned_match)\\n            skills.extend([skill.strip() for skill in individual_skills if skill.strip()])\\n\\n    # Responsibility extraction (using sentence splitting and keyword identification)\\n    responsibility_keywords = [\\\"responsible for\\\", \\\"responsibilities include\\\", \\\"duties include\\\", \\\"manage\\\", \\\"develop\\\", \\\"support\\\", \\\"lead\\\", \\\"coordinate\\\", \\\"implement\\\", \\\"maintain\\\"]\\n    sentences = re.split(r\\\"(?<!\\\\w\\\\.\\\\w.)(?<![A-Z][a-z]\\\\.)(?<=\\\\.|\\\\?)\\\\s\\\", job_description) # Split into sentences\\n    for sentence in sentences:\\n        for keyword in responsibility_keywords:\\n            if keyword in sentence.lower():\\n                responsibilities.append(sentence.strip())\\n                break  # Avoid adding the same sentence multiple times\\n\\n\\n    # Further cleaning and deduplication\\n    skills = list(set(skills)) # Remove duplicates\\n    responsibilities = list(set(responsibilities)) # Remove duplicates\\n\\n    return {\\\"skills\\\": skills, \\\"responsibilities\\\": responsibilities}\\n\\nif __name__ == '__main__':\\n    job_description = \\\"\\\"\\\"\\n    Job Title: Software Engineer\\n\\n    Responsibilities include designing, developing, and testing software applications.\\n    Responsible for maintaining existing systems and implementing new features.\\n    Duties include collaborating with cross-functional teams.\\n\\n    Proficient in Python, Java, and C++. Experience with cloud technologies like AWS and Azure.\\n    Knowledge of database systems such as MySQL and PostgreSQL.\\n    Python skills are required.\\n    Strong analytical skills.\\n    skills: javascript, HTML, CSS.\\n    skillset: Docker, Kubernetes\\n    \\\"\\\"\\\"\\n\\n    extracted_data = extract_skills_responsibilities(job_description)\\n\\n    if extracted_data:\\n        print(\\\"Skills:\\\", extracted_data[\\\"skills\\\"])\\n        print(\\\"Responsibilities:\\\", extracted_data[\\\"responsibilities\\\"])\\n    else:\\n        print(\\\"Extraction failed.\\\")\\n```\\nTask task1:\\n  Objective: Develop Python code to parse the candidate resume and extract skills and experience\\n  Result: ```python\\nimport re\\n\\ndef extract_skills_and_experience(resume_text):\\n    \\\"\\\"\\\"\\n    Extracts skills and experience from a resume text.\\n\\n    Args:\\n        resume_text: The text content of the resume.\\n\\n    Returns:\\n        A dictionary containing lists of skills and experience entries.\\n    \\\"\\\"\\\"\\n\\n    skills = extract_skills(resume_text)\\n    experience = extract_experience(resume_text)\\n\\n    return {\\n        \\\"skills\\\": skills,\\n        \\\"experience\\\": experience\\n    }\\n\\ndef extract_skills(resume_text):\\n    \\\"\\\"\\\"\\n    Extracts skills from the resume text using regex.\\n\\n    Args:\\n        resume_text: The text content of the resume.\\n\\n    Returns:\\n        A list of skills.\\n    \\\"\\\"\\\"\\n\\n    # Define common skill keywords and patterns\\n    skill_patterns = [\\n        r\\\"(Python|Java|C++|JavaScript|SQL|HTML|CSS|React|Angular|Node\\\\.js)\\\",\\n        r\\\"(Data Science|Machine Learning|Deep Learning|Natural Language Processing)\\\",\\n        r\\\"(Cloud Computing|AWS|Azure|GCP)\\\",\\n        r\\\"(Project Management|Agile|Scrum)\\\",\\n        r\\\"(Communication|Leadership|Teamwork)\\\"\\n    ]\\n\\n    skills = []\\n    for pattern in skill_patterns:\\n        matches = re.findall(pattern, resume_text, re.IGNORECASE)\\n        skills.extend(matches)\\n    \\n    # Remove duplicates while preserving order\\n    unique_skills = []\\n    [unique_skills.append(x) for x in skills if x not in unique_skills]\\n\\n    return unique_skills\\n\\ndef extract_experience(resume_text):\\n    \\\"\\\"\\\"\\n    Extracts experience entries from the resume text using regex.\\n\\n    Args:\\n        resume_text: The text content of the resume.\\n\\n    Returns:\\n        A list of experience entries.\\n    \\\"\\\"\\\"\\n    # Define pattern for experience sections\\n    experience_pattern = r\\\"(?i)(?:Experience|Employment History)([\\\\s\\\\S]*?)(?:Education|Skills|References|$)\\\"\\n\\n    match = re.search(experience_pattern, resume_text)\\n    if match:\\n      experience_section = match.group(1)\\n\\n      #Split experience section into individual entries based on common separators like dates or job titles\\n      experience_entries = re.split(r\\\"\\\\d{4}[-–—]\\\\d{4}|\\\\d{4}\\\\s*-\\\\s*(Present|Current)|\\\\b(?:[A-Z][a-z]+\\\\s)+[A-Z][a-z]+(?:,\\\\s(?:[A-Z][a-z]+))?\\\\b\\\", experience_section)\\n      \\n      #Clean up the entries by removing whitespace and empty strings\\n      experience_entries = [entry.strip() for entry in experience_entries if entry.strip()]\\n\\n      return experience_entries\\n\\n    return []\\n\\n\\n\\nif __name__ == '__main__':\\n    # Example usage:\\n    resume_text = \\\"\\\"\\\"\\n    John Doe\\n    john.doe@example.com\\n    (123) 456-7890\\n\\n    Summary\\n    A highly motivated and experienced software engineer with a passion for developing innovative solutions.\\n\\n    Experience\\n    Software Engineer, Acme Corp, 2018-2022\\n    - Developed and maintained web applications using Python, JavaScript, and React.\\n    - Designed and implemented REST APIs using Node.js.\\n    - Worked with databases such as SQL and MongoDB.\\n\\n    Senior Software Engineer, Beta Inc, 2022-Present\\n    - Led a team of engineers in the development of a new mobile application.\\n    - Utilized cloud computing platforms such as AWS and Azure.\\n    - Implemented machine learning algorithms for data analysis.\\n\\n    Education\\n    Bachelor of Science in Computer Science, University of Example, 2018\\n\\n    Skills\\n    Python, Java, JavaScript, SQL, HTML, CSS, React, Node.js, Data Science, Machine Learning, Cloud Computing, AWS, Azure, Project Management, Agile, Scrum, Communication, Leadership, Teamwork\\n\\n    References\\n    Available upon request.\\n    \\\"\\\"\\\"\\n\\n    extracted_data = extract_skills_and_experience(resume_text)\\n    print(\\\"Extracted Skills:\\\", extracted_data['skills'])\\n    print(\\\"Extracted Experience:\\\", extracted_data['experience'])\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task4:\\n  Objective: Implement the scoring algorithm in Python to evaluate candidate responses from the interview engine\\n\\n---\\n# **Current Task Requirements**\\nCreate the interview engine in Python that generates and delivers technical questions based on job requirements and candidate profile\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport random\\n\\nclass InterviewEngine:\\n    def __init__(self, job_description, resume):\\n        \\\"\\\"\\\"\\n        Initializes the InterviewEngine with the job description and candidate resume.\\n        Args:\\n            job_description (dict): A dictionary containing job description details like skills and responsibilities.\\n            resume (dict): A dictionary containing candidate resume details like skills and experience.\\n        \\\"\\\"\\\"\\n        self.job_description = job_description\\n        self.resume = resume\\n        self.question_bank = {\\n            \\\"Python\\\": [\\n                \\\"Explain the difference between lists and tuples in Python.\\\",\\n                \\\"What are decorators in Python?\\\",\\n                \\\"How does garbage collection work in Python?\\\",\\n            ],\\n            \\\"Java\\\": [\\n                \\\"Explain the difference between == and .equals() in Java.\\\",\\n                \\\"What are the principles of Object-Oriented Programming?\\\",\\n                \\\"How does the JVM work?\\\",\\n            ],\\n            \\\"JavaScript\\\": [\\n                \\\"What is the difference between '==' and '===' in JavaScript?\\\",\\n                \\\"Explain closures in JavaScript.\\\",\\n                \\\"What are promises in JavaScript?\\\",\\n            ],\\n            \\\"SQL\\\": [\\n                \\\"Explain the difference between INNER JOIN and OUTER JOIN.\\\",\\n                \\\"What is a primary key?\\\",\\n                \\\"How can you optimize SQL queries?\\\",\\n            ],\\n            \\\"Data Science\\\": [\\n                \\\"Explain the difference between supervised and unsupervised learning.\\\",\\n                \\\"What is the bias-variance tradeoff?\\\",\\n                \\\"How do you handle missing data?\\\",\\n            ],\\n            \\\"Machine Learning\\\": [\\n                \\\"Explain the difference between different machine learning algorithms?\\\",\\n                \\\"What is regularization?\\\",\\n                \\\"How do you evaluate the performance of a machine learning model?\\\",\\n            ],\\n            \\\"Cloud Computing\\\": [\\n                \\\"Explain the difference between IaaS, PaaS, and SaaS.\\\",\\n                \\\"What are the benefits of using cloud computing?\\\",\\n                \\\"How does cloud autoscaling work?\\\",\\n            ],\\n            \\\"AWS\\\": [\\n                \\\"What is EC2?\\\",\\n                \\\"What is S3?\\\",\\n                \\\"How do you deploy an application on AWS?\\\",\\n            ],\\n            \\\"Azure\\\": [\\n                \\\"What is Azure Virtual Machines?\\\",\\n                \\\"What is Azure Blob Storage?\\\",\\n                \\\"How do you deploy an application on Azure?\\\",\\n            ],\\n            \\\"Project Management\\\": [\\n                \\\"What are the different phases of project management?\\\",\\n                \\\"Explain Agile methodologies.\\\",\\n                \\\"How do you manage project risks?\\\",\\n            ]\\n        }\\n\\n    def generate_questions(self, num_questions=5):\\n        \\\"\\\"\\\"\\n        Generates technical questions based on the job description and candidate resume.\\n        Args:\\n            num_questions (int): The number of questions to generate.\\n        Returns:\\n            list: A list of technical questions.\\n        \\\"\\\"\\\"\\n        relevant_skills = set(self.job_description['skills']).intersection(set(self.resume['skills']))\\n        questions = []\\n        for skill in relevant_skills:\\n            if skill in self.question_bank:\\n                questions.extend(self.question_bank[skill])\\n\\n        selected_questions = random.sample(questions, min(num_questions, len(questions))) # Avoid exceeding list length\\n        return selected_questions\\n\\n    def deliver_question(self, question):\\n        \\\"\\\"\\\"\\n        Delivers a technical question to the candidate (simulated).\\n        Args:\\n            question (str): The technical question to deliver.\\n        Returns:\\n            None\\n        \\\"\\\"\\\"\\n        print(f\\\"Question: {question}\\\")\\n\\n    def get_candidate_response(self):\\n        \\\"\\\"\\\"\\n        Simulates getting a response from the candidate.\\n        Returns:\\n            str: The candidate's response.\\n        \\\"\\\"\\\"\\n        return input(\\\"Your Answer: \\\")\\n\\nif __name__ == '__main__':\\n    # Example Usage\\n    job_description = {\\n        \\\"skills\\\": [\\\"Python\\\", \\\"Data Science\\\", \\\"Machine Learning\\\"],\\n        \\\"responsibilities\\\": [\\\"Develop machine learning models\\\", \\\"Analyze data\\\"]\\n    }\\n    resume = {\\n        \\\"skills\\\": [\\\"Python\\\", \\\"Data Science\\\", \\\"Machine Learning\\\", \\\"SQL\\\"],\\n        \\\"experience\\\": [\\\"Developed machine learning models using Python\\\"]\\n    }\\n\\n    interview_engine = InterviewEngine(job_description, resume)\\n    questions = interview_engine.generate_questions(num_questions=3)\\n\\n    for question in questions:\\n        interview_engine.deliver_question(question)\\n        candidate_response = interview_engine.get_candidate_response()\\n        print(f\\\"Candidate's Response: {candidate_response}\\\\n\\\")\\n```\",\n  \"timestamp\": \"2026-05-27T16:26:19.810072\"\n}"}
