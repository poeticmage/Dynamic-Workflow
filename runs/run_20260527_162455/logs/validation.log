st of technical questions.\\n        \\\"\\\"\\\"\\n        relevant_skills = set(self.job_description['skills']).intersection(set(self.resume['skills']))\\n        questions = []\\n        for skill in relevant_skills:\\n            if skill in self.question_bank:\\n                questions.extend(self.question_bank[skill])\\n\\n        selected_questions = random.sample(questions, min(num_questions, len(questions))) # Avoid exceeding list length\\n        return selected_questions\\n\\n    def deliver_question(self, question):\\n        \\\"\\\"\\\"\\n        Delivers a technical question to the candidate (simulated).\\n        Args:\\n            question (str): The technical question to deliver.\\n        Returns:\\n            None\\n        \\\"\\\"\\\"\\n        print(f\\\"Question: {question}\\\")\\n\\n    def get_candidate_response(self):\\n        \\\"\\\"\\\"\\n        Simulates getting a response from the candidate.\\n        Returns:\\n            str: The candidate's response.\\n        \\\"\\\"\\\"\\n        return input(\\\"Your Answer: \\\")\\n\\nif __name__ == '__main__':\\n    # Example Usage\\n    job_description = {\\n        \\\"skills\\\": [\\\"Python\\\", \\\"Data Science\\\", \\\"Machine Learning\\\"],\\n        \\\"responsibilities\\\": [\\\"Develop machine learning models\\\", \\\"Analyze data\\\"]\\n    }\\n    resume = {\\n        \\\"skills\\\": [\\\"Python\\\", \\\"Data Science\\\", \\\"Machine Learning\\\", \\\"SQL\\\"],\\n        \\\"experience\\\": [\\\"Developed machine learning models using Python\\\"]\\n    }\\n\\n    interview_engine = InterviewEngine(job_description, resume)\\n    questions = interview_engine.generate_questions(num_questions=3)\\n\\n    for question in questions:\\n        interview_engine.deliver_question(question)\\n        candidate_response = interview_engine.get_candidate_response()\\n        print(f\\\"Candidate's Response: {candidate_response}\\\\n\\\")\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task6:\\n  Objective: Generate the final evaluation report in Python by aggregating candidate profile and interview scores\\n\\n---\\n# **Current Task Requirements**\\nImplement the scoring algorithm in Python to evaluate candidate responses from the interview engine\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport re\\nfrom collections import Counter\\n\\nclass ScoringAlgorithm:\\n    def __init__(self, expected_keywords=None, keyword_weights=None):\\n        \\\"\\\"\\\"\\n        Initializes the ScoringAlgorithm with expected keywords and optional weights.\\n\\n        Args:\\n            expected_keywords (list of str, optional): List of required keywords for the question.\\n            keyword_weights (dict, optional): A dictionary mapping keywords to weights.\\n                                             If None, all expected keywords have weight 1.\\n        \\\"\\\"\\\"\\n        self.expected_keywords = [kw.lower() for kw in (expected_keywords or [])]\\n        self.keyword_weights = keyword_weights or {kw: 1 for kw in self.expected_keywords}\\n\\n    def preprocess(self, text):\\n        \\\"\\\"\\\"\\n        Lowercases, removes punctuation, and splits into words.\\n        \\\"\\\"\\\"\\n        text = text.lower()\\n        text = re.sub(r'[^\\\\w\\\\s]', ' ', text)\\n        words = text.split()\\n        return words\\n\\n    def score_response(self, response):\\n        \\\"\\\"\\\"\\n        Scores a candidate's response against expected keywords.\\n\\n        Args:\\n            response (str): The candidate's response.\\n\\n        Returns:\\n            int: The score for the response (0-10).\\n        \\\"\\\"\\\"\\n        words = self.preprocess(response)\\n        word_counts = Counter(words)\\n\\n        # Sum up weights for matched keywords\\n        raw_score = 0\\n        for kw in self.expected_keywords:\\n            if word_counts.get(kw, 0) > 0:\\n                raw_score += self.keyword_weights.get(kw, 1)\\n\\n        # Normalize: maximum possible raw score is the sum of all weights\\n        max_raw = sum(self.keyword_weights.values()) or 1\\n        normalized = (raw_score / max_raw) * 10\\n\\n        # Cap and round\\n        final_score = min(10, round(normalized))\\n        return final_score\\n\\nif __name__ == '__main__':\\n    # Example Usage\\n    expected_keywords = [\\\"mutable\\\", \\\"immutable\\\", \\\"faster\\\", \\\"list\\\", \\\"tuple\\\"]\\n    weights = {\\\"mutable\\\": 2, \\\"immutable\\\": 2, \\\"faster\\\": 1, \\\"list\\\": 1, \\\"tuple\\\": 1}\\n\\n    scorer = ScoringAlgorithm(expected_keywords=expected_keywords,\\n                              keyword_weights=weights)\\n\\n    response1 = \\\"Lists are mutable, while tuples are immutable. Tuples are also faster.\\\"\\n    print(\\\"Score1:\\\", scorer.score_response(response1))  # Should be 10\\n\\n    response2 = \\\"Lists are mutable but I don't know about speed differences.\\\"\\n    print(\\\"Score2:\\\", scorer.score_response(response2))  # Partial score\\n\\n    response3 = \\\"Tuples are immutable.\\\"\\n    print(\\\"Score3:\\\", scorer.score_response(response3))  # Lower score\\n```\",\n  \"timestamp\": \"2026-05-27T16:26:52.267327\"\n}"}
