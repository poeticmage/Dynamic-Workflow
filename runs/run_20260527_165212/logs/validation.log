tle']\\n                company = experience['company']\\n                self.questions.append(f\\\"Tell me more about your role as a {job_title} at {company}.\\\")\\n                self.questions.append(f\\\"What were your key accomplishments as a {job_title} at {company}?\\\")\\n                self.questions.append(f\\\"What were the biggest challenges you faced as a {job_title} at {company}?\\\")\\n\\n        return self.questions\\n\\n    def get_questions(self):\\n        \\\"\\\"\\\"\\n        Returns the generated interview questions.\\n\\n        Returns:\\n            list: A list of interview questions.\\n        \\\"\\\"\\\"\\n        if not self.questions:\\n            self.generate_questions()  # Generate if not already generated\\n        return self.questions\\n\\nif __name__ == '__main__':\\n    # Example Usage:\\n    job_description_text = \\\"\\\"\\\"\\nJob Title: Software Engineer\\n\\nWe are looking for a Software Engineer with 5+ years of experience in Python and Java.\\nCandidates should have a Bachelor's degree in Computer Science. Experience with AWS and Machine Learning is a plus. Strong communication and leadership skills are required.\\n\\\"\\\"\\\"\\n\\n    resume_text = \\\"\\\"\\\"\\n    John Doe\\n    john.doe@example.com\\n    123-456-7890\\n\\n    Summary\\n    Experienced software engineer with a passion for developing innovative solutions.\\n\\n    Skills\\n    Python, Java, C++, JavaScript, SQL, AWS\\n\\n    Experience\\n    Software Engineer\\n    Acme Corp\\n    2020 - Present\\n    - Developed and maintained web applications using Python and JavaScript.\\n    - Designed and implemented REST APIs.\\n    - Worked with AWS cloud services.\\n\\n    Data Scientist\\n    Beta Corp\\n    2018 - 2020\\n    - Developed machine learning models using Python.\\n    - Analyzed large datasets to identify trends and insights.\\n\\n    Education\\n    University of Example\\n    Bachelor of Science in Computer Science\\n    2014 - 2018\\n\\n    Stanford University\\n    Master of Science in Data Science\\n    2018 - 2020\\n    \\\"\\\"\\\"\\n    from task0 import JobDescriptionAnalyzer\\n    from task1 import analyze_resume\\n\\n    analyzer = JobDescriptionAnalyzer(job_description_text)\\n    job_description_data = analyzer.analyze()\\n\\n    resume_data = analyze_resume(resume_text)\\n\\n\\n    interview_module = InterviewModule(job_description_data, resume_data)\\n    questions = interview_module.get_questions()\\n\\n    print(\\\"Generated Interview Questions:\\\")\\n    for question in questions:\\n        print(question)\\n```\\n\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task5:\\n  Objective: Develop a Report Generator that compiles analysis summaries, interview questions, and scores into a final .txt evaluation\\n\\n---\\n# **Current Task Requirements**\\nImplement a Response Scorer that evaluates candidate answers against JD and resume criteria\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nclass ResponseScorer:\\n    def __init__(self, job_description_data, resume_data):\\n        self.job_description_data = job_description_data\\n        self.resume_data = resume_data\\n\\n    def score_response(self, question, response):\\n        score = 0\\n        feedback = []\\n\\n        # Skill-based scoring\\n        for skill in self.job_description_data.get('skills', []):\\n            if skill.lower() in question.lower():  # Check if the question is about a specific skill\\n                if skill.lower() in response.lower():\\n                    score += 5\\n                    feedback.append(f\\\"Demonstrated knowledge of {skill}.\\\")\\n                else:\\n                    score -= 2\\n                    feedback.append(f\\\"Could elaborate more on {skill}.\\\")\\n\\n        # Experience-based scoring\\n        experience_years = self.job_description_data.get('experience')\\n        if experience_years and \\\"experience\\\" in question.lower():\\n            # Simple check for mentioning years of experience\\n            if str(experience_years) in response:\\n                score += 3\\n                feedback.append(\\\"Addressed experience requirements.\\\")\\n            else:\\n                score -= 1\\n                feedback.append(\\\"Ensure to address your total years of experience.\\\")\\n\\n        # Resume-based scoring (matching resume content with response)\\n        for past_experience in self.resume_data.get('experience', []):\\n            if past_experience['job_title'].lower() in question.lower() or past_experience['company'].lower() in question.lower():\\n                if past_experience['job_title'].lower() in response.lower() or past_experience['company'].lower() in response.lower():\\n                    score += 4\\n                    feedback.append(\\\"Response aligns with resume details.\\\")\\n                else:\\n                    score -= 2\\n                    feedback.append(\\\"Consider referencing resume details more explicitly.\\\")\\n\\n        #Generic positive/negative keywords\\n        if any(keyword in response.lower() for keyword in ['excellent', 'strong', 'proficient', 'adept']):\\n            score += 2\\n            feedback.append(\\\"Positive keywords detected.\\\")\\n\\n        if any(keyword in response.lower() for keyword in ['struggled', 'difficulty', 'limited']):\\n            score -= 1\\n            feedback.append(\\\"Negative keywords detected; clarify challenges with solutions\\\")\\n\\n        return max(0, min(10, score)), feedback  # Scale score between 0 and 10\\n\\n\\nif __name__ == '__main__':\\n    # Example Usage:\\n    job_description_data = {\\n        'skills': ['Python', 'Java', 'Machine Learning'],\\n        'experience': 5\\n    }\\n\\n    resume_data = {\\n        'experience': [\\n            {'job_title': 'Software Engineer', 'company': 'Acme Corp'},\\n            {'job_title': 'Data Scientist', 'company': 'Beta Corp'}\\n        ],\\n        'skills': ['Python', 'SQL']\\n    }\\n\\n    scorer = ResponseScorer(job_description_data, resume_data)\\n\\n    question1 = \\\"Tell me about your experience with Python.\\\"\\n    response1 = \\\"I have 5 years of experience using Python for web development and data analysis.\\\"\\n    score1, feedback1 = scorer.score_response(question1, response1)\\n    print(f\\\"Question: {question1}\\\\nResponse: {response1}\\\\nScore: {score1}\\\\nFeedback: {feedback1}\\\\n\\\")\\n\\n    question2 = \\\"What were your key accomplishments as a Software Engineer at Acme Corp?\\\"\\n    response2 = \\\"I led a team that developed a new feature using Java.\\\"\\n    score2, feedback2 = scorer.score_response(question2, response2)\\n    print(f\\\"Question: {question2}\\\\nResponse: {response2}\\\\nScore: {score2}\\\\nFeedback: {feedback2}\\\\n\\\")\\n```\",\n  \"timestamp\": \"2026-05-27T16:54:19.599028\"\n}"}
