                match_length += 1\\n                    \\n                    if match_length >= 3:\\n                         matches_found = True\\n                         self.score += MATCH_CLEAR_SCORES.get(match_length, 0)\\n                         for i in range(match_length):\\n                            self.grid[y][x+i] = None\\n        \\n        # Basic gravity implementation after clearing matches\\n        if matches_found:\\n            self.apply_gravity()\\n\\n    def apply_gravity(self):\\n        for x in range(GRID_WIDTH):\\n            empty_space = 0\\n            for y in range(GRID_HEIGHT):\\n                if self.grid[y][x] is None:\\n                    empty_space += 1\\n                elif empty_space > 0:\\n                    self.grid[y - empty_space][x] = self.grid[y][x]\\n                    self.grid[y][x] = None\\n```\",\n  \"timestamp\": \"2026-05-22T12:18:42.009289\"\n}"}
