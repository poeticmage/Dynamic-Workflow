LEAR_SCORES = {\\n    3: 50,\\n    4: 100,\\n    5: 200,\\n}\\n# Extra points beyond length 5\\nEXTRA_PER_GEM = 20\\nCHAIN_BONUS_MULTIPLIER = 1.5\\n\\ndef create_empty_grid():\\n    \\\"\\\"\\\"Return a GRID_HEIGHT×GRID_WIDTH grid initialized to None.\\\"\\\"\\\"\\n    return [[None for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]\\n\\ndef detect_matches(grid):\\n    \\\"\\\"\\\"\\n    Detect all horizontal and vertical runs of length >= 3.\\n    Returns a list of matches, each a list of (x,y) coordinates.\\n    \\\"\\\"\\\"\\n    matches = []\\n\\n    # Horizontal runs\\n    for y in range(GRID_HEIGHT):\\n        x = 0\\n        while x < GRID_WIDTH - 2:\\n            if grid[y][x] is not None:\\n                color = grid[y][x]\\n                length = 1\\n                # extend run\\n                while x + length < GRID_WIDTH and grid[y][x + length] == color:\\n                    length += 1\\n                if length >= 3:\\n                    runs = [(x + i, y) for i in range(length)]\\n                    matches.append(runs)\\n                    x += length\\n                    continue\\n            x += 1\\n\\n    # Vertical runs\\n    for x in range(GRID_WIDTH):\\n        y = 0\\n        while y < GRID_HEIGHT - 2:\\n            if grid[y][x] is not None:\\n                color = grid[y][x]\\n                length = 1\\n                while y + length < GRID_HEIGHT and grid[y + length][x] == color:\\n                    length += 1\\n                if length >= 3:\\n                    runs = [(x, y + i) for i in range(length)]\\n                    matches.append(runs)\\n                    y += length\\n                    continue\\n            y += 1\\n\\n    return matches\\n\\ndef clear_matches(grid, matches):\\n    \\\"\\\"\\\"\\n    Clear all matched cells by setting them to None.\\n    Returns the total number of gems cleared.\\n    \\\"\\\"\\\"\\n    cleared = 0\\n    for run in matches:\\n        for x, y in run:\\n            if grid[y][x] is not None:\\n                grid[y][x] = None\\n                cleared += 1\\n    return cleared\\n\\ndef apply_gravity(grid):\\n    \\\"\\\"\\\"\\n    For each column, collapse all non‐None cells down,\\n    filling from the bottom up.\\n    \\\"\\\"\\\"\\n    for x in range(GRID_WIDTH):\\n        write_y = GRID_HEIGHT - 1\\n        # scan from bottom to top\\n        for read_y in range(GRID_HEIGHT - 1, -1, -1):\\n            if grid[read_y][x] is not None:\\n                grid[write_y][x] = grid[read_y][x]\\n                if write_y != read_y:\\n                    grid[read_y][x] = None\\n                write_y -= 1\\n        # fill any remaining above with None\\n        for fill_y in range(write_y, -1, -1):\\n            grid[fill_y][x] = None\\n\\ndef handle_chain_reaction_and_score(grid):\\n    \\\"\\\"\\\"\\n    Repeatedly detect, score, clear, and apply gravity until\\n    no further matches. Returns (total_score, chain_length).\\n    \\\"\\\"\\\"\\n    total_score = 0\\n    chain_length = 0\\n\\n    while True:\\n        matches = detect_matches(grid)\\n        if not matches:\\n            break\\n\\n        # score each match by its length\\n        for run in matches:\\n            length = len(run)\\n            if length in MATCH_CLEAR_SCORES:\\n                total_score += MATCH_CLEAR_SCORES[length]\\n            else:\\n                # for runs >5\\n                total_score += MATCH_CLEAR_SCORES[5] + (length - 5) * EXTRA_PER_GEM\\n\\n        clear_matches(grid, matches)\\n        apply_gravity(grid)\\n        chain_length += 1\\n\\n    # apply chain bonus once\\n    if chain_length > 1:\\n        total_score = int(total_score * (CHAIN_BONUS_MULTIPLIER ** (chain_length - 1)))\\n\\n    return total_score, chain_length\\n\\n# Example usage & simple test\\nif __name__ == '__main__':\\n    # Simulate a grid with colored gems represented by integers\\n    COLORS = [1, 2, 3, 4]  # placeholders for actual RGB tuples\\n\\n    grid = create_empty_grid()\\n    # create a horizontal match of color 1 at row 0\\n    grid[0][0:4] = [1, 1, 1, 1]\\n    # create a vertical match of color 2 in col 5\\n    for i in range(3):\\n        grid[i][5] = 2\\n\\n    print(\\\"Before:\\\")\\n    for row in grid:\\n        print(row)\\n\\n    score, chains = handle_chain_reaction_and_score(grid)\\n\\n    print(f\\\"\\\\nAfter: score={score}, chains={chains}\\\")\\n    for row in grid:\\n        print(row)\\n```\"}"}
