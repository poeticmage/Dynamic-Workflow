n  Objective: Define core data structures and constants: grid representation, tetromino shapes, gem colors, and scoring parameters.\\n  Result: from enum import Enum\\nfrom collections import namedtuple\\n\\n# Grid dimensions\\nGRID_WIDTH = 10\\nGRID_HEIGHT = 20\\n\\n# Point on the grid\\nPoint = namedtuple('Point', ['x', 'y'])\\n\\n# Tetromino types\\nclass PieceType(Enum):\\n    I = 'I'\\n    O = 'O'\\n    T = 'T'\\n    S = 'S'\\n    Z = 'Z'\\n    J = 'J'\\n    L = 'L'\\n\\n# Tetromino shapes: list of rotations, each rotation is list of 4 Points\\nTETROMINO_SHAPES = {\\n    PieceType.I: [\\n        [Point(0,1), Point(1,1), Point(2,1), Point(3,1)],\\n        [Point(2,0), Point(2,1), Point(2,2), Point(2,3)],\\n        [Point(0,2), Point(1,2), Point(2,2), Point(3,2)],\\n        [Point(1,0), Point(1,1), Point(1,2), Point(1,3)],\\n    ],\\n    PieceType.O: [\\n        [Point(1,0), Point(2,0), Point(1,1), Point(2,1)],\\n    ] * 4,\\n    PieceType.T: [\\n        [Point(1,0), Point(0,1), Point(1,1), Point(2,1)],\\n        [Point(1,0), Point(1,1), Point(2,1), Point(1,2)],\\n        [Point(0,1), Point(1,1), Point(2,1), Point(1,2)],\\n        [Point(1,0), Point(0,1), Point(1,1), Point(1,2)],\\n    ],\\n    PieceType.S: [\\n        [Point(1,0), Point(2,0), Point(0,1), Point(1,1)],\\n        [Point(1,0), Point(1,1), Point(2,1), Point(2,2)],\\n        [Point(1,1), Point(2,1), Point(0,2), Point(1,2)],\\n        [Point(0,0), Point(0,1), Point(1,1), Point(1,2)],\\n    ],\\n    PieceType.Z: [\\n        [Point(0,0), Point(1,0), Point(1,1), Point(2,1)],\\n        [Point(2,0), Point(1,1), Point(2,1), Point(1,2)],\\n        [Point(0,1), Point(1,1), Point(1,2), Point(2,2)],\\n        [Point(1,0), Point(0,1), Point(1,1), Point(0,2)],\\n    ],\\n    PieceType.J: [\\n        [Point(0,0), Point(0,1), Point(1,1), Point(2,1)],\\n        [Point(1,0), Point(2,0), Point(1,1), Point(1,2)],\\n        [Point(0,1), Point(1,1), Point(2,1), Point(2,2)],\\n        [Point(1,0), Point(1,1), Point(0,2), Point(1,2)],\\n    ],\\n    PieceType.L: [\\n        [Point(2,0), Point(0,1), Point(1,1), Point(2,1)],\\n        [Point(1,0), Point(1,1), Point(1,2), Point(2,2)],\\n        [Point(0,1), Point(1,1), Point(2,1), Point(0,2)],\\n        [Point(0,0), Point(1,0), Point(1,1), Point(1,2)],\\n    ],\\n}\\n\\n# Color palette (RGB) for tetrominoes and gems\\nTETROMINO_COLORS = {\\n    PieceType.I: (0, 240, 240),\\n    PieceType.O: (240, 240,   0),\\n    PieceType.T: (160,   0, 240),\\n    PieceType.S: (0, 240,   0),\\n    PieceType.Z: (240,   0,   0),\\n    PieceType.J: (0,   0, 240),\\n    PieceType.L: (240, 160,   0),\\n}\\n\\nGEM_COLORS = list(TETROMINO_COLORS.values())\\n\\n# Scoring parameters\\nLINE_CLEAR_SCORES = {\\n    1: 100,\\n    2: 300,\\n    3: 500,\\n    4: 800,\\n}\\n\\nMATCH_CLEAR_SCORES = {\\n    3: 50,\\n    4: 100,\\n    5: 200,\\n}\\n\\nCHAIN_BONUS_MULTIPLIER = 1.5\\n\\n# Grid cell representation: None or (r, g, b)\\ndef create_empty_grid():\\n    return [[None for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task4:\\n  Objective: Develop the Pygame-based GUI and main game loop: render the grid, animations, current score, next tetromino preview, and integrate controls with mechanics modules.\\n\\n---\\n# **Current Task Requirements**\\nCreate Tetris line-clearing logic: detect full horizontal lines, clear them, collapse above gems, and award line-clear points.\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nfrom task0 import GRID_WIDTH, GRID_HEIGHT, LINE_CLEAR_SCORES\\n\\ndef clear_lines(grid):\\n    \\\"\\\"\\\"\\n    Detects and clears full horizontal lines in the grid, collapsing gems above.\\n\\n    Args:\\n        grid: The game grid (list of lists), where each cell is None or a gem color (RGB tuple).\\n\\n    Returns:\\n        A tuple containing:\\n            - The updated grid.\\n            - The number of lines cleared.\\n            - The score earned from clearing lines.\\n    \\\"\\\"\\\"\\n    lines_cleared = 0\\n    score = 0\\n    new_grid = [row[:] for row in grid]  # Create a copy to modify\\n\\n    # Identify full lines\\n    full_lines = []\\n    for i in range(GRID_HEIGHT):\\n        if all(new_grid[i][j] is not None for j in range(GRID_WIDTH)):\\n            full_lines.append(i)\\n\\n    lines_cleared = len(full_lines)\\n\\n    # Clear lines and collapse gems\\n    if lines_cleared > 0:\\n        score = LINE_CLEAR_SCORES.get(lines_cleared, 0)  # Get score for lines cleared\\n\\n        # Remove the full lines from the grid\\n        for line_index in sorted(full_lines, reverse=True):\\n            del new_grid[line_index]\\n            new_grid.insert(0, [None] * GRID_WIDTH)  # Add an empty line at the top\\n\\n    return new_grid, lines_cleared, score\\n\\nif __name__ == '__main__':\\n    # Example usage\\n    sample_grid = [\\n        [(255, 0, 0)] * GRID_WIDTH if i in [3, 5, 7] else [None] * GRID_WIDTH\\n        for i in range(GRID_HEIGHT)\\n    ]\\n\\n    # Fill some more cells to test\\n    sample_grid[0][0] = (255, 255, 255)\\n    sample_grid[1][1] = (255, 255, 255)\\n    sample_grid[GRID_HEIGHT - 1][GRID_WIDTH - 1] = (255, 255, 255)\\n    \\n    print(\\\"Original Grid:\\\")\\n    for row in sample_grid:\\n        print(row)\\n\\n    updated_grid, lines_cleared, score = clear_lines(sample_grid)\\n\\n    print(\\\"\\\\nUpdated Grid:\\\")\\n    for row in updated_grid:\\n        print(row)\\n\\n    print(f\\\"\\\\nLines Cleared: {lines_cleared}\\\")\\n    print(f\\\"Score: {score}\\\")\\n```\",\n  \"timestamp\": \"2026-05-22T12:15:17.046175\"\n}"}
