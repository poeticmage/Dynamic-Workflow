or _ in range(GRID_HEIGHT)]\\n\\nclass Tetromino:\\n    def __init__(self, piece_type):\\n        self.type = piece_type\\n        self.shape = TETROMINO_SHAPES[self.type][0]\\n        self.color = TETROMINO_COLORS[self.type]\\n        self.rotation = 0\\n        self.x = GRID_WIDTH // 2 - 2  # Center at the top\\n        self.y = 0\\n\\n    def rotate(self, direction):\\n        # direction: 1 for clockwise, -1 for counterclockwise\\n        self.rotation = (self.rotation + direction) % len(TETROMINO_SHAPES[self.type])\\n        self.shape = TETROMINO_SHAPES[self.type][self.rotation]\\n\\n    def get_absolute_positions(self):\\n        return [Point(p.x + self.x, p.y + self.y) for p in self.shape]\\n\\n    def collides(self, grid):\\n        for point in self.get_absolute_positions():\\n            if (point.x < 0 or point.x >= GRID_WIDTH or\\n                point.y >= GRID_HEIGHT or  # Allow piece to be partially above the grid.\\n                (point.y >= 0 and grid[point.y][point.x] is not None)):\\n                return True\\n        return False\\n\\n\\ndef new_tetromino():\\n    piece_type = random.choice(list(PieceType))\\n    return Tetromino(piece_type)\\n\\ndef lock_tetromino(grid, tetromino):\\n    for point in tetromino.get_absolute_positions():\\n        if point.y >= 0:  # Only lock blocks within the grid\\n            grid[point.y][point.x] = tetromino.color\\n\\ndef move_tetromino(tetromino, dx, grid):\\n    tetromino.x += dx\\n    if tetromino.collides(grid):\\n        tetromino.x -= dx\\n        return False\\n    return True\\n\\ndef drop_tetromino(tetromino, grid):\\n    tetromino.y += 1\\n    if tetromino.collides(grid):\\n        tetromino.y -= 1\\n        return False\\n    return True\\n\\ndef rotate_tetromino(tetromino, direction, grid):\\n    original_rotation = tetromino.rotation\\n    tetromino.rotate(direction)\\n    if tetromino.collides(grid):\\n        tetromino.rotation = original_rotation\\n        tetromino.shape = TETROMINO_SHAPES[tetromino.type][tetromino.rotation] # Reset shape\\n        return False\\n    return True\\n\\ndef main():\\n    pygame.init()\\n\\n    # Define some colors\\n    BLACK = (0, 0, 0)\\n    WHITE = (255, 255, 255)\\n    GRAY = (128, 128, 128)\\n\\n    # Set the width and height of the screen [width, height]\\n    size = (300, 600)  # Example size\\n    screen = pygame.display.set_mode(size)\\n\\n    pygame.display.set_caption(\\\"Tetris Bejeweled\\\")\\n\\n    # Loop until the user clicks the close button.\\n    done = False\\n\\n    # Used to manage how fast the screen updates\\n    clock = pygame.time.Clock()\\n\\n    grid = create_empty_grid()\\n    current_tetromino = new_tetromino()\\n    game_over = False\\n    fall_speed = 1 # Blocks per second\\n    fall_timer = 0\\n\\n    # -------- Main Program Loop -----------\\n    while not done:\\n        # --- Main event loop\\n        for event in pygame.event.get():\\n            if event.type == pygame.QUIT:\\n                done = True\\n            if event.type == pygame.KEYDOWN:\\n                if event.key == pygame.K_LEFT:\\n                    move_tetromino(current_tetromino, -1, grid)\\n                if event.key == pygame.K_RIGHT:\\n                    move_tetromino(current_tetromino, 1, grid)\\n                if event.key == pygame.K_UP: # Rotate clockwise\\n                    rotate_tetromino(current_tetromino, 1, grid)\\n                if event.key == pygame.K_DOWN: # Rotate counter-clockwise\\n                    rotate_tetromino(current_tetromino, -1, grid)\\n\\n        # --- Game logic\\n\\n        if not game_over:\\n            fall_timer += clock.get_time()\\n            if fall_timer > 1000 / fall_speed:\\n                fall_timer = 0\\n                if not drop_tetromino(current_tetromino, grid):\\n                    lock_tetromino(grid, current_tetromino)\\n                    current_tetromino = new_tetromino()\\n                    if current_tetromino.collides(grid):\\n                        game_over = True\\n                        print(\\\"Game Over!\\\")\\n\\n\\n        # --- Drawing code should go here\\n\\n        # First, clear the screen to black. Don't put other drawing commands\\n        # above this, or they will be erased with this command.\\n        screen.fill(BLACK)\\n\\n        # Draw the grid\\n        block_size = 300 // GRID_WIDTH  # Adjust as needed to fit the screen\\n\\n        for row in range(GRID_HEIGHT):\\n            for col in range(GRID_WIDTH):\\n                if grid[row][col] is not None:\\n                    pygame.draw.rect(screen, grid[row][col], [col * block_size, row * block_size, block_size, block_size])\\n                    pygame.draw.rect(screen, GRAY, [col * block_size, row * block_size, block_size, block_size], 1) # Add grid lines\\n                else:\\n                     pygame.draw.rect(screen, GRAY, [col * block_size, row * block_size, block_size, block_size], 1) # Add grid lines even to empty cells\\n\\n        # Draw the current tetromino\\n        if current_tetromino:\\n            for point in current_tetromino.get_absolute_positions():\\n                if point.y >= 0: # Only draw blocks within the grid\\n                    pygame.draw.rect(screen, current_tetromino.color, [point.x * block_size, point.y * block_size, block_size, block_size])\\n                    pygame.draw.rect(screen, GRAY, [point.x * block_size, point.y * block_size, block_size, block_size], 1)\\n\\n\\n        # --- Go ahead and update the screen with what we've drawn.\\n        pygame.display.flip()\\n\\n        # --- Limit to 60 frames per second\\n        clock.tick(60)\\n\\n    # Close the window and quit.\\n    pygame.quit()\\n\\nif __name__ == \\\"__main__\\\":\\n    main()\\n```\",\n  \"timestamp\": \"2026-05-22T12:15:29.312522\"\n}"}
