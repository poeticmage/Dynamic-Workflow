ceType.I: [\\n        [Point(0,1), Point(1,1), Point(2,1), Point(3,1)],\\n        [Point(2,0), Point(2,1), Point(2,2), Point(2,3)],\\n        [Point(0,2), Point(1,2), Point(2,2), Point(3,2)],\\n        [Point(1,0), Point(1,1), Point(1,2), Point(1,3)],\\n    ],\\n    PieceType.O: [\\n        [Point(1,0), Point(2,0), Point(1,1), Point(2,1)],\\n    ] * 4,\\n    PieceType.T: [\\n        [Point(1,0), Point(0,1), Point(1,1), Point(2,1)],\\n        [Point(1,0), Point(1,1), Point(2,1), Point(1,2)],\\n        [Point(0,1), Point(1,1), Point(2,1), Point(1,2)],\\n        [Point(1,0), Point(0,1), Point(1,1), Point(1,2)],\\n    ],\\n    PieceType.S: [\\n        [Point(1,0), Point(2,0), Point(0,1), Point(1,1)],\\n        [Point(1,0), Point(1,1), Point(2,1), Point(2,2)],\\n        [Point(1,1), Point(2,1), Point(0,2), Point(1,2)],\\n        [Point(0,0), Point(0,1), Point(1,1), Point(1,2)],\\n    ],\\n    PieceType.Z: [\\n        [Point(0,0), Point(1,0), Point(1,1), Point(2,1)],\\n        [Point(2,0), Point(1,1), Point(2,1), Point(1,2)],\\n        [Point(0,1), Point(1,1), Point(1,2), Point(2,2)],\\n        [Point(1,0), Point(0,1), Point(1,1), Point(0,2)],\\n    ],\\n    PieceType.J: [\\n        [Point(0,0), Point(0,1), Point(1,1), Point(2,1)],\\n        [Point(1,0), Point(2,0), Point(1,1), Point(1,2)],\\n        [Point(0,1), Point(1,1), Point(2,1), Point(2,2)],\\n        [Point(1,0), Point(1,1), Point(0,2), Point(1,2)],\\n    ],\\n    PieceType.L: [\\n        [Point(2,0), Point(0,1), Point(1,1), Point(2,1)],\\n        [Point(1,0), Point(1,1), Point(1,2), Point(2,2)],\\n        [Point(0,1), Point(1,1), Point(2,1), Point(0,2)],\\n        [Point(0,0), Point(1,0), Point(1,1), Point(1,2)],\\n    ],\\n}\\n\\n# Colors for each tetromino (and gems)\\nTETROMINO_COLORS = {\\n    PieceType.I: (0, 240, 240),\\n    PieceType.O: (240, 240,   0),\\n    PieceType.T: (160,   0, 240),\\n    PieceType.S: (0, 240,   0),\\n    PieceType.Z: (240,   0,   0),\\n    PieceType.J: (0,   0, 240),\\n    PieceType.L: (240, 160,   0),\\n}\\n\\n# A Gem class to represent locked blocks\\nclass Gem:\\n    def __init__(self, color):\\n        self.color = color\\n\\ndef create_empty_grid():\\n    # Grid stores either None or Gem instances\\n    return [[None for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]\\n\\nclass Tetromino:\\n    def __init__(self, piece_type):\\n        self.type = piece_type\\n        self.rotation = 0\\n        self.shape = TETROMINO_SHAPES[piece_type][0]\\n        self.color = TETROMINO_COLORS[piece_type]\\n        self.x = GRID_WIDTH // 2 - 2\\n        self.y = 0\\n\\n    def rotate(self):\\n        self.rotation = (self.rotation + 1) % len(TETROMINO_SHAPES[self.type])\\n        self.shape = TETROMINO_SHAPES[self.type][self.rotation]\\n\\n    def get_positions(self):\\n        return [(self.x + p.x, self.y + p.y) for p in self.shape]\\n\\nclass GameState:\\n    def __init__(self):\\n        self.grid = create_empty_grid()\\n        self.current = self._new_tetromino()\\n        self.next_piece = self._new_tetromino()\\n        self.game_over = False\\n\\n    def _new_tetromino(self):\\n        return Tetromino(random.choice(list(PieceType)))\\n\\n    def move(self, dx):\\n        self.current.x += dx\\n        if self._collides():\\n            self.current.x -= dx\\n            return False\\n        return True\\n\\n    def rotate(self):\\n        old_rot = self.current.rotation\\n        self.current.rotate()\\n        if self._collides():\\n            # revert on collision\\n            self.current.rotation = old_rot\\n            self.current.shape = TETROMINO_SHAPES[self.current.type][old_rot]\\n\\n    def drop(self):\\n        self.current.y += 1\\n        if self._collides():\\n            # lock in place\\n            self.current.y -= 1\\n            self._lock()\\n            self.current = self.next_piece\\n            self.next_piece = self._new_tetromino()\\n            if self._collides():\\n                self.game_over = True\\n            return False\\n        return True\\n\\n    def _collides(self):\\n        for x, y in self.current.get_positions():\\n            if x < 0 or x >= GRID_WIDTH or y >= GRID_HEIGHT:\\n                return True\\n            if y >= 0 and self.grid[y][x] is not None:\\n                return True\\n        return False\\n\\n    def _lock(self):\\n        for x, y in self.current.get_positions():\\n            if 0 <= y < GRID_HEIGHT:\\n                self.grid[y][x] = Gem(self.current.color)\\n\\n# Pygame entry point\\nif __name__ == '__main__':\\n    pygame.init()\\n\\n    # Screen & layout\\n    SCREEN_WIDTH, SCREEN_HEIGHT = 600, 800\\n    GRID_X, GRID_Y = 100, 50\\n    CELL = 30\\n\\n    screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\\n    pygame.display.set_caption(\\\"Tetris-Bejeweled Fusion\\\")\\n\\n    state = GameState()\\n    clock = pygame.time.Clock()\\n    fall_event = pygame.USEREVENT + 1\\n    pygame.time.set_timer(fall_event, 500)  # drop every 0.5s\\n\\n    running = True\\n    while running:\\n        for evt in pygame.event.get():\\n            if evt.type == pygame.QUIT:\\n                running = False\\n            elif evt.type == pygame.KEYDOWN and not state.game_over:\\n                if evt.key == pygame.K_LEFT:\\n                    state.move(-1)\\n                elif evt.key == pygame.K_RIGHT:\\n                    state.move(1)\\n                elif evt.key == pygame.K_UP:\\n                    state.rotate()\\n                elif evt.key == pygame.K_DOWN:\\n                    state.drop()\\n            elif evt.type == fall_event and not state.game_over:\\n                state.drop()\\n\\n        # draw\\n        screen.fill((0,0,0))\\n        # draw grid & gems\\n        for row in range(GRID_HEIGHT):\\n            for col in range(GRID_WIDTH):\\n                cell = state.grid[row][col]\\n                if isinstance(cell, Gem):\\n                    color = cell.color\\n                    pygame.draw.rect(screen, color,\\n                                     (GRID_X + col*CELL, GRID_Y + row*CELL, CELL, CELL))\\n                # grid lines\\n                pygame.draw.rect(screen, (50,50,50),\\n                                 (GRID_X + col*CELL, GRID_Y + row*CELL, CELL, CELL), 1)\\n\\n        # draw current tetromino\\n        for x,y in state.current.get_positions():\\n            if y >= 0:\\n                pygame.draw.rect(screen, state.current.color,\\n                                 (GRID_X + x*CELL, GRID_Y + y*CELL, CELL, CELL))\\n                pygame.draw.rect(screen, (50,50,50),\\n                                 (GRID_X + x*CELL, GRID_Y + y*CELL, CELL, CELL), 1)\\n\\n        pygame.display.flip()\\n        clock.tick(60)\\n\\n    pygame.quit()\\n```\"}"}
