oint(1,2)],\\n    ],\\n    PieceType.L: [\\n        [Point(2,0), Point(0,1), Point(1,1), Point(2,1)],\\n        [Point(1,0), Point(1,1), Point(1,2), Point(2,2)],\\n        [Point(0,1), Point(1,1), Point(2,1), Point(0,2)],\\n        [Point(0,0), Point(1,0), Point(1,1), Point(1,2)],\\n    ],\\n}\\n\\n# Color palette (RGB) for tetrominoes and gems\\nTETROMINO_COLORS = {\\n    PieceType.I: (0, 240, 240),\\n    PieceType.O: (240, 240,   0),\\n    PieceType.T: (160,   0, 240),\\n    PieceType.S: (0, 240,   0),\\n    PieceType.Z: (240,   0,   0),\\n    PieceType.J: (0,   0, 240),\\n    PieceType.L: (240, 160,   0),\\n}\\n\\nGEM_COLORS = list(TETROMINO_COLORS.values())\\n\\n# Scoring parameters\\nLINE_CLEAR_SCORES = {\\n    1: 100,\\n    2: 300,\\n    3: 500,\\n    4: 800,\\n}\\n\\nMATCH_CLEAR_SCORES = {\\n    3: 50,\\n    4: 100,\\n    5: 200,\\n}\\n\\nCHAIN_BONUS_MULTIPLIER = 1.5\\n\\n# Grid cell representation: None or (r, g, b)\\ndef create_empty_grid():\\n    return [[None for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task4:\\n  Objective: Develop the Pygame-based GUI and main game loop: render the grid, animations, current score, next tetromino preview, and integrate controls with mechanics modules.\\n\\n---\\n# **Current Task Requirements**\\nImplement tetromino spawning with a next-piece queue, keyboard controls (move, rotate), gravity, locking into the grid, and conversion of locked tetromino blocks into colored gems.\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport pygame\\nimport random\\nfrom enum import Enum\\nfrom collections import namedtuple\\n\\n# Import constants and data structures from task0\\nGRID_WIDTH = 10\\nGRID_HEIGHT = 20\\nPoint = namedtuple('Point', ['x', 'y'])\\nPieceType = Enum('PieceType', 'I O T S Z J L')\\nTETROMINO_SHAPES = {\\n    PieceType.I: [\\n        [Point(0,1), Point(1,1), Point(2,1), Point(3,1)],\\n        [Point(2,0), Point(2,1), Point(2,2), Point(2,3)],\\n        [Point(0,2), Point(1,2), Point(2,2), Point(3,2)],\\n        [Point(1,0), Point(1,1), Point(1,2), Point(1,3)],\\n    ],\\n    PieceType.O: [\\n        [Point(1,0), Point(2,0), Point(1,1), Point(2,1)],\\n    ] * 4,\\n    PieceType.T: [\\n        [Point(1,0), Point(0,1), Point(1,1), Point(2,1)],\\n        [Point(1,0), Point(1,1), Point(2,1), Point(1,2)],\\n        [Point(0,1), Point(1,1), Point(2,1), Point(1,2)],\\n        [Point(1,0), Point(0,1), Point(1,1), Point(1,2)],\\n    ],\\n    PieceType.S: [\\n        [Point(1,0), Point(2,0), Point(0,1), Point(1,1)],\\n        [Point(1,0), Point(1,1), Point(2,1), Point(2,2)],\\n        [Point(1,1), Point(2,1), Point(0,2), Point(1,2)],\\n        [Point(0,0), Point(0,1), Point(1,1), Point(1,2)],\\n    ],\\n    PieceType.Z: [\\n        [Point(0,0), Point(1,0), Point(1,1), Point(2,1)],\\n        [Point(2,0), Point(1,1), Point(2,1), Point(1,2)],\\n        [Point(0,1), Point(1,1), Point(1,2), Point(2,2)],\\n        [Point(1,0), Point(0,1), Point(1,1), Point(0,2)],\\n    ],\\n    PieceType.J: [\\n        [Point(0,0), Point(0,1), Point(1,1), Point(2,1)],\\n        [Point(1,0), Point(2,0), Point(1,1), Point(1,2)],\\n        [Point(0,1), Point(1,1), Point(2,1), Point(2,2)],\\n        [Point(1,0), Point(1,1), Point(0,2), Point(1,2)],\\n    ],\\n    PieceType.L: [\\n        [Point(2,0), Point(0,1), Point(1,1), Point(2,1)],\\n        [Point(1,0), Point(1,1), Point(1,2), Point(2,2)],\\n        [Point(0,1), Point(1,1), Point(2,1), Point(0,2)],\\n        [Point(0,0), Point(1,0), Point(1,1), Point(1,2)],\\n    ],\\n}\\nTETROMINO_COLORS = {\\n    PieceType.I: (0, 240, 240),\\n    PieceType.O: (240, 240,   0),\\n    PieceType.T: (160,   0, 240),\\n    PieceType.S: (0, 240,   0),\\n    PieceType.Z: (240,   0,   0),\\n    PieceType.J: (0,   0, 240),\\n    PieceType.L: (240, 160,   0),\\n}\\nGEM_COLORS = list(TETROMINO_COLORS.values())\\ncreate_empty_grid = lambda: [[None for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]\\n\\nclass Tetromino:\\n    def __init__(self, piece_type, position=Point(GRID_WIDTH // 2 - 2, 0)):\\n        self.type = piece_type\\n        self.shape = TETROMINO_SHAPES[piece_type][0]\\n        self.color = TETROMINO_COLORS[piece_type]\\n        self.position = position\\n        self.rotation = 0\\n\\n    def rotate(self):\\n        self.rotation = (self.rotation + 1) % len(TETROMINO_SHAPES[self.type])\\n        self.shape = TETROMINO_SHAPES[self.type][self.rotation]\\n\\n    def get_absolute_positions(self):\\n        return [Point(p.x + self.position.x, p.y + self.position.y) for p in self.shape]\\n\\n    def collides(self, grid):\\n        for point in self.get_absolute_positions():\\n            if point.x < 0 or point.x >= GRID_WIDTH or point.y >= GRID_HEIGHT:\\n                return True\\n            if point.y >= 0 and grid[point.y][point.x] is not None:\\n                return True\\n        return False\\n\\nclass GameState:\\n    def __init__(self):\\n        self.grid = create_empty_grid()\\n        self.next_pieces = self.generate_piece_queue()\\n        self.current_piece = self.next_pieces.pop(0)\\n        self.next_pieces.extend(self.generate_piece_queue())\\n        self.score = 0\\n        self.game_over = False\\n        self.drop_timer = 0\\n        self.drop_speed = 60 # Frames per drop\\n\\n    def generate_piece_queue(self, num_pieces = 3):\\n       return [Tetromino(random.choice(list(PieceType))) for _ in range(num_pieces)]\\n\\n    def spawn_new_piece(self):\\n        self.current_piece = self.next_pieces.pop(0)\\n        self.current_piece.position = Point(GRID_WIDTH // 2 - 2, 0)\\n        self.next_pieces.extend(self.generate_piece_queue(1)) # Add one piece to maintain queue length\\n        if self.current_piece.collides(self.grid):\\n            self.game_over = True\\n\\n    def move_piece(self, dx):\\n        new_position = Point(self.current_piece.position.x + dx, self.current_piece.position.y)\\n        self.current_piece.position = new_position\\n        if self.current_piece.collides(self.grid):\\n            self.current_piece.position = Point(self.current_piece.position.x - dx, self.current_piece.position.y) # Undo move\\n\\n    def rotate_piece(self):\\n        original_rotation = self.current_piece.rotation\\n        self.current_piece.rotate()\\n        if self.current_piece.collides(self.grid):\\n            self.current_piece.rotation = original_rotation\\n            self.current_piece.shape = TETROMINO_SHAPES[self.current_piece.type][self.current_piece.rotation]\\n\\n    def drop_piece(self):\\n        new_position = Point(self.current_piece.position.x, self.current_piece.position.y + 1)\\n        self.current_piece.position = new_position\\n        if self.current_piece.collides(self.grid):\\n            self.current_piece.position = Point(self.current_piece.position.x, self.current_piece.position.y - 1)\\n            self.lock_piece()\\n            return True\\n        return False\\n\\n    def lock_piece(self):\\n        for point in self.current_piece.get_absolute_positions():\\n            self.grid[point.y][point.x] = self.current_piece.color\\n        self.spawn_new_piece()\\n\\n    def update(self):\\n        if self.game_over:\\n            return\\n\\n        self.drop_timer += 1\\n        if self.drop_timer >= self.drop_speed:\\n            self.drop_timer = 0\\n            self.drop_piece()\\n\\n    def handle_input(self, event):\\n        if event.type == pygame.KEYDOWN:\\n            if event.key == pygame.K_LEFT:\\n                self.move_piece(-1)\\n            elif event.key == pygame.K_RIGHT:\\n                self.move_piece(1)\\n            elif event.key == pygame.K_DOWN:\\n                self.drop_piece()\\n            elif event.key == pygame.K_UP:\\n                self.rotate_piece()\\n\\nif __name__ == '__main__':\\n    pygame.init()\\n\\n    # Window dimensions\\n    screen_width = 600\\n    screen_height = 800\\n    screen = pygame.display.set_mode((screen_width, screen_height))\\n    pygame.display.set_caption(\\\"Tetris Bejeweled\\\")\\n\\n    # Colors\\n    black = (0, 0, 0)\\n    white = (255, 255, 255)\\n\\n    # Grid cell size\\n    cell_size = 30\\n\\n    # Calculate grid offset to center the grid\\n    grid_offset_x = (screen_width - GRID_WIDTH * cell_size) // 2\\n    grid_offset_y = (screen_height - GRID_HEIGHT * cell_size) // 2\\n\\n    game_state = GameState()\\n\\n    running = True\\n    while running:\\n        for event in pygame.event.get():\\n            if event.type == pygame.QUIT:\\n                running = False\\n            game_state.handle_input(event)\\n\\n        game_state.update()\\n\\n        # Drawing\\n        screen.fill(black)\\n\\n        # Draw the grid\\n        for y in range(GRID_HEIGHT):\\n            for x in range(GRID_WIDTH):\\n                cell_value = game_state.grid[y][x]\\n                if cell_value is not None:\\n                    pygame.draw.rect(screen, cell_value, (grid_offset_x + x * cell_size, grid_offset_y + y * cell_size, cell_size, cell_size))\\n                    pygame.draw.rect(screen, white, (grid_offset_x + x * cell_size, grid_offset_y + y * cell_size, cell_size, cell_size), 1)  # White outline\\n\\n        # Draw the current piece\\n        if not game_state.game_over:\\n            for point in game_state.current_piece.get_absolute_positions():\\n                pygame.draw.rect(screen, game_state.current_piece.color, (grid_offset_x + point.x * cell_size, grid_offset_y + point.y * cell_size, cell_size, cell_size))\\n                pygame.draw.rect(screen, white, (grid_offset_x + point.x * cell_size, grid_offset_y + point.y * cell_size, cell_size, cell_size), 1)  # White outline\\n\\n        # Game Over message\\n        if game_state.game_over:\\n            font = pygame.font.Font(None, 50)\\n            text = font.render(\\\"Game Over\\\", True, white)\\n            text_rect = text.get_rect(center=(screen_width // 2, screen_height // 2))\\n            screen.blit(text, text_rect)\\n\\n        pygame.display.flip()\\n\\n        pygame.time.Clock().tick(60)  # Limit frame rate to 60 FPS\\n\\n    pygame.quit()\\n```\",\n  \"timestamp\": \"2026-05-22T12:18:03.328142\"\n}"}
