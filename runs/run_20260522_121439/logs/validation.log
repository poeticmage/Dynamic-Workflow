ell_size, cell_size), 1)\\n\\n        # Game Over\\n        if state.game_over:\\n            font = pygame.font.Font(None, 50)\\n            msg = font.render(\\\"Game Over\\\", True, white)\\n            rect = msg.get_rect(center=(screen_width//2, screen_height//2))\\n            screen.blit(msg, rect)\\n\\n        pygame.display.flip()\\n        clock.tick(60)\\n\\n    pygame.quit()\\n\\nif __name__ == '__main__':\\n    main()\\n```\"}"}
