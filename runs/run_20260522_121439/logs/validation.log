rotations each)\\nTETROMINO_SHAPES = {\\n    PieceType.I: [\\n        [Point(0,1), Point(1,1), Point(2,1), Point(3,1)],\\n        [Point(2,0), Point(2,1), Point(2,2), Point(2,3)],\\n        [Point(0,2), Point(1,2), Point(2,2), Point(3,2)],\\n        [Point(1,0), Point(1,1), Point(1,2), Point(1,3)],\\n    ],\\n    PieceType.O: [[Point(1,0), Point(2,0), Point(1,1), Point(2,1)]] * 4,\\n    PieceType.T: [\\n        [Point(1,0), Point(0,1), Point(1,1), Point(2,1)],\\n        [Point(1,0), Point(1,1), Point(2,1), Point(1,2)],\\n        [Point(0,1), Point(1,1), Point(2,1), Point(1,2)],\\n        [Point(1,0), Point(0,1), Point(1,1), Point(1,2)],\\n    ],\\n    PieceType.S: [\\n        [Point(1,0), Point(2,0), Point(0,1), Point(1,1)],\\n        [Point(1,0), Point(1,1), Point(2,1), Point(2,2)],\\n        [Point(1,1), Point(2,1), Point(0,2), Point(1,2)],\\n        [Point(0,0), Point(0,1), Point(1,1), Point(1,2)],\\n    ],\\n    PieceType.Z: [\\n        [Point(0,0), Point(1,0), Point(1,1), Point(2,1)],\\n        [Point(2,0), Point(1,1), Point(2,1), Point(1,2)],\\n        [Point(0,1), Point(1,1), Point(1,2), Point(2,2)],\\n        [Point(1,0), Point(0,1), Point(1,1), Point(0,2)],\\n    ],\\n    PieceType.J: [\\n        [Point(0,0), Point(0,1), Point(1,1), Point(2,1)],\\n        [Point(1,0), Point(2,0), Point(1,1), Point(1,2)],\\n        [Point(0,1), Point(1,1), Point(2,1), Point(2,2)],\\n        [Point(1,0), Point(1,1), Point(0,2), Point(1,2)],\\n    ],\\n    PieceType.L: [\\n        [Point(2,0), Point(0,1), Point(1,1), Point(2,1)],\\n        [Point(1,0), Point(1,1), Point(1,2), Point(2,2)],\\n        [Point(0,1), Point(1,1), Point(2,1), Point(0,2)],\\n        [Point(0,0), Point(1,0), Point(1,1), Point(1,2)],\\n    ],\\n}\\n\\n# Colors for each tetromino/gem\\nTETROMINO_COLORS = {\\n    PieceType.I: (0,240,240),\\n    PieceType.O: (240,240,0),\\n    PieceType.T: (160,0,240),\\n    PieceType.S: (0,240,0),\\n    PieceType.Z: (240,0,0),\\n    PieceType.J: (0,0,240),\\n    PieceType.L: (240,160,0),\\n}\\n\\n# Represent locked blocks as Gems\\nclass Gem:\\n    def __init__(self, color):\\n        self.color = color\\n\\ndef create_empty_grid():\\n    # Grid holds either None or Gem instances\\n    return [[None for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]\\n\\nclass Tetromino:\\n    def __init__(self, piece_type):\\n        self.type = piece_type\\n        self.rotation = 0\\n        self.shape = TETROMINO_SHAPES[piece_type][0]\\n        self.color = TETROMINO_COLORS[piece_type]\\n        self.x = GRID_WIDTH//2 - 2\\n        self.y = 0\\n\\n    def rotate(self):\\n        self.rotation = (self.rotation + 1) % len(TETROMINO_SHAPES[self.type])\\n        self.shape = TETROMINO_SHAPES[self.type][self.rotation]\\n\\n    def get_cells(self):\\n        return [(self.x + p.x, self.y + p.y) for p in self.shape]\\n\\nclass GameState:\\n    def __init__(self):\\n        self.grid = create_empty_grid()\\n        self.current = self.spawn()\\n        self.next_piece = self.spawn()\\n        self.game_over = False\\n\\n    def spawn(self):\\n        return Tetromino(random.choice(list(PieceType)))\\n\\n    def is_valid(self, tetro):\\n        for x,y in tetro.get_cells():\\n            if x < 0 or x >= GRID_WIDTH or y >= GRID_HEIGHT:\\n                return False\\n            if y >= 0 and self.grid[y][x] is not None:\\n                return False\\n        return True\\n\\n    def lock(self):\\n        for x,y in self.current.get_cells():\\n            if 0 <= y < GRID_HEIGHT:\\n                self.grid[y][x] = Gem(self.current.color)\\n        self.current = None\\n\\n    def move(self, dx, dy=0):\\n        self.current.x += dx\\n        self.current.y += dy\\n        if not self.is_valid(self.current):\\n            self.current.x -= dx\\n            self.current.y -= dy\\n            return False\\n        return True\\n\\n    def rotate(self):\\n        old_rot = self.current.rotation\\n        self.current.rotate()\\n        if not self.is_valid(self.current):\\n            # revert\\n            self.current.rotation = old_rot\\n            self.current.shape = TETROMINO_SHAPES[self.current.type][old_rot]\\n\\n    def update(self):\\n        if self.current is None:\\n            self.current = self.next_piece\\n            self.next_piece = self.spawn()\\n            if not self.is_valid(self.current):\\n                self.game_over = True\\n                return\\n        # gravity\\n        if not self.move(0,1):\\n            self.lock()\\n\\ndef draw_grid(surface, grid, cell_size):\\n    for r in range(GRID_HEIGHT):\\n        for c in range(GRID_WIDTH):\\n            cell = grid[r][c]\\n            if isinstance(cell, Gem):\\n                pygame.draw.rect(surface, cell.color,\\n                                 (c*cell_size, r*cell_size, cell_size, cell_size))\\n            # grid lines\\n            pygame.draw.rect(surface, (50,50,50),\\n                             (c*cell_size, r*cell_size, cell_size, cell_size), 1)\\n\\ndef draw_tetromino(surface, tetro, cell_size):\\n    if tetro is None: return\\n    for x,y in tetro.get_cells():\\n        if y >= 0:\\n            pygame.draw.rect(surface, tetro.color,\\n                             (x*cell_size, y*cell_size, cell_size, cell_size))\\n            pygame.draw.rect(surface, (50,50,50),\\n                             (x*cell_size, y*cell_size, cell_size, cell_size), 1)\\n\\ndef main():\\n    pygame.init()\\n    CELL = 30\\n    W, H = GRID_WIDTH*CELL, GRID_HEIGHT*CELL\\n    screen = pygame.display.set_mode((W,H))\\n    pygame.display.set_caption(\\\"Tetris-Bejeweled\\\")\\n    clock = pygame.time.Clock()\\n\\n    state = GameState()\\n\\n    # use timer event for gravity\\n    FALL = pygame.USEREVENT+1\\n    pygame.time.set_timer(FALL, 500)  # half-second drop\\n\\n    running = True\\n    while running and not state.game_over:\\n        for e in pygame.event.get():\\n            if e.type == pygame.QUIT:\\n                running = False\\n            elif e.type == pygame.KEYDOWN:\\n                if e.key == pygame.K_LEFT:\\n                    state.move(-1,0)\\n                elif e.key == pygame.K_RIGHT:\\n                    state.move(1,0)\\n                elif e.key == pygame.K_DOWN:\\n                    state.move(0,1)\\n                elif e.key == pygame.K_UP:\\n                    state.rotate()\\n            elif e.type == FALL:\\n                state.update()\\n\\n        screen.fill((0,0,0))\\n        draw_grid(screen, state.grid, CELL)\\n        draw_tetromino(screen, state.current, CELL)\\n        pygame.display.flip()\\n        clock.tick(60)\\n\\n    pygame.quit()\\n\\nif __name__ == '__main__':\\n    main()\\n```\"}"}
