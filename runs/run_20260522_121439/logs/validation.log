S = 'S'\\n    Z = 'Z'\\n    J = 'J'\\n    L = 'L'\\n\\n# [Tetromino shapes and colors omitted for brevity; same as before]\\n\\n# Scoring parameters\\nMATCH_CLEAR_SCORES = {\\n    3: 50,\\n    4: 100,\\n    5: 200,\\n}\\nCHAIN_BONUS_MULTIPLIER = 1.5\\n\\ndef create_empty_grid():\\n    \\\"\\\"\\\"Initialize an empty GRID_HEIGHT×GRID_WIDTH grid of None.\\\"\\\"\\\"\\n    return [[None for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]\\n\\ndef detect_matches(grid):\\n    \\\"\\\"\\\"\\n    Detects horizontal and vertical matches of length >=3.\\n    Returns a list of match-lists, each a list of (x,y) tuples.\\n    \\\"\\\"\\\"\\n    matches = []\\n\\n    # Horizontal\\n    for y in range(GRID_HEIGHT):\\n        x = 0\\n        while x < GRID_WIDTH - 2:\\n            if grid[y][x] is not None:\\n                color = grid[y][x]\\n                length = 1\\n                # count run length\\n                while x + length < GRID_WIDTH and grid[y][x+length] == color:\\n                    length += 1\\n                if length >= 3:\\n                    match = [(x+i, y) for i in range(length)]\\n                    matches.append(match)\\n                    x += length\\n                    continue\\n            x += 1\\n\\n    # Vertical\\n    for x in range(GRID_WIDTH):\\n        y = 0\\n        while y < GRID_HEIGHT - 2:\\n            if grid[y][x] is not None:\\n                color = grid[y][x]\\n                length = 1\\n                while y + length < GRID_HEIGHT and grid[y+length][x] == color:\\n                    length += 1\\n                if length >= 3:\\n                    match = [(x, y+i) for i in range(length)]\\n                    matches.append(match)\\n                    y += length\\n                    continue\\n            y += 1\\n\\n    return matches\\n\\ndef clear_matches(grid, matches):\\n    \\\"\\\"\\\"Clears all matched cells. Returns number of gems cleared.\\\"\\\"\\\"\\n    cleared = 0\\n    for match in matches:\\n        for x,y in match:\\n            if grid[y][x] is not None:\\n                grid[y][x] = None\\n                cleared += 1\\n    return cleared\\n\\ndef apply_gravity(grid):\\n    \\\"\\\"\\\"Let gems fall down to fill empty cells.\\\"\\\"\\\"\\n    for x in range(GRID_WIDTH):\\n        write_row = GRID_HEIGHT - 1\\n        for y in range(GRID_HEIGHT - 1, -1, -1):\\n            if grid[y][x] is not None:\\n                grid[write_row][x] = grid[y][x]\\n                if write_row != y:\\n                    grid[y][x] = None\\n                write_row -= 1\\n\\ndef handle_chain_reaction_and_score(grid):\\n    \\\"\\\"\\\"\\n    Repeatedly detect & clear matches, apply gravity,\\n    accumulate score per match, then apply chain bonus.\\n    Returns (total_score, chain_length).\\n    \\\"\\\"\\\"\\n    total_score = 0\\n    chain_length = 0\\n\\n    while True:\\n        matches = detect_matches(grid)\\n        if not matches:\\n            break\\n\\n        # Score each match in this cycle\\n        for match in matches:\\n            length = len(match)\\n            if length in MATCH_CLEAR_SCORES:\\n                total_score += MATCH_CLEAR_SCORES[length]\\n            else:\\n                # extra points beyond size 5\\n                total_score += MATCH_CLEAR_SCORES[5] + (length - 5) * 20\\n\\n        # Clear & gravity\\n        clear_matches(grid, matches)\\n        apply_gravity(grid)\\n\\n        chain_length += 1\\n\\n    # Apply chain bonus if more than one reaction\\n    if chain_length > 1:\\n        total_score = int(total_score * (CHAIN_BONUS_MULTIPLIER ** (chain_length - 1)))\\n\\n    return total_score, chain_length\\n\\n# Example standalone test\\nif __name__ == '__main__':\\n    grid = create_empty_grid()\\n    # Populate test grid with some colors\\n    grid[0][0:3] = [(255,0,0)]*3  # horizontal red match\\n    grid[1][0] = (0,255,0)\\n    grid[2][0] = (0,255,0)\\n    grid[3][0] = (0,255,0)        # vertical green match\\n\\n    print(\\\"Before:\\\")\\n    for row in grid:\\n        print(row)\\n\\n    score, chains = handle_chain_reaction_and_score(grid)\\n\\n    print(f\\\"\\\\nAfter: (score={score}, chains={chains})\\\")\\n    for row in grid:\\n        print(row)\\n```\\n\\nKey improvements:\\n- `detect_matches` now skips past full runs to avoid duplicate sub-matches.\\n- Scoring is done per match, then a single chain multiplier is applied.\\n- Merged scoring into `handle_chain_reaction_and_score` for simpler downstream use.\"}"}
