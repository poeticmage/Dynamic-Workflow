oint(1,2)],\\n    ],\\n    PieceType.L: [\\n        [Point(2,0), Point(0,1), Point(1,1), Point(2,1)],\\n        [Point(1,0), Point(1,1), Point(1,2), Point(2,2)],\\n        [Point(0,1), Point(1,1), Point(2,1), Point(0,2)],\\n        [Point(0,0), Point(1,0), Point(1,1), Point(1,2)],\\n    ],\\n}\\n\\n# Color palette (RGB) for tetrominoes and gems\\nTETROMINO_COLORS = {\\n    PieceType.I: (0, 240, 240),\\n    PieceType.O: (240, 240,   0),\\n    PieceType.T: (160,   0, 240),\\n    PieceType.S: (0, 240,   0),\\n    PieceType.Z: (240,   0,   0),\\n    PieceType.J: (0,   0, 240),\\n    PieceType.L: (240, 160,   0),\\n}\\n\\nGEM_COLORS = list(TETROMINO_COLORS.values())\\n\\n# Scoring parameters\\nLINE_CLEAR_SCORES = {\\n    1: 100,\\n    2: 300,\\n    3: 500,\\n    4: 800,\\n}\\n\\nMATCH_CLEAR_SCORES = {\\n    3: 50,\\n    4: 100,\\n    5: 200,\\n}\\n\\nCHAIN_BONUS_MULTIPLIER = 1.5\\n\\n# Grid cell representation: None or (r, g, b)\\ndef create_empty_grid():\\n    return [[None for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task4:\\n  Objective: Develop the Pygame-based GUI and main game loop: render the grid, animations, current score, next tetromino preview, and integrate controls with mechanics modules.\\n\\n---\\n# **Current Task Requirements**\\nImplement tetromino spawning, keyboard controls (move, rotate), gravity, locking into the grid, and conversion of locked tetromino blocks into colored gems.\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport pygame\\nimport random\\nfrom enum import Enum\\nfrom collections import namedtuple\\n\\n# Import constants and data structures from task0\\nGRID_WIDTH = 10\\nGRID_HEIGHT = 20\\nPoint = namedtuple('Point', ['x', 'y'])\\nPieceType = Enum('PieceType', 'I O T S Z J L')\\nTETROMINO_SHAPES = {\\n    PieceType.I: [\\n        [Point(0,1), Point(1,1), Point(2,1), Point(3,1)],\\n        [Point(2,0), Point(2,1), Point(2,2), Point(2,3)],\\n        [Point(0,2), Point(1,2), Point(2,2), Point(3,2)],\\n        [Point(1,0), Point(1,1), Point(1,2), Point(1,3)],\\n    ],\\n    PieceType.O: [\\n        [Point(1,0), Point(2,0), Point(1,1), Point(2,1)],\\n    ] * 4,\\n    PieceType.T: [\\n        [Point(1,0), Point(0,1), Point(1,1), Point(2,1)],\\n        [Point(1,0), Point(1,1), Point(2,1), Point(1,2)],\\n        [Point(0,1), Point(1,1), Point(2,1), Point(1,2)],\\n        [Point(1,0), Point(0,1), Point(1,1), Point(1,2)],\\n    ],\\n    PieceType.S: [\\n        [Point(1,0), Point(2,0), Point(0,1), Point(1,1)],\\n        [Point(1,0), Point(1,1), Point(2,1), Point(2,2)],\\n        [Point(1,1), Point(2,1), Point(0,2), Point(1,2)],\\n        [Point(0,0), Point(0,1), Point(1,1), Point(1,2)],\\n    ],\\n    PieceType.Z: [\\n        [Point(0,0), Point(1,0), Point(1,1), Point(2,1)],\\n        [Point(2,0), Point(1,1), Point(2,1), Point(1,2)],\\n        [Point(0,1), Point(1,1), Point(1,2), Point(2,2)],\\n        [Point(1,0), Point(0,1), Point(1,1), Point(0,2)],\\n    ],\\n    PieceType.J: [\\n        [Point(0,0), Point(0,1), Point(1,1), Point(2,1)],\\n        [Point(1,0), Point(2,0), Point(1,1), Point(1,2)],\\n        [Point(0,1), Point(1,1), Point(2,1), Point(2,2)],\\n        [Point(1,0), Point(1,1), Point(0,2), Point(1,2)],\\n    ],\\n    PieceType.L: [\\n        [Point(2,0), Point(0,1), Point(1,1), Point(2,1)],\\n        [Point(1,0), Point(1,1), Point(1,2), Point(2,2)],\\n        [Point(0,1), Point(1,1), Point(2,1), Point(0,2)],\\n        [Point(0,0), Point(1,0), Point(1,1), Point(1,2)],\\n    ],\\n}\\nTETROMINO_COLORS = {\\n    PieceType.I: (0, 240, 240),\\n    PieceType.O: (240, 240,   0),\\n    PieceType.T: (160,   0, 240),\\n    PieceType.S: (0, 240,   0),\\n    PieceType.Z: (240,   0,   0),\\n    PieceType.J: (0,   0, 240),\\n    PieceType.L: (240, 160,   0),\\n}\\nGEM_COLORS = list(TETROMINO_COLORS.values())\\nLINE_CLEAR_SCORES = {\\n    1: 100,\\n    2: 300,\\n    3: 500,\\n    4: 800,\\n}\\nMATCH_CLEAR_SCORES = {\\n    3: 50,\\n    4: 100,\\n    5: 200,\\n}\\nCHAIN_BONUS_MULTIPLIER = 1.5\\n\\ndef create_empty_grid():\\n    return [[None for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]\\n\\nclass Tetromino:\\n    def __init__(self, piece_type):\\n        self.type = piece_type\\n        self.shape = TETROMINO_SHAPES[self.type][0]\\n        self.color = TETROMINO_COLORS[self.type]\\n        self.rotation = 0\\n        self.x = GRID_WIDTH // 2 - 2  # Center the piece horizontally\\n        self.y = 0\\n\\n    def rotate(self, direction):\\n        \\\"\\\"\\\"Rotates the tetromino.\\\"\\\"\\\"\\n        self.rotation = (self.rotation + direction) % len(TETROMINO_SHAPES[self.type])\\n        self.shape = TETROMINO_SHAPES[self.type][self.rotation]\\n\\n    def get_absolute_positions(self):\\n        \\\"\\\"\\\"Returns the absolute positions of the tetromino blocks on the grid.\\\"\\\"\\\"\\n        return [Point(x=block.x + self.x, y=block.y + self.y) for block in self.shape]\\n\\n    def collides(self, grid):\\n        \\\"\\\"\\\"Checks if the tetromino collides with the grid boundaries or other blocks.\\\"\\\"\\\"\\n        for block in self.get_absolute_positions():\\n            if block.x < 0 or block.x >= GRID_WIDTH or block.y >= GRID_HEIGHT:\\n                return True\\n            if block.y >= 0 and grid[block.y][block.x] is not None:\\n                return True\\n        return False\\n\\nclass GameState:\\n    def __init__(self):\\n        self.grid = create_empty_grid()\\n        self.current_piece = self.new_tetromino()\\n        self.next_piece = self.new_tetromino()\\n        self.score = 0\\n        self.game_over = False\\n        self.drop_speed = 1 # blocks per second\\n\\n    def new_tetromino(self):\\n        \\\"\\\"\\\"Creates a new tetromino of a random type.\\\"\\\"\\\"\\n        piece_type = random.choice(list(PieceType))\\n        return Tetromino(piece_type)\\n\\n    def lock_piece(self):\\n        \\\"\\\"\\\"Locks the current piece into the grid and converts it to gems.\\\"\\\"\\\"\\n        for block in self.current_piece.get_absolute_positions():\\n            self.grid[block.y][block.x] = self.current_piece.color\\n        self.current_piece = None  # Remove the current piece\\n        \\n\\n    def move_piece_down(self):\\n        \\\"\\\"\\\"Moves the current piece down by one cell.\\\"\\\"\\\"\\n        self.current_piece.y += 1\\n        if self.current_piece.collides(self.grid):\\n            self.current_piece.y -= 1\\n            self.lock_piece()\\n            return True # Indicate that the piece was locked\\n\\n        return False\\n\\n    def move_piece_sideways(self, direction):\\n        \\\"\\\"\\\"Moves the current piece sideways (left or right).\\\"\\\"\\\"\\n        self.current_piece.x += direction\\n        if self.current_piece.collides(self.grid):\\n            self.current_piece.x -= direction\\n\\n    def rotate_piece(self, direction):\\n        \\\"\\\"\\\"Rotates the current piece.\\\"\\\"\\\"\\n        original_rotation = self.current_piece.rotation\\n        self.current_piece.rotate(direction)\\n        if self.current_piece.collides(self.grid):\\n            self.current_piece.rotation = original_rotation\\n            self.current_piece.shape = TETROMINO_SHAPES[self.current_piece.type][self.current_piece.rotation] # Restore the original shape\\n\\n    def update(self):\\n        \\\"\\\"\\\"Updates the game state (gravity, collision detection, locking).\\\"\\\"\\\"\\n        if self.current_piece is None:\\n            self.current_piece = self.new_tetromino()\\n            if self.current_piece.collides(self.grid):\\n                self.game_over = True\\n                return\\n            self.next_piece = self.new_tetromino()\\n\\n\\n        piece_locked = self.move_piece_down()\\n        if piece_locked:\\n            self.clear_lines()\\n            self.find_matches()\\n\\n    def clear_lines(self):\\n        \\\"\\\"\\\"Clears complete lines in the grid.\\\"\\\"\\\"\\n        lines_to_clear = []\\n        for i in range(GRID_HEIGHT):\\n            if all(self.grid[i][j] is not None for j in range(GRID_WIDTH)):\\n                lines_to_clear.append(i)\\n\\n        if lines_to_clear:\\n            self.score += LINE_CLEAR_SCORES[len(lines_to_clear)]\\n            for line_index in lines_to_clear:\\n                del self.grid[line_index]\\n                self.grid.insert(0, [None] * GRID_WIDTH)  # Add empty line at the top\\n\\n    def find_matches(self):\\n        \\\"\\\"\\\"Finds and clears matching gems in the grid.\\\"\\\"\\\"\\n        # Implement the gem matching logic here.  This is a stub.\\n        pass  # Replace with actual match-3 detection and clearing logic\\n\\n# Pygame initialization (moved to task 4)\\n# SCREEN_WIDTH = 800\\n# SCREEN_HEIGHT = 600\\n# GRID_CELL_SIZE = 30\\n# pygame.init()\\n# screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\\n# pygame.display.set_caption(\\\"Tetris Bejeweled\\\")\\n\\n# Colors (moved to task 4)\\n# BLACK = (0, 0, 0)\\n# WHITE = (255, 255, 255)\\n\\n# Game loop (moved to task 4)\\n# game_state = GameState()\\n# clock = pygame.time.Clock()\\n\\n# def draw_grid(screen, grid):\\n#     \\\"\\\"\\\"Draws the grid on the screen.\\\"\\\"\\\"\\n#     for row_index, row in enumerate(grid):\\n#         for col_index, cell in enumerate(row):\\n#             if cell is not None:\\n#                 pygame.draw.rect(\\n#                     screen,\\n#                     cell,\\n#                     (col_index * GRID_CELL_SIZE, row_index * GRID_CELL_SIZE, GRID_CELL_SIZE, GRID_CELL_SIZE)\\n#                 )\\n#                 pygame.draw.rect(\\n#                     screen,\\n#                     WHITE,\\n#                     (col_index * GRID_CELL_SIZE, row_index * GRID_CELL_SIZE, GRID_CELL_SIZE, GRID_CELL_SIZE),\\n#                     1\\n#                 ) # Add white borders around the gems\\n\\n# def draw_tetromino(screen, tetromino):\\n#     \\\"\\\"\\\"Draws the current tetromino on the screen.\\\"\\\"\\\"\\n#     if tetromino is not None:\\n#         for block in tetromino.get_absolute_positions():\\n#             pygame.draw.rect(\\n#                 screen,\\n#                 tetromino.color,\\n#                 (block.x * GRID_CELL_SIZE, block.y * GRID_CELL_SIZE, GRID_CELL_SIZE, GRID_CELL_SIZE)\\n#             )\\n#             pygame.draw.rect(\\n#                 screen,\\n#                 WHITE,\\n#                 (block.x * GRID_CELL_SIZE, block.y * GRID_CELL_SIZE, GRID_CELL_SIZE, GRID_CELL_SIZE),\\n#                 1\\n#             ) # Add white borders around the tetrominos\\n\\n# def draw_score(screen, score):\\n#     \\\"\\\"\\\"Draws the score on the screen.\\\"\\\"\\\"\\n#     font = pygame.font.Font(None, 36)\\n#     text = font.render(f\\\"Score: {score}\\\", True, WHITE)\\n#     screen.blit(text, (10, 10))\\n\\n# def draw_next_piece(screen, next_piece):\\n#     \\\"\\\"\\\"Draws the next piece preview on the screen.\\\"\\\"\\\"\\n#     font = pygame.font.Font(None, 24)\\n#     text = font.render(\\\"Next Piece:\\\", True, WHITE)\\n#     screen.blit(text, (SCREEN_WIDTH - 150, 10))\\n#     if next_piece:\\n#         for block in next_piece.shape:\\n#             pygame.draw.rect(\\n#                 screen,\\n#                 next_piece.color,\\n#                 ((block.x + 12) * GRID_CELL_SIZE, (block.y + 2) * GRID_CELL_SIZE, GRID_CELL_SIZE, GRID_CELL_SIZE)\\n#             )\\n#             pygame.draw.rect(\\n#                 screen,\\n#                 WHITE,\\n#                 ((block.x + 12) * GRID_CELL_SIZE, (block.y + 2) * GRID_CELL_SIZE, GRID_CELL_SIZE, GRID_CELL_SIZE),\\n#                 1\\n#             )\\n\\n\\n# last_drop_time = pygame.time.get_ticks() # Initialize time\\n# drop_interval = 1000 / game_state.drop_speed # milliseconds\\n\\n# running = True\\n# while running:\\n#     for event in pygame.event.get():\\n#         if event.