the grid, moving gems down to fill empty spaces.\\\"\\\"\\\"\\n    for x in range(GRID_WIDTH):\\n        empty_space = None\\n        for y in range(GRID_HEIGHT - 1, -1, -1):\\n            if grid[y][x] is None:\\n                if empty_space is None:\\n                    empty_space = y\\n            else:\\n                if empty_space is not None:\\n                    grid[empty_space][x] = grid[y][x]\\n                    grid[y][x] = None\\n                    empty_space -= 1\\n\\n\\ndef handle_chain_reaction(grid):\\n    \\\"\\\"\\\"Handles chain reactions, detecting and clearing matches until no more matches are found.\\\"\\\"\\\"\\n    total_cleared = 0\\n    chain_length = 0\\n    while True:\\n        matches = detect_matches(grid)\\n        if not matches:\\n            break\\n\\n        cleared_count = clear_matches(grid, matches)\\n        total_cleared += cleared_count\\n        apply_gravity(grid)\\n        chain_length += 1\\n\\n    return total_cleared, chain_length\\n\\n\\ndef calculate_match_score(cleared_count, chain_length):\\n    \\\"\\\"\\\"Calculates the score for clearing matches, including chain bonus.\\\"\\\"\\\"\\n    score = 0\\n    match_count = cleared_count\\n    if match_count in MATCH_CLEAR_SCORES:\\n            score += MATCH_CLEAR_SCORES[match_count]\\n    elif match_count > 5:\\n        score += MATCH_CLEAR_SCORES[5] + (match_count - 5) * 20  # Add extra points for matches > 5\\n\\n    if chain_length > 1:\\n        score *= (CHAIN_BONUS_MULTIPLIER ** (chain_length - 1))\\n\\n    return int(score)\\n\\n\\nif __name__ == '__main__':\\n    # Example usage:\\n    grid = create_empty_grid()\\n\\n    # Fill the grid with some example gem colors\\n    grid[0][0] = (255, 0, 0)  # Red\\n    grid[0][1] = (255, 0, 0)  # Red\\n    grid[0][2] = (255, 0, 0)  # Red\\n    grid[0][3] = (0, 255, 0)  # Green\\n    grid[1][0] = (0, 0, 255)  # Blue\\n    grid[1][1] = (255, 0, 0)  # Red\\n    grid[1][2] = (0, 255, 0)  # Green\\n    grid[2][0]