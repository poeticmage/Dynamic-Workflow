\\"\\\"\\\"\\n        if scoring_criteria is None and scoring_file is None:\\n            raise ValueError(\\\"Provide either scoring_criteria dict or scoring_file path\\\")\\n\\n        if scoring_criteria is not None:\\n            self.scoring_criteria = scoring_criteria\\n        else:\\n            try:\\n                with open(scoring_file, 'r', encoding='utf-8') as f:\\n                    self.scoring_criteria = json.load(f)\\n            except Exception as e:\\n                raise ValueError(f\\\"Failed to load scoring criteria from '{scoring_file}': {e}\\\")\\n\\n    def score_response(self, question: str, response: str) -> int:\\n        \\\"\\\"\\\"\\n        Calculates a total score for a given response.\\n\\n        For each criterion under the question, counts how many keywords appear\\n        (case-insensitive) and awards `score * occurrences`.\\n\\n        Args:\\n            question: The interview question key.\\n            response: The candidate's answer.\\n\\n        Returns:\\n            Total integer score. Zero if no criteria or no matches.\\n        \\\"\\\"\\\"\\n        criteria = self.scoring_criteria.get(question, {})\\n        if not criteria:\\n            return 0\\n\\n        resp_lower = response.lower()\\n        total_score = 0\\n\\n        for crit_conf in criteria.values():\\n            keywords: List[str] = crit_conf.get(\\\"keywords\\\", [])\\n            weight: int = crit_conf.get(\\\"score\\\", 0)\\n            occurrences = sum(resp_lower.count(kw.lower()) for kw in keywords)\\n            total_score += weight * occurrences\\n\\n        return total_score\\n\\n    def generate_feedback(self, question: str, response: str) -> str:\\n        \\\"\\\"\\\"\\n        Produces feedback listing which criteria were met or missed.\\n\\n        A criterion is 'met' if at least one keyword was found; otherwise 'missed'.\\n\\n        Args:\\n            question: The interview question key.\\n            response: The candidate's answer.\\n\\n        Returns:\\n            Multi-line string feedback.\\n        \\\"\\\"\\\"\\n        criteria = self.scoring_criteria.get(question, {})\\n        if not criteria:\\n            return f\\\"No scoring criteria defined for question: '{question}'.\\\"\\n\\n        resp_lower = response.lower()\\n        feedback_lines: List[str] = []\\n\\n        for crit_name, crit_conf in criteria.items():\\n            keywords: List[str] = crit_conf.get(\\\"keywords\\\", [])\\n            weight: int = crit_conf.get(\\\"score\\\", 0)\\n            found = [kw for kw in keywords if kw.lower() in resp_lower]\\n            if found:\\n                feedback_lines.append(\\n                    f\\\"  - Met '{crit_name}' (+{weight} per match): matched {found}\\\"\\n                )\\n            else:\\n                feedback_lines.append(\\n                    f\\\"  - Missed '{crit_name}': expected keywords {keywords}\\\"\\n                )\\n\\n        return \\\"\\\\n\\\".join(feedback_lines)\\n\\n\\n# Example usage:\\nif __name__ == \\\"__main__\\\":\\n    # Load criteria from JSON file\\n    scorer = ResponseScorer(scoring_file=\\\"scoring_criteria.json\\\")\\n\\n    # Sample question and response\\n    q = \\\"What is the difference between TCP and UDP?\\\"\\n    r = \\\"TCP is connection-oriented and reliable; UDP is connectionless, faster, but less reliable.\\\"\\n\\n    score = scorer.score_response(q, r)\\n    feedback = scorer.generate_feedback(q, r)\\n\\n    print(f\\\"Score: {score}\\\")\\n    print(\\\"Feedback:\\\")\\n    print(feedback)\\n```\"}"}
