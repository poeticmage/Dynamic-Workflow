ng criteria.\\n                                         The JSON file should have a structure like:\\n                                         {\\n                                             \\\"question1\\\": {\\n                                                 \\\"criteria1\\\": {\\\"keywords\\\": [\\\"keyword1\\\", \\\"keyword2\\\"], \\\"score\\\": 2},\\n                                                 \\\"criteria2\\\": {\\\"keywords\\\": [\\\"keyword3\\\"], \\\"score\\\": 3}\\n                                             },\\n                                             \\\"question2\\\": {\\n                                                 \\\"criteria1\\\": {\\\"keywords\\\": [\\\"keyword4\\\"], \\\"keyword5\\\"], \\\"score\\\": 5}\\n                                             }\\n                                         }\\n        \\\"\\\"\\\"\\n        try:\\n            with open(scoring_criteria_file, 'r') as f:\\n                self.scoring_criteria = json.load(f)\\n        except FileNotFoundError:\\n            print(f\\\"Error: Scoring criteria file '{scoring_criteria_file}' not found.\\\")\\n            self.scoring_criteria = {}\\n        except json.JSONDecodeError:\\n            print(f\\\"Error: Invalid JSON format in '{scoring_criteria_file}'.\\\")\\n            self.scoring_criteria = {}\\n\\n    def score_response(self, question: str, response: str) -> int:\\n        \\\"\\\"\\\"\\n        Scores a candidate's response based on the predefined scoring criteria.\\n\\n        Args:\\n            question (str): The interview question.\\n            response (str): The candidate's response.\\n\\n        Returns:\\n            int: The total score for the response.\\n        \\\"\\\"\\\"\\n        if not self.scoring_criteria:\\n            print(\\\"Warning: No scoring criteria loaded. Returning a default score of 0.\\\")\\n            return 0\\n\\n        question_criteria = self.scoring_criteria.get(question)\\n        if not question_criteria:\\n            print(f\\\"Warning: No scoring criteria found for question '{question}'. Returning a score of 0.\\\")\\n            return 0\\n\\n        total_score = 0\\n        for criteria, details in question_criteria.items():\\n            keywords = details.get(\\\"keywords\\\", [])\\n            score = details.get(\\\"score\\\", 0)\\n\\n            if any(keyword.lower() in response.lower() for keyword in keywords):\\n                total_score += score\\n\\n        return total_score\\n\\n    def generate_feedback(self, question: str, response: str) -> str:\\n        \\\"\\\"\\\"\\n        Generates feedback for a candidate's response based on the scoring criteria.\\n\\n        Args:\\n            question (str): The interview question.\\n            response (str): The candidate's response.\\n\\n        Returns:\\n            str: Feedback string indicating which criteria were met or missed.\\n        \\\"\\\"\\\"\\n        if not self.scoring_criteria:\\n            return \\\"No scoring criteria loaded, so no feedback can be provided.\\\"\\n\\n        question_criteria = self.scoring_criteria.get(question)\\n        if not question_criteria:\\n            return f\\\"No scoring criteria found for question '{question}', so no feedback can be provided.\\\"\\n\\n        feedback = \\\"\\\"\\n        for criteria, details in question_criteria.items():\\n            keywords = details.get(\\\"keywords\\\", [])\\n            score = details.get(\\\"score\\\", 0)\\n            met_criteria = any(keyword.lower() in response.lower() for keyword in keywords)\\n\\n            if met_criteria:\\n                feedback += f\\\"  - Met criteria: {criteria} (Score: {score})\\\\n\\\"\\n            else:\\n                feedback += f\\\"  - Missed criteria: {criteria} (Keywords: {keywords})\\\\n\\\"\\n\\n        return feedback\\n\\n    def evaluate_interview(self, interview_data: Dict) -> Dict:\\n        \\\"\\\"\\\"\\n        Evaluates the entire interview, scoring each response and generating feedback.\\n\\n        Args:\\n            interview_data (Dict): A dictionary containing interview data, structured as:\\n                                     {\\n                                         \\\"candidate_email\\\": \\\"email@example.com\\\",\\n                                         \\\"responses\\\": [\\n                                             {\\\"question\\\": \\\"Question 1\\\", \\\"response\\\": \\\"Answer 1\\\"},\\n                                             {\\\"question\\\": \\\"Question 2\\\", \\\"response\\\": \\\"Answer 2\\\"}\\n                                         ]\\n                                     }\\n\\n        Returns:\\n            Dict: A dictionary containing the evaluation report, including scores and feedback\\n                  for each question. The structure is as follows:\\n                  {\\n                      \\\"candidate_email\\\": \\\"email@example.com\\\",\\n                      \\\"evaluation_results\\\": [\\n                          {\\n                              \\\"question\\\": \\\"Question 1\\\",\\n                              \\\"score\\\": 3,\\n                              \\\"feedback\\\": \\\"Feedback for Question 1\\\"\\n                          },\\n                          {\\n                              \\\"question\\\": \\\"Question 2\\\",\\n                              \\\"score\\\": 5,\\n                              \\\"feedback\\\": \\\"Feedback for Question 2\\\"\\n                          }\\n                      ],\\n                      \\\"total_score\\\": 8\\n                  }\\n        \\\"\\\"\\\"\\n\\n        candidate_email = interview_data.get(\\\"candidate_email\\\", \\\"unknown\\\")\\n        responses = interview_data.get(\\\"responses\\\", [])\\n        evaluation_results = []\\n        total_score = 0\\n\\n        for qa in responses:\\n            question = qa.get(\\\"question\\\", \\\"\\\")\\n            respon