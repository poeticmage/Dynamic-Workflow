       \\\"definition\\\": {\\n                    \\\"keywords\\\": [\\\"objects\\\", \\\"different\\\", \\\"classes\\\", \\\"method\\\"],\\n                    \\\"score\\\": 3\\n                },\\n                \\\"example\\\": {\\n                    \\\"keywords\\\": [\\\"inheritance\\\", \\\"override\\\", \\\"implementation\\\"],\\n                    \\\"score\\\": 2\\n                }\\n            },\\n            \\\"What is the difference between TCP and UDP?\\\": {\\n                \\\"reliability\\\": {\\n                    \\\"keywords\\\": [\\\"connection-oriented\\\", \\\"reliable\\\", \\\"acknowledgement\\\"],\\n                    \\\"score\\\": 3\\n                },\\n                \\\"speed\\\": {\\n                    \\\"keywords\\\": [\\\"faster\\\", \\\"lightweight\\\", \\\"low-overhead\\\"],\\n                    \\\"score\\\": 2\\n                }\\n            }\\n        }\\n        \\\"\\\"\\\"\\n        try:\\n            with open(scoring_criteria_file, 'r', encoding='utf-8') as f:\\n                self.scoring_criteria: Dict[str, Dict[str, Dict[str, object]]] = json.load(f)\\n        except FileNotFoundError as e:\\n            raise FileNotFoundError(f\\\"Scoring criteria file not found: {scoring_criteria_file}\\\") from e\\n        except json.JSONDecodeError as e:\\n            raise ValueError(f\\\"Invalid JSON in scoring criteria file: {scoring_criteria_file}\\\") from e\\n\\n    def score_response(self, question: str, response: str) -> int:\\n        \\\"\\\"\\\"\\n        Scores a candidate's response based on the predefined scoring criteria.\\n\\n        Args:\\n            question (str): The interview question.\\n            response (str): The candidate's response.\\n\\n        Returns:\\n            int: The total score for the response.\\n        \\\"\\\"\\\"\\n        question_criteria = self.scoring_criteria.get(question, {})\\n        if not question_criteria:\\n            # No criteria defined for this question\\n            return 0\\n\\n        total_score = 0\\n        response_lower = response.lower()\\n        for crit_name, details in question_criteria.items():\\n            keywords: List[str] = details.get(\\\"keywords\\\", [])\\n            score_value: int = details.get(\\\"score\\\", 0)\\n            if any(kw.lower() in response_lower for kw in keywords):\\n                total_score += score_value\\n        return total_score\\n\\n    def generate_feedback(self, question: str, response: str) -> str:\\n        \\\"\\\"\\\"\\n        Generates feedback for a candidate's response based on the scoring criteria.\\n\\n        Args:\\n            question (str): The interview question.\\n            response (str): The candidate's response.\\n\\n        Returns:\\n            str: Feedback string indicating which criteria were met or missed.\\n        \\\"\\\"\\\"\\n        question_criteria = self.scoring_criteria.get(question, {})\\n        if not question_criteria:\\n            return f\\\"No scoring criteria for question: '{question}'.\\\"\\n\\n        feedback_lines = []\\n        response_lower = response.lower()\\n        for crit_name, details in question_criteria.items():\\n            keywords: List[str] = details.get(\\\"keywords\\\", [])\\n            score_value: int = details.get(\\\"score\\\", 0)\\n            if any(kw.lower() in response_lower for kw in keywords):\\n                feedback_lines.append(f\\\"  - Met '{crit_name}' (+{score_value}): keywords {keywords}\\\")\\n            else:\\n                feedback_lines.append(f\\\"  - Missed '{crit_name}': expected keywords {keywords}\\\")\\n        return \\\"\\\\n\\\".join(feedback_lines)\\n\\n    def evaluate_interview(self, interview_data: Dict) -> Dict:\\n        \\\"\\\"\\\"\\n        Evaluates the entire interview, scoring each response and generating feedback.\\n\\n        Args:\\n            interview_data (Dict): A dictionary containing interview data:\\n                {\\n                    \\\"candidate_email\\\": str,\\n                    \\\"responses\\\": [\\n                        {\\\"question\\\": str, \\\"response\\\": str},\\n                        ...\\n                    ]\\n                }\\n\\n        Returns:\\n            Dict: A report with per-question scores, feedback, and total score.\\n        \\\"\\\"\\\"\\n        candidate_email = interview_data.get(\\\"candidate_email\\\", \\\"\\\")\\n        responses = interview_data.get(\\\"responses\\\", [])\\n\\n        evaluation_results = []\\n        total_score = 0\\n\\n        for item in responses:\\n            q = item.get(\\\"question\\\", \\\"\\\")\\n            r = item.get(\\\"response\\\", \\\"\\\")\\n            score = self.score_response(q, r)\\n            feedback = self.generate_feedback(q, r)\\n            evaluation_results.append({\\n                \\\"question\\\": q,\\n                \\\"response\\\": r,\\n                \\\"score\\\": score,\\n                \\\"feedback\\\": feedback\\n            })\\n            total_score += score\\n\\n        return {\\n            \\\"candidate_email\\\": candidate_email,\\n            \\\"evaluation_results\\\": evaluation_results,\\n            \\\"total_score\\\": total_score\\n        }\\n\\ndef main():\\n    # Example usage\\n    scorer = ResponseScorer(\\\"scoring_criteria.json\\\")\\n    interview_data = {\\n        \\\"candidate_email\\\": \\\"candidate@example.com\\\",\\n        \\\"responses\\\": [\\n            {\\n                \\\"question\\\": \\\"Explain the concept of polymorphism.\\\",\\n                \\\"response\\\": \\\"Polymorphism allows objects of different classes to respond to the same method call in their own way.\\\"\\n            },\\n            {\\n                \\\"question\\\": \\\"What is the difference between TCP and UDP?\\\",\\n                \\\"response\\\": \\\"TCP is connection-oriented and reliable with acknowledgements, whereas UDP is connectionless, faster, but less reliable.\\\"\\n            }\\n        ]\\n    }\\n    report = scorer.evaluate_interview(interview_data)\\n    print(json.dumps(report, indent=2))\\n\\nif __name__ == \\\"__main__\\\":\\n    main()\\n```\"}"}
