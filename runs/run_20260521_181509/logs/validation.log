previous tasks context available.\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task1:\\n  Objective: Build tetromino generation and rotation logic with next-piece queue\\nTask task2:\\n  Objective: Develop keyboard control module: move, rotate, drop tetrominoes\\nTask task3:\\n  Objective: Implement Tetris line-clearing mechanics: detect full rows and clear them\\nTask task4:\\n  Objective: Implement Bejeweled match-3 detection and clearing with chain reaction logic\\n\\n---\\n# **Current Task Requirements**\\nImplement core data structures: grid representation, gem storage, and tetromino shape definitions\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport random\\nfrom enum import Enum\\nfrom typing import List, Tuple, Optional\\n\\n# Grid dimensions\\nGRID_WIDTH = 10\\nGRID_HEIGHT = 20\\n\\n# Gem color definitions\\nclass GemColor(Enum):\\n    NONE    = 0  # Empty cell\\n    CYAN    = 1\\n    YELLOW  = 2\\n    PURPLE  = 3\\n    GREEN   = 4\\n    RED     = 5\\n    BLUE    = 6\\n    ORANGE  = 7\\n\\n# Tetromino shape definitions: for each shape, four rotation states of (x, y) offsets\\nTETROMINO_SHAPES = {\\n    'I': [\\n        [(0,1), (1,1), (2,1), (3,1)],\\n        [(2,0), (2,1), (2,2), (2,3)],\\n        [(0,2), (1,2), (2,2), (3,2)],\\n        [(1,0), (1,1), (1,2), (1,3)],\\n    ],\\n    'O': [\\n        [(1,0), (2,0), (1,1), (2,1)],\\n        [(1,0), (2,0), (1,1), (2,1)],\\n        [(1,0), (2,0), (1,1), (2,1)],\\n        [(1,0), (2,0), (1,1), (2,1)],\\n    ],\\n    'T': [\\n        [(1,0), (0,1), (1,1), (2,1)],\\n        [(1,0), (1,1), (2,1), (1,2)],\\n        [(0,1), (1,1), (2,1), (1,2)],\\n        [(1,0), (0,1), (1,1), (1,2)],\\n    ],\\n    'S': [\\n        [(1,0), (2,0), (0,1), (1,1)],\\n        [(1,0), (1,1), (2,1), (2,2)],\\n        [(1,1), (2,1), (0,2), (1,2)],\\n        [(0,0), (0,1), (1,1), (1,2)],\\n    ],\\n    'Z': [\\n        [(0,0), (1,0), (1,1), (2,1)],\\n        [(2,0), (1,1), (2,1), (1,2)],\\n        [(0,1), (1,1), (1,2), (2,2)],\\n        [(1,0), (0,1), (1,1), (0,2)],\\n    ],\\n    'J': [\\n        [(0,0), (0,1), (1,1), (2,1)],\\n        [(1,0), (2,0), (1,1), (1,2)],\\n        [(0,1), (1,1), (2,1), (2,2)],\\n        [(1,0), (1,1), (0,2), (1,2)],\\n    ],\\n    'L': [\\n        [(2,0), (0,1), (1,1), (2,1)],\\n        [(1,0), (1,1), (1,2), (2,2)],\\n        [(0,1), (1,1), (2,1), (0,2)],\\n        [(0,0), (1,0), (1,1), (1,2)],\\n    ],\\n}\\n\\n# Map each tetromino to a gem color\\nTETROMINO_COLORS = {\\n    'I': GemColor.CYAN,\\n    'O': GemColor.YELLOW,\\n    'T': GemColor.PURPLE,\\n    'S': GemColor.GREEN,\\n    'Z': GemColor.RED,\\n    'J': GemColor.BLUE,\\n    'L': GemColor.ORANGE,\\n}\\n\\nclass Cell:\\n    \\\"\\\"\\\"\\n    Represents a single cell in the grid.\\n    \\\"\\\"\\\"\\n    def __init__(self, color: GemColor = GemColor.NONE):\\n        self.color = color\\n\\n    def is_empty(self) -> bool:\\n        return self.color == GemColor.NONE\\n\\n    def set_gem(self, color: GemColor):\\n        self.color = color\\n\\n    def clear(self):\\n        self.color = GemColor.NONE\\n\\nclass Grid:\\n    \\\"\\\"\\\"\\n    Represents the game grid. Stores cells containing gems.\\n    \\\"\\\"\\\"\\n    def __init__(self, width: int = GRID_WIDTH, height: int = GRID_HEIGHT):\\n        self.width = width\\n        self.height = height\\n        self.cells: List[List[Cell]] = [\\n            [Cell() for _ in range(self.width)] for _ in range(self.height)\\n        ]\\n\\n    def in_bounds(self, x: int, y: int) -> bool:\\n        return 0 <= x < self.width and 0 <= y < self.height\\n\\n    def get_cell(self, x: int, y: int) -> Optional[Cell]:\\n        if self.in_bounds(x, y):\\n            return self.cells[y][x]\\n        return None\\n\\n    def set_gem(self, x: int, y: int, color: GemColor):\\n        cell = self.get_cell(x, y)\\n        if cell:\\n            cell.set_gem(color)\\n\\n    def clear_cell(self, x: int, y: int):\\n        cell = self.get_cell(x, y)\\n        if cell:\\n            cell.clear()\\n\\nclass Tetromino:\\n    \\\"\\\"\\\"\\n    Represents a falling tetromino piece.\\n    \\\"\\\"\\\"\\n    def __init__(self, shape: str):\\n        self.shape = shape\\n        self.rotations: List[List[Tuple[int,int]]] = TETROMINO_SHAPES[shape]\\n        self.color: GemColor = TETROMINO_COLORS[shape]\\n        self.rotation_index: int = 0\\n        # Initial spawn position (x, y) of top-left bounding box\\n        self.x: int = (GRID_WIDTH // 2) - 2\\n        self.y: int = 0\\n\\n    @property\\n    def blocks(self) -> List[Tuple[int,int]]:\\n        \\\"\\\"\\\"\\n        Returns absolute (x, y) positions of the four blocks.\\n        \\\"\\\"\\\"\\n        coords = []\\n        for dx, dy in self.rotations[self.rotation_index]:\\n            coords.append((self.x + dx, self.y + dy))\\n        return coords\\n\\n    def rotate(self, clockwise: bool = True):\\n        \\\"\\\"\\\"\\n        Rotate tetromino to next state.\\n        \\\"\\\"\\\"\\n        if clockwise:\\n            self.rotation_index = (self.rotation_index + 1) % len(self.rotations)\\n        else:\\n            self.rotation_index = (self.rotation_index - 1) % len(self.rotations)\\n\\ndef generate_random_tetromino() -> Tetromino:\\n    \\\"\\\"\\\"\\n    Returns a new random Tetromino instance.\\n    \\\"\\\"\\\"\\n    shape = random.choice(list(TETROMINO_SHAPES.keys()))\\n    return Tetromino(shape)\\n```\",\n  \"timestamp\": \"2026-05-21T18:15:48.410878\"\n}"}
