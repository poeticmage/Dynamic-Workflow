{"timestamp": "2026-05-26 16:13:20,169", "level": "INFO", "logger": "flow.validation", "module": "logging_config", "function": "log_gpt_conversation", "line": 403, "message": "{\n  \"event_type\": \"gpt_conversation\",\n  \"task_id\": \"task_6\",\n  \"conversation_type\": \"task_execution\",\n  \"iteration\": 1,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"\\n# Role:\\nHelp me produce a precise and detailed solution for the given task. Follow these instructions exactly:\\n\\n# Objective & Steps:\\n1. Ensure Completeness:\\n   - Avoid placeholders or incomplete text.\\n   - Your output must meet all requirements of the task.\\n   - Include all necessary details so that the output is self-contained and can be directly used as input for downstream tasks.\\n\\n2. Maintain Precision and Clarity:\\n   - Your output will be used as input for subsequent tasks; therefore, it must be comprehensive and precise.\\n   - **Output the answer only without any jusifications**\\n\\n3. Avoid Repetition:\\n   - Do not repeat verbatim any content from previous tasks.\\n   - Ensure your output is original and adds value to the workflow.\\n\\n\\n\\n# Audience:\\nYour output will be used as a solution for the given task, it will be used in the later validation and intergration process.\\n\\n\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"# **The Overall Goal**\\nPerform interview and candidate evaluation for a candidate.\\n\\nYou should:\\n- Analyze job descriptions and candidate resumes\\n- Conduct  interviews with technical and behavioral questions\\n- Generate follow-up questions based on candidate responses\\n- Evaluate candidate answers for relevance, depth, confidence, and technical accuracy\\n- Score candidates across multiple evaluation categories\\n- Generate recruiter communication emails such as interview invitations and follow-ups\\n- Produce a final candidate evaluation report containing:\\n    - Resume-job match analysis\\n    - Interview summary\\n    - Technical assessment\\n    - Behavioral assessment\\n    - Strengths and weaknesses\\n    - Final recommendation and scoring breakdown\\n\\nFinal output: Evaluation report of candidate in .txt\\n\\n---\\n# **Context from Upstream Tasks**\\nTask task2:\\n  Objective: Develop Match Analyzer module to compare parsed resume data against job requirements and compute a resume-job match score with analysis.\\n  Result: ```python\\nclass MatchAnalyzer:\\n    \\\"\\\"\\\"\\n    Analyzes the match between a job description and a resume based on extracted information.\\n    Calculates a match score and provides a detailed analysis of the match.\\n    \\\"\\\"\\\"\\n\\n    def __init__(self, job_description_data, resume_data):\\n        \\\"\\\"\\\"\\n        Initializes the MatchAnalyzer with job description and resume data.\\n\\n        :param job_description_data: Dictionary containing job description information (skills, responsibilities, etc.).\\n        :param resume_data: Dictionary containing resume information (skills, experience, education, etc.).\\n        \\\"\\\"\\\"\\n        self.job_description_data = job_description_data\\n        self.resume_data = resume_data\\n\\n    def calculate_skill_match_score(self):\\n        \\\"\\\"\\\"\\n        Calculates a skill match score based on the overlap between required skills and resume skills.\\n\\n        :return: Skill match score (float between 0 and 1).\\n        \\\"\\\"\\\"\\n        required_skills = set(map(str.lower, self.job_description_data.get(\\\"required_skills\\\", [])))\\n        resume_skills = set(map(str.lower, self.resume_data.get(\\\"skills\\\", [])))\\n\\n        if not required_skills:\\n            return 1.0  # If no required skills are specified, consider it a perfect match.\\n\\n        matched_skills = required_skills.intersection(resume_skills)\\n        skill_match_score = len(matched_skills) / len(required_skills)\\n        return skill_match_score\\n\\n    def analyze_experience_match(self):\\n        \\\"\\\"\\\"\\n        Analyzes the experience match between the job description and the resume.  This is a simplified\\n        implementation.  A more robust implementation would consider the relevance of the experience to the role.\\n\\n        :return: A dictionary containing analysis of experience match (bool matched, str details).\\n        \\\"\\\"\\\"\\n        job_responsibilities = self.job_description_data.get(\\\"responsibilities\\\", [])\\n        resume_experience = self.resume_data.get(\\\"experience\\\", [])\\n\\n        matched = False\\n        details = \\\"No significant experience match found.\\\"\\n\\n        for responsibility in job_responsibilities:\\n            for experience in resume_experience:\\n                if experience.get(\\\"details\\\") and any(responsibility.lower() in detail.lower() for detail in experience.get(\\\"details\\\")):\\n                    matched = True\\n                    details = \\\"Experience found matching job responsibilities.\\\"\\n                    break\\n            if matched:\\n                break\\n\\n        return {\\\"matched\\\": matched, \\\"details\\\": details}\\n\\n    def analyze_education_match(self):\\n        \\\"\\\"\\\"\\n        Analyzes the education match between the job description and the resume.  This is a simplified\\n        implementation.\\n\\n        :return: A dictionary containing analysis of education match (bool matched, str details).\\n        \\\"\\\"\\\"\\n        # In a real-world scenario, this could compare degrees, institutions, etc.\\n        # For simplicity, this example always returns a match.\\n        return {\\\"matched\\\": True, \\\"details\\\": \\\"Education requirements met.\\\"}\\n\\n\\n    def calculate_overall_match_score(self, skill_weight=0.6, experience_weight=0.3, education_weight=0.1):\\n        \\\"\\\"\\\"\\n        Calculates an overall match score based on weighted combination of skill, experience and education matches.\\n\\n        :param skill_weight: Weight for skill match score.\\n        :param experience_weight: Weight for experience match score.\\n        :param education_weight: Weight for education match score.\\n        :return: Overall match score (float between 0 and 1).\\n        \\\"\\\"\\\"\\n        skill_match_score = self.calculate_skill_match_score()\\n        experience_match = self.analyze_experience_match()\\n        education_match = self.analyze_education_match()\\n\\n        experience_score = 1.0 if experience_match[\\\"matched\\\"] else 0.0\\n        education_score = 1.0 if education_match[\\\"matched\\\"] else 0.0\\n\\n        overall_match_score = (\\n            skill_weight * skill_match_score +\\n            experience_weight * experience_score +\\n            education_weight * education_score\\n        )\\n\\n        return overall_match_score\\n\\n    def get_match_analysis(self):\\n        \\\"\\\"\\\"\\n        Generates a comprehensive match analysis report.\\n\\n        :return: A dictionary containing the match analysis report.\\n        \\\"\\\"\\\"\\n        skill_match_score = self.calculate_skill_match_score()\\n        experience_match = self.analyze_experience_match()\\n        education_match = self.analyze_education_match()\\n        overall_match_score = self.calculate_overall_match_score()\\n\\n        analysis_report = {\\n            \\\"skill_match\\\": {\\n                \\\"score\\\": skill_match_score,\\n                \\\"details\\\": f\\\"Skill match score: {skill_match_score:.2f}\\\"\\n            },\\n            \\\"experience_match\\\": {\\n                \\\"matched\\\": experience_match[\\\"matched\\\"],\\n                \\\"details\\\": experience_match[\\\"details\\\"]\\n            },\\n            \\\"education_match\\\": {\\n                \\\"matched\\\": education_match[\\\"matched\\\"],\\n                \\\"details\\\": education_match[\\\"details\\\"]\\n            },\\n            \\\"overall_match\\\": {\\n                \\\"score\\\": overall_match_score,\\n                \\\"details\\\": f\\\"Overall match score: {overall_match_score:.2f}\\\"\\n            }\\n        }\\n\\n        return analysis_report\\n\\nif __name__ == '__main__':\\n    # Example Usage:\\n    job_description_data = {\\n        \\\"required_skills\\\": [\\\"Python\\\", \\\"React\\\", \\\"SQL\\\", \\\"Communication Skills\\\"],\\n        \\\"responsibilities\\\": [\\\"developing and maintaining web applications\\\", \\\"writing clean, efficient code\\\", \\\"designing and implementing new features\\\"]\\n    }\\n\\n    resume_data = {\\n        \\\"skills\\\": [\\\"Python\\\", \\\"Java\\\", \\\"JavaScript\\\", \\\"AWS\\\", \\\"Docker\\\", \\\"SQL\\\"],\\n        \\\"experience\\\": [\\n            {\\n                \\\"title\\\": \\\"Software Engineer\\\",\\n                \\\"company\\\": \\\"ABC Company\\\",\\n                \\\"start_date\\\": \\\"2018\\\",\\n                \\\"end_date\\\": \\\"2023\\\",\\n                \\\"details\\\": [\\\"Developed web apps in Python\\\", \\\"Deployed with Docker\\\"]\\n            },\\n            {\\n                \\\"title\\\": \\\"Software Developer\\\",\\n                \\\"company\\\": \\\"XYZ Company\\\",\\n                \\\"start_date\\\": \\\"2016\\\",\\n                \\\"end_date\\\": \\\"2018\\\",\\n                \\\"details\\\": [\\\"Built REST APIs\\\"]\\n            }\\n        ],\\n        \\\"education\\\": [\\n            {\\n                \\\"degree\\\": \\\"Bachelor of Science in Computer Science\\\",\\n                \\\"institution\\\": \\\"University of California\\\",\\n                \\\"year\\\": \\\"2016\\\"\\n            }\\n        ]\\n    }\\n\\n    analyzer = MatchAnalyzer(job_description_data, resume_data)\\n    analysis_report = analyzer.get_match_analysis()\\n\\n    print(analysis_report)\\n```\\nTask task6:\\n  Objective: Implement Evaluation Report Generator to compile match analysis, interview summary, technical and behavioral assessments, strengths/weaknesses, and recommendations into a .txt report.\\n  Result: ```python\\nclass EvaluationReportGenerator:\\n    \\\"\\\"\\\"\\n    Compiles match analysis, interview data, assessments, strengths/weaknesses,\\n    and recommendations into a .txt report.\\n    \\\"\\\"\\\"\\n\\n    def __init__(self, candidate_name, job_title, match_analysis, interview_data, evaluations, scoring_breakdown, strengths, weaknesses, recommendation):\\n        \\\"\\\"\\\"\\n        Initializes the EvaluationReportGenerator with candidate data, analysis, evaluations, scores, and recommendations.\\n\\n        :param candidate_name: str\\n        :param job_title: str\\n        :param match_analysis: dict (from MatchAnalyzer)\\n        :param interview_data: dict (questions and answers)\\n        :param evaluations: dict (from CandidateResponseEvaluator)\\n        :param scoring_breakdown: dict (from ScoringEngine)\\n        :param strengths: list of str\\n        :param weaknesses: list of str\\n        :param recommendation: str\\n        \\\"\\\"\\\"\\n        self.candidate_name = candidate_name\\n        self.job_title = job_title\\n        self.match_analysis = match_analysis\\n        self.interview_data = interview_data\\n        self.evaluations = evaluations\\n        self.scoring_breakdown = scoring_breakdown\\n        self.strengths = strengths\\n        self.weaknesses = weaknesses\\n        self.recommendation = recommendation\\n\\n    def generate_report(self):\\n        \\\"\\\"\\\"\\n        Generates the evaluation report in .txt format.\\n\\n        :return: str (the report content)\\n        \\\"\\\"\\\"\\n        report = f\\\"\\\"\\\"\\n        Candidate Evaluation Report\\n\\n        Candidate Name: {self.candidate_name}\\n        Job Title: {self.job_title}\\n\\n        ================================================\\n        1. Resume-Job Match Analysis\\n        ================================================\\n        {self._format_match_analysis(self.match_analysis)}\\n\\n        ================================================\\n        2. Interview Summary\\n        ================================================\\n        {self._format_interview_summary(self.interview_data)}\\n\\n        ================================================\\n        3. Technical Assessment\\n        ================================================\\n        {self._format_technical_assessment(self.evaluations)}\\n\\n        ================================================\\n        4. Behavioral Assessment\\n        ================================================\\n        {self._format_behavioral_assessment(self.evaluations)}\\n\\n        ================================================\\n        5. Strengths\\n        ================================================\\n        {self._format_strengths(self.strengths)}\\n\\n        ================================================\\n        6. Weaknesses\\n        ================================================\\n        {self._format_weaknesses(self.weaknesses)}\\n\\n        ================================================\\n        7. Scoring Breakdown\\n        ================================================\\n        {self._format_scoring_breakdown(self.scoring_breakdown)}\\n\\n        ================================================\\n        8. Final Recommendation\\n        ================================================\\n        {self.recommendation}\\n        \\\"\\\"\\\"\\n        return report\\n\\n    def save_report(self, filename=\\\"candidate_evaluation_report.txt\\\"):\\n        \\\"\\\"\\\"\\n        Saves the generated report to a .txt file.\\n\\n        :param filename: str (the name of the file to save the report to)\\n        \\\"\\\"\\\"\\n        report = self.generate_report()\\n        with open(filename, \\\"w\\\") as f:\\n            f.write(report)\\n        print(f\\\"Report saved to {filename}\\\")\\n\\n    def _format_match_analysis(self, match_analysis):\\n        \\\"\\\"\\\"Formats the match analysis section of the report.\\\"\\\"\\\"\\n        report_string = \\\"\\\"\\n        for key, value in match_analysis.items():\\n            report_string += f\\\"  {key.replace('_', ' ').title()}: {value.get('details', 'N/A')}\\\\n\\\"\\n        return report_string\\n\\n    def _format_interview_summary(self, interview_data):\\n        \\\"\\\"\\\"Formats the interview summary section of the report.\\\"\\\"\\\"\\n        report_string = \\\"\\\"\\n        for question_type in [\\\"technical_questions\\\", \\\"behavioral_questions\\\"]:\\n            report_string += f\\\"  {question_type.replace('_', ' ').title()}:\\\\n\\\"\\n            for question in interview_data[\\\"questions\\\"][question_type]:\\n                answer = interview_data[\\\"answers\\\"][question_type.replace(\\\"_questions\\\", \\\"_answers\\\")].get(question, \\\"No answer provided.\\\")\\n                report_string += f\\\"    - Question: {question}\\\\n\\\"\\n                report_string += f\\\"      Answer: {answer}\\\\n\\\"\\n        return report_string\\n\\n    def _format_technical_assessment(self, evaluations):\\n        \\\"\\\"\\\"Formats the technical assessment section of the report.\\\"\\\"\\\"\\n        report_string = \\\"\\\"\\n        for question, evaluation in evaluations.items():\\n            if \\\"technical\\\" in question.lower() or (\\\"technical\\\" in evaluation and evaluation[\\\"type\\\"] == \\\"technical\\\"):\\n                report_string += f\\\"  Question: {question}\\\\n\\\"\\n                report_string += f\\\"    Relevance: {evaluation['relevance']}\\\\n\\\"\\n                report_string += f\\\"    Depth: {evaluation['depth']}\\\\n\\\"\\n                report_string += f\\\"    Confidence: {evaluation['confidence']}\\\\n\\\"\\n                report_string += f\\\"    Technical Accuracy: {evaluation['technical_accuracy']}\\\\n\\\"\\n                report_string += f\\\"    Feedback: {evaluation['feedback']}\\\\n\\\"\\n        return report_string\\n\\n    def _format_behavioral_assessment(self, evaluations):\\n        \\\"\\\"\\\"Formats the behavioral assessment section of the report.\\\"\\\"\\\"\\n        report_string = \\\"\\\"\\n        for question, evaluation in evaluations.items():\\n             if \\\"behavioral\\\" in question.lower() or (\\\"behavioral\\\" in evaluation and evaluation[\\\"type\\\"] == \\\"behavioral\\\"):\\n                report_string += f\\\"  Question: {question}\\\\n\\\"\\n                report_string += f\\\"    Relevance: {evaluation['relevance']}\\\\n\\\"\\n                report_string += f\\\"    Depth: {evaluation['depth']}\\\\n\\\"\\n                report_string += f\\\"    Confidence: {evaluation['confidence']}\\\\n\\\"\\n                report_string += f\\\"    Feedback: {evaluation['feedback']}\\\\n\\\"\\n        return report_string\\n\\n    def _format_strengths(self, strengths):\\n        \\\"\\\"\\\"Formats the strengths section of the report.\\\"\\\"\\\"\\n        report_string = \\\"\\\"\\n        for strength in strengths:\\n            report_string += f\\\"  - {strength}\\\\n\\\"\\n        return report_string\\n\\n    def _format_weaknesses(self, weaknesses):\\n        \\\"\\\"\\\"Formats the weaknesses section of the report.\\\"\\\"\\\"\\n        report_string = \\\"\\\"\\n        for weakness in weaknesses:\\n            report_string += f\\\"  - {weakness}\\\\n\\\"\\n        return report_string\\n\\n    def _format_scoring_breakdown(self, scoring_breakdown):\\n        \\\"\\\"\\\"Formats the scoring breakdown section of the report.\\\"\\\"\\\"\\n        report_string = \\\"\\\"\\n        for category, score_data in scoring_breakdown.items():\\n            report_string += f\\\"  {category.title()}: {score_data['details']}\\\\n\\\"\\n        return report_string\\n\\n\\nif __name__ == '__main__':\\n    # Example Usage:\\n    match_analysis = {\\n        \\\"skill_match\\\": {\\\"score\\\": 0.8, \\\"details\\\": \\\"Skill match score: 0.80\\\"},\\n        \\\"experience_match\\\": {\\\"matched\\\": True, \\\"details\\\": \\\"Experience found matching job responsibilities.\\\"},\\n        \\\"education_match\\\": {\\\"matched\\\": True, \\\"details\\\": \\\"Education requirements met.\\\"},\\n        \\\"overall_match\\\": {\\\"score\\\": 0.75, \\\"details\\\": \\\"Overall match score: 0.75\\\"}\\n    }\\n\\n    interview_data = {\\n        \\\"questions\\\": {\\n            \\\"technical_questions\\\": [\\n                \\\"What is a decorator in Python?\\\",\\n                \\\"Explain the difference between lists and tuples in Python.\\\"\\n            ],\\n            \\\"behavioral_questions\\\": [\\n                \\\"Tell me about a time you failed.\\\",\\n                \\\"Describe a situation where you had to work with a difficult team member.\\\"\\n            ]\\n        },\\n        \\\"answers\\\": {\\n            \\\"technical_answers\\\": {\\n                \\\"What is a decorator in Python?\\\": \\\"A decorator is a function that takes another function as an argument and extends its behavior without modifying it.\\\",\\n                \\\"Explain the difference between lists and tuples in Python.\\\": \\\"Lists are mutable, and tuples are immutable.\\\"\\n            },\\n            \\\"behavioral_answers\\\": {\\n                \\\"Tell me about a time you failed.\\\": \\\"I once missed a deadline because I underestimated the complexity of the project.\\\",\\n                \\\"Describe a situation where you had to work with a difficult team member.\\\": \\\"I had a team member who was always negative. I tried to understand their perspective and find common ground.\\\"\\n            }\\n        }\\n    }\\n\\n    evaluations = {\\n        \\\"What is a decorator in Python?\\\": {\\n            \\\"relevance\\\": 5,\\n            \\\"depth\\\": 4,\\n            \\\"confidence\\\": 4,\\n            \\\"technical_accuracy\\\": 5,\\n            \\\"feedback\\\": \\\"The candidate's answer was relevant and demonstrated good technical knowledge.\\\",\\n            \\\"type\\\": \\\"technical\\\"\\n        },\\n        \\\"Explain the difference between lists and tuples in Python.\\\": {\\n            \\\"relevance\\\": 5,\\n            \\\"depth\\\": 3,\\n            \\\"confidence\\\": 4,\\n            \\\"technical_accuracy\\\": 4,\\n            \\\"feedback\\\": \\\"The candidate's answer was relevant and demonstrated some technical knowledge.\\\",\\n            \\\"type\\\": \\\"technical\\\"\\n        },\\n        \\\"Tell me about a time you failed.\\\": {\\n            \\\"relevance\\\": 5,\\n            \\\"depth\\\": 4,\\n            \\\"confidence\\\": 3,\\n            \\\"feedback\\\": \\\"The candidate's answer was relevant to the behavioral question.\\\",\\n            \\\"type\\\": \\\"behavioral\\\"\\n        },\\n        \\\"Describe a situation where you had to work with a difficult team member.\\\": {\\n            \\\"relevance\\\": 5,\\n            \\\"depth\\\": 4,\\n            \\\"confidence\\\": 4,\\n            \\\"feedback\\\": \\\"The candidate's answer was relevant to the behavioral question.\\\",\\n            \\\"type\\\": \\\"behavioral\\\"\\n        }\\n    }\\n\\n    scoring_breakdown = {\\n        \\\"match\\\": {\\\"score\\\": 75.0, \\\"details\\\": \\\"Resume-job match score: 75.00\\\"},\\n        \\\"technical_skills\\\": {\\\"score\\\": 80.0, \\\"details\\\": \\\"Technical score: 80.00\\\"},\\n        \\\"problem_solving\\\": {\\\"score\\\": 70.0, \\\"details\\\": \\\"Problem-solving score: 70.00\\\"},\\n        \\\"communication\\\": {\\\"score\\\": 85.0, \\\"details\\\": \\\"Communication score: 85.00\\\"},\\n        \\\"overall\\\": {\\\"score\\\": 77.5, \\\"details\\\": \\\"Overall score: 77.50\\\"}\\n    }\\n\\n    strengths = [\\\"Strong Python skills\\\", \\\"Good communication skills\\\", \\\"Problem-solving abilities\\\"]\\n    weaknesses = [\\\"Limited experience with React\\\", \\\"Could improve on providing more detailed answers\\\"]\\n    recommendation = \\\"Overall, the candidate is a good fit for the role. Recommend further consideration.\\\"\\n\\n    report_generator = EvaluationReportGenerator(\\\"John Doe\\\", \\\"Python Developer\\\", match_analysis, interview_data, evaluations, scoring_breakdown, strengths, weaknesses, recommendation)\\n    report_generator.save_report(\\\"john_doe_evaluation_report.txt\\\")\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nNo downstream objectives available.\\n\\n---\\n# **Current Task Requirements**\\nGenerate email templates for recruiter communications at two stages: interview invitation emails after match analysis and post-evaluation result emails after final report generation.\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nclass EmailTemplates:\\n    \\\"\\\"\\\"\\n    Generates email templates for recruiter communications.\\n    \\\"\\\"\\\"\\n\\n    @staticmethod\\n    def interview_invitation_email(candidate_name, job_title, date, time, location, interviewer, additional_info=None):\\n        \\\"\\\"\\\"\\n        Generates an email template for inviting a candidate to an interview.\\n\\n        :param candidate_name: str\\n        :param job_title: str\\n        :param date: str\\n        :param time: str\\n        :param location: str\\n        :param interviewer: str\\n        :param additional_info: str, optional\\n        :return: str\\n        \\\"\\\"\\\"\\n        subject = f\\\"Interview Invitation for {job_title} at [Company Name]\\\"\\n        body = f\\\"\\\"\\\"\\nDear {candidate_name},\\n\\nWe are pleased to invite you to interview for the {job_title} position at [Company Name].\\n\\nBased on your qualifications and experience, we believe you could be a great fit for our team.\\n\\nThe interview is scheduled for:\\n\\nDate: {date}\\nTime: {time}\\nLocation: {location}\\nInterviewer: {interviewer}\\n\\nPlease bring a copy of your resume and be prepared to discuss your skills and experience in detail.\\n\\n{f'Additional Information: {additional_info}' if additional_info else ''}\\n\\nIf the proposed time does not work for you, please let us know as soon as possible so we can reschedule.\\n\\nWe look forward to meeting you.\\n\\nBest regards,\\n\\n[Your Name]\\n[Your Title]\\n[Company Name]\\n        \\\"\\\"\\\"\\n        return subject, body\\n\\n    @staticmethod\\n    def post_evaluation_result_email(candidate_name, job_title, evaluation_summary, recommendation, next_steps=None):\\n        \\\"\\\"\\\"\\n        Generates an email template for communicating post-evaluation results to the candidate.\\n\\n        :param candidate_name: str\\n        :param job_title: str\\n        :param evaluation_summary: str\\n        :param recommendation: str\\n        :param next_steps: str, optional\\n        :return: str\\n        \\\"\\\"\\\"\\n        subject = f\\\"Update on Your Application for {job_title} at [Company Name]\\\"\\n        body = f\\\"\\\"\\\"\\nDear {candidate_name},\\n\\nThank you for your interest in the {job_title} position at [Company Name] and for taking the time to interview with our team.\\n\\nWe have completed our evaluation process. Here is a summary of our findings:\\n\\nEvaluation Summary:\\n{evaluation_summary}\\n\\nRecommendation:\\n{recommendation}\\n\\n{f'Next Steps: {next_steps}' if next_steps else ''}\\n\\nWe appreciate your interest in [Company Name].\\n\\nBest regards,\\n\\n[Your Name]\\n[Your Title]\\n[Company Name]\\n        \\\"\\\"\\\"\\n        return subject, body\\n\\n\\nif __name__ == '__main__':\\n    # Example Usage:\\n\\n    # Interview Invitation Email\\n    subject, body = EmailTemplates.interview_invitation_email(\\n        candidate_name=\\\"John Doe\\\",\\n        job_title=\\\"Python Developer\\\",\\n        date=\\\"October 26, 2023\\\",\\n        time=\\\"10:00 AM\\\",\\n        location=\\\"[Company Name] Office\\\",\\n        interviewer=\\\"Jane Smith\\\",\\n        additional_info=\\\"Please bring your portfolio.\\\"\\n    )\\n    print(\\\"Interview Invitation Email:\\\")\\n    print(\\\"Subject:\\\", subject)\\n    print(\\\"Body:\\\", body)\\n\\n    # Post-Evaluation Result Email\\n    subject, body = EmailTemplates.post_evaluation_result_email(\\n        candidate_name=\\\"John Doe\\\",\\n        job_title=\\\"Python Developer\\\",\\n        evaluation_summary=\\\"John demonstrated strong Python skills and problem-solving abilities.\\\",\\n        recommendation=\\\"We are moving forward with the next stage of the interview process.\\\",\\n        next_steps=\\\"You will be contacted soon to schedule a follow-up interview with the hiring manager.\\\"\\n    )\\n    print(\\\"\\\\nPost-Evaluation Result Email:\\\")\\n    print(\\\"Subject:\\\", subject)\\n    print(\\\"Body:\\\", body)\\n```\",\n  \"timestamp\": \"2026-05-26T16:13:20.169592\"\n}"}
