, y in self.get_cells():\\n            if y >= 0:\\n                pygame.draw.rect(\\n                    surface,\\n                    COLORS[self.color],\\n                    pygame.Rect(x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE)\\n                )\\n                pygame.draw.rect(\\n                    surface,\\n                    COLORS['grey'],\\n                    pygame.Rect(x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE),\\n                    1\\n                )\\n\\nclass Game:\\n    def __init__(self):\\n        pygame.init()\\n        self.screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\\n        pygame.display.set_caption(\\\"Tetris-Bejeweled Hybrid\\\")\\n        self.clock = pygame.time.Clock()\\n        self.grid = Grid(GRID_WIDTH, GRID_HEIGHT)\\n        self.current = Tetromino(self.grid)\\n        pygame.time.set_timer(FALL_EVENT, FALL_INTERVAL)\\n\\n    def spawn_new(self):\\n        self.grid.lock_tetromino(self.current)\\n        self.current = Tetromino(self.grid)\\n\\n    def run(self):\\n        running = True\\n        while running:\\n            for event in pygame.event.get():\\n                if event.type == pygame.QUIT:\\n                    running = False\\n\\n                elif event.type == FALL_EVENT:\\n                    if not self.current.move_down():\\n                        self.spawn_new()\\n\\n                elif event.type == pygame.KEYDOWN:\\n                    if event.key == pygame.K_LEFT:\\n                        self.current.move(-1)\\n                    elif event.key == pygame.K_RIGHT:\\n                        self.current.move(1)\\n                    elif event.key == pygame.K_UP:\\n                        self.current.rotate()\\n                    elif event.key == pygame.K_DOWN:\\n                        if not self.current.move_down():\\n                            self.spawn_new()\\n\\n            # Draw\\n            self.screen.fill((0, 0, 0))\\n            self.grid.draw(self.screen)\\n            self.current.draw(self.screen)\\n            pygame.display.flip()\\n            self.clock.tick(60)\\n\\n        pygame.quit()\\n        sys.exit()\\n\\nif __name__ == \\\"__main__\\\":\\n    Game().run()\\n```\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"# **The Overall Goal**\\nDevelop a game that fuses Tetris and Bejeweled mechanics. \\nThis game needs to add keyboard control function.\\nFalling tetrominoes should lock into a grid and transform into colored gems. \\nThe game must support both Tetris line-clearing and Bejeweled match-3 clearing, triggering chain reactions and bonus points. \\nInclude a GUI (using a framework like Pygame) that displays the game grid, current score, and next tetromino preview, along with smooth animations. \\nNo sound effects are needed.\\n\\nOutput Format: python\\n\\n---\\n# **Context from Upstream Tasks**\\nTask task0:\\n  Objective: Implement the core grid data structure (matrix) and cell occupancy management for blocks and gems\\n  Result: ```python\\nclass Grid:\\n    def __init__(self, width, height):\\n        self.width = width\\n        self.height = height\\n        self.grid = [[None for _ in range(width)] for _ in range(height)]\\n\\n    def is_valid_position(self, x, y):\\n        \\\"\\\"\\\"Check if a given position is within the grid boundaries.\\\"\\\"\\\"\\n        return 0 <= x < self.width and 0 <= y < self.height\\n\\n    def is_cell_occupied(self, x, y):\\n        \\\"\\\"\\\"Check if a given cell is occupied by a block or gem.\\\"\\\"\\\"\\n        if not self.is_valid_position(x, y):\\n            return True  # Treat out-of-bounds as occupied\\n        return self.grid[y][x] is not None\\n\\n    def place_block(self, x, y, block):\\n        \\\"\\\"\\\"Place a block or gem at a given position.\\\"\\\"\\\"\\n        if self.is_valid_position(x, y):\\n            self.grid[y][x] = block\\n        else:\\n            raise ValueError(\\\"Invalid position for placing block.\\\")\\n\\n    def remove_block(self, x, y):\\n        \\\"\\\"\\\"Remove a block or gem from a given position.\\\"\\\"\\\"\\n        if self.is_valid_position(x, y):\\n            self.grid[y][x] = None\\n        else:\\n            raise ValueError(\\\"Invalid position for removing block.\\\")\\n\\n    def get_cell_value(self, x, y):\\n          \\\"\\\"\\\"Get the value of a cell at the specified coordinates.\\\"\\\"\\\"\\n          if self.is_valid_position(x,y):\\n            return self.grid[y][x]\\n          else:\\n            return None\\n\\n    def print_grid(self):\\n        \\\"\\\"\\\"Print the grid for debugging purposes.\\\"\\\"\\\"\\n        for row in self.grid:\\n            print(row)\\n\\n    def clear_grid(self):\\n        \\\"\\\"\\\"Clear all blocks/gems from the grid.\\\"\\\"\\\"\\n        self.grid = [[None for _ in range(self.width)] for _ in range(self.height)]\\n```\\n\\n---\\n# **Downstream Tasks Objectives**\\nTask task2:\\n  Objective: Implement conversion of locked tetromino blocks into colored gems on the grid\\nTask task6:\\n  Objective: Implement the Pygame-based GUI and main game loop integrating grid, tetromino logic, conversion, clearing engines, and score display with next-piece preview\\n\\n---\\n# **Current Task Requirements**\\nDevelop tetromino generation and movement logic with keyboard controls, including spawning, rotation, horizontal movement, and gravity\\n\\n---\\n\\n# **Required Output Format**\\nPython code\"\n    }\n  ],\n  \"gpt_response\": \"```python\\nimport pygame\\nimport random\\nimport sys\\n\\n# Constants\\nCELL_SIZE = 30\\nGRID_WIDTH = 10\\nGRID_HEIGHT = 20\\nSCREEN_WIDTH = CELL_SIZE * GRID_WIDTH\\nSCREEN_HEIGHT = CELL_SIZE * GRID_HEIGHT\\nFALL_EVENT = pygame.USEREVENT + 1\\nFALL_INTERVAL = 500  # milliseconds\\n\\n# Colors\\nCOLORS = {\\n    'red': (255, 0, 0),\\n    'green': (0, 255, 0),\\n    'blue': (0, 0, 255),\\n    'yellow': (255, 255, 0),\\n    'purple': (128, 0, 128),\\n    'cyan': (0, 255, 255),\\n    'grey': (50, 50, 50),\\n    None: (0, 0, 0)\\n}\\n\\nclass Grid:\\n    def __init__(self, width, height):\\n        self.width = width\\n        self.height = height\\n        # 2D grid of colors or None\\n        self.grid = [[None for _ in range(width)] for _ in range(height)]\\n\\n    def is_valid_position(self, x, y):\\n        return 0 <= x < self.width and 0 <= y < self.height\\n\\n    def is_cell_occupied(self, x, y):\\n        if not self.is_valid_position(x, y):\\n            return True\\n        return self.grid[y][x] is not None\\n\\n    def lock_tetromino(self, tetromino):\\n        for x, y in tetromino.get_cells():\\n            if 0 <= y < self.height:\\n                self.grid[y][x] = tetromino.color\\n\\n    def draw(self, surface):\\n        for y in range(self.height):\\n            for x in range(self.width):\\n                color = COLORS[self.grid[y][x]]\\n                pygame.draw.rect(\\n                    surface,\\n                    color,\\n                    pygame.Rect(x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE)\\n                )\\n                # grid lines\\n                pygame.draw.rect(\\n                    surface,\\n                    COLORS['grey'],\\n                    pygame.Rect(x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE),\\n                    1\\n                )\\n\\nclass Tetromino:\\n    SHAPES = [\\n        [['X', 'X', 'X', 'X']],  # I\\n        [['X', 'X'],\\n         ['X', 'X']],           # O\\n        [['0', 'X', 'X'],\\n         ['X', 'X', '0']],      # Z\\n        [['X', 'X', '0'],\\n         ['0', 'X', 'X']],      # S\\n        [['X', 'X', 'X'],\\n         ['0', '0', 'X']],      # J\\n        [['X', 'X', 'X'],\\n         ['X', '0', '0']],      # L\\n        [['X', 'X', 'X'],\\n         ['0', 'X', '0']]       # T\\n    ]\\n\\n    def __init__(self, grid):\\n        self.grid = grid\\n        self.shape = random.choice(Tetromino.SHAPES)\\n        self.color = random.choice(list(COLORS.keys() - {'grey', None}))\\n        # Start position (top-center)\\n        self.x = grid.width // 2 - len(self.shape[0]) // 2\\n        self.y = 0\\n        self.rotation = 0\\n\\n    def get_cells(self, rotation=None, x_offset=0, y_offset=0):\\n        \\\"\\\"\\\"Return list of (x, y) for occupied blocks.\\\"\\\"\\\"\\n        cells = []\\n        rot = self.rotation if rotation is None else rotation\\n        for i, row in enumerate(self.shape[rot]):\\n            for j, cell in enumerate(row):\\n                if cell == 'X':\\n                    cells.append((self.x + j + x_offset, self.y + i + y_offset))\\n        return cells\\n\\n    def rotate(self):\\n        new_rot = (self.rotation + 1) % len(self.shape)\\n        for x, y in self.get_cells(rotation=new_rot):\\n            if not self.grid.is_valid_position(x,y) or self.grid.is_cell_occupied(x, y):\\n                return  # collision, cancel\\n        self.rotation = new_rot\\n\\n    def move(self, dx):\\n        for x, y in self.get_cells(x_offset=dx):\\n            if not self.grid.is_valid_position(x,y) or self.grid.is_cell_occupied(x, y):\\n                return\\n        self.x += dx\\n\\n    def move_down(self):\\n        for x, y in self.get_cells(y_offset=1):\\n            if not self.grid.is_valid_position(x,y) or self.grid.is_cell_occupied(x, y):\\n                return False\\n        self.y += 1\\n        return True\\n\\n    def draw(self, surface):\\n        for x, y in self.get_cells():\\n            if y >= 0:\\n                pygame.draw.rect(\\n                    surface,\\n                    COLORS[self.color],\\n                    pygame.Rect(x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE)\\n                )\\n                pygame.draw.rect(\\n                    surface,\\n                    COLORS['grey'],\\n                    pygame.Rect(x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE),\\n                    1\\n                )\\n\\nclass Game:\\n    def __init__(self):\\n        pygame.init()\\n        self.screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\\n        pygame.display.set_caption(\\\"Tetris-Bejeweled Hybrid\\\")\\n        self.clock = pygame.time.Clock()\\n        self.grid = Grid(GRID_WIDTH, GRID_HEIGHT)\\n        self.current = Tetromino(self.grid)\\n        pygame.time.set_timer(FALL_EVENT, FALL_INTERVAL)\\n\\n    def spawn_new(self):\\n        self.grid.lock_tetromino(self.current)\\n        self.current = Tetromino(self.grid)\\n\\n    def run(self):\\n        running = True\\n        while running:\\n            for event in pygame.event.get():\\n                if event.type == pygame.QUIT:\\n                    running = False\\n\\n                elif event.type == FALL_EVENT:\\n                    if not self.current.move_down():\\n                        self.spawn_new()\\n\\n                elif event.type == pygame.KEYDOWN:\\n                    if event.key == pygame.K_LEFT:\\n                        self.current.move(-1)\\n                    elif event.key == pygame.K_RIGHT:\\n                        self.current.move(1)\\n                    elif event.key == pygame.K_UP:\\n                        self.current.rotate()\\n                    elif event.key == pygame.K_DOWN:\\n                        if not self.current.move_down():\\n                            self.spawn_new()\\n\\n            # Draw\\n            self.screen.fill((0, 0, 0))\\n            self.grid.draw(self.screen)\\n            self.current.draw(self.screen)\\n            pygame.display.flip()\\n            self.clock.tick(60)\\n\\n        pygame.quit()\\n        sys.exit()\\n\\nif __name__ == \\\"__main__\\\":\\n    Game().run()\\n```\",\n  \"timestamp\": \"2026-05-22T16:58:31.001511\"\n}"}
